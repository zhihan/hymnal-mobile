    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Riches of Christ are what He is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us who are His members true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His fulness is what we become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As body doth to man accrue."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Riches of Christ are typified"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Canaan’s produce rich and sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With which the temple great was built,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church’s greatest type replete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Eve to Adam fulness was,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So is the Church to Christ her Head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Eve from Adam’s being came,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church by Christ’s own life is bred."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s riches are Himself within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His fulness is the Church without,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As His expression, full of Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church with Christ is built throughout."
            }
          ]
        }
