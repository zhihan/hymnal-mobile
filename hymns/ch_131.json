  "title": "主当我们漂流旷野",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 当"
            },
            {
              "chord": "",
              "text": "我 们"
            },
            {
              "chord": "C",
              "text": "飘 流"
            },
            {
              "chord": "G",
              "text": "旷 野，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 爱"
            },
            {
              "chord": "Em",
              "text": "前 来"
            },
            {
              "chord": "C",
              "text": "寻"
            },
            {
              "chord": "D7",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "们："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 用"
            },
            {
              "chord": "",
              "text": "恩 手"
            },
            {
              "chord": "G",
              "text": "逐 步"
            },
            {
              "chord": "",
              "text": "提"
            },
            {
              "chord": "D",
              "text": "挈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "至 终"
            },
            {
              "chord": "D",
              "text": "十 架"
            },
            {
              "chord": "A",
              "text": "舍 己"
            },
            {
              "chord": "D7",
              "text": "身。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "唱 罢，"
            },
            {
              "chord": "D",
              "text": "我 魂，"
            },
            {
              "chord": "G",
              "text": "祂 爱"
            },
            {
              "chord": "D",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "耶 稣"
            },
            {
              "chord": "C",
              "text": "为 我"
            },
            {
              "chord": "G",
              "text": "舍"
            },
            {
              "chord": "D7",
              "text": "自"
            },
            {
              "chord": "G",
              "text": "己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听哪，这是谁的哭声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来自溪边的荒园？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是我主儆醒守更，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然门徒已疲倦。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿，我魂，祂真爱你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，祂为我舍己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "此时祂正对父求恳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深尝义怒的滋味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂为着我们罪人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "情愿喝干这苦杯。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿，爱！我魂，祂爱你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以为你舍自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "再后就是惨案末幕："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的波浪和洪涛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "漫过祂身，使祂痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才好使我成新造。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这爱无比又无极！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣为我舍自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请再听哪！祂正呼喊："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "－当祂见父与己分－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神哪、神哪，你竟摧残"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那常顺服你的人？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿，我魂，这是为你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，祂为我舍己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我心乐，因你苦难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今都已成往事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已升天坐父右边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远活着不再死。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那为我们舍己的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我魂今活着为你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们因你的奇恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在敬拜、颂赞你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久你要成全我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你相见同欢喜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而我们今唱说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣舍己为着我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
