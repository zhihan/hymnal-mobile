    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So many spirits here are dry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grace's ointment do apply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So many hearts need light divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your gracious light in man's heart shine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Revive them, deeper to love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To self examine, growth pursue."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Cause me to be strong inwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I from outward bonds be free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I in spirit pow'rful be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart more from the self set free"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Your life would be formed in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To give Your will free way through me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet still I would beseech, dear Lord:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The pow'r of Pentecost outpour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With bitter tears, with conscience pricked,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Caused man to turn, Your grace to seek:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That sick be healed; that dark see light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That bound, enslaved, be freed with might."
            }
          ]
        }
      ],
