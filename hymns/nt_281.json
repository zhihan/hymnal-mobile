  "title": "Lord, the Spirit, Truth divine",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Truth divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dawn upon this heart of mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Word of God, and inward light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wake my spirit, clear my sight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Love divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glow within this heart of mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kindle every high desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perish self in Thy pure fire."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Power divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill and nerve this will of mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee may I strongly live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bravely bear, and nobly strive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Peace divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still this restless heart of mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to calm this tossing sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stayed in Thy tranquillity."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Joy divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladden Thou this heart of mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the desert ways I’ll sing:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spring, O Well, forever spring!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spring, O Well, forever spring!"
            }
          ]
        },
