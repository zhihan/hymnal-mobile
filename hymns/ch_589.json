{
  "url": "https://www.hymnal.net/cn/hymn/ch/589",
  "title": "活着不是单靠食物",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "『活 著"
            },
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "Bm",
              "text": "是 单"
            },
            {
              "chord": "A",
              "text": "靠 食"
            },
            {
              "chord": "D",
              "text": "物， 乃"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠 神"
            },
            {
              "chord": "Bm",
              "text": "口 所"
            },
            {
              "chord": "A7",
              "text": "出"
            },
            {
              "chord": "D",
              "text": "的"
            },
            {
              "chord": "A",
              "text": "话；』 因"
            },
            {
              "chord": "",
              "text": "此"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "须"
            },
            {
              "chord": "Em",
              "text": "将 神"
            },
            {
              "chord": "D",
              "text": "话 当"
            },
            {
              "chord": "A",
              "text": "作"
            },
            {
              "chord": "G",
              "text": "生 命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "之"
            },
            {
              "chord": "D",
              "text": "粮， 时"
            },
            {
              "chord": "A",
              "text": "常"
            },
            {
              "chord": "A7",
              "text": "吃"
            },
            {
              "chord": "D",
              "text": "下。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们受造非仅身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是身体与魂与灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是里面最深部分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着接受神作供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "正如我们身体需要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属地物质食物营养，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵也需要神的话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作它属天生命食粮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你是灵，且借你话"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你自己完全表明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今需要运用我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你话接受你灵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，我们接受你话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅用眼读其字句，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并用心思领会其意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更须用灵将其吸取。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "须在灵里吃你的话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将其接到最深部分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "运用我灵祷读你话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就供应，浸透全人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话留在我的心思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仅是知识，变作重担；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若被接受到我灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就变灵与生命、平安。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我真肯运用我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接受你话并接触你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就得着你话𫗪养，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深处摸着你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，教我每读你话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就肯操练运用我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使我灵得到𫗪养，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就作我生命供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
  "metadata": {
    "category": "读经",
