    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God forbid that we should boast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save in the death of Christ, our Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the vain things that charm us most,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’d sacrifice them to His blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There from His head, His hands, His feet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sorrow and love flowed mingled down;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did e’er such love and sorrow meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or thorns compose so rich a crown?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His dying crimson, from His head"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spreads o’er His body on the tree;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all the world then am I dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the world is dead to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Were the whole realm of nature ours,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That were an offering far too small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love that transcends our highest pow’rs,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Demands our heart, our life, our all."
            }
          ]
        }
