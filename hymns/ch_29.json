      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我在罪中，你爱来寻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感动我心相信；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我因信得着安乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你基督得活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我为圣徒，现在所享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和我将来盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无一是我自己配得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是因你恩泽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神，你这样丰富的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能报答得来？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱真是远超人意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣！不可思议！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦父，但愿你今使我"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻明白更多："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像你这样慈爱的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当得我命、我心！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心若说要报你爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聊以表明感戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就还是不知你爱"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深阔远超洋海！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿我们对你大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不致当作买卖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你向我们所有爱心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们怎能报尽！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我们不再说报，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "－你爱实是太高－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们惟有满心感戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你永远敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "慈爱父神，我们欠你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切都欠了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们只好一面感激，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一面因子安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
