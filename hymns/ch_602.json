{
  "url": "https://www.hymnal.net/cn/hymn/ch/602",
  "title": "主阿你是房角首石",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "你 是 房 角"
            },
            {
              "chord": "A",
              "text": "首 石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "犹 太"
            },
            {
              "chord": "",
              "text": "匠 人"
            },
            {
              "chord": "A",
              "text": "所"
            },
            {
              "chord": "A7",
              "text": "轻"
            },
            {
              "chord": "D",
              "text": "弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 你 却 为 神 所"
            },
            {
              "chord": "A",
              "text": "珍 视，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "从 死"
            },
            {
              "chord": "",
              "text": "复 活"
            },
            {
              "chord": "A",
              "text": "所"
            },
            {
              "chord": "A7",
              "text": "设"
            },
            {
              "chord": "D",
              "text": "立。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 靠 你"
            },
            {
              "chord": "G",
              "text": "得 蒙"
            },
            {
              "chord": "A",
              "text": "救 恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "也 得"
            },
            {
              "chord": "",
              "text": "一 同"
            },
            {
              "chord": "E7",
              "text": "被 建"
            },
            {
              "chord": "A",
              "text": "造；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "犹 太、"
            },
            {
              "chord": "",
              "text": "外 邦 成 一"
            },
            {
              "chord": "A",
              "text": "新 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "作 神"
            },
            {
              "chord": "",
              "text": "居 所"
            },
            {
              "chord": "A",
              "text": "永"
            },
            {
              "chord": "A7",
              "text": "和"
            },
            {
              "chord": "D",
              "text": "好。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是属灵磐石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅为解人干渴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也非仅为给人倚恃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更是为造神居所。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是锡安所放基石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "试过、稳固，神所立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是召会所靠磐石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会惟一的根基。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会建造在你身上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阴间之门难胜过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽经各种风雨冲撞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍然屹立不灭没。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会在此有你权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "捆绑你所要捆绑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进天国，驱逐邪灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放你所要释放。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你更是生命活石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所拣选、所宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也使我们成为活石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同性、同地位；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同被建造成为灵宫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是祭司的体系，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给神居住，对神事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献上可悦的灵祭。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你又是大卫苗裔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要建造神圣殿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "君王、祭司两职合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就得尽你职权。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你作君王为神掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "权柄人就肯顺服；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你作祭司显在神前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通人就能进入。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "权柄出于神的宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神子民能平定；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通来自生命水河，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫神子民得供应。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "权柄、交通平衡并行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造进行才可能；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "君王、祭司在你合并，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的建造得完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神成肉身帐幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神荣耀的圣殿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在你里人间居住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面得彰显。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是召会，神、人联属，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满一切神丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且是我们每个圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着建造神圣殿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，你还是永久居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们历代的住处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面我们生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得蒙永远的遮护。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你对我们也是圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与我们的同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们和神共同生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向神不断的敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "角石、基石、磐石、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活石、圣殿、召会、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造者、居所、圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你全都是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是建造的一切！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美你的所是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美你是何奇妙！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿我们这些活石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你所是被建造！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
