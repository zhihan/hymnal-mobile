              "text": "God in a man manifest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You died for humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To redeem man for eternity."
            }
          ]
        },
        {
          "segments": [
