    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, dear Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death can’t hold You in the grave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now You’re the Spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You can enter man to save."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan plotted and killed You dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That destroyed him the devil instead."
            }
          ]
        },
        {
          "segments": [
            {
