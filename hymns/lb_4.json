    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re beyond man’s word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re a God-man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re divine and human."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re immortal with eternal might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet became a mortal finite."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re almighty, eternally the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet a man in time became."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You partook blood and flesh."
            }
          ]
        },
        {
          "segments": [
            {
