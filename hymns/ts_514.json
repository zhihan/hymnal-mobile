            },
            {
              "chord": "G",
              "text": "息。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "這 是 地 方 召 會，"
            }
          ]
        },
