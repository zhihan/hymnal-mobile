        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "站 住"
            },
            {
              "chord": "",
              "text": "立 場 同 聚"
            },
            {
              "chord": "G",
              "text": "集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 金 燈 臺 照 亮"
            },
            {
              "chord": "C",
              "text": "各 地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "使 神"
            },
            {
              "chord": "",
