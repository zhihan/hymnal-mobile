          "segments": [
            {
              "chord": "C",
              "text": "是 神"
            },
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "揀 選，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "所 有"
            },
            {
              "chord": "",
              "text": "聖"
            },
            {
              "chord": "A7",
              "text": "徒 合"
            },
            {
              "chord": "",
              "text": "為"
            },
            {
              "chord": "D",
              "text": "一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "這 是"
            },
            {
              "chord": "G",
              "text": "地 方"
            },
            {
              "chord": "",
              "text": "召 會，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "是 神"
            },
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "揀 選，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所 有 聖"
            },
            {
              "chord": "D7",
              "text": "徒 合"
            },
            {
              "chord": "",
              "text": "為"
            },
            {
              "chord": "G",
              "text": "一。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！他们正在聚会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们声音何响亮！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄姊妹踊跃分享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将主基督来显扬。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听哪！他们都在祷读，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将生命的话吸入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告，赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喝主，吃主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们何等享受主！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听哪！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们喊‘主耶稣，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们何等爱这名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当他们宣告祂是主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐就越发加增。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听哪！他们阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "声音如大雷爆炸！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌已经被摔下！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！圣徒们在移民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主行动开始，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会在各城市显明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主快来不延迟。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！主基督将要来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为祂曾舍命召会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今妆饰祂的心爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂新妇与祂配。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀的召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫无斑点皱纹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满了主的荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀的召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫无斑点皱纹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满了主的荣耀。"
            }
          ]
        }
      ]
    }
