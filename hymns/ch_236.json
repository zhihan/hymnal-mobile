    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝血为我永远在天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神说出美言；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主看圣徒如同奇珍，"
            }
          ]
        },
        {
          "segments": [
