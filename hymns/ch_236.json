      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘不再定罪！’我的魂哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神说的话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在基督复活主里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已是完全美丽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神阿，教我注目仰望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主基督，我王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我才会爱你的心情，"
            }
          ]
        },
        {
          "segments": [
