{
  "url": "https://www.hymnal.net/cn/hymn/ch/506",
  "title": "祂不误事因祂是神",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "祂 不"
            },
            {
              "chord": "",
              "text": "誤 事， 因"
            },
            {
              "chord": "E",
              "text": "祂"
            },
            {
              "chord": "E7",
              "text": "是"
            },
            {
              "chord": "A",
              "text": "神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 不"
            },
            {
              "chord": "",
              "text": "誤"
            },
            {
              "chord": "A",
              "text": "事， 祂"
            },
            {
              "chord": "E",
              "text": "樂"
            },
            {
              "chord": "B7",
              "text": "施"
            },
            {
              "chord": "E",
              "text": "恩！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "祂 不"
            },
            {
              "chord": "",
              "text": "誤 事， 祂"
            },
            {
              "chord": "E",
              "text": "已"
            },
            {
              "chord": "E7",
              "text": "許"
            },
            {
              "chord": "A",
              "text": "過！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "有"
            },
            {
              "chord": "A",
              "text": "神， 還"
            },
            {
              "chord": "E",
              "text": "怕"
            },
            {
              "chord": "E7",
              "text": "誰"
            },
            {
              "chord": "A",
              "text": "何？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有何高山你不能锄？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何深水你不能渡？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的神专门处置"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人所以为不能的事。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是祂使铁浮水而起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是祂使海分成干地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是祂使日半空停止，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的神并无难事！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂使软沙作海界限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "波浪虽狂，不能再前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是你神，还有甚么"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是不能为你工作？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂心爱你，知你难处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以应许祂要照顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的神充满怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对待祂的无告子民。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的神不能不义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能将祂应许忘记；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的应许在基督里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是阿们，都是是的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的神不能失信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的恩约永远坚定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要照祂应许，答应"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们因信所发呼声。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们因信欢乐唱说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂不误我，祂已许过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂不误我，祂乐施恩！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂不误我，因祂是神！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
