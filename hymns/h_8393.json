    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fairest of all the fair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He pleases me in full."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Noble of nobles, He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My prize unmatchable."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life of all lives is He;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From death He makes me rise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy of holies, from"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world He sanctifies."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteous of righteous ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him I stand each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Strength of strengths,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Refreshing on the way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He, as the Pow’r of pow’rs,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renews with eagles’ wings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vict’ry of victories,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er all my foes He brings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Able of able ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My being He sets free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Might of mights,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit strength’ning me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the King of kings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who now reigns in my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Light of lights,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Illum’ning every part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Lord of lords,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He now lives in my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Way of ways,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who every step does chart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Healing of healings, He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cures spirit, body, soul;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wonder of wonders, He;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll share His glory full."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hope of all hopes is He,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drawing my heart above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The greatest prize to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He guides my steps in love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Love of loves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worthy to be adored;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Patience of patience He,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worthy of praise outpoured."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Greatest of all the great,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My adulations raise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory of glories He,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deserving all my praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    }
