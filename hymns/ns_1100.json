    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God appeared in Exodus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As “I AM THAT I AM” to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The God of old, of Abraham,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Isaac, Jacob—the I AM! (God is!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Numbers, three-fold blessing see:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Jehovah bless thee and keep thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jehovah cause His face to shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lift His countenance on thine!” (Amen!)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The shining Triune God is not for doctrine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The shining Triune God is for dispensing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is now dispensing; He is now dispensing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In you and me, in you and me!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jehovah, in Isaiah, said,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Whom shall I send? Whom shall I send?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, who will go, will go for Us?”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God now calls to us! (Send us!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Matthew’s gospel, Jesus said"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Disciple all, baptizing them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the Name of Father, Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Spirit,” — in the Three-and-One! (Three-One!)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The living Triune God is not for doctrine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The living Triune God is for dispensing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is now dispensing; He is now dispensing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In you and me, in you and me!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Paul’s epistles, here we find:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love of God, the grace of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit’s fellowship divine—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit now this blessing’s mine! (Amen!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We kneeling ask our Father, thus:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, through Your Spirit strengthen us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With pow’r into our inner man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So Christ can make His home within! (My heart!)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The moving Triune God is not for doctrine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The moving Triune God is for dispensing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is now dispensing; He is now dispensing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In you and me, in you and me!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now to the Triune God we sing:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Who was and is, and is coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The seven Spirits by the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Witness True and Son Firstborn!” (Praise Him!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God—the Trinity—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself dispenses into me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into my spirit, body, soul;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll sanctify my being whole! (Dispense!)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
