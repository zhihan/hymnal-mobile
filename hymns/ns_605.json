    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Have you had your cup, your cup of Christ in the morning?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Start your day with a little restoring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ as your life-giving drink."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll fill your cup, He’ll fill you up, until you sink in Christ."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink, drink up Christ in the morning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink the One who’s overflowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In your heart, from the throne He’s flowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To reach you. With the tree that’s growing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To cherish, to nourish, to refresh, to supply you."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
