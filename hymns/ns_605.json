              "text": "With Christ as the heavenly air."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just by one simple prayer, you can breathe Him anywhere."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call, call His name in the morning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Join yourself to the One who’s soaring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transcending over everything,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just call His name and breathe Him in."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t think; the breath knows where to go."
            }
          ]
        }
