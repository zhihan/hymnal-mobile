  "title": "照我本相",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "照 我"
            },
            {
              "chord": "",
              "text": "本 相， 無"
            },
            {
              "chord": "A",
              "text": "善"
            },
            {
              "chord": "A7",
              "text": "足"
            },
            {
              "chord": "D",
              "text": "稱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟"
            },
            {
              "chord": "A",
              "text": "你 流"
            },
            {
              "chord": "A7",
              "text": "血， 替"
            },
            {
              "chord": "D",
              "text": "我 受"
            },
            {
              "chord": "",
              "text": "懲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "並 且 召"
            },
            {
              "chord": "D7",
              "text": "我 就"
            },
            {
              "chord": "G",
              "text": "你 得"
            },
            {
              "chord": "",
              "text": "生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救"
            },
            {
              "chord": "D",
              "text": "主 耶"
            },
            {
              "chord": "",
              "text": "穌， 我"
            },
            {
              "chord": "A",
              "text": "來！"
            },
            {
              "chord": "A7",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "來！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照我本相，不必等到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己改变比前更好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你宝血除罪可靠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主耶稣，我来！我来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照我本相，反复不定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "疑信参半，如浪不平，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内有罣虑，外有恶行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主耶稣，我来！我来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照我本相，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "贫、瞎、可怜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我真需要你的恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感我恶心，开我盲眼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主耶稣，我来！我来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照我本相，你肯收留，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐我生命，赦我愆尤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既应许，必定成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主耶稣，我来！我来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
