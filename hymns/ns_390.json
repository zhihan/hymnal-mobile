          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is nothing else that can compare."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we realize there’s nothing we can do,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But all things are possible through You."
            }
          ]
        }
      ]
    },
