    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us open to the Lord Himself through prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breathe Him deeply as the living air."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain the life supply by praying into Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til our being’s filled up to the brim."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us those who’re one with You in prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Echoing the things for which You care."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, do make us one so that Your heart’s desire we share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this age, Lord gain Your men of prayer."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us fellowship with God in spir’t through prayer;"
