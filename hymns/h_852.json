    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For her, Thyself Thou gavest, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That she be Thine, complete;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For her, I too my body give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heart's desire to meet."
            }
          ]
        }
