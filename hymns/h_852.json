      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For her, Thou hast become my life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That she my living be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For her, I would forsake myself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That she be filled with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church is Thy beloved Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou in Thy Body seen;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She is my joy and heart's desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The one on whom I lean."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In her, Thy full supply, O Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost to me impart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In her am I possessed by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To satisfy Thy heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy dwelling place, O Lord, I love;"
