      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在神至高国度中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督得显为大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督掌权生命中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神就能有可夸。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当神施行祂统治，"
