            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂统治的权下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全祂的心意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有在神国度中，"
