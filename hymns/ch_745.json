            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂统治领受。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命荣耀的管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会现已豫尝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并催国度速实现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有都得分享。"
            }
          ]
        }
      ],
