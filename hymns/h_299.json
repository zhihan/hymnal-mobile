    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By nature and by practice far,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How very far from God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet now by grace brought nigh to Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through faith in Jesus’ blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So nigh, so very nigh to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot nearer be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in the person of His Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am as near as He."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So dear, so very dear to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More dear I cannot be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love wherewith He loves the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such is His love to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Why should I ever anxious be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since such a God is mine?"
            }
          ]
        },
        {
          "segments": [
