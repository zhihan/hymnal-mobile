          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I belong to You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My God, my Lord alone."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By life I keep on walking,"
