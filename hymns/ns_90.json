    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe in this house, Lord You’re cherished,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We treasure You above all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We grasp the chance to be with You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your presence our greatest joy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Comfort Your heart with our tears, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash the world’s hatred away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we serve You a meal, Lord?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we share in Your trial?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we prepare Your Body?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May our love satisfy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! We are blessed to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your house in Bethany."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sharing Your table, we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Focus our gaze on Thee."
            }
          ]
        }
      ],
