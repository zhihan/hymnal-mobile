      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, in our eyes You are worthy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And what we have, Lord, we give."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breaking our flask we anoint Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What is most precious we spend."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our heart’s ointment so costly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we pour out on Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May all the house be filled, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With fragrance sweet to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Your whole church then hunger,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With more desire for Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, may we always be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With You in Bethany."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our free will offering,"
            }
          ]
        },
        {
