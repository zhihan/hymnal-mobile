              "text": "我 当"
            },
            {
              "chord": "",
              "text": "如 何 爱"
            },
            {
              "chord": "D",
              "text": "我 的"
            },
            {
              "chord": "G",
              "text": "主？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "如 何"
            },
            {
              "chord": "",
              "text": "奉"
            },
            {
              "chord": "D",
              "text": "献 使"
            },
            {
              "chord": "A",
              "text": "祂 欢"
            },
            {
              "chord": "D",
              "text": "喜？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "稍 离"
            },
            {
              "chord": "D7",
              "text": "开 祂"
            },
            {
              "chord": "G",
              "text": "的 道"
            },
            {
              "chord": "",
              "text": "路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学"
            },
            {
              "chord": "D",
              "text": "习 如"
            },
            {
              "chord": "",
              "text": "何 与"
            },
            {
              "chord": "C",
              "text": "祂"
            },
            {
              "chord": "D7",
              "text": "亲"
            },
            {
              "chord": "G",
              "text": "密？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的途径若是痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我求你，禁我退缩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我仍然向你顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "追忆你的十架重负。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让我思念，你曾如何"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离开许多纯洁乐事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来忧、来饿、来倦、来渴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无家之夜，不息之日。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为我来忧、来倦、来死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你来不求自己喜悦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上安逸虽难恝置，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我岂爱你不胜这些？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，我算万事为损，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要来得你的注意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丢弃万事虽如土粪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着爱你有何可惜？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
