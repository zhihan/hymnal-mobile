              "text": "同心合意工作；地上万国"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要看见神荣耀的居所！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "万军之耶和华说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我殿要满荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上万国羡慕的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必定快要来到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这殿后来的荣耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必大过先前的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同享这荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐无比。"
            }
          ]
        }
      ]
    },
