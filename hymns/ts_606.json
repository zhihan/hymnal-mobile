    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听阿，神说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们要省察自己行为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒种虽多，收却少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因对我缺赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们要上到山上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去为我取木料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心建造我居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强！刚强！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全体起来建造！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神必定与我们同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使殿满了荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强！刚强！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心合意工作；地上万国"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要看见神荣耀的居所！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们蒙召的祭司"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当向神全顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神既与我们同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "管他世人怒目，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里激动并火热，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同来作工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿在其中"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一人放松。"
            }
          ]
        }
      ],
