            },
            {
              "chord": "D7",
              "text": "造。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "該 專"
            },
            {
              "chord": "",
              "text": "顧 你 的 家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而 神 家 卻 荒 廢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟"
            },
            {
              "chord": "A",
              "text": "兄 們，"
            },
            {
              "chord": "",
              "text": "快 快 興 起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建"
            },
            {
              "chord": "A7",
              "text": "造 召"
            },
            {
              "chord": "D7",
              "text": "會！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "剛"
            },
            {
              "chord": "G",
              "text": "強！ 剛"
            },
            {
              "chord": "G7",
              "text": "強！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全"
            },
            {
              "chord": "C",
              "text": "體 起"
            },
            {
              "chord": "",
              "text": "來 建"
            },
            {
              "chord": "G",
              "text": "造！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "D",
              "text": "必 定"
            },
            {
              "chord": "D7",
              "text": "與 我"
            },
            {
              "chord": "G",
              "text": "們 同"
            },
            {
              "chord": "",
              "text": "在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "A",
              "text": "殿 滿"
            },
            {
              "chord": "A7",
              "text": "了 榮"
            },
            {
              "chord": "D7",
              "text": "耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "剛"
            },
            {
              "chord": "G",
              "text": "強！ 剛"
            },
            {
              "chord": "G7",
              "text": "強！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同"
            },
            {
              "chord": "C",
              "text": "心 合"
            },
            {
              "chord": "",
              "text": "意 工"
            },
            {
              "chord": "B7",
              "text": "作； 地"
            },
            {
              "chord": "E7",
              "text": "上 萬"
            },
            {
              "chord": "",
              "text": "國"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都"
            },
            {
              "chord": "A",
              "text": "要 看"
            },
            {
              "chord": "A7",
              "text": "見 神"
            },
            {
              "chord": "G",
              "text": "榮 耀"
            },
            {
              "chord": "D7",
              "text": "的 居"
            },
            {
              "chord": "G",
              "text": "所！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听阿，神说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们要省察自己行为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒种虽多，收却少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因对我缺赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们要上到山上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去为我取木料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心建造我居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得荣耀。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强！刚强！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全体起来建造！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神必定与我们同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使殿满了荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强！刚强！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心合意工作；地上万国"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要看见神荣耀的居所！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们蒙召的祭司"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当向神全顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神既与我们同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "管他世人怒目，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里激动并火热，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同来作工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿在其中"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一人放松。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强！刚强！"
            }
          ]
        },
        {
          "segments": [
            {
