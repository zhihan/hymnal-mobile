            {
              "chord": "G",
              "text": "建 造"
            },
            {
              "chord": "",
              "text": "神 的 聖 殿 的 時 候"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已 經 來 到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "B7",
              "text": "有 的"
            },
            {
              "chord": "",
              "text": "地 方"
            },
            {
              "chord": "Em",
              "text": "召 會"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要"
            },
            {
              "chord": "A",
