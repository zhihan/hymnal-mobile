    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ark of testimony too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was but a type of Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In it the law of God was placed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But God in Thee we see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ark, in type, was made of wood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And overlaid with gold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It typifies Thee as a man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who God in full doth hold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the tabernacle too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s holy dwelling place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incarnate in the flesh Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And full of truth and grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s glory we behold in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Word divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy words and deeds of love and light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do God in life define."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The temple was a type of Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The house of God Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God dwells in Thee, Himself to show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His fulness to impart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though Thou by Satan wast destroyed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And numbered with the dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection Thou dost build"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A larger one instead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The city shows Thy fulness true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A figure of Thy Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The increase of Thyself in full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In whom Thou dost abide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee is God, the light divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lamp in her art Thou;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee God shines thru her on all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glory to avow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The tabernacle and the ark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The law within them stored,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The temple and the city too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are all Thyself, dear Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the hub, Thou art the rim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The all in all Thou art!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we see both God and man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How precious to our heart!"
            }
          ]
        }
      ],
