          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙的故事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝座要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因着宝血就停止，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公义审判，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟被神儿子担负，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此神就心满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪人也意足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美祂！赞美祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "工作已经成功！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢祂！感谢祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典真宽宏！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们荣耀耶稣，"
