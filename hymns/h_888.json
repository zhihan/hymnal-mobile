    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stand then in His great might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all His strength endued;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And take, to arm you for the fight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The panoply of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That, having all things done,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all your conflicts past,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ye may o’ercome through Christ alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And stand complete at last."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Leave no unguarded place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No weakness of the soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take every virtue, every grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fortify the whole."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To keep your armor bright"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Attend with constant care,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still walking in your Captain’s sight"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And watching unto prayer."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Pray, without ceasing pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Captain gives the word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His summons cheerfully obey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And call upon the Lord:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God your every want"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In instant prayer display;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pray always; pray, and never faint;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pray, without ceasing pray."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From strength to strength go on;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wrestle, and fight, and pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tread all the powers of darkness down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And win the well-fought day:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still let the Spirit cry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all His soldiers, “Come!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Christ the Lord descend from high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And take the conquerors home."
            }
          ]
