    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "信而顺从！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为除此以外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能得主的喜爱－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有信而顺从！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一个重担、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一点为难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是不顾，让我们苦痛；"
            }
          ]
        },
        {
          "segments": [
