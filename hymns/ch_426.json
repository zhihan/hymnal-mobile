        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为除此以外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能得主的喜爱－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有信而顺从！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一个重担、"
