      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地无一点黑影、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天无一片暗景"
            }
          ]
        },
        {
          "segments": [
