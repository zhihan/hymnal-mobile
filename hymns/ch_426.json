          "segments": [
            {
              "chord": "",
              "text": "惟 有"
            },
            {
              "chord": "A",
              "text": "信 而"
            },
            {
              "chord": "A7",
              "text": "顺"
            },
            {
              "chord": "D",
              "text": "从！"
