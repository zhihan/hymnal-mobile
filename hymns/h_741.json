            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Ere creation's"
            },
            {
              "chord": "E",
              "text": "work"
            },
            {
              "chord": "E7",
              "text": "was"
            },
            {
              "chord": "A",
              "text": "done,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "To conform"
            },
            {
              "chord": "",
              "text": "us by His"
            },
            {
              "chord": "A",
              "text": "Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "To the"
            },
            {
              "chord": "",
              "text": "image"
            },
            {
              "chord": "A",
              "text": "of"
            },
            {
              "chord": "A7",
              "text": "His"
            },
            {
              "chord": "D",
              "text": "Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His only"
            },
            {
              "chord": "A",
              "text": "dear"
            },
            {
              "chord": "A7",
              "text": "Be"
            },
            {
              "chord": "D",
              "text": "gotten"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Might become the"
            },
            {
              "chord": "E7",
              "text": "firstborn"
            },
            {
              "chord": "A",
              "text": "One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "And by"
            },
            {
              "chord": "D",
              "text": "Him with"
            },
            {
              "chord": "",
              "text": "many"
            },
            {
              "chord": "A",
              "text": "brethren"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "His expression"
            },
            {
              "chord": "A",
              "text": "full"
            },
            {
              "chord": "A7",
              "text": "be"
            },
            {
              "chord": "D",
              "text": "won."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By divine regeneration"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We the sons of God became,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But we must mature to fullness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the birthright to obtain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Born and fully grown to manhood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s adoption we may share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the measure of full stature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We God’s sonship will declare."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All our spirit, soul and body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto Christ conformed must be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This will be accomplished fully"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When our glorious Lord we see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By our body’s full redemption"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall adoption be complete;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the final transformation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God’s purpose we shall meet."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By that final transformation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll be fully sanctified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God will bring us into glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His Son identified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All creation is expecting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sons of God revealed to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That they might be freed from bondage"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into glorious liberty."
            }
          ]
        }
      ]
    }
