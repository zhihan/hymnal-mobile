              "text": "Hell beneath our feet is cast."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with Thee in resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death can never us oppress;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live we in Thy new creation,"
            }
          ]
        },
        {
