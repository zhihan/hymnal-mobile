          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The impress of God’s substance true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Effulgence of His glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou even art our God Himself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee is His full story."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee was made the universe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Subsisting by Thy merit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The heir, God hath appointed Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thou may inherit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thou hast purged our sins by death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In heaven Thou art seated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till all Thy foes will be subdued"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all God’s will completed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A better name than angels have,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From God Thou didst inherit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Son of God to us as life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou now art in the Spirit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy kingdom is of righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy throne will stand forever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God hath in love anointed Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou shalt wax old never."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou also art a man indeed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all our human nature;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By grace Thou tastedst death for us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may have Thy stature."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With glory and with honor crowned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things to Thee are subject;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Captain of salvation, full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art thru sufferings perfect."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By death the devil Thou hast spoiled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from death’s bondage freed us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou sanctifiest us in life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And dost to glory speed us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To us, Thy brethren, Thou art here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father’s Name declaring;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the Church Thou singest hymns,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s praises with us sharing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Superior Thou to Moses, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As to the house the builder;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, our Apostle sent from God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Art worthy of more splendor."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art our real Joshua,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee the rest we enter;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our full salvation is of Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our faith on Thee doth center."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the heav’nly rest to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now dwelling in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us to enter as the land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thy good inherit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Superior Thou to Aaron too—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself, the offering given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou enteredst, as our Great High Priest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The holiest place in heaven."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art our true Melchisedec,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With endless life in power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To minister the “bread and wine,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every needful hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the better sacrifice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru the eternal Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once offered unto God for us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may gain Thy merit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "16"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A better covenant was made"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy dear blood in heaven;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee this sure new testament"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thy redeemed was given."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "17"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art its Maker adequate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou dost have the merit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art its Giver competent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may all inherit;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "18"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Its qualified Executor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By life of resurrection;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its potent Mediator too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfilling God’s election."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "19"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art now within the veil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As our unique Forerunner,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That by Thy life, without the camp,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll in the race be runners."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "20"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Finisher of faith,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As well its Author perfect;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By faith and love we follow Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And e’er to Thee are subject."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "21"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Unequaled is Thy worth, dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thou art we treasure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art so perfect and complete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond all human measure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "22"
    }
  ],
