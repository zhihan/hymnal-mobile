    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God has cleared the way before us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the victory of His Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Raised the Victor’s banner o’er us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the battles He has won."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that’s left for us to do"
            }
          ]
        },
        {
          "segments": [
            {
