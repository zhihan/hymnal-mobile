              "text": "Labor thus will bring the increase"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the land with all its worth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Lord will have the harvest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When He comes to reap the earth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To provide the Lord the way,"
            }
          ]
        },
        {
          "segments": [
