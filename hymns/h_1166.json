      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s a land of hills and valleys,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brooks of water flowing free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fountains rich with living water,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Streams that flow abundantly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers, joyfully we stand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His promise, Christ the land."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
