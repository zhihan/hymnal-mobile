    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God has made the fruit to grow here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled the land with produce sweet:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Olive oil and pomegranates,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fig trees, honey, vines and wheat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need nothing else besides,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All we need the land provides."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
