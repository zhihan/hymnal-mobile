    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All we need to do is labor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Working on the land each day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not expecting ’manna’ blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Working in a normal way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God and man cooperating"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While for harvest we are waiting."
            }
          ]
        }
      ],
