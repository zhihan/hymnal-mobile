    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We have eaten unto fullness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with joy we bless the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the good land He has given;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithful to His promised Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we find there is no lack—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never, never we’ll go back!"
            }
          ]
        }
