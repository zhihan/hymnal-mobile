    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, Christ, Christ in my spirit’s flowing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, Christ, Christ in my soul is growing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burning all the oldness out of me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filling and transforming utterly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing me to full maturity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling, “Lord, Lord, Lord!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise, praise, praise, expressing God’s desire;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise, praise, praise stirs our spirit’s fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filling all our hearts to overflow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Telling of His purpose as we go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing all the wanderers to His flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Singing praise, praise, praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Church, church, church—one in every city;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Church, church, church—divisions what a pity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Babylon the Great is falling down;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jerusalem is where the Lord is crowned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers, won’t you meet on the local ground,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Building church, church, church."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Local church, praise the Lord we’ve seen it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Local church, praise the Lord we’re in it:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lighted city set upon a hill—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ and the Church—God’s only will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And this plan He will fulfill"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the local church."
            }
          ]
        }
      ],
