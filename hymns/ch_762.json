    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心所有忧伤与痛楚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无法平息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任何的人不能有帮助，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你不在这里。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有你来带我进永业，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我才满愿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要忘记路上这一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我看见你面。"
            }
          ]
        }
