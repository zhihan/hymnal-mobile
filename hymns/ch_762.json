      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你记念我的长等待，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实难继续；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若不能及时早回来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只好让我前去。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这久、这久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你不显荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "留在那边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无心的人已经在讥笑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说你不是迟延。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
