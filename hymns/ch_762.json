    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我是已经等待好疲倦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你记念；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "试炼使我渐易生埋怨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "渐易忘记奉献。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以求你不要再迟延，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你快来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已忍耐等候到今天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实在不易再挨。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
