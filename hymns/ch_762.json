    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "寡妇怎能在此不披素，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "回想已往；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欲见不得，怎能不哀哭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎不念念不忘？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新妇怎能不因爱成病，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切望婚期；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果久延无日徒引领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎不连连叹息？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是否须再等几年，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再有几度徘徊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再有几次流泪、几思念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然后，主，你才回来？"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会等候你许多年代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从古到今，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一世又一世一直忍耐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你仍未降临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也等候你许多岁月，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从少而老，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同时少年次第都永诀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是你仍未到。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
