    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take, drink this cup, each one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His death show till He come."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eat, drink, display this feast:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in the Lamb released!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Around the table, sup and dine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We eat the bread and drink the wine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All blessing in this cup we find."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No blood of cow or goat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could give us any hope."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our sins would all remain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still year by year the same."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A God-man, sinless, He must find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No other offering of His kind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A spotless lamb for all mankind."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come! Now enjoy His blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What access this to God!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here wondrous cleansing power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flows to us, hour by hour."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One sacrifice for all was made,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And peace our conscience does pervade."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption’s price is fully paid!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeemer! Savior! King!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy dear blood we sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in it now we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy mercy, boundless, free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This cup, our portion blessed of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is of the cov’nant in Thy blood—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear, precious, precious, priceless blood!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
