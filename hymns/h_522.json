            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I tried the broken cisterns, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, ah, the waters failed!"
