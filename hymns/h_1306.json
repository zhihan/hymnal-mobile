              "text": "To those we then shall see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We love Thy coming, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The time is very nigh."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts unblameable must be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To greet Thee from on high."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord Himself shall come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With loud assembling word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the saints in Christ shall be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever with the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re children of the day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re children of the light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That day should never come to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As does a thief at night."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, wholly sanctify"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And blameless let us be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit, soul, and body too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For that blest day with Thee."
            }
          ]
        }
