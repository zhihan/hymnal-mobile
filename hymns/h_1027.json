    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Why should we tarry when Jesus is pleading—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pleading for you and for me?"
