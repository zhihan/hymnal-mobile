    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As God in man, on earth Thou wast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A slave-form Thou didst own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As man in God, in heav’n Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Lord of all art known."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Man in glory there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And there by God enthroned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All pow’r in heaven and on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now by Thyself is owned."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Exalted highly to the heav’ns"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And giv’n the highest Name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All shall confess Thee as the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all bow at Thy Name."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God made Thee both the Lord and Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit hath declared;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In glory and in heav’n we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s throne by Thee is shared."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Lord of glory we adore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee our song we raise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We worship Thee as Lord of all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How worthy of our praise!"
            }
          ]
        }
      ]
