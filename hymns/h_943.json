    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Repent, the Kingdom has come near,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the Kingdom’s first demand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A change of mind we all must have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And on God’s side must firmly stand."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That we the Kingdom enter in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surpassing righteousness we need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exceeding that which is of law;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From life alone it must proceed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That we the Kingdom enter in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need to do the Father’s will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by our choice to work or act"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But His one purpose to fulfill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That we the Kingdom enter in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A simple child we must become—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Adjustable, obedient, meek—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And everything of self o’ercome."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Heav’nly Kingdom e’en requires"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we as God should perfect be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This standard we must fully meet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may share its ecstasy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom is the reign of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To match His nature is required;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis only by the life of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom’s entry is acquired."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom is the rule of heav’n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With heaven’s state we must accord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis only by the life of heav’n"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may share it with the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
