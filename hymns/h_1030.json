    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"I know thy life of guilt and pain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know each ache of heart and brain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How often I have called in vain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And offered pardon in my name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I plead yet once again!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!\""
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Though thou hast sinned I'll pardon thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From every sin I'll set thee free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all thy changing life I'll be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy God, thy guide on land and sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy bliss through all eternity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!\""
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Come, cast on Me thine every care;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heavy load I will upbear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, look to Me—dismiss thy fears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And trust Me through eternal years;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My hand shall wipe away thy tears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me, follow me, follow me!\""
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, I yield to Thee my will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll follow Thee, follow Thee, follow Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, bid my struggling soul be still;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll follow Thee, follow Thee, follow Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, cleanse me, with Thy Spirit fill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And keep me safe from every ill;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thy Word in me fulfill;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll follow Thee, follow Thee, follow Thee!"
            }
          ]
        }
