    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He hath taken our sins away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When on Calv’ry’s cross He bled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The disease of our soul He heals"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His Spirit freely shed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though Satan hath pierced us deep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And great the grace each prays;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we prove His might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Savior who saves always."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Long, alas! in the gloom I fought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Mid strife of wind and waves;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus seemed only this to me:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A Savior who sometimes saves."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But sweet are the light and calm"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That fill my happy days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since now I fully trust"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Savior who saves always."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O my Sun and my Shield art Thou"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lead on where Thou hast trod;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Salvation, my Joy, my Song,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Brother, and yet my God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whate’er then my life betide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I now can trust and praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each moment Thou wilt save,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Savior, who sav’st always."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
