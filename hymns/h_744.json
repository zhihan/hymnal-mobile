  "title": "In dealings with the Lord as life",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "In dealings"
            },
            {
              "chord": "D",
              "text": "with the"
            },
            {
              "chord": "D7",
              "text": "Lord as"
            },
            {
              "chord": "G",
              "text": "life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need a proper"
            },
            {
              "chord": "D",
              "text": "heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "That of"
            },
            {
              "chord": "",
              "text": "His riches,"
            },
            {
              "chord": "D",
              "text": "in His"
            },
            {
              "chord": "D7",
              "text": "grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "We fully"
            },
            {
              "chord": "D",
              "text": "may"
            },
            {
              "chord": "D7",
              "text": "take"
            },
            {
              "chord": "G",
              "text": "part."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We need a heart in all things pure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With mind both sound and clear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To understand His mind and heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In trembling and in fear."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We need a fervent, loving heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart on fire with love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With an emotion filled with zeal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him, all else above."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We need a true, obedient heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a submissive will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A will made pliable, yet strong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's purpose to fulfill."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We need a heart condemning not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all things right with God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart which has a conscience purged"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And covered with the blood."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grant us such a heart as this,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever fixed on Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That of Thyself we may partake"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy true fulness be."
            }
          ]
        }
      ]
    }
  ],
