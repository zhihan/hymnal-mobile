              "chord": "",
              "text": "Lower and lower, dear Savior, we pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Losing the self-life still more every day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Weak and unworthy, we’re looking above:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Empty us wholly; then fill us with love."
            }
          ]
        }
      ],
