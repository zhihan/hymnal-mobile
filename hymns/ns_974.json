{
  "url": "https://www.hymnal.net/en/hymn/ns/974",
  "title": "You Love Them",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They brought such joy to my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then they tore it apart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So broken and beyond repair."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Maybe they never really cared."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You love them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You love them."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They caused me suff’ring and pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I was never the same."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So full of trust, yet so betrayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then they simply walked away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You love them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You love them."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bridge:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can’t go on if I’m abiding in this hatred."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I live if I’m in death?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, infuse me with Your love to forgive them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And pass from death to life."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They wanted You crucified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They cursed You, left You to die."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You bled to save Your enemies."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Among those sinners, one was me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You love us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You love us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You love us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
