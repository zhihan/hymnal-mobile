      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ! Unique Creator,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Source whence all creation springs;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He o’er all is Lord and Master,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His the first place in all things."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All’s upheld by His commandment;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him do all things subsist."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the Heir, by God’s appointment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To inherit all that is."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, the Word incarnate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tabernacled among us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Virgin-born, a human perfect,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in flesh expressing thus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God yet man, without reluctance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Took slave’s form, was humbled thus."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the image of God’s substance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s effulgence glorious."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, in crucifixion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore our sins, e’en sin became."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Judged and killed by God’s conviction,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore death’s bitterness and shame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him slain, our old man’s over;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan’s vanquished mightily;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sin reigns over us no longer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all snares we’re wholly free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, in resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the Firstfruit from the dead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We receive His life infusion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through His resurrection led."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This Life-grain has brought forth others."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, the many grains are we!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now God’s Son has many brothers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve the same one source as He!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, as Spirit enters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into us as life to be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By partaking of God’s nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are made divine as He."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As He grows, He’s formed within us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till His image full we bear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till God’s riches, full and bounteous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His stature full we share."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, to heights ascended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Far above all rule, He reigns;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Honor, glory, crown resplendent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His the name above all names."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought with Him into ascension,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seated in the heavenlies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, too, share His strength, position,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even His authority."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, the Spirit sending,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has the church established thus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For its functions, gifts presenting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His church be built through us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How He loves His dear expression;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loves to nourish, cherish her."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She, His increase and extension,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spreads to all the universe."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, with kingdom coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints He’ll rapture, glorify;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foes He’ll crush, all nations judging,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kingdom to set up thereby."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will be beside Him reigning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en o’er earth’s remotest ends;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All lands peaceful, all men praising,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all earth His peace extends."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ, eternal center,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gains His city, His dear bride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The new heav’n and earth will enter;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that’s old He’ll cast aside."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s the Lamp; forth from within Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as light shines gloriously;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His bright city manifests Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled with Him eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
