        {
          "segments": [
            {
              "chord": "",
              "text": "Chosen vessels, containers to be filled with You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let’s keep fighting, dispensing with God’s purpose in view!"
            }
          ]
