    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit is within the holiest of all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s here we worship and have fellowship with God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not in the outer court;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond the Holy Place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must go further to behold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glorious shining of His face."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ lives inside my spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supplying me with grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He wants to spend His time with me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beholding face to face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sisters:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I shouldn’t merely touch Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then just walk away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in my spirit stay and linger"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All throughout the day."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Jesus lives inside us, so we all must take"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him daily as our fortress and our hiding place."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s being built in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re being built in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The resting place of God and man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all eternity, amen!"
            }
          ]
