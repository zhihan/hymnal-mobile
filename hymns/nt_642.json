{
  "url": "https://www.hymnal.net/en/hymn/nt/642",
  "title": "Within the veil",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Within the Veil”: be this, belov’d, thy portion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the secret of thy Lord to dwell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beholding Him, until thy face His glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy life His love, thy lips His praise shall tell."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sisters:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeking You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring me in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Your light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re so rich,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re so full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wonderful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My delight."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord You are"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All I need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious Lord."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Within the Veil,” for only as thou gazest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the matchless beauty of His face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Canst thou become a living revelation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of His great heart of love, His untold grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Within the Veil,” His fragrance poured upon thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without the Veil, that fragrance shed abroad;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Within the Veil,” His hand shall tune the music"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which sounds on earth the praises of Thy Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Within the Veil,” thy spirit deeply anchored,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou walkest calm above a world of strife;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Within the Veil,” thy soul with Him united,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall live on earth His resurrection life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
