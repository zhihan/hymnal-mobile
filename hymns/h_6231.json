    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just call with us, \"Lord Jesus,\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will surely set you free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If your heart is far, far from Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherever you may be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We simply call upon Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No matter where we are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And calling—thus, He enters,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, He's never very far."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just call upon our Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sure He'll hear you every time."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lean your weary head upon Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And rest in sweet recline."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For He is our strong fortress,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our peace, our joy, our rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we taste the grace of Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sure we're tasting the very best."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The best is just Himself now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Himself He freely gave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So let's open up to Him now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by His life be saved."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And when He comes to meet us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As His bride we'll ready be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If today He grows within us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall then His glory see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
