      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "光来明显一切，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光来除去自借，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光来，当光正缺，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐你自己的光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "甚么我都看不见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但正在施欺骗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你对准你光线"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我身上，我主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "光照我的生命，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使得自知之明，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有丝毫黑影，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光照使知软弱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "集中我心对你，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使它自由无羁，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照它使知你意，主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你的光，照我！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "使我永远能行动"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你无影亮光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不离同在的交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "认识光的拆毁。"
            }
          ]
        }
      ],
