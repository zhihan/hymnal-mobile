            },
            {
              "chord": "",
              "text": "最 黑 路"
            },
            {
              "chord": "D",
              "text": "上， 主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 求 你"
            },
            {
              "chord": "F♯7",
              "text": "的 大"
            },
            {
              "chord": "G",
              "text": "光， 主，"
