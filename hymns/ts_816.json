{
  "url": "https://www.hymnal.net/cn/hymn/ts/816",
  "title": "你为何被造",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 知"
            },
            {
              "chord": "G",
              "text": "道 你"
            },
            {
              "chord": "",
              "text": "为 何"
            },
            {
              "chord": "D",
              "text": "被 造？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有 否"
            },
            {
              "chord": "Em",
              "text": "想 过"
            },
            {
              "chord": "",
              "text": "这 问"
            },
            {
              "chord": "A",
              "text": "题？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你 的"
            },
            {
              "chord": "",
              "text": "生 存 有 何"
            },
            {
              "chord": "D",
              "text": "目 的？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Bm",
              "text": "你 今"
            },
            {
              "chord": "Em",
              "text": "活"
            },
            {
              "chord": "Em7",
              "text": "著 何"
            },
            {
              "chord": "",
              "text": "意"
            },
            {
              "chord": "Asus4",
              "text": "义！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 知"
            },
            {
              "chord": "",
              "text": "道 神"
            },
            {
              "chord": "Em",
              "text": "愿 作"
            },
            {
              "chord": "",
              "text": "你 生 命？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "A",
              "text": "愿 作"
            },
            {
              "chord": "",
              "text": "你 生"
            },
            {
              "chord": "A7",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "D",
              "text": "愿 作"
            },
            {
              "chord": "",
              "text": "你 生"
            },
            {
              "chord": "G",
              "text": "命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 乃"
            },
            {
              "chord": "",
              "text": "是 祂"
            },
            {
              "chord": "Em",
              "text": "所 造"
            },
            {
              "chord": "",
              "text": "的 器 皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为"
            },
            {
              "chord": "A",
              "text": "了 装"
            },
            {
              "chord": "",
              "text": "祂， 将"
            },
            {
              "chord": "A7",
              "text": "祂 表"
            },
            {
              "chord": "D",
              "text": "明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你有灵，在你最深处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比你的心更深入；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的心装许多事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你的灵仍缺如！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多少年来，你虚空度日；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然到处尝试，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总是不得满足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的深处岂不觉渴慕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿意敞开，尝尝耶稣？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不管你的看法如何，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神面前谁无过？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣已为你流血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你过错得解决。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主耶稣已成全一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不需你再努力─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "功过全无差别；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃是灵，你接受就行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂愿进来作你生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如你外面的身子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "容纳自己正合式，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的灵─在你的深处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是专为容纳主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何不现在从深处敞开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在让主进来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满你的心怀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何不现在从深处敞开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呼喊主名，祂必进来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
