{
  "url": "https://www.hymnal.net/cn/hymn/ts/239",
  "title": "我奉耶稣基督的名",
  "lines": [
    {
      "segments": [
        {
          "chord": "",
          "text": "‘金银财宝我没有，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "只把我所有的给你；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我奉耶稣基督的名，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "叫你现在起来行走！’"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "他就走着，又跳着，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "又赞美神；走着，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "又跳着，又赞美神。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，赞美我主！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "荣耀，荣耀归于主名！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "金银财宝我没有，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "却有七倍加强的灵；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我奉耶稣基督的名，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "刚强站起作祂见证！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我在召会中"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "又赞美又见证，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "召会中又赞美又见证。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，赞美我主！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "荣耀，荣耀归于主名！"
        }
      ]
    }
  ],
