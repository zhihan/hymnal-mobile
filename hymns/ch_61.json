  "title": "恩主耶稣你名我是",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D7",
              "text": "恩 主"
            },
            {
              "chord": "G",
              "text": "耶 稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 名"
            },
            {
              "chord": "D",
              "text": "『我 是，』"
            },
            {
              "chord": "",
              "text": "宝 贵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "圣 名，"
            },
            {
              "chord": "C",
              "text": "丰 美、"
            },
            {
              "chord": "D",
              "text": "真 实！"
            },
            {
              "chord": "",
              "text": "我 所"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "需 要"
            },
            {
              "chord": "",
              "text": "全 都"
            },
            {
              "chord": "C",
              "text": "在 此－"
            },
            {
              "chord": "Am",
              "text": "全 在"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "你"
            },
            {
              "chord": "D7",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "是！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是圣子、又是圣父，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神隐藏、是神显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且成那灵与我同处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我享丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是帐幕、你是圣殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给神安居，将神彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我在你与神相见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得享神肥甘。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是羔羊、你是新郎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为娶新妇，将罪担当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我舍己、为我受伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得安康。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是智慧、你是道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照神旨意，为我部署，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我蒙恩，使我受福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纳我入正途。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是公义、你是圣洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神相合，为神所悦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我称义，使我圣别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能与神和谐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是生命、你是亮光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "消除黑暗，吞灭死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我复生，使我明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得释放。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是复活、你是大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "冲破坟墓，胜过幽冥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我刚强，使我得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我占上风。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是灵粮、你是活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为作供应，甘愿降卑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "解我饥渴，苏我困惫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作了我美味。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是牧人、你是医生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我舍命，医我疾病，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "保养、顾惜、安慰、引领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事都照应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是祭司、你是君王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我带进神的面光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的权柄我得分享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地位何高尚！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是救赎、你是盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要将我改变形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我完全与你相像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你来显彰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "还是荣耀、喜乐、平安、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真理、恩典、活道、灵磐、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "日头、盾牌、居所、靠山，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何人能尽言！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的所是永远、无限、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长、阔、高、深、丰满、完全！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂只应付我的缺欠！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且从我溢漫！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    }
  ],
