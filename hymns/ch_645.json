  "title": "天上地下所有权柄",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "天 上"
            },
            {
              "chord": "",
              "text": "地 下 所"
            },
            {
              "chord": "D",
              "text": "有 权"
            },
            {
              "chord": "G",
              "text": "柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都"
            },
            {
              "chord": "C",
              "text": "已 赐"
            },
            {
              "chord": "",
              "text": "给 复"
            },
            {
              "chord": "D",
              "text": "活 基"
            },
            {
              "chord": "",
              "text": "督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与"
            },
            {
              "chord": "G",
              "text": "祂 联"
            },
            {
              "chord": "",
              "text": "合， 靠"
            },
            {
              "chord": "D",
              "text": "祂 生"
            },
            {
              "chord": "G",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "C",
              "text": "有 仇"
            },
            {
              "chord": "",
              "text": "敌 都"
            },
            {
              "chord": "D",
              "text": "要"
            },
            {
              "chord": "D7",
              "text": "屈"
            },
            {
              "chord": "G",
              "text": "服。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你当借主说你必定"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过魔鬼一切能力！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当从主支取权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "践踏地上蛇头、龙体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "管你甚么，你这高山！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "管你那里，或天或地！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论如何我总要铲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奉主的名，你当快离！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "信心命你离开此地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你当顺服投在海里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我当、我要、我能、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我必成功我神所有目的。"
            }
          ]
        }
      ],
