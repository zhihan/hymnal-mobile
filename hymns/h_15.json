    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Distinct, unique, and holy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not only right and pure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not only without defect,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with perfection more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For nothing can approach Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor e'er Thine equal be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If aught Thy place hath taken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis insult unto Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The excellent excelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fairest of the fair,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet differing from the finest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For none with Thee compare."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all the righteous different,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thine is absolute;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None beauteous with Thee vying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thine excels repute."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy holiness transcendent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast for us prepared,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And this distinctive nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have already shared."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We share in Thy transcendence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since we Thy nature own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy holy life we follow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till unto fulness grown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We give Thee praise and worship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all Thy holiness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy transcendent nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine utter peerlessness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We praise Thee that Thy nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unique, distinct—we share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This separating nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is ours now and fore'er."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
