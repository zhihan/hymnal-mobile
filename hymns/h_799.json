    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the breath of God as light to man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With rays divine man to illuminate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It shines in darkness and to man reveals"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What is his truest need and actual state."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the breath of God as life to man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nature divine to man it doth impart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The dead it quickens and regenerates,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transforms the soul-life and renews the heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the breath of God as wisdom too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knowledge divine to man it has to teach;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th’ eternal purpose of the Lord it shows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And leadeth man God’s final goal to reach."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the breath of God as strength to man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Power divine to man it doth transmit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strength’ning the weak, empowering the faint,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enabling man God’s purpose full to fit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the breath of God for us to breathe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That as our portion God we may enjoy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Receiving it by spirits exercised,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our need is met, His wealth we may employ."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
