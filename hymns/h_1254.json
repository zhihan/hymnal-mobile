    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll fill this house with glory, the Lord of hosts has said,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the desire of nations will be exhibited."
