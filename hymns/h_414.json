{
  "url": "https://www.hymnal.net/en/hymn/h/414",
  "title": "My Savior, Thou hast offered rest",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "My Savior,"
            },
            {
              "chord": "",
              "text": "Thou hast"
            },
            {
              "chord": "G7",
              "text": "offered"
            },
            {
              "chord": "C",
              "text": "rest:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Oh,"
            },
            {
              "chord": "C",
              "text": "give it"
            },
            {
              "chord": "F",
              "text": "then to"
            },
            {
              "chord": "G",
              "text": "me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "C",
              "text": "rest of"
            },
            {
              "chord": "F",
              "text": "ceasing"
            },
            {
              "chord": "C",
              "text": "from my"
            },
            {
              "chord": "Dm",
              "text": "self,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "To"
            },
            {
              "chord": "F",
              "text": "find my"
            },
            {
              "chord": "G7",
              "text": "all in"
            },
            {
              "chord": "C",
              "text": "Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This cruel self, oh, how it strives"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And works within my breast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To come between Thee and my soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And keep me back from rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How many subtle forms it takes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of seeming verity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As if it were not safe to rest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And venture all on Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, I seek a holy rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A victory over sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I seek that Thou alone shouldst reign"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er all without, within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy strong hand I lay me down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So shall the work be done;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For who can work so wondrously"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Almighty One?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Work on, then, Lord, till on my soul"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal light shall break,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, in Thy likeness perfected,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I “satisfied” shall wake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
