        {
          "segments": [
            {
              "chord": "",
              "text": "生 命"
            },
            {
              "chord": "E7",
              "text": "的 交"
            },
            {
              "chord": "A",
              "text": "通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "在 灵"
            },
            {
              "chord": "",
              "text": "里 的"
            },
            {
              "chord": "G",
              "text": "交 通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "使 灵"
            },
            {
              "chord": "A7",
              "text": "来 推"
            },
            {
              "chord": "D",
              "text": "动。"
            }
          ]
        }
