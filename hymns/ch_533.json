  "raw_sections": [
    "永 遠生 命帶 來",
    "生 命的 交通；",
    "在 靈裡 的交 通，",
    "使 靈來 推動。",
    "永远生命赐给",
    "神圣的交通；",
    "如此主灵与我，",
    "灵里同行动。",
    "乃是灵里生命，",
    "带来这交通；",
    "在灵里的交通，",
    "使我蒙恩宠。",
    "借着生命大能，",
    "能正确交通；",
    "在灵里的交通，",
    "带我到光中。",
    "借血外面洗净，",
    "交通得维持；",
    "借膏里面涂抹，",
    "交通能充实。",
    "借着十架工作，",
    "交通得加深；",
    "借着圣灵运行，",
    "交通得更新。",
    "这一生命交通，",
    "使我脱自己；",
    "这一生命交通，",
    "带我进神里。"
  ]
}