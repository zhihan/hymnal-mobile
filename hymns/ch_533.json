      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "永远生命赐给"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣的交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此主灵与我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里同行动。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是灵里生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来这交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里的交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我蒙恩宠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着生命大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能正确交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里的交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带我到光中。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借血外面洗净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通得维持；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借膏里面涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通能充实。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着十架工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通得加深；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着圣灵运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通得更新。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这一生命交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这一生命交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带我进神里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
