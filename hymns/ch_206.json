    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你多赐我们以圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让祂光照并焚烧，"
