      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the demands of righteousness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord has fully paid;"
            }
          ]
        },
        {
          "segments": [
