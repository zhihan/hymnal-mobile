      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, no more can You condemn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s offering has appeased;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m fully free, as far from sin"
            }
