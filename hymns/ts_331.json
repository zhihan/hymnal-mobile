            {
              "chord": "D",
              "text": "我 是"
            },
            {
              "chord": "",
              "text": "属"
            },
            {
              "chord": "A",
              "text": "主！ 哦，"
            },
            {
              "chord": "D",
              "text": "喜 乐"
            },
            {
              "chord": "",
              "text": "真 是"
            },
            {
              "chord": "G",
              "text": "难 述！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "甜 美"
            },
            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "回 应"
            },
            {
              "chord": "",
              "text": "主 爱 的 招"
            },
            {
              "chord": "A",
              "text": "呼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "\"你 是"
            },
            {
              "chord": "",
              "text": "属"
            },
            {
              "chord": "A",
              "text": "我， 别"
            },
            {
              "chord": "D",
              "text": "怕， 我"
            },
            {
              "chord": "",
              "text": "已 将"
            },
            {
              "chord": "G",
              "text": "你 赎\"─"
            },
            {
              "chord": "",
              "text": "祂 柔 声"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "应 许"
            },
            {
              "chord": "",
