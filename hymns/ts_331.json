      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我是属主！哦，心中欢喜承认！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享快乐之日，望婚娶之晨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我说\"我愿\"迎接祂进入心门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬爱顺从主永作\"主的人\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我是属主！哦，要学更深一步："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不愿自由去，因我爱我主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠贞、爱慕、犠牲事奉并降服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我毫无保留永作你奴仆。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我是属主！哦，灵、魂、体每一部，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都有你印记，永不再他属；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就像你，主，满带恩典和丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直到永远，全都归我属。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
