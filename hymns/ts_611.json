{
  "url": "https://www.hymnal.net/cn/hymn/ts/611",
  "title": "在宇宙中只有一个身体",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 我"
            },
            {
              "chord": "",
              "text": "们 是 你 身 体"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 此"
            },
            {
              "chord": "C",
              "text": "聚 集，"
            },
            {
              "chord": "",
              "text": "人 数 虽"
            },
            {
              "chord": "G",
              "text": "多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "们 仍"
            },
            {
              "chord": "",
              "text": "然 是"
            },
            {
              "chord": "G",
              "text": "一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 生 命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 们 成 为"
            },
            {
              "chord": "C",
              "text": "肢 体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 生 命"
            },
            {
              "chord": "G",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "们 完"
            },
            {
              "chord": "",
              "text": "全 是"
            },
            {
              "chord": "G",
              "text": "一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在 宇 宙 中 只"
            },
            {
              "chord": "C",
              "text": "有 一"
            },
            {
              "chord": "",
              "text": "个 身"
            },
            {
              "chord": "G",
              "text": "体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 将"
            },
            {
              "chord": "D",
              "text": "她"
            },
            {
              "chord": "D7",
              "text": "彰 显"
            },
            {
              "chord": "",
              "text": "于"
            },
            {
              "chord": "G",
              "text": "地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 站 住 地"
            },
            {
              "chord": "C",
              "text": "方 一"
            },
            {
              "chord": "",
              "text": "的 立"
            },
            {
              "chord": "G",
              "text": "场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让 所 有"
            },
            {
              "chord": "D",
              "text": "人"
            },
            {
              "chord": "D7",
              "text": "同 来"
            },
            {
              "chord": "",
              "text": "观"
            },
            {
              "chord": "G",
              "text": "赏。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这一个饼乃是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "表明你身体，曾被擘开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使众圣分享；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们吃饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此一同领受你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此见证我们真正是一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在宇宙中只有一个身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们将她彰显于地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们站住地方一的立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让所有人同来观赏。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现在桌上陈列着"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一饼一杯，说出我们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能分门别类；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同蒙主恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还有甚么话可说，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有喊说：‘阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是一！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
