        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能再被谁分离，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为这‘一’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出自基督自己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同一饼杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在这一里吃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有目共睹这个一的事实。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
