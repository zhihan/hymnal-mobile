    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能有分于这个一！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们深觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，这使你满意！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们豫尝了那日，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新郎新妇那最甜美的一。"
            }
          ]
        }
