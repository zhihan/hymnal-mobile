    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "进入幔内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瞻仰荣耀基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出到营外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随卑微耶稣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝座、冠冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果将我鼓舞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "马槽、十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂能使我裹足？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "进入幔内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吸取复活大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出到营外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奔跑十架路程；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我若看见祂在天上面容，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必步武祂在地上脚踪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "进入幔内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饱尝天上肥甘，"
            }
          ]
        },
        {
          "segments": [
