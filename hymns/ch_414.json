      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "进入幔内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到幔子不存，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出到营外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到营都灭尽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到天地所有同归于一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到神、人永远"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再分离。"
            }
          ]
        }
      ],
