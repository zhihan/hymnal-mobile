{
  "url": "https://www.hymnal.net/cn/hymn/ch/82",
  "title": "哦满了伤痕的头",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦， 满"
            },
            {
              "chord": "",
              "text": "了 伤 痕"
            },
            {
              "chord": "D",
              "text": "的 头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满 了 痛 苦、 谇"
            },
            {
              "chord": "G",
              "text": "诟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受 尽 万 般 的"
            },
            {
              "chord": "C",
              "text": "试 炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又"
            },
            {
              "chord": "D",
              "text": "戴 荆"
            },
            {
              "chord": "",
              "text": "棘 冠"
            },
            {
              "chord": "G",
              "text": "冕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这"
            },
            {
              "chord": "C",
              "text": "头 今"
            },
            {
              "chord": "",
              "text": "日 已"
            },
            {
              "chord": "G",
              "text": "得 荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "A",
              "text": "得 圣"
            },
            {
              "chord": "",
              "text": "徒 歌"
            },
            {
              "chord": "D",
              "text": "诵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可"
            },
            {
              "chord": "B7",
              "text": "怜 当"
            },
            {
              "chord": "",
              "text": "日 受"
            },
            {
              "chord": "C",
              "text": "死 伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "D",
              "text": "加 略"
            },
            {
              "chord": "D7",
              "text": "木 头"
            },
            {
              "chord": "G",
              "text": "上。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的面容原超凡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同光明太阳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父神一见就悦纳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟受罪人唾打。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你所受的一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都为我们罪孽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们债务得清付，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却被人剪除。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们想到你痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又想到你无辜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们又满心欢喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是感激无既！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿，当我们正如此"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "念你十字架时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是生命全舍弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "损失还算利益。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们救主－危难友，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们报恩无由！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你为我流血时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的痛苦谁知？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你使我从今后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天记念髑髅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到被提进荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远与你相交。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
