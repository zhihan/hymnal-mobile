    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He hears Thy precious Name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We claim it as our own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father must accept and bless"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His well-beloved Son."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast fulfilled the law,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we are justified:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ours is the blessing, Thine the curse;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We live, for Thou hast died."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the sinner’s Friend!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We cannot speak Thy praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No mortal voice can sing the song"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That ransomed hearts would raise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But when before the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy face we all shall see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clothed in our blood-bought robes of white,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll stand complete in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, we’ll give Thee then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such praises as are meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And give ten thousand thanks to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Adoring, at Thy feet."
            }
          ]
        }
      ],
