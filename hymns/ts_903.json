{
  "url": "https://www.hymnal.net/cn/hymn/ts/903",
  "title": "主随时随刻都可能回来",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主 隨"
            },
            {
              "chord": "",
              "text": "時 隨 刻 都 可 能 回 來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 隨 時"
            },
            {
              "chord": "F",
              "text": "隨 刻"
            },
            {
              "chord": "",
              "text": "都 可 能"
            },
            {
              "chord": "C",
              "text": "回 來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 隨 時 隨 刻 都 可 能 回 來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦， 讓 我 們"
            },
            {
              "chord": "G7",
              "text": "儆 醒"
            },
            {
              "chord": "",
              "text": "等"
            },
            {
              "chord": "C",
              "text": "待！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是我们可爱的新郎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复三次，下同）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们乃是祂的新妇！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已定意转眼注视主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不回头，永不回头！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "路程在前头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "缠累丢背后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加速向前！加速向前！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们正快跑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迎接主来到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久就要与主相遇！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
