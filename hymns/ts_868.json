  "title": "寻找、光照、接纳",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "耶 稣─"
            },
            {
              "chord": "",
              "text": "好"
            },
            {
              "chord": "A",
              "text": "牧 人，"
            },
            {
              "chord": "",
              "text": "寻"
            },
            {
              "chord": "Em",
              "text": "找 税"
            },
            {
              "chord": "D",
              "text": "吏、 罪"
            },
            {
              "chord": "A",
              "text": "人；"
            },
            {
              "chord": "Bm",
              "text": "祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 神 成"
            },
            {
              "chord": "A",
              "text": "肉 身，"
            },
            {
              "chord": "",
              "text": "拯"
            },
            {
              "chord": "G",
              "text": "救 世"
            },
            {
              "chord": "F♯",
              "text": "人 脱"
            },
            {
              "chord": "",
              "text": "沉"
            },
            {
              "chord": "Bm",
              "text": "沦；"
            },
            {
              "chord": "D",
              "text": "肩"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "负"
            },
            {
              "chord": "G",
              "text": "疲 魂，"
            },
            {
              "chord": "",
              "text": "喜 乐、"
            },
            {
              "chord": "D",
              "text": "情 深，"
            },
            {
              "chord": "",
              "text": "领"
            },
            {
              "chord": "Em",
              "text": "迷"
            },
            {
              "chord": "A7",
              "text": "羊 归"
            },
            {
              "chord": "D",
              "text": "神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那灵─光照者，正寻觅失落者；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之光照射，要世人知罪自责；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "银币蒙尘，祂心不舍，终被祂寻得。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神─亲爱父，怜悯世上罪奴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放荡挥霍无度，不知何时才醒悟？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "慈爱天父，朝思夜慕，浪子上归途。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神─接纳者，亲吻那流浪者；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "披华美，罪全赦，享肥甘，不再饥渴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死而复活，失而又得，神、人同欢乐。"
            }
          ]
        }
      ],
