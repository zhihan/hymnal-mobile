  "title": "尋找、光照、接納",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "耶 穌─"
            },
            {
              "chord": "",
              "text": "好"
            },
            {
              "chord": "A",
              "text": "牧 人，"
            },
            {
              "chord": "",
              "text": "尋"
            },
            {
              "chord": "Em",
              "text": "找 稅"
            },
            {
              "chord": "D",
              "text": "吏、 罪"
            },
            {
              "chord": "A",
              "text": "人；"
            },
            {
              "chord": "Bm",
              "text": "祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 神 成"
            },
            {
              "chord": "A",
              "text": "肉 身，"
            },
            {
              "chord": "",
              "text": "拯"
            },
            {
              "chord": "G",
              "text": "救 世"
            },
            {
              "chord": "F♯",
              "text": "人 脫"
            },
            {
              "chord": "",
              "text": "沉"
            },
            {
              "chord": "Bm",
              "text": "淪；"
            },
            {
              "chord": "D",
              "text": "肩"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "負"
            },
            {
              "chord": "G",
              "text": "疲 魂，"
            },
            {
              "chord": "",
              "text": "喜 樂、"
            },
            {
              "chord": "D",
              "text": "情 深，"
            },
            {
              "chord": "",
              "text": "領"
            },
            {
              "chord": "Em",
              "text": "迷"
            },
            {
              "chord": "A7",
              "text": "羊 歸"
            },
            {
              "chord": "D",
              "text": "神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那靈─光照者，正尋覓失落者；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之光照射，要世人知罪自責；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "銀幣蒙塵，祂心不捨，終被祂尋得。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神─親愛父，憐憫世上罪奴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放蕩揮霍無度，不知何時纔醒悟？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "慈愛天父，朝思夜慕，浪子上歸途。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神─接納者，親吻那流浪者；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "披華美，罪全赦，享肥甘，不再飢渴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死而復活，失而又得，神、人同歡樂。"
            }
          ]
        }
      ],
