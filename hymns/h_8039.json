    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abba, e’er- and self-existing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You span the two eternities;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your throne in heav’n’s established thus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Most holy, mighty, glorious."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A hopeless, helpless, sinful throng—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dare we entreat You though we’re wrong?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We only knew Your righteousness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And not Your heart of love for us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet through Your precious only Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re now the manifested One;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If sinner unredeemed is known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have no rest upon Your throne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your one Son briefly You eschewed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gain the sinful multitude;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You gave Him up to cross and pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we a way to You could gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought by the death of Your dear Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We many sons in Your name come;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You who did once inspire fear"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are now to us our Abba dear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So deep Your love, so high Your grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your debt we never can efface;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can but thank You evermore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Abba worship, praise, adore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
