  "title": "If it die, oh, hear the message",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "\"If it"
            },
            {
              "chord": "Bm",
              "text": "die,\" oh,"
            },
            {
              "chord": "Em",
              "text": "hear the"
            },
            {
              "chord": "A7",
              "text": "message"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Falling"
            },
            {
              "chord": "A7",
              "text": "from thy"
            },
            {
              "chord": "D",
              "text": "Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"If it"
            },
            {
              "chord": "B7",
              "text": "die,\" much"
            },
            {
              "chord": "Em",
              "text": "fruit it"
            },
            {
              "chord": "G",
              "text": "beareth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "'Tis thy"
            },
            {
              "chord": "",
              "text": "Savior's"
            },
            {
              "chord": "D",
              "text": "word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Would’st thou see life work in others,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou thyself must die."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fall into the ground, be buried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Low in darkness lie."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But He leaves thee not in darkness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Light shall greet thine eyes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in glad new life and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He shall bid thee rise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dost thou crave to tread the pathway"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His life to share?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As thou passest thru death’s gateway"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will meet thee there."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou shalt learn the blessed secret,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He shall live that dies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From a life poured out in secret"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall a harvest rise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
