    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of pow’r comes upon us today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who’s likened to clothing ourselves to array;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him we are baptized, with Him we are dressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For service equipping with power possessed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of life is as breath glorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As spirit of life it is breathed into us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of pow’r doth the wind typify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which bloweth upon us with pow’r from on high."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Into His disciples the risen Lord breathed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of life thus to them He bequeathed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th’ ascended Lord poured at the Pentecost hour"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon His disciples the Spirit of pow’r."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of life is within as the life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of power is giv’n for this life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As blowing of wind brings the fresh air to breathe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of power to life doth bequeath."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "These are not two spirits apart and afar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But of the one Spirit the two functions are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To clothe us with God and to fill us within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be thoroughly mingled with Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, fill with Thy Spirit of life every part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may grow up in Thy life as Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And clothe us without with Thy Spirit of pow’r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy will to fulfill in Thy service each hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
