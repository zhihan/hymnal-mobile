      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe in the arms of Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe from corroding care,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe from the world's temptations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sin cannot harm me there."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Free from the blight of sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Free from my doubts and fears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only a few more trials,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only a few more tears."
            }
          ]
        }
      ]
    },
    {
      "lines": [
