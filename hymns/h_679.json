              "text": "Sweetly my soul doth rest."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, my heart's dear Refuge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus has died for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Firm on the Rock of Ages"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever my trust shall be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here let me wait with patience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wait till the night is o'er,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wait till I see the morning"
            }
          ]
        },
        {
          "segments": [
