{
  "url": "https://www.hymnal.net/en/hymn/h/822",
  "title": "The Church the lampstand is to Christ",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "The Church"
            },
            {
              "chord": "",
              "text": "the lampstand"
            },
            {
              "chord": "D",
              "text": "is to"
            },
            {
              "chord": "G",
              "text": "Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ"
            },
            {
              "chord": "C",
              "text": "is the"
            },
            {
              "chord": "",
              "text": "lamp with"
            },
            {
              "chord": "D",
              "text": "God as"
            },
            {
              "chord": "",
              "text": "light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "G",
              "text": "light divine"
            },
            {
              "chord": "",
              "text": "from"
            },
            {
              "chord": "D",
              "text": "Christ doth"
            },
            {
              "chord": "G",
              "text": "shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "C",
              "text": "Church upholds"
            },
            {
              "chord": "",
              "text": "its"
            },
            {
              "chord": "D",
              "text": "glo"
            },
            {
              "chord": "D7",
              "text": "ry"
            },
            {
              "chord": "G",
              "text": "bright."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The light which shines within the lamp"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is God as life, unique, divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The stand must therefore be of gold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To match the glory which doth shine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Amid the darkness of this age"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The light of life divine doth beam"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In many centers of mankind"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where Jesus’ testimony’s seen."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To be this testimony pure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“First love” to Christ the Church must keep;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then from the “tree of life” she may"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The overcomer’s portion reap."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "She must the persecution bear"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That she the “crown of life” may gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Adult’ry spiritual o’ercome,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The “hidden manna” to obtain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The deeds of “Jezebel” desert,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That she may rule the earth with might;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Defiling deadness overcome"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be arrayed in “garments white.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Like “Philadelphia” she must be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To keep Christ’s word, confess His Name;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All “lukewarm” pride she must o’ercome"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feast with Him who overcame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus will the Church be purified"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be the lampstand of pure gold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To match the testimony pure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life of Jesus fit to hold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The local churches here on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lampstands in this age should be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glorious new Jerusalem"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lampstand in eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That city as pure gold will be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The final lampstand consummate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ as the lamp she e’er will hold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s full light will radiate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
