    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His sov’reign mercy made me see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The only way in God’s economy—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cross applied effectually;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What I am and can do must all desist."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My person of whate’er repute,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My devices, must not Christ substitute."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The center of my universe—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The all-op’rative cross; let Christ be first."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, the God of glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has appeared and called me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To a glorious calling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I was unworthy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, now for the building"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me more than willing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open for Your mingling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My all on the altar to bring."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now here we are, called on to build."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As members of Christ, we are richly filled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As He increases, we decrease;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The one new man wondrously comes to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our inward being we open wide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Spirit transform and occupy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soak, saturate, with Christ inwrought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till from glory to glory we are brought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
