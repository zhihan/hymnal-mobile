    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Laid hold by vision of His house,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We build earnestly, from indiff’rence roused."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Although the world thinks us but fools,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God, we’re exceedingly precious jewels."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our eyes behold eternity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious destiny seen transparently."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Arise! Make haste this age to turn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the glory longed for may soon return!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what glorious vision!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s will and intention—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The return of glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His house effulgently."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let this vision seize us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Measure, judge, possess us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we’re built up; come, dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill Your house with glory once more!"
            }
          ]
        }
      ],
      "type": "chorus"
