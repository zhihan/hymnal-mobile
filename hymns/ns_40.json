    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your whisper, Lord, so softly sounding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep within my heart does burn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Your stillness now subdue me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Your feeling I discern."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All idle thoughts and impure feelings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, remove from mind and heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash me in the crystal water"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And more life to me impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All hidden things that block my vision,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rocks of self-ambition, pride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now expose and burn away, Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your look intensified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase the weight of glory in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Your Spirit now transform,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all things would not be wasted"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But would work to save me more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, oh how much I need You!"
