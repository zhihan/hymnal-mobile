{
  "url": "https://www.hymnal.net/cn/hymn/ch/448",
  "title": "哦神赞美你的奥妙",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦 神，"
            },
            {
              "chord": "",
              "text": "讚 美 你"
            },
            {
              "chord": "D",
              "text": "的 奧"
            },
            {
              "chord": "G",
              "text": "妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟"
            },
            {
              "chord": "A",
              "text": "然 能"
            },
            {
              "chord": "",
              "text": "給 我 們"
            },
            {
              "chord": "A7",
              "text": "摸"
            },
            {
              "chord": "D",
              "text": "到；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "原 在"
            },
            {
              "chord": "",
              "text": "光"
            },
            {
              "chord": "C",
              "text": "中 人"
            },
            {
              "chord": "",
              "text": "難 靠"
            },
            {
              "chord": "D",
              "text": "近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今"
            },
            {
              "chord": "G",
              "text": "在 靈"
            },
            {
              "chord": "",
              "text": "裡 與"
            },
            {
              "chord": "D",
              "text": "我 相"
            },
            {
              "chord": "G",
              "text": "親。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是圣父、圣子、圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神作我生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面将我供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有你神圣性情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父在子里，子成为灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵临到我如气似风；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父、子、圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣、奥秘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我的实际经历。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父的一切全归子有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子的丰富全由灵受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵降我身并进我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你成为我的福分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父是源头，子是显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是你对我的进入；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父在子里显在人间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子成为灵进我里面。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父愿子能凡事居首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子愿凡事以父为头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵愿使子得着荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我心中向我启晓。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是你的最终形态，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入我灵受我敬拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要享受你的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须灵里与灵接触。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里敬拜，灵里交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里祷告、赞美、称颂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就摸着灵里圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你作一切供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
