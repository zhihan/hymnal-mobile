{
  "url": "https://www.hymnal.net/en/hymn/lb/57",
  "title": "Where have you laid Him, my Jesus?",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Where have"
            },
            {
              "chord": "",
              "text": "you laid Him, my Jesus?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where have you"
            },
            {
              "chord": "G",
              "text": "put Him,"
            },
            {
              "chord": "",
              "text": "my precious Lord?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There are His"
            },
            {
              "chord": "D",
              "text": "grave clothes,"
            },
            {
              "chord": "",
              "text": "but He's not there."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where is my"
            },
            {
              "chord": "G",
              "text": "Jesus,"
            },
            {
              "chord": "",
              "text": "my lovely One, where"
            },
            {
              "chord": "A",
              "text": "is He?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lord, I"
            },
            {
              "chord": "",
              "text": "can't forget"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the"
            },
            {
              "chord": "G",
              "text": "day we"
            },
            {
              "chord": "",
              "text": "first met."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my"
            },
            {
              "chord": "D",
              "text": "heart belongs"
            },
            {
              "chord": "",
              "text": "to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I just love"
            },
            {
              "chord": "G",
              "text": "You, just"
            },
            {
              "chord": "",
              "text": "You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just"
            },
            {
              "chord": "A",
              "text": "love You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, my dear Lord, I love You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can’t go on Lord, without You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m sick of love, my soul has failed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need You Jesus, my Beloved, I love You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Mary, My seeker, I am alive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stop, do not touch Me, as I have not"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet ascended to the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this freshness is for the Father’s enjoyment."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My dear Rabboni, my heart’s desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have risen out of the grave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, I love You, my dearest One."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve truly risen from among the dead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Rabboni,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I can’t believe it’s You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I don’t know how this could be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But I enjoy You here."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, my heart is filled with ecstasy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection, to be here with Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am elated, beside myself."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, I’ll love You with all my heart, forever."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Go tell my brothers you have seen Me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell them the words which I speak to you:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I must ascend to My Father"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to your Father, and to My God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "and to your God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have found my Love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has risen from the dead."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our Jesus is alive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have seen Him, seen Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love Him!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, we love You with all our heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Love, we need You so desperately."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, we love You immensely."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will be loving You for all eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
