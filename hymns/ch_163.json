{
  "url": "https://www.hymnal.net/cn/hymn/ch/163",
  "title": "主你是神的爱子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "是 神 的"
            },
            {
              "chord": "G",
              "text": "愛 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "G7",
              "text": "神 榮"
            },
            {
              "chord": "",
              "text": "耀 形"
            },
            {
              "chord": "C",
              "text": "像；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 聖 徒 的"
            },
            {
              "chord": "G",
              "text": "永"
            },
            {
              "chord": "C",
              "text": "分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "們 都"
            },
            {
              "chord": "G7",
              "text": "得 分"
            },
            {
              "chord": "C",
              "text": "享。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "是 受"
            },
            {
              "chord": "G7",
              "text": "造 首"
            },
            {
              "chord": "C",
              "text": "生 者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "F",
              "text": "切 造"
            },
            {
              "chord": "",
              "text": "物 之"
            },
            {
              "chord": "G",
              "text": "首；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "萬"
            },
            {
              "chord": "C",
              "text": "有 靠"
            },
            {
              "chord": "F",
              "text": "你 而"
            },
            {
              "chord": "C",
              "text": "被 造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "G",
              "text": "都 歸"
            },
            {
              "chord": "G7",
              "text": "你 承"
            },
            {
              "chord": "C",
              "text": "受。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是万有的由来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有存在之秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是万有的中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有靠你而立。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是从死首生者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切元始是你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是召会荣耀头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会是你身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父愿一切的丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都住你里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你凡事居首位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事得着彰显。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已借死使万有"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都与神和好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好将我们呈神前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣洁合神所要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神之所是全在你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所积智慧与知识"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都居住于你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是荣耀的盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今住我里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我们被成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神意足心满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切全都是影儿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有你是实际；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在你已生根，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在正被建立。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受所有你丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你身体持守你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长大因神增添。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同你藏神内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来同显荣耀里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽享你的丰盛。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你身体－新人里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是一切一切；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "包罗万有的基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你何丰富、超越！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
