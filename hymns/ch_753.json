{
  "url": "https://www.hymnal.net/cn/hymn/ch/753",
  "title": "主耶稣我正等待",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 耶"
            },
            {
              "chord": "",
              "text": "穌， 我"
            },
            {
              "chord": "G",
              "text": "正 等"
            },
            {
              "chord": "",
              "text": "待"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被"
            },
            {
              "chord": "D",
              "text": "提 到"
            },
            {
              "chord": "A7",
              "text": "你 面"
            },
            {
              "chord": "D",
              "text": "前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除 了 你 的"
            },
            {
              "chord": "G",
              "text": "快 再"
            },
            {
              "chord": "",
              "text": "來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "無"
            },
            {
              "chord": "D",
              "text": "別 如"
            },
            {
              "chord": "A7",
              "text": "此 甘"
            },
            {
              "chord": "D",
              "text": "甜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 今"
            },
            {
              "chord": "",
              "text": "盼 望"
            },
            {
              "chord": "D",
              "text": "你 再"
            },
            {
              "chord": "",
              "text": "來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 知"
            },
            {
              "chord": "",
              "text": "道"
            },
            {
              "chord": "E7",
              "text": "你 已"
            },
            {
              "chord": "A",
              "text": "近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 覺"
            },
            {
              "chord": "",
              "text": "得 你"
            },
            {
              "chord": "G",
              "text": "的 同"
            },
            {
              "chord": "",
              "text": "在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "D",
              "text": "經 包"
            },
            {
              "chord": "A7",
              "text": "圍 我"
            },
            {
              "chord": "D",
              "text": "心。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在我全人最深处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已听见你话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢你，因你清楚"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "语我以你计画。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的再临何等近！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的显现已快！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典馀日何等紧！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌就要败坏！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你斩断众藤蔓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我完全自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全脱去诸累缠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "紧紧跟随你走。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿放下‘合理事’，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得我心受拘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得当你再来时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不能自由去。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻等候并儆醒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是我的心意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我完全随从灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得错过被提；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得因我未豫备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我打盹睡觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就以为我不配，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "留我在地受熬。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的心哪，这真是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "极庄严的儆戒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，你所爱的事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当完全脱解。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当完全恋慕主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全想念见祂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论何时主招呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能将一切撇下。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然今日争战猛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多有撒但折磨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是不久要高升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以还怕甚么！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今黑暗虽加增，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎日子也近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以你可昂首等，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因不久主必临。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我所爱惟有主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我所想惟主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拒绝世界的贿赂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心已与主同处。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上束缚已经松；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主，求你就来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心盼望到天中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看见我主我爱！"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "荣耀的盼望",
    "time": "4/4",
    "hymn_code": "5543216112355421",
