              "chord": "",
              "text": "Jesus, Lord Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I love to touch You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s by calling on You!"
