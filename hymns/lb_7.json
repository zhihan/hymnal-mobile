          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No other One will do!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I call, I’m drinking,"
