    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why would Christians feel ashamed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And not call Your precious name?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That is the devil’s scheme."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my friends they tell me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have changed completely."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You satisfy me thoroughly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest name above all names!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call on Him and He will save."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh most precious name!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling Your dear Person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once I was opposing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now I am enjoying."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me call You all day long."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the world that’s something wrong."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your precious name, the sweetest song."
            }
          ]
        }
      ],
