{
  "url": "https://www.hymnal.net/cn/hymn/ts/441",
  "title": "羡慕看见并经历",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "求 主"
            },
            {
              "chord": "",
              "text": "賜 下"
            },
            {
              "chord": "A7",
              "text": "神 聖"
            },
            {
              "chord": "D",
              "text": "啟 示，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "使 我"
            },
            {
              "chord": "",
              "text": "有 光"
            },
            {
              "chord": "A7",
              "text": "得 看"
            },
            {
              "chord": "D",
              "text": "見，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 作 生 命"
            },
            {
              "chord": "A",
              "text": "何 其"
            },
            {
              "chord": "D",
              "text": "真 實，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "靈 中"
            },
            {
              "chord": "A7",
              "text": "時 增"
            },
            {
              "chord": "D",
              "text": "添；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "還 要 不 斷 充 滿"
            },
            {
              "chord": "D7",
              "text": "浸 透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "從 我"
            },
            {
              "chord": "D",
              "text": "靈 向"
            },
            {
              "chord": "",
              "text": "外 開"
            },
            {
              "chord": "A7",
              "text": "廣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "每 一"
            },
            {
              "chord": "",
              "text": "部 分"
            },
            {
              "chord": "A7",
              "text": "讓 你"
            },
            {
              "chord": "D",
              "text": "佔 有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "你 就"
            },
            {
              "chord": "",
              "text": "安 家"
            },
            {
              "chord": "A7",
              "text": "我 心"
            },
            {
              "chord": "D",
              "text": "房。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "非照己意追求完美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "品行端正人称羡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也非改良外在行为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "举止稳重似完全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是基督活的人位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与我灵中相调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且在我心独居首位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我凭祂而活着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我更深经历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生活、工作全凭你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "言语、行动、态度、定意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只求单单出于你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拒绝虚空教训、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "道理，放下规条和力劲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活着惟一凭倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你涌流的生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命感觉我肯响应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的生命就流通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏油涂抹丰厚运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活出你性情。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前我凭靠己意、己力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵有成就亦速逝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今我只愿照你心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活你─永远的\"我是\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此我愿被主充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我全人成圣别；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放下老旧宗教观念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "道理、规条全弃绝。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督我心安家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂自己时添加；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命供应无以复加，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全备、充足我所夸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
