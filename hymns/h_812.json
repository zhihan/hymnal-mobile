              "text": "I come"
            },
            {
              "chord": "",
              "text": "to"
            },
            {
              "chord": "G",
              "text": "Thee, dear"
            },
            {
              "chord": "D",
              "text": "Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart doth"
            },
            {
              "chord": "E7",
              "text": "thirst for"
            },
            {
              "chord": "A7",
              "text": "Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Of Thee"
            },
            {
              "chord": "",
              "text": "I'd eat, of"
            },
            {
              "chord": "G",
              "text": "Thee I'd"
            },
            {
              "chord": "",
              "text": "drink."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "En"
            },
            {
              "chord": "D",
              "text": "joy Thee"
            },
            {
              "chord": "A7",
              "text": "thorough"
            },
            {
              "chord": "D",
              "text": "ly."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to behold Thy face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this my heart doth cry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I deeply long to drink of Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thirst to satisfy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy glorious, radiant face"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart delights to see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here I’d abide and ne’er depart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beholding constantly."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In such a fellowship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, art grace to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart and spirit gladdened, filled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I enter rest in Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I would linger here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still seeking after Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Continue in the Word and prayer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou dost flow thru me."
            }
          ]
        }
      ]
    }
