    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lamb of God! Thy Father’s bosom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever was Thy dwelling place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His delight, in Him rejoicing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with Him in pow’r and grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what wondrous love and mercy!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst lay Thy glory by;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for us didst come from heaven"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Lamb of God to die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lamb of God! When we behold Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lowly in the manger laid,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wand’ring as a homeless stranger"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the world Thy hands had made;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we see Thee in the garden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thine agony of blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thy grace we are confounded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy, spotless Lamb of God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we see Thee, as the victim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bound to the accursed tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our guilt and folly stricken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our judgment borne by Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we own, with hearts adoring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast loved us unto blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory, glory everlasting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be to Thee, Thou Lamb of God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lamb of God, Thou soon in glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wilt to this sad earth return;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy foes shall quake before Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that now despise Thee mourn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then Thy saints all gathered to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee in Thy kingdom reign;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine the praise and Thine the glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lamb of God, for sinners slain!"
            }
          ]
        }
      ],
