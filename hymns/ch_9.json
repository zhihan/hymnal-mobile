{
  "url": "https://www.hymnal.net/cn/hymn/ch/9",
  "title": "哦神你是生命源头",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 神，"
            },
            {
              "chord": "",
              "text": "你 是 生 命 源"
            },
            {
              "chord": "G",
              "text": "头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "D",
              "text": "圣、 甘"
            },
            {
              "chord": "",
              "text": "美、 丰"
            },
            {
              "chord": "A",
              "text": "满！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "如 活"
            },
            {
              "chord": "",
              "text": "水 向"
            },
            {
              "chord": "G",
              "text": "外 涌"
            },
            {
              "chord": "A",
              "text": "流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "D",
              "text": "直 流"
            },
            {
              "chord": "A",
              "text": "到"
            },
            {
              "chord": "A7",
              "text": "永"
            },
            {
              "chord": "D",
              "text": "远！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在子里因爱流出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流到人类中间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且成那灵带爱流入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流进我们里面。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们虽都偏行己路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满了邪恶罪愆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在子里仍来救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐以生命恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们甚且将你欺侮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常抗拒圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你这灵仍然眷顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来作我们生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在子里、借成那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已与我们调和；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的成分借祂运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要涂抹加多。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的慈爱、子的恩典、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加上灵的交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得享神的丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永世无终！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父、子、圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此厚待我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得我们和声响应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美你爱不尽！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
