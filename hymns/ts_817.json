{
  "url": "https://www.hymnal.net/cn/hymn/ts/817",
  "title": "你为何得救？",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 知"
            },
            {
              "chord": "G",
              "text": "道 你"
            },
            {
              "chord": "",
              "text": "为 何"
            },
            {
              "chord": "D",
              "text": "得 救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有 否"
            },
            {
              "chord": "Em",
              "text": "想 过"
            },
            {
              "chord": "",
              "text": "这 问"
            },
            {
              "chord": "A",
              "text": "题？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "究 竟"
            },
            {
              "chord": "",
              "text": "神 有 甚 么"
            },
            {
              "chord": "D",
              "text": "计 画？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Bm",
              "text": "基 督"
            },
            {
              "chord": "Em",
              "text": "为"
            },
            {
              "chord": "Em7",
              "text": "何 拯"
            },
            {
              "chord": "",
              "text": "救"
            },
            {
              "chord": "Asus4",
              "text": "你？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "直 到"
            },
            {
              "chord": "",
              "text": "如 今，"
            },
            {
              "chord": "Em",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "只 知 道"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基"
            },
            {
              "chord": "A",
              "text": "督 活"
            },
            {
              "chord": "",
              "text": "在 我"
            },
            {
              "chord": "A7",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这"
            },
            {
              "chord": "D",
              "text": "实 在"
            },
            {
              "chord": "",
              "text": "是 美"
            },
            {
              "chord": "G",
              "text": "好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "但 是"
            },
            {
              "chord": "",
              "text": "神 有"
            },
            {
              "chord": "Em",
              "text": "更 深"
            },
            {
              "chord": "",
              "text": "的 启 示，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "A",
              "text": "的 旨"
            },
            {
              "chord": "",
              "text": "意 必"
            },
            {
              "chord": "A7",
              "text": "须 达"
            },
            {
              "chord": "D",
              "text": "到。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "伊甸河流有一目的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应生命滋润地。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的拯救如同水流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过几段的经历。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们先脱撒但的辖制，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以后再进一步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱开那基督教。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的恢复一直往前流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不会在中途停住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不是仅仅一个信徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "单单独独到处荡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是活石同被建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "团体基督得显彰。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们重生为着得更新，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但基督进你心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还有另一缘故；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作我们生命的缘故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要得着祂的新妇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不是零星散乱宝石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "个别属灵的造诣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是实际在生命里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同被建造在一起。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你永远不会完全满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除非耶稣基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着祂的新妇。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有否想过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今天主正在等待"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把你建造起来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
