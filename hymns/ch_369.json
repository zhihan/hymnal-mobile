{
  "url": "https://www.hymnal.net/cn/hymn/ch/369",
  "title": "当你住在肉身生命",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "當 你"
            },
            {
              "chord": "",
              "text": "住 在 肉 身 生"
            },
            {
              "chord": "A",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知"
            },
            {
              "chord": "D",
              "text": "我 識"
            },
            {
              "chord": "E",
              "text": "你 至"
            },
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "E7",
              "text": "深"
            },
            {
              "chord": "A",
              "text": "刻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "就 定"
            },
            {
              "chord": "",
              "text": "規 成 為 那 靈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要"
            },
            {
              "chord": "D",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "靈 啟"
            },
            {
              "chord": "A",
              "text": "示"
            },
            {
              "chord": "A7",
              "text": "明"
            },
            {
              "chord": "D",
              "text": "白。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前你是我救赎主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今你是我保惠师，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再是那外面接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是里面合一不弛。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今因你所成圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在灵里不断启示"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的自己、你的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "觉你同在，感你真实。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我能认识你的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超当日门徒经历；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然他们与你同行、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同食、同住、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同劳、同息。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，成为内住圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是何等实在、实在！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不摸，比摸更为可凭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不见，但已心中深爱。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵现今是从衷里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻将你供应给我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我救赎、圣洁、公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我智慧和我结果。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因你成灵，住我灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你供应，与我合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时刻刻是我自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时刻刻也都是你。"
            }
          ]
        }
      ]
    }
  ],
