        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你名也被称为‘基督，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀职事的名称；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你确是神的受膏者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神从永远所选定。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你是神的弥赛亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已因爱立了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要你彰显祂的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且完成祂心意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你也称为‘以马内利，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是‘神与人同在；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借恩神与人性调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远不能再分开。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在肉身得着彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有真理和恩典；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我见神的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且得着神丰满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我们珍爱你名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你名所示何丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你名价值和其甘美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱永远要守住。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵救主，荣耀基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬拜、爱戴全归你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱救主、以马内利，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要高举永无已！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
