  "title": "我主你名称为耶稣",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 主，"
            },
            {
              "chord": "",
              "text": "你 名"
            },
            {
              "chord": "C",
              "text": "称 为"
            },
            {
              "chord": "G",
              "text": "『耶 稣，』"
            },
            {
              "chord": "",
              "text": "可 爱"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "之"
            },
            {
              "chord": "C",
              "text": "名 何"
            },
            {
              "chord": "",
              "text": "奇"
            },
            {
              "chord": "G",
              "text": "妙； 你"
            },
            {
              "chord": "",
              "text": "由"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "圣 洁"
            },
            {
              "chord": "",
              "text": "童 女"
            },
            {
              "chord": "G",
              "text": "而 生，"
            },
            {
              "chord": "",
              "text": "取 了"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "人 性"
            },
            {
              "chord": "",
              "text": "与 人"
            },
            {
              "chord": "G",
              "text": "貌。 你"
            },
            {
              "chord": "",
              "text": "是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 『耶"
            },
            {
              "chord": "C",
              "text": "和 华"
            },
            {
              "chord": "G",
              "text": "救 主，』"
            },
            {
              "chord": "",
              "text": "拯 救 我 们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱 罪"
            },
            {
              "chord": "D",
              "text": "恶； 当"
