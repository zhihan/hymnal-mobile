    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Rescue me, Lord, from this dark world—it’s just display."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine in me, and show me, Lord, You are the way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing matches me but You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only Your life will do."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, cause my love for You to grow in me each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through this love, show me the world’s passing away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Separate me unto You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, my heart renew."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t let me go; I’m here for You and this You know."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day, Your life within me has to grow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though this world is so corrupt,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can and do love You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, become a river flowing out of me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the world may take a drink of You and see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You are the only way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One reality."
            }
          ]
        }
