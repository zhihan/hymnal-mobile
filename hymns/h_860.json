    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Before our Father’s throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We pour our ardent prayers;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our fears, our hopes, our aims are one—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our comforts and our cares."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We share our mutual woes;"
            }
          ]
        },
        {
          "segments": [
