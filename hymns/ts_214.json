    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "速速催促主再来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着吃喝产男孩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在吃祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直吃─要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着主的金灯台，"
            }
          ]
