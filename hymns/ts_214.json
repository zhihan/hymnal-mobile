{
  "url": "https://www.hymnal.net/cn/hymn/ts/214",
  "title": "得胜借着吃基督",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 曾"
            },
            {
              "chord": "",
              "text": "召 你 我 得 救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 再 召 你 我 得 勝。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "對 主"
            },
            {
              "chord": "G",
              "text": "呼 召"
            },
            {
              "chord": "",
              "text": "說 『阿 們』─ 要 得"
            },
            {
              "chord": "A",
              "text": "勝！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "召 會"
            },
            {
              "chord": "D",
              "text": "光"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "景 墮 落 了， 許 多"
            },
            {
              "chord": "G",
              "text": "道"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "理 都 知 道， 生 命"
            },
            {
              "chord": "D",
              "text": "卻"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 摸 不"
            },
            {
              "chord": "A7",
              "text": "著─ 要"
            },
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "D",
              "text": "勝！ 要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得 勝！ 要"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得 勝！ 勝 過 死 沉"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "的 宗 教， 要"
            },
            {
              "chord": "A",
              "text": "得 勝！"
            },
            {
              "chord": "A7",
              "text": "放"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "下 所"
            },
            {
              "chord": "",
              "text": "有"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "的 辛 勞， 脫"
            },
            {
              "chord": "G",
              "text": "離 一"
            },
            {
              "chord": "",
              "text": "切"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "的 老 套， 只"
            },
            {
              "chord": "D",
              "text": "管 單"
            },
            {
              "chord": "",
              "text": "單"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "來"
            },
            {
              "chord": "A7",
              "text": "喫 主─"
            },
            {
              "chord": "",
              "text": "要"
            },
            {
              "chord": "D",
              "text": "得"
            },
            {
              "chord": "G",
              "text": "勝！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神原命定人来吃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃是今日的恢复，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃是得胜的道路─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "快来享受生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱去道理的束缚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜借着吃基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过死沉的宗教，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放下所有的辛劳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离一切的老套，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只管单单来吃主─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "教训不能变化魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫神旨意受亏损，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃主构上神标准─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若要得胜就要吃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论聚集或独处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃到全人得饱足─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        }
      ],
      "type": "verse",
