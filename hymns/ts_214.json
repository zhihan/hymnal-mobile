  "title": "得胜借着吃基督",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 曾"
            },
            {
              "chord": "",
              "text": "召 你 我 得 救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 再 召 你 我 得 胜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对 主"
            },
            {
              "chord": "G",
              "text": "呼 召"
            },
            {
              "chord": "",
              "text": "说 『阿 们』─ 要 得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "胜！"
            },
            {
              "chord": "A7",
              "text": "召 会"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "光 景"
            },
            {
              "chord": "",
              "text": "堕 落 了， 许 多"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "道 理"
            },
            {
              "chord": "",
              "text": "都 知 道， 生 命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "却 是"
            },
            {
              "chord": "",
              "text": "摸 不"
            },
            {
              "chord": "A7",
              "text": "著─ 要"
            },
            {
              "chord": "",
              "text": "得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "胜！ 要"
            },
            {
              "chord": "",
              "text": "得"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "胜！ 要 得 胜！ 胜 过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死 沉 的 宗 教， 要 得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "胜！"
            },
            {
              "chord": "A7",
              "text": "放 下"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "所 有"
            },
            {
              "chord": "",
              "text": "的 辛 劳， 脱 离"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "一 切"
            },
            {
              "chord": "",
              "text": "的 老 套， 只 管"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "单 单"
            },
            {
              "chord": "",
              "text": "来 吃"
            },
            {
              "chord": "A7",
              "text": "主─ 要"
            },
            {
              "chord": "",
              "text": "得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "胜！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神原命定人来吃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃是今日的恢复，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃是得胜的道路─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "快来享受生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱去道理的束缚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜借着吃基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过死沉的宗教，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放下所有的辛劳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离一切的老套，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只管单单来吃主─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "教训不能变化魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫神旨意受亏损，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃主构上神标准─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若要得胜就要吃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论聚集或独处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃到全人得饱足─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜！"
            }
          ]
        }
