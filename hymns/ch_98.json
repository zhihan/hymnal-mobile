    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们应当高声颂美"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那用己血买我们的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂替我们备尝死味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂为我们费尽心力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "此世有一特别诗歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟独蒙恩罪人会唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此外无人懂那音乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因不知其意义之纲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天使虽能欢然承认"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怜悯如何由血洞晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是他们不像我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能以证明这血功效。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天使虽能赞美拜朝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说神是神，向神恭敬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们却能欢乐唱道："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在宝座还带人性！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我们赞美那使"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你来流血受死的爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿不久在天相值，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你赞美、向你敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
