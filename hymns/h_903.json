  "title": "Lord, speak to me, that I may speak",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Lord, speak"
            },
            {
              "chord": "",
              "text": "to me, that"
            },
            {
              "chord": "D",
              "text": "I may"
            },
            {
              "chord": "G",
              "text": "speak"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In"
            },
            {
              "chord": "C",
              "text": "living"
            },
            {
              "chord": "",
              "text": "echoes"
            },
            {
              "chord": "D",
              "text": "of Thy"
            },
            {
              "chord": "",
              "text": "tone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As"
            },
            {
              "chord": "G",
              "text": "Thou hast"
            },
            {
              "chord": "",
              "text": "sought, so"
            },
            {
              "chord": "D",
              "text": "let me"
            },
            {
              "chord": "G",
              "text": "seek"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy"
            },
            {
              "chord": "C",
              "text": "erring"
            },
            {
              "chord": "",
              "text": "children"
            },
            {
              "chord": "D",
              "text": "lost"
            },
            {
              "chord": "D7",
              "text": "and"
            },
            {
              "chord": "G",
              "text": "lone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O lead me, Lord, that I may lead"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wandering and the wavering feet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O feed me, Lord, that I may feed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy hungering ones with manna sweet."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O strengthen me, that while I stand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Firm on the rock, and strong in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I may stretch out a loving hand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To wrestlers with the troubled sea."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O teach me, Lord, that I may teach"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The precious things Thou dost impart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And wing my words, that they may reach"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The hidden depths of many a heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O give Thine own sweet rest to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may speak with soothing power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A word in season, as from Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To weary ones in needful hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O fill me with Thy fulness, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until my very heart o'erflow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In kindling thought and glowing word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love to tell, Thy praise to show."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O use me, Lord, use even me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just as Thou wilt, and when, and where,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until Thy blessed face I see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy rest, Thy joy, Thy glory share!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
