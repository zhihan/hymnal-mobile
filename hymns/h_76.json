    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At His voice creation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sprang at once to sight:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the angel faces,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the hosts of light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thrones and dominations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stars upon their way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the heav’nly orders,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In their great array."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Humbled for a season,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To receive a Name"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the lips of sinners"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto whom He came,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithfully He bore it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spotless to the last,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought it back victorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When from death He passed;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore it up triumphant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With its human light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all ranks of creatures,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the central height;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the throne of Godhead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Father’s breast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled it with the glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of that perfect rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Name Him, brothers, name Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With love strong as death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with awe and wonder,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with bated breath;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is God the Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is Christ the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever to be worshiped,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trusted, and adored."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In your hearts enthrone Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There let Him subdue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that is not holy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that is not true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crown Him as your Captain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In temptation’s hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let His will enfold you"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In its light and power."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers, this Lord Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall return again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His Father’s glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His angel train;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all wreaths of empire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meet upon His brow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our hearts confess Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King of glory now."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
