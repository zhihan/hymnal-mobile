        {
          "segments": [
            {
              "chord": "",
              "text": "That ocean unexplored!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord hath yet more light and truth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To break forth from His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Darkling our great forefathers went"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The first steps of the way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas but the dawning yet to grow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the perfect day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grow it shall, our glorious Sun"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More fervid rays afford:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord hath yet more light and truth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To break forth from His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The valleys past, ascending still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our souls would higher climb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And look down from supernal heights,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On all the bygone times;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upward we press, the air is clear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the sphere-music heard!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord hath yet more light and truth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To break forth from His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Father, Son and Spirit, send"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Us increase from above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enlarge, expand all Christian hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To comprehend Thy love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make us all go on to know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With nobler powers conferred:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord hath yet more light and truth"
            }
          ]
        },
