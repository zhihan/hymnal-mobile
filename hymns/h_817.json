    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who dares to bind by his dull sense"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The oracles of heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all the nations, tongues and climes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the ages given!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The universe how much unknown!"
            }
          ]
