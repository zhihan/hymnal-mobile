    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For all Your churches, Lord, this prayer we bring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to divide or one another shun."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw us that we to one another cling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus drawn, we’ll all hold fast to You as one."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then but one loaf, one Body, we’ll be made,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breaking of bread the sign of this displayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We also pray for all the sheep who’ve left;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Good Shepherd, bring them back, no more to stray."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Back to the truth Your first disciples kept,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Back to the church that keeps this truth today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon but one loaf, one Body, we’ll be made,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breaking of bread the sign of this displayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, soon the signs will all have passed away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In heav’nly Zion, we’ll be one fore’er,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all saints, changeless peace enjoy for aye,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Limitless love toward one another share."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What matchless joy, with all God’s sons to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying love and peace eternally!"
            }
          ]
        }
