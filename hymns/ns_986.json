{
  "url": "https://www.hymnal.net/en/hymn/ns/986",
  "title": "Christ came, the Lamb of God",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ came, the Lamb of God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo! From His piercéd side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A sin-removing tide!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re justified!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, in flesh-likeness sent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sin condemned in the flesh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfilled God’s righteousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re free in Him!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the last Adam, came,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our old man is through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We there “with Him” were nailed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His death’s ours too!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ as the true Firstborn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Died on behalf of all—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freed from creation’s thorn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, new we are!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the brass Serpent, was"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In serpent’s form, yet pure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan He judged and crushed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our cure!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, our Peacemaker true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The middle wall broke down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All differences are through!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him we’re one!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, as the grain of wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By death, His life released;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He brought forth you and me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One loaf are we!"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "Praise of the Lord"
  },
