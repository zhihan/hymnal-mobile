              "chord": "",
              "text": "总叫我们快乐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "可爱的主，保守我们"
