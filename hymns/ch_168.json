              "chord": "",
              "text": "四围仇敌陷阱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们却从深处着想，"
            }
          ]
        },
        {
          "segments": [
