    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然我们行在野地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寂寞、干渴、骇惊，"
            }
