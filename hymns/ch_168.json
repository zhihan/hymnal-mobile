              "text": "知道你爱价值；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们因此心里明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美你恩不置。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们生命、力量、"
            }
          ]
        },
        {
          "segments": [
