    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我遭遇患难、折磨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "希望成空，忧惧缠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督十架永不弃我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！喜乐与平安。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有福太阳，以光以爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照耀在我路程上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督十架放射光彩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我人生更光亮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是祸是福，是苦是乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架使我全成圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此平安深广莫测，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐永远不变更。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督十架是我夸耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "年代灭没它独存；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣事迹光辉环绕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架巍然是中心。"
            }
          ]
        }
      ],
