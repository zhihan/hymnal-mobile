    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“When through the deep waters I call thee to go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The rivers of sorrow shall not overflow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I will be with thee, thy troubles to bless,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sanctify to thee thy deepest distress.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“When through fiery trials thy pathway shall lie,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My grace, all sufficient, shall be thy supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The flame shall not hurt thee; I only design"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy dross to consume, and thy gold to refine.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“E’en down to old age all My people shall prove"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sovereign, eternal, unchangeable love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then, when grey hairs shall their temples adorn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like lambs they shall still in My bosom be borne.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“The soul that on Jesus hath leaned for repose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will not, I will not desert to his foes;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That soul, though all hell should endeavor to shake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never, no, never, no, never forsake!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
