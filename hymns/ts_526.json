    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在流中，忘记背后，随灵向前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弃绝宗教，将世界丢干净。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今主在全地不断作新事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！这是神的恢复。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在各城站住地方的立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不倚靠自己天然力量。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再是一个信徒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "单独的追求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是一直跟召会的水流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迎主再临。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "七倍灵─众召会是纯金灯台，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会，人子显出丰采。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "七灯台在各地焚烧并照耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！这是神的恢复。"
            }
          ]
        }
      ],
