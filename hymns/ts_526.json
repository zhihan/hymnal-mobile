  "title": "这是神的恢复",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "Cm",
              "text": "神 救"
            },
            {
              "chord": "D♯",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "脫 離 邪 惡"
            },
            {
              "chord": "A♯",
              "text": "的 世"
            },
            {
              "chord": "",
              "text": "代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Cm",
              "text": "聚 集"
            },
            {
              "chord": "D♯",
              "text": "一 起"
            },
            {
              "chord": "",
              "text": "為 祂 永 遠 旨"
            },
            {
              "chord": "A♯",
              "text": "意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Cm",
              "text": "神 的"
            },
            {
              "chord": "D♯",
              "text": "兒 女"
            },
            {
              "chord": "",
              "text": "都 該 看 見"
            },
            {
              "chord": "A♯",
              "text": "這 異"
            },
            {
              "chord": "",
              "text": "象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Cm",
              "text": "阿 利"
            },
            {
              "chord": "D♯",
              "text": "路 亞！"
            },
            {
              "chord": "",
              "text": "這"
            },
            {
              "chord": "Cm",
              "text": "是 神"
            },
            {
              "chord": "G7",
              "text": "的 恢"
            },
            {
              "chord": "Cm",
              "text": "復。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
