              "chord": "A",
              "text": "Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "G",
              "text": "Father's"
            },
            {
              "chord": "A7",
              "text": "dwelling-"
            },
            {
              "chord": "D",
              "text": "place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The gathering of the"
            },
            {
              "chord": "G",
              "text": "called ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God blended"
            },
            {
              "chord": "D",
              "text": "with man's"
            },
            {
              "chord": "A",
              "text": "race;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E"
            },
            {
              "chord": "D",
              "text": "lect before"
            },
            {
              "chord": "",
              "text": "cre"
            },
            {
              "chord": "G",
              "text": "a"
            },
            {
              "chord": "D",
              "text": "tion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeemed by"
            },
            {
              "chord": "B7",
              "text": "Calv'ry's"
            },
            {
              "chord": "Em",
              "text": "death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her"
            },
            {
              "chord": "D",
              "text": "character"
            },
            {
              "chord": "",
              "text": "and"
            },
            {
              "chord": "G",
              "text": "standing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of"
            },
            {
              "chord": "A",
              "text": "heaven,"
            },
            {
              "chord": "A7",
              "text": "not of"
            },
            {
              "chord": "D",
              "text": "earth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "New man of new creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Born through her risen Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Baptized in God the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made holy by His Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is her life and content,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself her glorious Head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She has ascended with Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er all her foes to tread."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is her one foundation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None other man may lay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that she has, as Christ, is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Divine in every way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her members through the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their death on Calv’ry own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They’re built in resurrection—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gold, silver, precious stone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One God, one Lord, one Spirit—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her elements all one—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One faith, one hope, one baptism,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One Body in the Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The triune God is in her,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One Body members own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By faith they are united,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In hope of glory shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From every tribe and nation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do all the members come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Regardless of their classes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "United to be one."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No high there is, nor lowly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No Jew, nor Gentile clan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No free, nor slave, nor master,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Christ, the “one new man.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One Body universal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in each place expressed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Locality of dwelling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her only ground possessed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Administration local,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each answ’ring to the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Communion universal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upheld in one accord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Her local gatherings model"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its aspects and its details"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must show in all of them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the Lamp that shineth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God within, the Light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They are the lampstands bearing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glorious Image bright."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
