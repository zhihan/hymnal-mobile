    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There's a hov'ring cloud a-following the wind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Covering us! Covering us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the presence of the Lord the cloud does bring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Covering us! Covering us!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Covering us, God's overshadowing cloud—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God has come to stay with us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Covering us, the gracious cloud of God—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strength and comfort glorious!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With the cloud continually a fire does flash"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burning us! Burning us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It exposes sin, the soul life, and the flesh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burning us! Burning us!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it burn! the jealous flame of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it burn continually!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it burn! this all-consuming flame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it burn us thoroughly!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then from out the fire does the electrum glow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining forth! Shining forth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The redeeming God does our experience show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining forth! Shining forth!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Him shine! This gold and silver One;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Him shine for all to see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis the Lamb-God who has now become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our enjoyment inwardly."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the wind, cloud, fire and th' electrum be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wrought in us, o'er and o'er;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let this cycle be repeated constantly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More and more, more and more!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blow and hover, burn and shine forth, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our being to possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we all may gain Thee constantly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy likeness to express."
            }
          ]
        }
      ],
      "type": "chorus"
    }
