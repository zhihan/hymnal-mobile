    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Adieu! ye vain delights of earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Insipid sports, and childish mirth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I taste no sweets in you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unknown delights are in the cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All joy beside to me is dross;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Jesus thought so too."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Cross! O ravishment and bliss—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How grateful e'en its anguish is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its bitterness how sweet!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There every sense, and all the mind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all her faculties refined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Taste happiness complete."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Self-love no grace in sorrow sees,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consults her own peculiar ease:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis all the bliss she knows;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But nobler aims true love employ."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In self-denial is her joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In suffering her repose."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy choice and mine shall be the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inspirer of that holy flame"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which must forever blaze!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take the cross and follow Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where love and duty lead, shall be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My portion and my praise."
            }
          ]
        }
      ]
    }
