    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "超越的大能使基督高升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坐在神右边，远超万有："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "执政掌权者，有能主治者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因基督大名无不拜叩。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能大能，超越一切大能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内里运行，使人离地上腾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能大能，超越一切大能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的人离地得上腾。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "征服的大能使万有归服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "悖逆尽消弭，基督为大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂的身体，分享祂能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何不踏在我们脚下？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能大能，征服一切大能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内里运行，处处施行管治；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能大能，征服一切大能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的人处处施管治。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "归一的大能使基督居首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向着召会作万有的头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能的输供成功主身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂的丰满神旨成就。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能大能，掌管万有大能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里里外外，一切尽都归顺；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能大能，掌管万有大能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的人率先来归顺。"
            }
          ]
        }
      ],
