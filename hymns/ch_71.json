            },
            {
              "chord": "",
              "text": "的 初"
            },
            {
              "chord": "D",
              "text": "熟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "們 見"
            },
            {
              "chord": "G7",
              "text": "你 已"
            },
            {
              "chord": "C",
              "text": "被 提，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "榮"
            },
            {
              "chord": "D",
