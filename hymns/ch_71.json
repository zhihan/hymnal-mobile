            },
            {
              "chord": "D7",
              "text": "首 基"
            },
            {
              "chord": "G",
              "text": "督。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙 恩 得 與 你"
            },
            {
              "chord": "D",
              "text": "相 交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
