            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "來 想 你"
            },
            {
              "chord": "G7",
              "text": "的 眾"
            },
            {
              "chord": "C",
              "text": "榮 耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因"
            },
            {
              "chord": "G",
              "text": "已 與"
            },
            {
              "chord": "D7",
              "text": "你 合"
            },
            {
              "chord": "G",
              "text": "一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是万有的元首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你有最大权柄；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是以‘人’升父右，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你有最高的名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加略已显最高能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也显你最高爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱已完全得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "痛苦最暗残害。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不久万有宝珍你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有赞美你名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久万有承认你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你表示欢迎。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今只有我们能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "认识你的大爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能尝你爱满衷情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你赞美不迨。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你名更比万名彰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你赐越乎众赐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱高于万爱上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不、永不中止。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们欢乐来称道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因已合一不改；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远乃是你荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远乃是你爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
