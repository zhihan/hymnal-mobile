          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How we’ll love Thee evermore!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus, lovely Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the church, forevermore!"
            }
          ]
        }
