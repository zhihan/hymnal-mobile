    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The nourishing rich Spirit in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cherished by our Christ so tenderly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feeds us with the spiritual milk, the word of God, that we may grow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto salvation in our inward being."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The sanctifying Spirit from our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Captivated, gained, by Christ the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sanctifies us with God’s nature, disposition penetrating,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus to make us holy unto God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The fresh renewing Spirit in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Indwelt by the rich, abundant Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renews us that we may put on the one new man, as we put off"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The old man through the breaking of the cross."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The strong transforming Spirit in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled by Christ and spreading to our soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transforms us, glory unto glory, into Christ’s own glorious image,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His expression to the uttermost."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The master building Spirit in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Possessed by Christ and mingled with the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Builds us up into the house of God and Christ’s own Body for the"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mutual dwelling of the Triune God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The full-maturing Spirit in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day enriched with Christ the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conforms us to Christ’s image, to the measure of the stature of God’s"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Firstborn Son, the model of God’s sons."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The sealing, inking Spirit in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which exults with Christ, our glorious life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saturates us with and brings us into God’s own glory for our"
