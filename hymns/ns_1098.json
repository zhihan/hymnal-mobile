        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full glorification by His life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The life-releasing consummated Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Becomes intensified with seven burning eyes,"
            }
