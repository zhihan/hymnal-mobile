    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw me, Lord, and win completely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all bondage, set me free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Footsteps of the flock I’ll follow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly we’ll run after Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus, our Belovèd,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, our inmost heart’s desire;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Charming love our hearts hath captured—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love burns within as fire."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what joy it is preparing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our wedding with the Lord—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit—beautifying"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through each rhema-spoken word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stitch by stitch we are preparing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Price we’re paying o’er and o’er"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life maturing, Body building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rapture ready, joyous soar!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How we love Thee, dearest Bridegroom!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Long to hear Thy charming voice!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come  Belovèd with Thy kingdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou our best and fairest choice."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus, how we love Thee!"
