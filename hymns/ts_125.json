{
  "url": "https://www.hymnal.net/cn/hymn/ts/125",
  "title": "主是生命种子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主 是"
            },
            {
              "chord": "",
              "text": "生 命 種 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已 經 撒"
            },
            {
              "chord": "C",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "們 心"
            },
            {
              "chord": "G",
              "text": "裡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 要 發 苗 漸 漸 長 大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "長"
            },
            {
              "chord": "A7",
              "text": "成 祂"
            },
            {
              "chord": "",
              "text": "的 身"
            },
            {
              "chord": "D",
              "text": "量。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "G",
              "text": "不 需"
            },
            {
              "chord": "",
              "text": "要 規 條， 儀 文，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只"
            },
            {
              "chord": "C",
              "text": "需 活"
            },
            {
              "chord": "",
              "text": "水 澆"
            },
            {
              "chord": "G",
              "text": "灌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "C",
              "text": "此， 包"
            },
            {
              "chord": "",
              "text": "羅 萬 有 生 命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "D",
              "text": "要 逐"
            },
            {
              "chord": "D7",
              "text": "漸 成"
            },
            {
              "chord": "G",
              "text": "長。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何 等 奇 妙 的"
            },
            {
              "chord": "C",
              "text": "種 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "A7",
              "text": "是 耶"
            },
            {
              "chord": "",
              "text": "穌 我"
            },
            {
              "chord": "D",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "祂"
            },
            {
              "chord": "G7",
              "text": "撒 在"
            },
            {
              "chord": "",
              "text": "我 的"
            },
            {
              "chord": "C",
              "text": "裡 面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "長 大"
            },
            {
              "chord": "G",
              "text": "並 達"
            },
            {
              "chord": "D7",
              "text": "到 成"
            },
            {
              "chord": "G",
              "text": "熟。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们许多个别麦粒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能沾沾自喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有麦粒必须"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一起接受捣碎磨细；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到麦子磨成细面"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并作成一个饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有圣徒相调为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "模成主的身体。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们都须被磨细，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到失去自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有个别麦粒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都模成祂一个身体。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "种子已种，麦子长成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "细面是那成品，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们乃是神的田地"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在合一里长进。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有生命的长大"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是为着建造召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让神和人得一居所"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再无家可归。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命是为着建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与人可安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此神与祂子民"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大家都和睦同居。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的建造乃在于"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "精金、宝石和银子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "细面需经多少压榨苦楚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "麦子不能停在细面阶段"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自满自足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须经过生命变化"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为金银宝石。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "细面须经历痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能变成宝石；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然后建造在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全达到祂旨意。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命变化完全成熟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结出一颗珍珠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "简单、珍贵、包罗万有、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且是满有价值。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀之主死而复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过生产之苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终于得着召会─新妇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫祂心满意足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍珠是祂心所要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新妇是祂所悦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是祂心爱配偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "单纯净、又宝贝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿主保守我们灵里贫穷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "清心向主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们作好土，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子长大，丰富。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到目标达到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同被建造，你能满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着无价至宝─珍珠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是你的新妇。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，倒空我们的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们心纯净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我们生命成熟"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你心爱新妇"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "。"
            }
          ]
        }
      ]
    }
  ],
