    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I offer now without reserve"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that I am and all I have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy purpose to fulfill."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may the Lord accept and keep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That henceforth I may only seek"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To do the Father's will."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When I look back, what grief and shame"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I've brought none to trust Thy name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy word I've locked within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may the Lord anointing give"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And richly through my being live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may speak of Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My gracious Lord has giv'n much grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exceeding e'en a friend my place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I fain would be His bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'd share His life and suffer loss,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Accepting willingly the cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him identified."
            }
          ]
        }
      ],
