    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When all are sweetly joined"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(True followers of the Lamb),"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They’re one in heart and mind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They think and speak the same;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When all in love together dwell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The comfort is unspeakable!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Where unity takes place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The joys of heav’n we prove;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the gospel grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The unction from above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit on all saints is shed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Descending swift from Christ the Head."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Where unity is found,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sweet anointing grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Extends to all around,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shines from every face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To every praising saint it comes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fills him with divine perfumes."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On all His chosen ones"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The precious oil comes down:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anointing as it runs,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anointing on and on."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en to His skirts (the meanest name"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That longs to love the bleeding Lamb)."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From Aaron’s beard it rolls,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Those nearest to His face),"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The humble, trembling souls"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who know abundant grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The grace, the grace for all is free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For, lo, it reaches now to me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
