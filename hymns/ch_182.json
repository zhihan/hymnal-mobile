    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们为你所有召会祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求使我们不再分裂排逼，"
