{
  "url": "https://www.hymnal.net/cn/hymn/ch/66",
  "title": "耶稣这名甜美芬芳",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "耶 穌，"
            },
            {
              "chord": "",
              "text": "這 名 甜"
            },
            {
              "chord": "C",
              "text": "美、 芬"
            },
            {
              "chord": "",
              "text": "芳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "慰"
            },
            {
              "chord": "G",
              "text": "我 痛"
            },
            {
              "chord": "",
              "text": "苦 心"
            },
            {
              "chord": "D",
              "text": "情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "心 歡"
            },
            {
              "chord": "",
              "text": "樂， 我"
            },
            {
              "chord": "C",
              "text": "口 歌"
            },
            {
              "chord": "",
              "text": "唱"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 個 寶"
            },
            {
              "chord": "D",
              "text": "貴 的"
            },
            {
              "chord": "G",
              "text": "名。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "美 哉、 妙 哉， 神"
            },
            {
              "chord": "C",
              "text": "的 愛"
            },
            {
              "chord": "",
              "text": "子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作"
            },
            {
              "chord": "G",
              "text": "我 寶"
            },
            {
              "chord": "",
              "text": "貴 救"
            },
            {
              "chord": "D",
              "text": "主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為"
            },
            {
              "chord": "G",
              "text": "我 降"
            },
            {
              "chord": "",
              "text": "生， 為"
            },
            {
              "chord": "C",
              "text": "我 受"
            },
            {
              "chord": "",
              "text": "死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流 血 將"
            },
            {
              "chord": "D7",
              "text": "我 救"
            },
            {
              "chord": "G",
              "text": "贖。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣原有神的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟来成为人子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚己取了奴仆形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我作神后嗣。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣乃是生命、亮光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是真理、道路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今在我心作主、作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我引导、安抚。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵救主远胜奇珍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻满足我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "解我愁苦、消我烦闷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远与我相亲。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵救主不久再临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接我与祂同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我贱体变成荣身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安息直到万代。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣哉、乐哉，耶稣我主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永是我的荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀之名乃是耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要永远称道。"
            }
          ]
        }
      ]
    }
  ],
