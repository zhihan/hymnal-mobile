      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou, within no walls confined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inhabitest the humble mind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such ever bring Thee where they come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And going, take Thee to their home."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Shepherd of Thy chosen few,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy former mercies here renew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here, to our waiting hearts, proclaim"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sweetness of Thy saving Name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here may we prove the power of prayer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To strengthen faith and sweeten care;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To teach our faint desires to rise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bring Thy light before our eyes."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we are few, but Thou art near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor short Thine arm, nor deaf Thine ear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, rend the heavens, come quickly down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make our waiting hearts Thine own."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Command Thy blessing in this hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as the Spirit full of pow’r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life and vision fill this place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thy purpose we may trace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Thou, our Head, our Life, our Guide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May nought in life or death divide"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The saints in Thy communion blessed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thy fulness be expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
