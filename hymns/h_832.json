    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the other teachings used improperly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are the “winds of doctrine,” spoiling unity:"
            }
          ]
        },
        {
