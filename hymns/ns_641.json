              "text": "To do God’s will, His fare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Takes on the lower place—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lowly in heart, not grand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But humbled, serves in grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bends in response to change,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfectly flexible"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our way to rearrange."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Does all things properly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Setting things in array,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His living orderly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loves all those frail and weak;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He does not break the bruised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor quench them in critique."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cherishes sinful men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeking to save the lost"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Jubilee begin."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Serves as a slave of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His service rendered by"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our ransom bought with blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On earth, constrained by time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfills each prophecy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death’s hour endures, sublime."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reconstitutes the saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Building the church, His house,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherein His rest awaits."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cherish with holy praise!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus, in remembrance here,"
            }
          ]
