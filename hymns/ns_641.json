        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ humanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unique beyond compare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfills all righteousness;"
            }
          ]
        },
        {
          "segments": [
            {
