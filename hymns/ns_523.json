    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lampstands, gold living trees, incarnate God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God’s nature, show forth resurrection;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Planting new church trees, to all earth spreading;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sprouting, growing and blooming, bearing fruit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The seven lampstands: one form, one nature;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Testimony, expression are but one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship and move all are in one flow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just one ministry, and one Body."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, take me, break me; I’d hold nothing back from Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill me till it is no more I that live;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That by Your resurrection life, we would Your testimony be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We would be the church You long for, testimony of Jesus on the earth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, Your dear bride are we, loving You so crazily,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill us wholly, live Yourself exclusively;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, by Your resurrection power, make us fully one with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Your shining golden lampstands, Fulfilling Your heart’s desire today."
            }
          ]
        }
      ],
      "type": "chorus"
    }
