{
  "url": "https://www.hymnal.net/cn/hymn/ch/543",
  "title": "圣殿深处是至圣所",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "聖 殿"
            },
            {
              "chord": "",
              "text": "深 處 是"
            },
            {
              "chord": "A",
              "text": "至 聖"
            },
            {
              "chord": "D",
              "text": "所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "內 有 約 櫃 並 施 恩"
            },
            {
              "chord": "A",
              "text": "座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其 上 有"
            },
            {
              "chord": "A7",
              "text": "神 榮"
            },
            {
              "chord": "D",
              "text": "耀"
            },
            {
              "chord": "D7",
              "text": "同"
            },
            {
              "chord": "G",
              "text": "在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "A",
              "text": "此 神"
            },
            {
              "chord": "D",
              "text": "給 祭"
            },
            {
              "chord": "A",
              "text": "司"
            },
            {
              "chord": "A7",
              "text": "遇"
            },
            {
              "chord": "D",
              "text": "著。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今乃是神的圣殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是其中的至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神和基督在此居住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那灵在此与我同活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此，在我最深之处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在主里作我一切；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此，那灵使主基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我实际，取用不竭。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此，我在我灵里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和主接触，与主同在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此，我也借着我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神交通，向神敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此，基督如同美地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我居其中，享其丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也当在此进攻仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "运用权柄对付阴府。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我当追求对灵认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远将灵从魂分开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且活在这至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受神与主的同在。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我当永远拒绝我魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "努力进入神的安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我丰满得着基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全神的永远旨意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
