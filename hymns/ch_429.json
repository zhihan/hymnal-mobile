  "title": "出到营外就耶稣",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "『出 到"
            },
            {
              "chord": "A",
              "text": "营 外』"
            },
            {
              "chord": "A7",
              "text": "就 耶"
            },
            {
              "chord": "D",
              "text": "稣， 忍"
            },
            {
              "chord": "",
              "text": "受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "祂 受"
            },
            {
              "chord": "A7",
              "text": "的 凌"
            },
            {
              "chord": "D",
              "text": "辱；"
            },
            {
              "chord": "A",
              "text": "祂 在"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E7",
              "text": "城 外"
            },
            {
              "chord": "",
              "text": "受 苦"
            },
            {
              "chord": "A",
              "text": "楚，"
            },
            {
              "chord": "D",
              "text": "我 岂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "可 以"
            },
            {
              "chord": "A7",
              "text": "贪 舒"
            },
            {
              "chord": "D",
              "text": "服。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘出到营外’就耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十字苦架甘背负；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂曾走过这窄路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今跟随祂脚步。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘出到营外’就耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撇下亲人和家族；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父神旨意祂所顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人情岂能将我阻？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘出到营外’就耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除非与祂不为伍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界团体、宗教组，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就此永远不再属。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘出到营外’就耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任凭人都与我疏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这路虽然苦且孤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂作伴心已足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘出到营外’就耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂同行乐何如；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂笑容受鼓舞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以祂同在作寄庐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘出到营外’就耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到路尽天已曙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时见祂必欢呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得祂称许进国度。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
