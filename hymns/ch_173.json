{
  "url": "https://www.hymnal.net/cn/hymn/ch/173",
  "title": "我们照你恩惠话语",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "照 你 恩"
            },
            {
              "chord": "D",
              "text": "惠 話"
            },
            {
              "chord": "G",
              "text": "語，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "帶 著 謙 卑 心"
            },
            {
              "chord": "D",
              "text": "意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "受"
            },
            {
              "chord": "G",
              "text": "死 的"
            },
            {
              "chord": "",
              "text": "主， 我"
            },
            {
              "chord": "C",
              "text": "們 會"
            },
            {
              "chord": "",
              "text": "聚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "現"
            },
            {
              "chord": "D",
              "text": "今 來"
            },
            {
              "chord": "",
              "text": "記"
            },
            {
              "chord": "D7",
              "text": "念"
            },
            {
              "chord": "G",
              "text": "你。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的身体为我裂开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要成我的供给；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今举起立约杯来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为的是记念你。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "能否我忘客西马尼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或看你的孤寂、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的血汗和你哭泣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而不来记念你？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我转眼看十字架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看你在髑髅地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的羔羊，我的救法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我必须记念你。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "记念你和你的苦痛、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和你对我爱意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一息尚存、一脉尚动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我必定记念你。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我渐衰，嘴唇无音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "思想、记忆软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你在你国度降临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，求你记念我。"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "赞美主",
