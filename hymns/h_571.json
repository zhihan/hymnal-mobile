    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst keep my feet from falling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even my poor wayward feet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou who dost present me faultless"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee—Righteousness complete;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord, in knowing Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what strength and victory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the sin in me, my Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst conquer and subdue;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy sanctifying power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Permeate my spirit through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Thy government increase,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Risen, crowned, Prince of Peace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst keep me upward looking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever upward in Thy face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst make me stand, upholden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the greatness of Thy grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every promise of Thy word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I claim from Thee, dear Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! what joy to trust Thee, Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mighty Victor o’er the grave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to learn amid earth’s shadows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine unceasing power to save!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only those who prove Thee know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What the grace Thou dost bestow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my life a bright outshining"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy life, that all may see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own resurrection power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mightily put forth in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever let my heart become"
            }
          ]
        },
        {
