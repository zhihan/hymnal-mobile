      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For me Thy body Thou didst give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may ever share in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me Thy precious blood was shed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That from my sins I might be free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By resurrection Thou didst change"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy form and as the Spirit come;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst that I be filled with Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thy riches mine become."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now as the symbols we behold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy loving self we see anew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We thank Thee for Thy heart’s desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As all Thy travail we review."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We eat the bread and drink the wine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to Thy sweetness we are led;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit each receiving Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirits with Thyself are fed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We long to eat and drink e’en more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take Thyself in spirit thus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou shalt all our being fill"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And true remembrance have from us."
            }
          ]
        }
      ],
