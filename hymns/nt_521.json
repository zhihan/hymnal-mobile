    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How wonderful! I never knew"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I might trust Thee so;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou wouldst be so much to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all the way I go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That every need Thou wouldst supply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all my longings satisfy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take Thee as my keeper now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I commit to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My soul, my way, my works, my cause."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy sole charge to be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my deposit, Thou, I know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wilt guard secure from every foe."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take Thee for my peace, O Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart to keep and fill"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own great calm, amid earth’s storms"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall keep me always still;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as Thy kingdom doth increase,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So shall Thine ever-deep’ning peace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take Thee as my wisdom too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For wisdom’s sum Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, who dost choose the foolish things."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set me henceforth apart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may speak and work for Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Thou shalt work and speak in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take Thee, Lord, to be my all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since all Thou art is mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I nothing have, and nothing am;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That nothing, Lord, is Thine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou shalt be everything to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all things my sufficiency."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
