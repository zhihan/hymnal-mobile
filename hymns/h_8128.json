{
  "url": "https://www.hymnal.net/cn/hymn/h/8128",
  "title": "I prostrate, Lord, before Thee",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "I prostrate,"
            },
            {
              "chord": "",
              "text": "Lord, before Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mar"
            },
            {
              "chord": "A",
              "text": "vel at"
            },
            {
              "chord": "",
              "text": "boundless"
            },
            {
              "chord": "D",
              "text": "grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I, though"
            },
            {
              "chord": "G",
              "text": "chief of"
            },
            {
              "chord": "F♯m",
              "text": "sin"
            },
            {
              "chord": "Bm",
              "text": "ners,"
            }
          ]
        },
        {
          "segments": [
