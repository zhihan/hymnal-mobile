            },
            {
              "chord": "A7",
              "text": "to Thy"
            },
            {
              "chord": "D",
              "text": "face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "World- loving"
            },
            {
              "chord": "A7",
              "text": "as a"
            },
            {
              "chord": "D",
              "text": "sinner,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I"
            },
            {
              "chord": "G",
              "text": "never"
            },
            {
              "chord": "",
              "text": "thought of"
            },
            {
              "chord": "D",
              "text": "Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Encompass"
            },
            {
              "chord": "A",
              "text": "ing with"
            },
            {
              "chord": "Bm",
              "text": "mer"
            },
            {
              "chord": "D",
              "text": "cy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou"
            },
            {
              "chord": "Em",
              "text": "sought and"
            },
            {
              "chord": "A7",
              "text": "came to"
            },
            {
              "chord": "D",
              "text": "me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Tangled and troubled daily"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By sins that filled my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I never sought Thy freedom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All seeking's on Thy part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I did hear Thee calling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I never cared for Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I even fought Thy working,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Became an enemy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For reasons I can't fathom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou lovest one in sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The price in blood brought pardon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy peace and rest came in."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A sinner midst the sinful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In flesh I spent my days;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why lovest Thee this sinner"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With vile and crafty ways?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Crude manger was Thy cradle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of fastings didst partake;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A painful path Thou takest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And suffered for my sake."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me Thou didst consider?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No bitterness forego?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus I was spared such fury,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And taste God's blessings so?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Midst men, then, am I better?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More noble, then, was I"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou should'st so be willing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To suffer, bleed, and die?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I myself consider,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There's nothing to be praised;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wonder at such ransom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by such love amazed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I find no cause nor reason"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou, my God, should'st gain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By loving this vile rebel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such grace I can't explain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No, not because I'm worthy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor that I've merit high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But that Thou dost love sinners,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That, that alone is why."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Much was the grace imparted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Much may I earnest be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both loving and obeying"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And not ashamed of Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More mercy show unto me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For still this heart is cold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though mighty grace I've sighted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still more I need to hold."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heav'nly throne Thou leavest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me to Calv'ry trod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet I am still half-hearted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With apathy toward God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world holds my allegiance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy path too narrow felt,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My little self too precious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And yet I am indwelt."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When I my case consider,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart does feel some loss;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hating my nature rotten,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My vicious living's dross."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Lord, didst know already"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart would be like this."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thou foreknew my coolness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why didst Thou impart grace?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To bear with pain and mockings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From heaven to depart?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Accepting earth's mistreatings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To woo this hard, cold heart?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en though Thou knew my nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To shed dear blood for me?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en though Thou knew I'm evil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To suffer painfully?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, Thou didst know my coolness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My fickle mood and heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou wouldst pay most dearly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Die for me, life impart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I such love consider,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I weep without restraint;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior is all-giving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thanks compared is faint."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, Thy love in vastness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot understand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not seemly I would worship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor can I comprehend."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though glory's joy I've tasted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart is much too small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll sing Thy praises ever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before Thy throne I'll fall."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While in that brightness glor'ous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll never cease to praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For grace and love that sought me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worship through endless days."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I long in Thy bright city"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My praise might be complete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love and grace to fathom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thanks to Thee replete."
            }
          ]
        }
      ]
    }
  ],
