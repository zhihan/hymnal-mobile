{
  "url": "https://www.hymnal.net/cn/hymn/ch/758",
  "title": "自伯大尼你与我们",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "自 伯"
            },
            {
              "chord": "",
              "text": "大 尼 你 與 我 們 分"
            },
            {
              "chord": "F",
              "text": "手 後，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 有"
            },
            {
              "chord": "C",
              "text": "個 真"
            },
            {
              "chord": "",
              "text": "空 無 可 補"
            },
            {
              "chord": "G",
              "text": "滿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 坐 河"
            },
            {
              "chord": "C",
              "text": "濱， 將"
            },
            {
              "chord": "",
              "text": "琴 掛"
            },
            {
              "chord": "C7",
              "text": "在 柳"
            },
            {
              "chord": "F",
              "text": "枝 頭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 不 在"
            },
            {
              "chord": "C",
              "text": "此， 我"
            },
            {
              "chord": "G",
              "text": "怎 有"
            },
            {
              "chord": "",
              "text": "心 鼓"
            },
            {
              "chord": "C",
              "text": "彈？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "當 我 深 夜 孤"
            },
            {
              "chord": "F",
              "text": "獨 安"
            },
            {
              "chord": "",
              "text": "靜 的"
            },
            {
              "chord": "C",
              "text": "時 候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（此 時 我 無 忍"
            },
            {
              "chord": "F",
              "text": "受， 我"
            },
            {
              "chord": "",
              "text": "也 無"
            },
            {
              "chord": "G",
              "text": "享 受，）"
            },
            {
              "chord": "G7",
              "text": "不 禁"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "歎 息，"
            },
            {
              "chord": "F",
              "text": "我 想"
            },
            {
              "chord": "",
              "text": "著 你"
            },
            {
              "chord": "C",
              "text": "是 多"
            },
            {
              "chord": "",
              "text": "遠， 我 想"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "著 你 應 許"
            },
            {
              "chord": "G",
              "text": "已 久"
            },
            {
              "chord": "G7",
              "text": "的 歸"
            },
            {
              "chord": "C",
              "text": "旋。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的马槽使我生无家之想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的苦架使我无所欲喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的再来使我怀未见之乡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的自己成我追求目的。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你不在此，喜乐已减它滋味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "诗歌也缺它所应有的甜美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你不在此，终日我若有所失，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我要你来，我不要你迟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽我在此也能享受你同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我深处依然有个缺憾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然有你光照，也有你抚爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有个甚么我不知仍不满！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "平安里面，我却仍感觉孤单，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐时候，我仍不免有吁叹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最是足意中间，也有不足意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是我还不能当面看见你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亡人怎不想见生长的乡邑？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "俘虏怎不想见故国故人？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "情人分离，怎不一心羁两地？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "儿女远游，怎不思家思亲？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我想看见你面的心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还非这些人间情形可比拟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今在此，我无法见你丰采，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是否只好叹息等到你回来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主你能否忘记你曾经应许，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要回来，接我与你同在？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但一天天又一年年的过去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我仍等候，你却仍未回来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你记念，我已等得好疲倦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而你踪迹好像当初一样远！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多久？多久？还有多久的时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才应验应许来把我提走？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "日出日落，一世过去又一代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的圣徒生活、等候、安睡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一位一位，他们已逐渐离开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一次一次，我们望你快回。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主，为何你仍没有显动静，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天仍闭住，我们观看仍对镜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在此依然等候再等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哎呀，是否我们等候还不够？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我回想，我已等候多长久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不禁叹息，低头独自流泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你别再迟延不听我要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今就来接我与你相会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢，我主，这是召会的求呼！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢，我主，请听圣徒的催促！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢，历世历代累积的共鸣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主，能否求你今天一起听！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "荣耀的盼望",
    "time": "4/2",
