        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "無 論"
            },
            {
              "chord": "",
              "text": "甚 麼"
            },
            {
              "chord": "G",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 是"
            },
            {
              "chord": "C",
              "text": "救 主"
            },
            {
              "chord": "Am",
              "text": "的 呼"
            },
            {
              "chord": "D",
              "text": "召；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "祂 能、"
            },
            {
              "chord": "G",
              "text": "祂 肯、"
