            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣现在等候你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂既仍招呼："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘请你就我来！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你当回应：‘我愿意。’"
            }
          ]
