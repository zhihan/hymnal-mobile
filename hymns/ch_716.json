    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "欢 迎"
            },
            {
              "chord": "G",
              "text": "你 来，"
            },
            {
              "chord": "G7",
              "text": "你 来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "无 论"
            },
            {
              "chord": "",
              "text": "甚 么"
            },
            {
              "chord": "G",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这 是"
            },
            {
              "chord": "C",
              "text": "救 主"
            },
            {
              "chord": "Am",
              "text": "的 呼"
            },
            {
              "chord": "D",
              "text": "召；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "祂 能、"
            },
            {
              "chord": "G",
              "text": "祂 肯、"
            },
            {
              "chord": "G7",
              "text": "祂 等，"
            }
