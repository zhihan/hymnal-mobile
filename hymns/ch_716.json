            },
            {
              "chord": "Am",
              "text": "恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 过"
            },
            {
              "chord": "G",
              "text": "只 要"
            },
            {
              "chord": "D7",
              "text": "你 信"
            },
            {
              "chord": "G",
              "text": "靠。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽然不羁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流荡已经远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "沉溺罪中已经深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂仍然等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍耐着申劝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得你这疲倦人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "欢迎你来，你来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论甚么人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是救主的呼召；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能、祂肯、祂等，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等着施救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过只要你信靠。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽已多次拒祂的恩召，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多次使祂空眷顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的爱不因你冷落生恼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今又向你来催促。"
            }
          ]
        }
      ],
