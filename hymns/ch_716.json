          "segments": [
            {
              "chord": "C",
              "text": "等 著"
            },
            {
              "chord": "",
              "text": "施 救"
            },
            {
              "chord": "Am",
              "text": "恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 過"
            },
            {
              "chord": "G",
              "text": "只 要"
            },
            {
