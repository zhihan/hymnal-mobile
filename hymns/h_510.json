{
  "url": "https://www.hymnal.net/en/hymn/h/510",
  "title": "I’ve found the One of peerless worth",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "I've found"
            },
            {
              "chord": "",
              "text": "the One of"
            },
            {
              "chord": "A",
              "text": "peerless"
            },
            {
              "chord": "",
              "text": "worth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart doth"
            },
            {
              "chord": "A7",
              "text": "sing for"
            },
            {
              "chord": "D",
              "text": "joy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sing I must, for"
            },
            {
              "chord": "G",
              "text": "Christ I"
            },
            {
              "chord": "D",
              "text": "have:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh,"
            },
            {
              "chord": "A",
              "text": "what a"
            },
            {
              "chord": "",
              "text": "Christ"
            },
            {
              "chord": "A7",
              "text": "have"
            },
            {
              "chord": "D",
              "text": "I!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Christ, He is the Lamb of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who full salvation brings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Sun of Righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With healing in His wings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Christ, He is the Tree of Life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With fruit abundant, sweet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My hunger He doth satisfy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Him I daily eat."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Christ, He is the smitten Rock"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whence living waters burst;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the fountain in my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which quenches all my thirst."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my life, my light, my way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My comfort and my health,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My peace, my rest, my joy, my hope,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My glory and my wealth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my wisdom and my pow’r,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My boast and righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My vict’ry and redemption sure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My truth and holiness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my Savior, Shepherd, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Advocate above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Counsellor, my Father, God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Brother, Friend, and Love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my Captain and my Guard,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Teacher and my Guide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Bridegroom, Master and my Head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In me doth He reside."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my Prophet, Priest, and King;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Prophet full of sight;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Priest that stands ’twixt me and God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My King that rules with might."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the Author of my faith,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And its Perfecter too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Mediator, Guarantee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And faithful Witness true."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my everlasting home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My all-sufficient land;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My fortress, tower, hiding-place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my eternal stand."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my sabbath and new moon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My morning and my day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My age and my eternity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That ne’er will pass away."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is my trust and my desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In comeliness replete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My satisfaction and delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who all my need doth meet."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Christ, the all-inclusive One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Christ what shall I call?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the first, He is the last,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Christ is All in all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since such a treasure I possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart doth sing for joy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I must sing, and sing again;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a Christ have I!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    }
  ],
