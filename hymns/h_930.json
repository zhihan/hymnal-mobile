    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not at death I shrink nor falter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my Savior saves me now;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to meet Him empty-handed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thought of that now clouds my brow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Must I go, and empty-handed?”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must I meet my Savior so?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not one soul with which to greet Him:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must I empty-handed go?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O the years in sinning wasted;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could I but recall them now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would give them to my Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His will I’d gladly bow."
            }
          ]
        }
