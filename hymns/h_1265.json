    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how we need the churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All of them, great or small!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need their many portions"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To profit us withal."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, Lord, enlarge the churches;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We love their needs to bear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enlarge our hearts, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship and prayer."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The churches, the churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the earth today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, stir our hearts for Thy desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And build us, oh, build us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we pray."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord’s eyes o’er the whole earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are running to and fro;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those seven, burning, searching,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our heart’s desire to know."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His purpose—many churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built up in one accord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This golden testimony"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will thus express the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
