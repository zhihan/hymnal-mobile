            {
              "chord": "",
              "text": "如同膏油在涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满、浇灌、加力、滋润，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面供应我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "大能！大能！大能生命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能生命是基督！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已带我与祂同钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我不再作罪奴。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂也带我同祂复生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我和祂同活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历祂的复活大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面供应我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜！得胜！得胜生命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜生命是基督！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在十架已经得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我不再作俘虏。"
            }
          ]
        },
        {
          "segments": [
            {
