    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣！神圣！神圣生命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣生命是基督！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已化身成为圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到我里面来居住。"
            }
          ]
        },
        {
          "segments": [
