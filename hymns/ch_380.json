              "text": "撒但、鬼魔、世界、人情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂都为我全胜过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今来作我得胜生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面供应我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀！神圣！大能生命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜生命是基督！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我刚强，使我得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我长大并成熟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我变质，使我像祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我自由且超脱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到那日被提变化，"
            }
          ]
        },
