          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "关锁的园，禁闭的井，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全封闭给你的泉源。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "北风南风快快兴起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我心园能发出香气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引我良人进祂园内，"
            }
          ]
        },
        {
          "segments": [
