    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为何我能成你心爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满带着圣灵犹如烟柱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能效法你的死，复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没药乳香显出。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何我能成为你华轿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你能借我行动安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我怎能如勇士持刀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你防备夜间的袭击。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因多人巡逻殷勤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我能在其中得以安稳；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因你那无量爱情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "琢磨使我成形。"
            }
          ]
        }
      ],
