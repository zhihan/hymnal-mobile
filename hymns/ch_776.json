{
  "url": "https://www.hymnal.net/cn/hymn/ch/776",
  "title": "何等荣耀何等光明",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "榮"
            },
            {
              "chord": "Bm",
              "text": "耀， 何"
            },
            {
              "chord": "A",
              "text": "等 光"
            },
            {
              "chord": "D",
              "text": "明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何 等 神"
            },
            {
              "chord": "Bm",
              "text": "聖 耶"
            },
            {
              "chord": "A7",
              "text": "路"
            },
            {
              "chord": "D",
              "text": "撒"
            },
            {
              "chord": "A",
              "text": "冷！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃 是 神"
            },
            {
              "chord": "Em",
              "text": "在 人"
            },
            {
              "chord": "D",
              "text": "間 帳"
            },
            {
              "chord": "A",
              "text": "幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "又 是"
            },
            {
              "chord": "",
              "text": "羔"
            },
            {
              "chord": "D",
              "text": "羊 所"
            },
            {
              "chord": "A",
              "text": "娶"
            },
            {
              "chord": "A7",
              "text": "新"
            },
            {
              "chord": "D",
              "text": "婦。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "新约圣徒，旧约选民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是圣城组成成分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同蒙救赎，同承应许，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同被建造，给神安居。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城四方，完美、方正，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长宽高度全都相等，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何多馀，无何不及，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何偏斜，无何不齐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "精金城身、精金街道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同玻璃明净、透照；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "象征神的尊贵生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是圣城本质本性。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "十二城门全是珍珠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因蒙基督奥妙救赎；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重生使其变质成珍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣事物由此入门。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "十二墙基十二宝石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "石石都是珍贵装饰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过烧压，经过组织，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "方有如此永远价值。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "碧玉城墙明如水晶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的光辉在此照明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "射出神的荣耀光芒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照出神的碧玉形像。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "城墙为界，里外分别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摒除一切不圣、不洁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有精金、珍珠、宝石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能合圣城荣耀性质。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神和羔羊为城的殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人得时常见祂荣面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的同在永不离开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人在祂前事奉、敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "城不需要日、月、灯光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有神荣耀昼夜照亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羔羊是灯，城是灯台，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神荣光四射城外。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "城中神和羔羊宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出生命活水明河；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流在城内街道中间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命果树长在两岸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是表明神的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅流出、滋润、供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且带着神的权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全城盘旋流通、运行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所以神性成为街道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满城尽是精金、珠宝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有道可行，有水可饮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命粮食丰富、鲜新。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "十二数目表明政权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是表明永远完全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更是表明神、人调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三四相乘，融洽无隔。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "再无死亡，再无黑夜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "咒诅、痛苦也都根绝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "旧事全过，一切更新，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人互居，相安相亲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城非但有神形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且为神掌权作王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全神的永远心愿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神心，直到永远！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "16"
    }
  ],
