    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Jubilee is Christ the feast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoyed by all who eat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We take Him as our dwelling place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To have true rest and peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secret of the Jubilee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is gaining Christ, our rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ in us and us in Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life is really blessed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit is upon Me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To cause the blind to see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Announce the gospel to the poor..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open up the prison doors..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come let us enjoy the Lord..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be set free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "JUBILEE!!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The living in the Jubilee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Christ lived out in us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through every trial and circumstance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ reigns victorious;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Release your voice, proclaim the news"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all the captured ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejoicing, thanking, praising God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the kingdom comes!"
            }
          ]
        }
