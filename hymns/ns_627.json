    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my hands full today, O Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You lived a life all absolute."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I lay my hands upon You, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In union, grafted, one with You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my hands full right now, O Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I’d partake of You today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By eating of Your living Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My old self would be purged away."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my hands full, my Savior Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You were made sin and judged by God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all my sins may be no more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would, each day, apply Your blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my hands full; You are my peace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In everything, I’d talk to You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God no longer enemies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying peace with all saints, too."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my hands full; this is my prayer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remind me, Lord, how rich are You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d on Thee labor, to prepare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To offer Christ in worship true."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my hands full with only You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing of self, but all of Christ."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Savor so sweet and fragrant, too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rises to God, now satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
