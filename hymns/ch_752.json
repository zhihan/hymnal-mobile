    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "若祂在一清晨回来结算，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一一指名传我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们各人要将银子交还，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能否说‘好，仆人？’"
            }
          ]
        }
