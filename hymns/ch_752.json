      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "若祂在一清晨回来结算，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一一指名传我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们各人要将银子交还，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能否说‘好，仆人？’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我能否说，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是已经准备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "准备坦然见主面？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "会否祂来正逢我仍不睡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍然等候，直至祂显现？"
