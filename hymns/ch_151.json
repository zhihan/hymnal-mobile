      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是石头，多人试过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所宝贵，我所爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "极其稳固、极其可靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的力量永不衰。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是那永生活石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所拣选，归我们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何其坚强、何其有力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无穷生命是我分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们珍贵你的价值，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你之所是全为我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在此因爱记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满享你富的广阔。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你又是那神圣基石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所安放，稳而坚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你这稳固根基，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们永远享安全。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对于我们，在你之外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人能立别根基；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们惟一基础，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永远不更移。"
            }
          ]
        }
      ],
