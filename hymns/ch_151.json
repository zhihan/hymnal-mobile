    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "珍 贵 你 的 价 值，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "你 之"
            },
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "A7",
              "text": "是 全"
            },
            {
              "chord": "",
              "text": "为"
            },
            {
              "chord": "D",
              "text": "我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 在"
            },
            {
              "chord": "G",
              "text": "此 因"
            },
            {
              "chord": "",
              "text": "爱"
            },
            {
              "chord": "D",
              "text": "记 念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "满 享"
            },
            {
              "chord": "",
