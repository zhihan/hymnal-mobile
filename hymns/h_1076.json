      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O teach me what it meaneth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love beyond compare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love that reacheth deeper"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than depths of self-despair!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yea, teach me, till there gloweth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this cold heart of mine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Some feeble, pale reflection"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of that pure love of Thine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O teach me what it meaneth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I am full of sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grace alone can reach me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love alone can win."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O teach me, for I need Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have no hope beside,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The chief of all the sinners"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For whom the Savior died."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O teach me what it meaneth:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The rest which Thou dost give"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all the heavy-laden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who look to Thee and live."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because I am a rebel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy pardon I receive:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thou dost command me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can, I do believe."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O infinite Redeemer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I bring no other plea;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thou dost invite me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cast myself on Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thou dost accept me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love and I adore;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thy love constraineth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll praise Thee evermore."
            }
          ]
        }
      ],
