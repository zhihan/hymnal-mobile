          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That sacred crimson tide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blood and water flowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Thine own wounded side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach me that if none other"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "*Had sinned, but I alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet still, Thy blood, O Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine only, must atone."
            }
          ]
        }
