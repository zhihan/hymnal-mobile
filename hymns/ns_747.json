    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily, weekly, monthly, yearly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ our milk and Christ our honey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sabbath, new moon and new feasts!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eat Him! Eat Him! Eat more of Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink Him! Drink Him! Overflow Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breathe Him! Be His life increase!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our good land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A rich and vast land;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We lack for nothing in Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now walk more in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Absorb more of Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled more and more to the brim!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ must be preeminent in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our love, our tripartite being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our daily living too!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our spiritual experience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our private universes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He must have the first place true!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve all been chosen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A corporate person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To make Christ preeminent!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s ruling o’er us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our universe"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To give Christ preeminence."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, God’s myst’ry, God embodied—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him we’re made full and splendid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God’s fullness dwells in Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us realize what is in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exercise faith, partake of Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lose sight of all but Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all He is and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Attained and obtained"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Belongs to us already!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all that He has"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Experienced has"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Become our own history!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ we have one position,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One life, living, destination,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory, in the heavenlies!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our life, Christ’s subjective;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s our living with one motive—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life and glory to release!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s all the members,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all the members;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He constitutes the new man!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His peace must rule us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His word must fill us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To manifest one new man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Broaden, lengthen, heighten, deepen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spiritual dimensions;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Your fullness manifest!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In each daily situation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With each person, time, location,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Magnify Your boundlessness!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re all inclusive!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re all extensive!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This light must penetrate us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May all Your riches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your exhaustlessness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be day by day wrought in us!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
