        {
          "segments": [
            {
              "chord": "",
              "text": "The love of Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is now constraining me to love Him utterly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His mighty love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has touched me deep within to consecrate to Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This charming One so excelling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His touch I’m now responding;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To surrender, to surrender to Him."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This tide of love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has flowed to me from Him that keeps on rushing in."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m for Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond my own control; He’s now my final goal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
