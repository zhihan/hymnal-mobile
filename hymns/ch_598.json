{
  "url": "https://www.hymnal.net/cn/hymn/ch/598",
  "title": "教会是主的身体",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "召 會"
            },
            {
              "chord": "",
              "text": "是 主 的"
            },
            {
              "chord": "A",
              "text": "身 體，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "G",
              "text": "是 神"
            },
            {
              "chord": "A7",
              "text": "的 居"
            },
            {
              "chord": "D",
              "text": "所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 眾 聖 徒 的"
            },
            {
              "chord": "G",
              "text": "結 集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也 是 神"
            },
            {
              "chord": "D",
              "text": "人 調"
            },
            {
              "chord": "A",
              "text": "和；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "創"
            },
            {
              "chord": "D",
              "text": "世 以"
            },
            {
              "chord": "",
              "text": "前 神"
            },
            {
              "chord": "G",
              "text": "所"
            },
            {
              "chord": "D",
              "text": "選，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十 架 主"
            },
            {
              "chord": "B7",
              "text": "死 所"
            },
            {
              "chord": "Em",
              "text": "贖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "性"
            },
            {
              "chord": "D",
              "text": "質、 地"
            },
            {
              "chord": "",
              "text": "位 全"
            },
            {
              "chord": "G",
              "text": "屬 天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地"
            },
            {
              "chord": "A",
              "text": "上 任"
            },
            {
              "chord": "A7",
              "text": "何 不"
            },
            {
              "chord": "D",
              "text": "屬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她是新造的新人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督复活所生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵里面受了浸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借道之洗成圣。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是她的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是她的元首；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她与基督同性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高升远超万有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她的根基已立定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是耶稣基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能与基督同神圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才是她的事物。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡属她者都需要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过十架妙死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在复活里被建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是金、银、宝石。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她的元素全是一："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一神、一主、一灵、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一身、一信并一洗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一望，神所命定。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神在里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众人成为一身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借信联结，因洗断，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭望等候主临。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她的所有众肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出自各方、各民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都结合成为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不分任何身分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有犹太或外邦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有自主、为奴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有卑下或高尚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有新人‘基督。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙之中独一个，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分在各地出现；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一地一会为原则，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方立场为限。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方行政虽独立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各向元首负责，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙交通却一体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何离异间隔。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她在各地的出现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是撒冷雏形；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为作基督的丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "先有圣城情景："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是灯，神是光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她是灯台照明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出荣耀的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到撒冷完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
