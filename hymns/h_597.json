    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I know that my Redeemer lives,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A quick’ning Spirit He;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know eternal life He gives—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amazing grace—to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I find Him lifting up my head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He brings salvation near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His presence makes me free indeed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He will soon appear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He wills that I should holy be:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What can withstand His will?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The counsel of His grace in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He surely shall fulfill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, I hang upon Thy word:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I steadfastly believe"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt return and claim me, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to Thyself receive."
            }
          ]
        }
      ],
