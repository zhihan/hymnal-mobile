    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stronger His love than death and hell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its riches are unsearchable:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The first-born sons of light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Desire in vain its depths to see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They cannot reach the mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The length, and breadth, and height."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God only knows the love of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, that it now were shed abroad"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this poor stony heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For love I sigh, for love I pine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This only portion, Lord, be mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be mine this better part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, that I could forever sit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Mary, at the Master’s feet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be this my happy choice;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My only care, delight, and bliss,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My joy, my rest on earth be this,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To hear the Bridegroom’s voice."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
