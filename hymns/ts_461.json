    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在 人"
            },
            {
              "chord": "G",
              "text": "手 中"
            },
            {
              "chord": "A",
              "text": "被 推"
            },
            {
              "chord": "D",
              "text": "挤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 人 口 中 被 唾"
            },
            {
              "chord": "A",
              "text": "弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "面 如"
            },
            {
              "chord": "",
              "text": "坚 石 肃"
            },
            {
              "chord": "D",
              "text": "然 伫"
            },
            {
              "chord": "Bm",
              "text": "立；"
            }
