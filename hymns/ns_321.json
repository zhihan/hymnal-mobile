    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Heav’n and earth shall have one living: God and man in organic union live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resurrection power supplying, Conformed to Christ’s death, no longer I live!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take His model, tread His footsteps, Go out the camp to live within the veil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Walk with God, obey His headship, New man un’versal, God’s kingdom to bring."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, we give ourselves afresh, Into Your training hands to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Molded, shaped, and worked on daily, To be vessels of Your glory!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May all my life and work declare, Uniqueness of Your recovery"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To build Your Body, prepare Your bride, To bring You back, fulfill Your longing!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the members of one Body, Built up in love, support in spirit each,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ dispensing, Spirit minist’ring, Blending until we’re all made one in Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Give our whole being, one soul to be, Vital groups forming, build up Body His,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gospelize and truthize widely, Shepherd as God, New Revival to reach."
            }
          ]
        }
      ]
    },
