{
  "url": "https://www.hymnal.net/cn/hymn/ch/194",
  "title": "神灵今是基督的灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 灵"
            },
            {
              "chord": "",
              "text": "今 是 基"
            },
            {
              "chord": "A",
              "text": "督 的"
            },
            {
              "chord": "D",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "G",
              "text": "此 来"
            },
            {
              "chord": "D",
              "text": "作 实"
            },
            {
              "chord": "",
              "text": "际 的"
            },
            {
              "chord": "A",
              "text": "灵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "D",
              "text": "乃 基"
            },
            {
              "chord": "",
              "text": "督 住"
            },
            {
              "chord": "A",
              "text": "在 我"
            },
            {
              "chord": "D",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "G",
              "text": "祂 作"
            },
            {
              "chord": "D",
              "text": "我 实"
            },
            {
              "chord": "A",
              "text": "际"
            },
            {
              "chord": "A7",
              "text": "供"
            },
            {
              "chord": "D",
              "text": "应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是神的化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显明神的圣别性情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这灵也是基督化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启示基督作我生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的本性一切丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全在基督有形有体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督带着一切丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为这灵来作实际。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父在子里得着彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子今成为实际的灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父是源头，子是流出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是流入作我供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当灵刚强我里面人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督安家在我心间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父所有的一切丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就将我人全都充满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在子里面我得着父，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接受祂来应付所缺；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里面我经历子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我生命和我一切。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主用你神圣实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你灵将我充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得以充满了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你丰富享得完全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
