  "title": "Crazy Lover of the Lord",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m a crazy lover of the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every day I love You more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your beauty has attracted me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m longing for Your sweet embrace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to see You face to face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I turn my heart a thousand times a day to say:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, it’s true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m in love with You!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m done with all formalities."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I simply want to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit where You live in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything I am, have, and can do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only comes from loving You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I turn my heart a thousand times a day to say:"
            }
          ]
        }
      ],
