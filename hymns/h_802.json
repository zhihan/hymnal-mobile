              "text": "Thou art"
            },
            {
              "chord": "",
              "text": "the"
            },
            {
              "chord": "C",
              "text": "Word and"
            },
            {
              "chord": "D7",
              "text": "Spirit,"
            },
            {
              "chord": "G",
              "text": "Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in one"
            },
            {
              "chord": "D",
              "text": "spirit"
            },
            {
              "chord": "A7",
              "text": "worship"
            },
            {
              "chord": "D",
              "text": "we;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis"
            },
            {
              "chord": "G",
              "text": "by the"
            },
            {
              "chord": "",
              "text": "Word we"
            },
            {
              "chord": "C",
              "text": "understand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the"
            },
            {
              "chord": "G",
              "text": "Spirit"
            },
            {
              "chord": "D",
              "text": "contact"
            },
            {
              "chord": "G",
              "text": "Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thou with me hast joined in one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art my all, O Lord, thereby;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as the Spirit and the Word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou cam’st to me as my supply."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If Thou art Lord, yet not the Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How couldest Thou be known to me?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If Thou art God yet Spirit not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How could I ever contact Thee?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word reveals Thyself to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And knowledge of Thyself imparts;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit is Thy substance true"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whereby I touch Thee as Thou art."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art my life, my light, my way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My food, my strength and guaranty;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Word made known, as Spirit these"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Become experience to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word in Scripture is expressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit, the Indwelling One;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word is spirit and is life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When to my spirit it doth come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If I Thy Word would understand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I must Thy Holy Spirit touch;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not only grasp it with my mind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with my spirit, praying much."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precious Word my heart doth love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit fellowships with Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart rejoices in Thy Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit praises sings in Thine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
