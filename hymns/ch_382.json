    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的丰盛藏你里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀从你彰显；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前在肉身成功救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今成那灵与我联属。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，大神化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奥妙、丰富，享受不尽！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣中之圣，人中之人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵里作我福分！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凡父所有全由你承，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡你所是都归于灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵进我灵作你实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你成为我的经历。"
            }
          ]
        }
      ],
      "type": "verse",
