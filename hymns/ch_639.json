{
  "url": "https://www.hymnal.net/cn/hymn/ch/639",
  "title": "如果争战凶猛",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A7",
              "text": "如"
            },
            {
              "chord": "D",
              "text": "果 争"
            },
            {
              "chord": "",
              "text": "战 凶"
            },
            {
              "chord": "A",
              "text": "猛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "仇"
            },
            {
              "chord": "E7",
              "text": "敌 强"
            },
            {
              "chord": "A7",
              "text": "盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "当 坚"
            },
            {
              "chord": "",
              "text": "信 主"
            },
            {
              "chord": "G",
              "text": "话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "并 发"
            },
            {
              "chord": "",
              "text": "歌"
            },
            {
              "chord": "D",
              "text": "声。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "只要呼喊一声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就要得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不要哑口不作"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反抗见证。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵现在郁闷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像无能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若借血祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就要高升。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌虽然蛮横，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你可与争，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果坚守地位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久就胜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所以应当发声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "证明主胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光景虽然黑暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但必变更。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
