    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though hot the fight, why quit the field?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why must I either fly or yield,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Jesus is my mighty shield?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus my shield!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When creature comforts fade and die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worldlings may weep, but why should I?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus still lives, and still is nigh."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is nigh!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though all the flocks and herds were dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My soul a famine need not dread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Jesus is my living bread."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus my bread!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I know not what may soon betide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or how my wants shall be supplied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Jesus knows, and will provide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus provides!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though sin would fill me with distress,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The throne of grace I dare address,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Jesus is my righteousness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My righteousness!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though faint my prayers and cold my love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My steadfast hope shall not remove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While Jesus intercedes above."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He intercedes!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Against me earth and hell combine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But on my side is power divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is all, and He is mine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is mine!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
