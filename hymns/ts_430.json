      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我羡慕只属于你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "速来释放我这容器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全归你占有；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但暴政我既得脱，"
            }
          ]
