  "title": "主，你得胜",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "A",
              "text": "勝， 我"
            },
            {
              "chord": "",
              "text": "今 服"
            },
            {
              "chord": "D",
              "text": "矣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩 典 迫 使 我 心 決"
            },
            {
              "chord": "G",
              "text": "意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "奉"
            },
            {
              "chord": "D",
              "text": "獻 一"
            },
            {
              "chord": "A",
              "text": "切"
            },
            {
              "chord": "E7",
              "text": "於"
            },
            {
              "chord": "A",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "的 可"
            },
            {
              "chord": "",
              "text": "畏 我"
            },
            {
              "chord": "A",
              "text": "能 久"
            },
            {
              "chord": "D",
              "text": "抗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 你 大 愛 有"
            },
            {
              "chord": "G",
              "text": "誰"
            },
            {
              "chord": "A7",
              "text": "能"
            },
            {
              "chord": "D",
              "text": "擋？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愛"
            },
            {
              "chord": "G",
              "text": "大，"
