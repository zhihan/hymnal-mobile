              "chord": "",
              "text": "of"
            },
            {
              "chord": "D7",
              "text": "His"
            },
            {
              "chord": "C",
              "text": "grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My gracious Master and my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Assist me to proclaim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To spread through all the earth abroad,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The honors of Thy name."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! the name that charms our fears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That bids our sorrows cease;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis music in the sinner's ears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis life, and health, and peace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His love my heart has captive made,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His captive would I be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For He was bound, and scourged and died,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My captive soul to free."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He breaks the power of canceled sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He sets the prisoner free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood can make the foulest clean;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood availed for me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So now Thy blessed Name I love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy will would e'er be mine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Had I a thousand hearts to give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord, they all were Thine!"
            }
          ]
        }
      ]
    }
  ],
