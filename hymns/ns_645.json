    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the beatings, the scourging, the thorns,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ravage You suffered and bore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In these two precious symbols are shown here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In bread and in cup evermore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your flesh and Your blood, separated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are both here, on the Table displayed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all eat and we drink, reassured that"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your death every righteous debt paid."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We gather in love to remember,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Partaking the bread and the cup,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Your death is an eternal splendor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which satisfies God as we sup."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When the brothers, with hands on the bread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Press downward to break it apart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I see You in my stead being broken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And weep with a gratified heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Your wounds, without number created,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Borne as You were poured out mortally,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Your sufferings, eternally slated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Accomplished redemption for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
