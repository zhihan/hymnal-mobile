    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You were pierced on the cross for my sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forsaken of men and despised."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You were poured out like water in death, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Affliction that God Himself prized."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here, one bread and one cup both exhibit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How Your death reconciles us to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the oneness that’s in God the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For which we rejoice gratefully!"
            }
          ]
        }
      ],
