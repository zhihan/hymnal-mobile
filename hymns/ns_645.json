              "text": "You were wounded for all our transgressions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore stripes for our healing and rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chastening for our peace fell upon You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even all our iniquity too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our burdens, our sickness, our sorrow."
            }
          ]
        },
