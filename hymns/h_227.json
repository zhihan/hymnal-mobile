              "text": "That from God, no longer severed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may ever see His face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God's righteousness and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have been fully satisfied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Thy death's abundant merit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may now with God abide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
