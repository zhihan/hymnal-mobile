            {
              "chord": "",
              "text": "All the barriers have been broken;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We approach the throne of grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There receiving grace and mercy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the timely need to meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drinking as of living water,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tasting God Himself replete."
            }
          ]
        }
