            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy death the veil was riven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Opened was the holiest place,"
            }
          ]
