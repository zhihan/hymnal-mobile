    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我爱你名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未有天地未有时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神爱无境，就已显明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要施恩典救亡世；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这爱真是永远爱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "堕落如我也眷顾！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱叫你来，为我负债，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我成为你珍物。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我爱你名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的降生何寒微！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的慈心满有恩情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的道路孤且卑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的痛苦你替背，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的荆冕你替戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的祸杯你替尝备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常经忧患是为爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我爱你名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘神的羔羊’何清洁！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你被豫定为我受刑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出宝血洗罪孽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在你坐高天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊贵、荣耀为冠冕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你打胜仗，我得释放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚主名甜！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
