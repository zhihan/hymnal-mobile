{
  "url": "https://www.hymnal.net/cn/hymn/ch/247",
  "title": "惊人恩典何等甘甜",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "惊 人"
            },
            {
              "chord": "",
              "text": "恩 典！ 何"
            },
            {
              "chord": "C",
              "text": "等 甘"
            },
            {
              "chord": "G",
              "text": "甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来 救 无"
            },
            {
              "chord": "A7",
              "text": "赖 如"
            },
            {
              "chord": "D",
              "text": "我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "前"
            },
            {
              "chord": "G",
              "text": "曾 失"
            },
            {
              "chord": "G7",
              "text": "落， 今"
            },
            {
              "chord": "C",
              "text": "被 寻"
            },
            {
              "chord": "G",
              "text": "见！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前 盲， 今"
            },
            {
              "chord": "D",
              "text": "不"
            },
            {
              "chord": "D7",
              "text": "摸"
            },
            {
              "chord": "G",
              "text": "索！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典教导我心惧怕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又将惧怕除掉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典在我初信刹那，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显为何等可宝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主已应许向我施恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂话就是保证；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要作我盾牌、永分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带我经过此生。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我见主万年之后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍像太阳照耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比我开始赞美时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美仍不减少。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
