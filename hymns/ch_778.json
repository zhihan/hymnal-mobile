            },
            {
              "chord": "A",
              "text": "物："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新 妇 作"
            },
            {
              "chord": "D",
              "text": "神 心"
            },
            {
              "chord": "",
              "text": "爱 佳"
            },
            {
              "chord": "A",
              "text": "偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建"
            },
            {
              "chord": "D",
              "text": "筑 作"
            },
            {
              "chord": "",
              "text": "神 安"
            },
            {
              "chord": "A",
              "text": "居 之"
            },
            {
              "chord": "D",
              "text": "处。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "旧约所有召会豫表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不外妇女以及建筑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "妇女作人称心配偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建筑给人安居作主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "古时神的以色列民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被神称作祂的妻子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其中有殿给神居住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也有圣城给神管治。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为人之神，神人基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作了新郎来娶新妇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂用己命将她重生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可作配偶使祂满足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督今在复活里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像所罗门为神建殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神可有安息之所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全祂的所有心愿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会乃是基督新妇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂称心，作祂丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会也是神的居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给神安居，将神彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将来的新耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是所有新妇、建筑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切豫表终极成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神得以心满意足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她是新妇作主配偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主称心，作主丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是帐幕作神居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给神安居，作王掌权。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她是神在人里工作"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终极完满的集大成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作神人性里的表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰满、永远、而且神圣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
