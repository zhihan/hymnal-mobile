{
  "url": "https://www.hymnal.net/cn/hymn/h/1100",
  "title": "God shall rise, His foes be scattered",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "God shall"
            },
            {
              "chord": "",
              "text": "rise, His foes be"
            },
            {
              "chord": "A",
              "text": "scattered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that"
            },
            {
              "chord": "D",
              "text": "hate Him"
            },
            {
              "chord": "A7",
              "text": "flee a"
            },
            {
              "chord": "D",
              "text": "way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the wax before the"
            },
            {
              "chord": "A",
              "text": "fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the"
            },
            {
              "chord": "D",
              "text": "wicked"
            },
            {
              "chord": "A7",
              "text": "He shall"
            },
            {
              "chord": "D",
              "text": "slay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "But the"
            },
            {
              "chord": "",
              "text": "righteous shall rejoice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "With a"
            },
            {
              "chord": "D",
              "text": "loud, triumphant"
            },
            {
              "chord": "",
              "text": "voice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Singing praises, singing"
            },
            {
              "chord": "A",
              "text": "praises,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "Singing"
            },
            {
              "chord": "D",
              "text": "praises"
            },
            {
              "chord": "A7",
              "text": "unto"
            },
            {
              "chord": "D",
              "text": "God!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is riding through the deserts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing in His saints in need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He's a Father to the orphans"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And a refuge tried indeed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His holy habitation—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a wonderful salvation!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here the lone have found a family,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here the desolate a home;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prisoners are brought from bondage"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To prosperity unknown."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the flock—what wondrous grace—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God prepared this dwelling place:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the Lord in mighty triumph"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sends the news of victory;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We the \"women\" spread the tidings—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Kings of armies flee, they flee!\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more sweat and dreary toil;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We at home divide the spoil!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, on high Christ hath ascended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leading captives in His train;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These as gifts He has perfected"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Lord may dwell with them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers, sisters, we are those,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're those transformed, vanquished foes!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessed be the Lord forever:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day He loads with good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en the God of our salvation—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spread His worthy praise abroad."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His the goings forth from death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every foe He conquereth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They have seen, O God, Thy goings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy holy dwelling place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy triumphal, high processions"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Midst a mighty voice of praise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "See the singers go before,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praising, praising o'er and o'er:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Little Benjamin is leading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then great Judah's company:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Son of sorrow at God's right hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lion with the scepter see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Zebulun and Naphtali"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make the joyful tidings fly:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, thy strength has been commanded"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the temple glorious;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still we pray that God may strengthen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that He has wrought for us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Higher yet our praise shall rise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the utmost earth replies:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen!"
            }
          ]
        }
      ]
    }
  ],
