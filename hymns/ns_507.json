    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have come to You. I am thirsty; let me drink!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the riches of this life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flood in me, with joy I cry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“I am no longer dry!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You have come to us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we come to drink!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are filled with Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drinking at the Fount of life am I!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I fail each day, I return to You and pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Asking Lord, “Unveil my face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep me always in Your grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I drown without You Lord!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I fail each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I return and pray."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I’m drawn to say"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord make home in all my heart and stay!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There is a river flowing from the throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reaching man in every place."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our problems are erased."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We love You Jesus Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
