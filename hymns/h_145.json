      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "People and realms of every tongue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dwell on His love with sweetest song;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And infant voices shall proclaim"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their early blessings on His name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessings abound where’er He reigns:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The prisoner leaps to lose his chains,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The weary find eternal rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the sons of want are blest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Where He displays His healing power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death and the curse are known no more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him the tribes of Adam boast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More blessings than their father lost."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let every creature rise and bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Peculiar honors to our King;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Angels descend with songs again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And earth repeat the loud Amen."
            }
          ]
        }
