    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him shall endless prayer be made."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And princes throng to crown His head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His name like sweet perfume shall rise"
            }
          ]
        },
        {
          "segments": [
            {
