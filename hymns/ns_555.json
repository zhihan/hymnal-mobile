          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To believe the gospel brought to them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the duty is it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of those ’trusted with it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To make known this gospel to all men."
            }
          ]
        }
