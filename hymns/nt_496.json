        {
          "segments": [
            {
              "chord": "",
              "text": "If we’re devoid of Christ we’re empty still."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our real God, our real Lord,"
