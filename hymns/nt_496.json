      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are vanity of vanities,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the reality all things to fill;"
