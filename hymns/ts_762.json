        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并以利沙跟随以利亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心放胆说主话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配搭的榜样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "保罗、西拉在灵里刚强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身陷牢中仍赞美歌唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神救恩大得显彰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看我们脸上荣光更加有福、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盼望同领受一个异象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有不同的方向，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟上时代随主前往，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使新路更开广，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿为神国度福音走四方。"
            }
          ]
        }
