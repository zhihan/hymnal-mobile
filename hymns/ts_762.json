      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们知道眼前所奔跑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非属地康庄大道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要经过主一再焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "炼净我天然、爱好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽管我渺小，常是软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "会沮丧跌倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们却又把我带回到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主那起初的怀抱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我真是欢喜跳跃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有主作我至宝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又能与你们联调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有比这更美好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要时时向外宣报，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让更多人进入"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督与召会永远的荣耀。"
            }
          ]
        }
