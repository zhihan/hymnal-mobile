{
  "url": "https://www.hymnal.net/cn/hymn/ch/73",
  "title": "主接纳我们的诗歌",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 接"
            },
            {
              "chord": "F",
              "text": "纳 我"
            },
            {
              "chord": "",
              "text": "们 的"
            },
            {
              "chord": "C",
              "text": "诗 歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽 然 声 音"
            },
            {
              "chord": "D",
              "text": "顶 柔"
            },
            {
              "chord": "G",
              "text": "弱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "我 们"
            },
            {
              "chord": "F",
              "text": "述 说"
            },
            {
              "chord": "",
              "text": "你 的"
            },
            {
              "chord": "C",
              "text": "恩 笃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 你 是 我"
            },
            {
              "chord": "G",
              "text": "们 救"
            },
            {
              "chord": "C",
              "text": "主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因你舍去荣耀、丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的信徒才得福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你变贫穷，叫你信徒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你享荣耀、丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天上有何使你心厌？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界有何使你羡？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因而你就离天临世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "孤单、凄凉直到死？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在天上何等荣耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在世上何萧条！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你早已知此行艰难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只因爱我竟甘愿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我想到你的良善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就不禁又喜又惭！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜，因你能这样爱好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惭，因我这样还报。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但我们望那日快到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱尽所有的阻挠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时我们进荣耀里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要照本分服事你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现今我们等在这里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因这盼望受策励；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，使我们活着为你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到你前同聚集。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
