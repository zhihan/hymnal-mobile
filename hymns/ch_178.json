            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人知何能及！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们永远的分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此豫尝何有福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们等候你的国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的显现我催促。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你显现在你国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同着得胜的圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重新享受你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你心爱的新妇。"
            }
          ]
        }
      ],
