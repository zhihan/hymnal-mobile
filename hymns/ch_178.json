{
  "url": "https://www.hymnal.net/cn/hymn/ch/178",
  "title": "为这筵席我献感谢",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "為 這"
            },
            {
              "chord": "",
              "text": "筵 席 我 獻"
            },
            {
              "chord": "A",
              "text": "感 謝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "餅、 杯"
            },
            {
              "chord": "A",
              "text": "在 此"
            },
            {
              "chord": "A7",
              "text": "同 陳"
            },
            {
              "chord": "D",
              "text": "列；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 此 享 受 你 的"
            },
            {
              "chord": "A",
              "text": "自 己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 聖"
            },
            {
              "chord": "A7",
              "text": "愛 筵"
            },
            {
              "chord": "",
              "text": "何 超"
            },
            {
              "chord": "D",
              "text": "絕。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "這 餅"
            },
            {
              "chord": "A7",
              "text": "是 你"
            },
            {
              "chord": "D",
              "text": "所 捨"
            },
            {
              "chord": "",
              "text": "身 體，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 們"
            },
            {
              "chord": "A7",
              "text": "在 此"
            },
            {
              "chord": "D",
              "text": "同 分"
            },
            {
              "chord": "",
              "text": "享；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 杯 是 你"
            },
            {
              "chord": "G",
              "text": "所 流"
            },
            {
              "chord": "D",
              "text": "寶 血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 們"
            },
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "A7",
              "text": "同 飲"
            },
            {
              "chord": "D",
              "text": "嘗。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看， 這 神 聖 筵"
            },
            {
              "chord": "A",
              "text": "席！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其 上"
            },
            {
              "chord": "A7",
              "text": "何 等"
            },
            {
              "chord": "D",
              "text": "表 記！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "意 義 深 厚，"
            },
            {
              "chord": "G",
              "text": "永 垂"
            },
            {
              "chord": "",
              "text": "不 朽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "人 知"
            },
            {
              "chord": "A7",
              "text": "何 能"
            },
            {
              "chord": "D",
              "text": "及！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你的救赎之死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将生命来分赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将自己给了我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我有分你所是。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着分享这饼、这杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们陈列你的死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此吃喝你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此记念到永世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看，这神圣筵席！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其上何等表记！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "意义深厚，永垂不朽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人知何能及！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这饼在此也是指明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那奥秘的身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此与众肢体交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证身体的合一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这杯也是神圣福杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现在所祝福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你血我们交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你所有的圣徒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看，这神圣筵席！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其上何等表记！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "意义深厚，永垂不朽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人知何能及！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们永远的分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此豫尝何有福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们等候你的国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的显现我催促。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你显现在你国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同着得胜的圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重新享受你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你心爱的新妇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
