  "title": "为这筵席我献感谢",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "为 这"
            },
            {
              "chord": "",
              "text": "筵 席 我 献"
            },
            {
              "chord": "A",
              "text": "感 谢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "饼、 杯"
            },
            {
              "chord": "A",
              "text": "在 此"
            },
            {
              "chord": "A7",
              "text": "同 陈"
            },
            {
              "chord": "D",
              "text": "列；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 此 享 受 你 的"
            },
            {
              "chord": "A",
              "text": "自 己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 圣"
            },
            {
              "chord": "A7",
              "text": "爱 筵"
            },
            {
              "chord": "",
              "text": "何 超"
            },
            {
              "chord": "D",
              "text": "绝。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "这 饼"
            },
            {
              "chord": "A7",
              "text": "是 你"
            },
            {
              "chord": "D",
              "text": "所 舍"
            },
            {
              "chord": "",
              "text": "身 体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 们"
            },
            {
              "chord": "A7",
              "text": "在 此"
            },
            {
              "chord": "D",
              "text": "同 分"
            },
            {
              "chord": "",
              "text": "享；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这 杯 是 你"
            },
            {
              "chord": "G",
              "text": "所 流"
            },
            {
              "chord": "D",
              "text": "宝 血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "A7",
              "text": "同 饮"
            },
            {
              "chord": "D",
              "text": "尝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看， 这 神 圣 筵"
            },
            {
              "chord": "A",
              "text": "席！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其 上"
            },
            {
              "chord": "A7",
              "text": "何 等"
            },
            {
              "chord": "D",
              "text": "表 记！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "意 义 深 厚，"
            },
            {
              "chord": "G",
              "text": "永 垂"
            },
            {
              "chord": "",
              "text": "不 朽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "人 知"
            },
            {
              "chord": "A7",
              "text": "何 能"
            },
            {
              "chord": "D",
              "text": "及！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你的救赎之死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将生命来分赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将自己给了我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我有分你所是。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着分享这饼、这杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们陈列你的死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此吃喝你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此记念到永世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看，这神圣筵席！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其上何等表记！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "意义深厚，永垂不朽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人知何能及！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这饼在此也是指明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那奥秘的身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此与众肢体交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证身体的合一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这杯也是神圣福杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现在所祝福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你血我们交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你所有的圣徒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
