{
  "url": "https://www.hymnal.net/en/hymn/ns/389",
  "title": "The Lord is my greatest love",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is my greatest love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s won me completely;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Comforter He ever brings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Timely help and sympathy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He died, that I be redeemed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He rose, a life-giving Stream;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now He in me abides,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My peace, my joy, my life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord! How I love Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Evermore, I love Thee!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The church is my home sweet home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She fills all my longing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord’s beloved bride is she,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my days for her shall be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O home full of love and care!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s river of life we share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m strengthened every day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And guided all the way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Church! How I love Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Home sweet home, I love Thee!"
            }
          ]
        }
      ],
