              "chord": "",
              "text": "无法祷告。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "就因我的眼目不明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我反安全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在暗中摸索失凭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂手能觉，祂声能听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂并不远。"
            }
