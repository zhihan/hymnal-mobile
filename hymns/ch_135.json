{
  "url": "https://www.hymnal.net/cn/hymn/ch/135",
  "title": "哦愿我有千万舌头",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦， 願"
            },
            {
              "chord": "",
              "text": "我 有 千"
            },
            {
              "chord": "G",
              "text": "萬 舌"
            },
            {
              "chord": "D",
              "text": "頭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前 來 讚 美 救"
            },
            {
              "chord": "A7",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "說"
            },
            {
              "chord": "D",
              "text": "祂 恩"
            },
            {
              "chord": "",
              "text": "典 何"
            },
            {
              "chord": "G",
              "text": "等 深"
            },
            {
              "chord": "D",
              "text": "厚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "榮"
            },
            {
              "chord": "G",
              "text": "耀 何"
            },
            {
              "chord": "A",
              "text": "等"
            },
            {
              "chord": "A7",
              "text": "豐"
            },
            {
              "chord": "D",
              "text": "富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣这名，慰我苦情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "驱尽我的惊怯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我安息、是我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我的音乐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂因爱我，竟愿经历"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人世所有苦楚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已消灭罪的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放罪的囚徒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我每静念救我的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立即感觉不配；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知祂为甚么恩待"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我这人中罪魁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今作祂爱的俘虏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘心作到永久；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂为我受死、忍辱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得以自由。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我既从你可爱的名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知你待我美意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "假若我有千万的心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也当一一归你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
