{
  "url": "https://www.hymnal.net/en/hymn/lb/73",
  "title": "I love You, always and forever more",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always and forever more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in darkness where I lived in death"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You showed Your light to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, I love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And that is what You are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this love You suffered death for me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the world to be redeemed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I’m worth no more than dust,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your eyes I am prized."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your mercy purchased me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my sin and my death."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are love, You are love."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give my all to You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my mind, my heart and all my strength"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll offer all to You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now You live in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, strengthen me to take my cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To follow You each day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I learn to call Your name."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Your riches come in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As my grace, reality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My life and destiny."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are love, You are love."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my sins are colored scarlet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have cleansed them white as snow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Your blood poured out on Calvary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My redemption will always be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I need You and You’ll always be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My life through eternity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love You. Yes, I love You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I always will love You."
            }
          ]
        }
      ],
      "type": "verse"
    }
