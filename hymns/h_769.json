            },
            {
              "chord": "G",
              "text": "come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "There within"
            },
            {
              "chord": "",
              "text": "the veil to"
            },
            {
              "chord": "D",
              "text": "be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "There to"
            },
            {
              "chord": "",
              "text": "touch the"
            },
            {
              "chord": "C",
              "text": "throne of"
            },
            {
              "chord": "D",
              "text": "grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Let life's"
            },
            {
              "chord": "C",
              "text": "water"
            },
            {
              "chord": "D",
              "text": "flow"
            },
            {
              "chord": "D7",
              "text": "thru"
            },
            {
              "chord": "G",
              "text": "me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the holiest place of all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Right within my spirit is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here the Lord in me abides,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my spirit joins with His."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To my spirit I'd return,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For 'tis here the Lord I'll meet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O how marvellous it is!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He's within, in me complete."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fragrance of the risen Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru my spirit may be spread;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If in spirit I will pray"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ will be exhibited."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If in spirit Him I touch,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His riches filled I'll be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life and light and love and grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a stream will flow thru me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Touching deeply, richly I"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Himself experience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the law of life I touch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His clear anointing sense."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In my spirit deeper still"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would touch the Lord I love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Touch Him in His hidden depth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His hidden manna prove."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When the resurrection life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is made real in pow'r to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the rod with sprouting buds,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will then accepted be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here I find the throne of grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where the living water flows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a river full of grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into me grace to bestow."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then whene'er we meet to pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our spirits we'll release;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingled will our spirits be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we'll serve the Lord as priests."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This the holiest place is too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where we all may touch the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Touch His throne in many ways"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till His grace on us is poured."
            }
          ]
        }
      ]
    }
  ],
