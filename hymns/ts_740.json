  "raw_sections": [
    "誰 是在 主 這 邊？",
    "誰 要迎 接王？",
    "誰 要在 新 樣 中，",
    "常 青而 發旺？",
    "誰 要脫 離宗 教，",
    "活 在靈 裡面，",
    "為 主斷 送前 途，",
    "站 在主這邊？",
    "我 們 在 主這邊！",
    "切 勿 變 冷 淡；",
    "靈 裡 時 常 火 熱，",
    "在 靈裡 壯膽！"
  ]
