    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our doubts and fears are now all gone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re for Thy purpose and Thy plan."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whatever may befall us—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Great I Am, we fully trust."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where’er Thou wilt send us, we’ll go."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whate’er Thou dispensed, we’ll outflow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beget, nourish, perfect, and build,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thy divine plan is fulfilled."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, we give ourselves to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Thy blessing we will serve Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer for ourselves alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But for Thy Church, we will go on."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bless us Lord, till we’re fully blessed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us persons blessed to bless."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We stand before Thee face to face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exhibit how we ran the race."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we’re not here with empty hands,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But filled with Jesus and Thy brands."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love, and grace, and fellowship—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All for the Body, not for ’self’."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Threefold blessing for three-part man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold the blessings, here we stand!"
            }
          ]
        }
      ]
    },
