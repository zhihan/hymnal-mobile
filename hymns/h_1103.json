    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s the river."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the mighty flowing river."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He waters me in a desert land."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s my hiding place; He is our man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the river! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s the vine tree."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the branch, the root of Jesse."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the tree of life: we have the right"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To eat of Him and have His life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the vine tree! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s the Shepherd."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the lamb of God, the he-goat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We rest and feed in the pasture land."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We strike the blood and eat the lamb."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the Shepherd! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s the Spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the all-inclusive Spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s our everything; He’s our all in all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gives life to us whene’er we call."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the Spirit! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s a Person."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s a real and living Person."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is living now inside of us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This Person is so glorious."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s a Person! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s the Body;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the fulness of the Godhead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the center of the Father’s plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ and the church, the one new man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is wonderful, wonderful."
            }
          ]
        }
      ],
