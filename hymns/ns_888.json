    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus, Jesus, gladly I’d"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That deep love of Mary’s outpour,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Waste” all on You with  all  my might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No matter the cost, my dear Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I can’t pour oil whene’er I please;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just while You still sit at the feast."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before it’s gone, this chance I’ll seize,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon You, sweet ointment release."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though sometimes I’m fallen and low,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rebellious, rejecting and cold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I just turn, what grace I know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love that will not let me go!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
