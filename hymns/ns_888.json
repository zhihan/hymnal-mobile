            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do I for self still harbor goals?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do I for base gain still aspire?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was ointment poured out just for show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not truly for Your heart’s desire?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, rid me of natural self."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d seek only You, all my days."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Completely break me, Lord, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till meet as Your vessel I’m made."
            }
          ]
        }
      ]
    },
