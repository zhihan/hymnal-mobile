          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Lord but find thee emptied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living branch in Christ the Vine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vessels of the world’s despising,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vessels weak and poor and base,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearing wealth God’s heart is prizing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory from Christ’s blessed face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh to be but emptier, lowlier,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mean, unnoticed—and unknown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to God a vessel holier,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled with Christ and Christ alone!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Naught of earth to cloud the glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Naught of self the light to dim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Telling forth His wondrous story,"
            }
          ]
        },
