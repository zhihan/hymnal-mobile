    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus though worn, and tried, and tempted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious calling, saint, is thine;"
