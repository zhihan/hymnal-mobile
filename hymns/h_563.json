    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide in Thee! my Savior God, I know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How love of Thine so vast in me may flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My empty vessel, running o’er with joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must overflow to Thee without alloy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide in Thee! nor doubt, nor self, nor sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can e’er prevail with Thy blest life within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined to Thyself, communing deep, my soul"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knows naught besides its motions to control."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide in Thee! ’tis thus I only know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secrets of Thy mind e’en while below—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All joy and peace, and knowledge of Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All pow’r and fruit, and service for the Lord."
            }
          ]
        }
      ]
