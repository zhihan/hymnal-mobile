    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如果地乐消减，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你多给天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然心可伤痛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿灵仍赞颂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地的香甜联结，"
            }
          ]
        },
        {
          "segments": [
