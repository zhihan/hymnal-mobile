              "text": "we worship"
            },
            {
              "chord": "A",
              "text": "Your blest"
            },
            {
              "chord": "D",
              "text": "name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O great \"I"
            },
            {
              "chord": "A",
              "text": "AM,\" You're"
            },
            {
              "chord": "D",
              "text": "all in"
            },
            {
              "chord": "A",
              "text": "deed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surpassing"
            },
            {
              "chord": "E",
              "text": "every"
            },
            {
              "chord": "E7",
              "text": "thing You’ve"
            },
            {
              "chord": "A",
              "text": "made—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "All that"
            },
            {
              "chord": "D7",
              "text": "You"
            },
            {
              "chord": "G",
              "text": "are is"
            },
            {
              "chord": "A",
              "text": "all"
            },
            {
              "chord": "A7",
              "text": "we"
            },
            {
              "chord": "D",
              "text": "need!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God of the living, not the dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life with power overcomes!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death is annulled! Life reigns instead!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re made alive in Christ Your Son!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From heaven’s seat, enthroned on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord, Your Son, that Man most dear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leads us to seek You inwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit sensing You draw near."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As You draw near, we apprehend"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we experience all You are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond constraints of time and space,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life, in Christ, a realm entire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Have You not willed that Christ should be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything to us inwardly?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, You are the source of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In faith, our true reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Highways to Zion in our hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From strength to strength we go each day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Depending on Your life alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your supply of Christ we stay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In this supply, Your heart of love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Makes known Your will subjectively."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wooed by Your grace and perfect will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We come to know You inwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, in reverent praise we sing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We worship You for all You are!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life, in Christ, is everything!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory to You forevermore!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
