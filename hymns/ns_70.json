    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And days ahead I shall not fear"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I trust Thy sovereign Hand!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So all creation bend and hear"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This cry!  My joyful stand!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer days of sad neglect"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now shall affront my view"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor sorrowed nights of deep regret"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll waste apart from You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ambition shall no longer keep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unyielding grip on me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While true ’tis pride’s veins do run deep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They’re severed Lord in Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It was with joy that Caleb stood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Hind Joshua on that day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And glory comes to all who would"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now enter Caleb’s way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though not through my own efforts vain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could I e’er make You glad"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But through apostles’ teaching gain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The view such brothers had."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And through their practice enter in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My crown in hand that day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And joy with Your apostles then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not having turned away."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart, my soul, I have resigned"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink off’ring for Your joy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Imagination  ne’er could find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or want greater employ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will not let Thee go my Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will not let Thee go!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Confession glad on Thee outpoured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own dear heart to know."
            }
          ]
        }
