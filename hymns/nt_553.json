    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Only this I know: I tell Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my doubts and griefs and fears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how patiently He listens!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my drooping soul He cheers;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you think He ne’er reproves me?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a false friend He would be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If He never, never told me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the sins which He must see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Would you like to know that sweetness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the secret of the Lord?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go and hide beneath His shadow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This shall then be your reward;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And whene’er you leave the silence"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of that happy meeting-place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Spirit bear the image"
            }
          ]
        },
        {
          "segments": [
            {
