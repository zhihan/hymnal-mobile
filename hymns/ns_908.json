    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From this day, Lord, to eternity—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An eternal hunger grant to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And a thirst unquenchable, my plea—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You alone, Lord, will I ever seek."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, You’ll never give up on me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doing so much on my behalf."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m enjoying grace upon grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To You be all the glory, thanks, and praise!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m unworthy, yet Your love reached me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How unchanging, Lord, You’ll always be!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You love me dearly, Lord, I can feel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In return, I give You back a love so real!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
