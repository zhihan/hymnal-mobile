    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How dare I, Lord, to ask for more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since I’m not my own anymore?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I was bought with the great, great price—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your blood—the greatest sacrifice!"
            }
          ]
        }
