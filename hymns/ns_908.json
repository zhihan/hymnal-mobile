    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, there’s no one in this world like You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re sweet, full of love, so charming too!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can’t help but deeply be in love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With You alone, oh my Beloved!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
