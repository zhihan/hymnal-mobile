    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the years, there’s longing deep within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That, in all that we experience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With enjoyments, dealings—You’d lead us all—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To perfect growth, till we’re mature in full!"
            }
          ]
