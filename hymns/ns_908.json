    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Days, weeks, years have flown by apace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wasted in bemoaning my case."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The end is near, then soon You’ll appear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Am I precious, Lord, enough for You to steal?"
            }
          ]
        }
      ],
