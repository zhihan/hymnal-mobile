    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It seems the price that’s required for Your joy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is that I’m hindered and knocked down by You;"
