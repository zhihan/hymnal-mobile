    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Laboring on Jesus! My heart has been set,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Labor’s begun, and I have no regret,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For with my labor God’s sending the rain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all my labor on Christ yields much gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus! You’re God’s good land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me to labor on!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll bit by bit possess You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the whole is won!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Canaan is God’s purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The labor He will bless;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, here I gain Yourself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Person to possess."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Laboring on Jesus this practical way—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praying His Word in the spirit each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foll’wing His living anointing within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built up with others, the church life to win."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
