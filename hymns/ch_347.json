  "raw_sections": [
    "主， 我今 背 十 架，",
    "前 來跟 隨你；",
    "浮 名利、虛 榮華，",
    "一 概都 捨棄；",
    "人 譏笑，人 辱罵，",
    "我 全不 在意；",
    "雖 受 苦，雖 受壓，",
    "窄 路不 稍離；",
    "靠 主恩， 遵 主 話，",
    "忠 心直 到底；",
    "到 那日，蒙 主誇，",
    "冠 冕榮 無比；",
    "冠 冕榮 無比，",
    "冠 冕榮 無比。"
  ]
