    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m dwelling with Jesus my King;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve found where He dwells with His own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve opened the door of my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s made it His temple and throne."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Mary I sit at His feet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like John I recline on His breast;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His presence is fulness of joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His bosom is infinite rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I dwell with the King for His work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve part in His glorious plan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring in His kingdom to earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And tell His salvation to man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world has its work and rewards,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I count them but folly and loss;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My business is only His work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My message is only His cross."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I dwell with the King for His work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The work, it is His and not mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He plans and prepares it for me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fills me with power divine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So duty is changed to delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And prayer into praise as I sing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I dwell with my King for His work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And work in the strength of my King."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll dwell with the King for His work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And work thru each day of the year."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perhaps ere it passes, the King"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In glory Himself shall appear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, then in some closer embrace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, then in some nobler employ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll dwell with the King for His work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In endless, ineffable joy!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
