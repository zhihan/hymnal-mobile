    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast laid our sins on Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy justice He was killed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy holy law’s requirements"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy justice He fulfilled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Recompense from Him receiving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art fully satisfied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How couldst Thou, O God most righteous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Claim it once more from our side?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father God, Thou hast accepted"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus as our Substitute;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Judged the Just One for the unjust,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Couldst Thou change Thy attitude?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a proof of perfect justice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thine own right hand He sits;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He, as Thy full satisfaction,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteously Thy need befits."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, through the blood of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We possess Thy righteousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy righteousness protected,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None can shake our stedfastness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteousness of Thine Thou mad’st us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None can ever us condemn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll forever testify this"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the new Jerusalem."
            }
          ]
        }
