    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To seek that forlorn, wayward sheep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You left the ninety-nine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sinner on Your shoulders bore;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth’s joy and heaven’s combine!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To You who give eternal life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Good Shepherd, we give thanks;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You know our names—as we Your voice—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And hold us in Your hands."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From many “folds” You led us out,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be one flock divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Shepherd, Door, our Pasture too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through You real rest we find."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lamb, our Shepherd on the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You guide us all the way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To springs of waters, founts of life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each tear You wipe away."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Great Shepherd of the Church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How faithful is Your care—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inclusive, gentle, rich, and strong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both present and fore’er."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant us a shepherd’s heart, like Yours,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With tenderest concern;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feed Your sheep, to nurse Your lambs,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of You we all will learn."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May we be carers of men’s souls,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With You, Chief Shepherd dear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A crown of glory we’ll receive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The hour when You appear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
