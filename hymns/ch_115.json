{
  "url": "https://www.hymnal.net/cn/hymn/ch/115",
  "title": "看哪耶稣天上坐着",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "看 哪，"
            },
            {
              "chord": "",
              "text": "耶 穌 天 上"
            },
            {
              "chord": "D",
              "text": "坐 著！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 主"
            },
            {
              "chord": "D7",
              "text": "基 督"
            },
            {
              "chord": "",
              "text": "登 寶"
            },
            {
              "chord": "G",
              "text": "座！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 是 那 人"
            },
            {
              "chord": "G7",
              "text": "神 所"
            },
            {
              "chord": "C",
              "text": "高 舉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "榮 耀、"
            },
            {
              "chord": "G",
              "text": "尊 貴"
            },
            {
              "chord": "D7",
              "text": "已 得"
            },
            {
              "chord": "G",
              "text": "著。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂曾穿上人的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照神计画且死过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带著身体从死复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍然是人升天坐。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面神降为卑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神来地上同人处；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面人升为高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人到天上同神住。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是真神与人调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在人里被宣告；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是真人与神联合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人在神里得荣耀。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从那升天得荣耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "降下包罗万有灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣身位和祂工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全由这灵来证明。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "和那升天得荣耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今天召会能联合；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这位耶稣的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督肢体能同活。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，一人天上坐着！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有之主在宝座！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是救主耶稣基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀、尊贵永得着！"
            }
          ]
        }
      ]
    }
  ],
