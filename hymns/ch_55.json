{
  "url": "https://www.hymnal.net/cn/hymn/ch/55",
  "title": "哦主，你是神的活话",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 是 神"
            },
            {
              "chord": "G",
              "text": "的 活"
            },
            {
              "chord": "C",
              "text": "話，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又 是 神"
            },
            {
              "chord": "D7",
              "text": "的 兒"
            },
            {
              "chord": "G",
              "text": "子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "是 神"
            },
            {
              "chord": "G",
              "text": "的 真"
            },
            {
              "chord": "C",
              "text": "實 形"
            },
            {
              "chord": "F",
              "text": "像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有"
            },
            {
              "chord": "C",
              "text": "神 榮"
            },
            {
              "chord": "G",
              "text": "耀 樣"
            },
            {
              "chord": "C",
              "text": "式。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的本性一切丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都住你里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的具体化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你神得彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是神荣耀所发光辉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神原本是一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神本体所有真像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你神成实际。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你神是我们生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你神是亮光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我们有神性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你因神增长。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你神的恩典常存，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我得着神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你神的实际可寻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我看见神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你领受神的丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而且恩上加恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我们与神调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神一切有分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我神，我敬拜你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的一切在你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心珍爱你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远欣赏不已！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "赞美主",
