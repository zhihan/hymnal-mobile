    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God in Christ, embodied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As God's lampstand, He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has become the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The reality."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit as the lampstand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has been multiplied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many local churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now are realized!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Caring for the churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Son of Man:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Voice of many waters,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stars in His right hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eyes aflame; His face is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining as the sun;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Churches—fear no trial,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He's the living One!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What can quench the lampstands?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can them defy?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More the opposition—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More they multiply!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deeper darkness 'round them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brighter do they shine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They are constituted"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the life divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon the local churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall the Bride become,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing in that city—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the many lampstands"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall one lampstand be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Triune God expressing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Universally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, from heav'n descending,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the earth shall see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's complete expression,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For eternity."
            }
          ]
        }
      ],
      "type": "chorus"
    }
