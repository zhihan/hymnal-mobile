{
  "url": "https://www.hymnal.net/cn/hymn/ts/341",
  "title": "愿一生爱你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前沉溺罪恶地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良心终日无安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深感痛苦、无能力我知罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我自责，因罪污不义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "悲惨人生无所期，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚空世界无意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "追求快乐和刺激如捕风，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如捉影，既虚空又无益。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神！我曾远离你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你至高、至大、独一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！你竟然成为肉体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲来寻觅，血将我洗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "钉死作我代替。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿一生爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿与你更亲密，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿将生命和一切全献给你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿一生爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿与你更亲密，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿将生命和一切全献给你。"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
