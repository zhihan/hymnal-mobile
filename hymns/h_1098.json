      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, Thou art fairer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than all the sons of men;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy goodness is transcendent—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Amen!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon Thy lips most holy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abundant grace is poured;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever God has blessed Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our gracious, glorious Lord!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the mighty Warrior"
