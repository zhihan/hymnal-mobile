              "text": "Ride on triumphantly!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The peoples fall beneath Thee—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The conquering One Thou art."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine arrows in their sharpness"
            }
          ]
        },
        {
          "segments": [
            {
