  "title": "阿爸我们来颂赞你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "阿 爸，"
            },
            {
              "chord": "",
              "text": "我 们"
            },
            {
              "chord": "A",
              "text": "来 颂"
            },
            {
              "chord": "",
              "text": "赞"
            },
            {
              "chord": "D",
              "text": "你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "Em",
              "text": "谦 卑"
            },
            {
              "chord": "A7",
              "text": "敬 拜"
            },
            {
              "chord": "D",
              "text": "你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 现 今"
            },
            {
              "chord": "A",
              "text": "得 认"
            },
            {
              "chord": "",
              "text": "识"
            },
            {
              "chord": "D",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "真 是"
            },
            {
              "chord": "",
              "text": "我 们"
            },
            {
              "chord": "A7",
              "text": "的 福"
            },
            {
              "chord": "D",
              "text": "气。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 得 著"
            },
            {
              "chord": "G",
              "text": "这 样"
            },
            {
              "chord": "D",
              "text": "权 柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 因"
            },
            {
              "chord": "Bm",
              "text": "耶 稣"
            },
            {
              "chord": "E7",
              "text": "的 尊"
            },
            {
              "chord": "A",
              "text": "名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 灵"
            },
            {
              "chord": "",
              "text": "也 和"
            },
            {
              "chord": "A",
              "text": "我 们"
            },
            {
              "chord": "D",
              "text": "的 灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "证 明"
            },
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "D",
              "text": "有"
            },
            {
              "chord": "A7",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世界还未起首时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就在基督里头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫定我们作你儿子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得你生命的恩赐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦父，你是何等慈爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟使我们蒙恩待！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我们这凡俗罪人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得与你性情有分！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们天性在亚当里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真是败坏无可比；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是你的永远旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫定我们归于你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠着救主我们得赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因重生称你为父；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主、天父、教会合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，这恩典何希奇！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，境遇虽然转迁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽有患难和试炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的慈爱总是不变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要领我们直到天。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久，你所赎的儿女，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要在宝座前相聚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "述说他们得救故事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并向你赞美不置。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
