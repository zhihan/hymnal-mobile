{
  "url": "https://www.hymnal.net/cn/hymn/ch/124",
  "title": "主你乃是王中王",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 你"
            },
            {
              "chord": "D",
              "text": "乃 是"
            },
            {
              "chord": "G",
              "text": "王 中"
            },
            {
              "chord": "",
              "text": "王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们"
            },
            {
              "chord": "D",
              "text": "何 人"
            },
            {
              "chord": "A",
              "text": "不 归"
            },
            {
              "chord": "D",
              "text": "向？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "D",
              "text": "受 膏"
            },
            {
              "chord": "G",
              "text": "我 敬"
            },
            {
              "chord": "",
              "text": "拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "衷 心"
            },
            {
              "chord": "D",
              "text": "敬 畏"
            },
            {
              "chord": "A7",
              "text": "又 爱"
            },
            {
              "chord": "D",
              "text": "戴！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "对 你"
            },
            {
              "chord": "G",
              "text": "这 位"
            },
            {
              "chord": "D",
              "text": "王 中"
            },
            {
              "chord": "G",
              "text": "王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千 万"
            },
            {
              "chord": "C",
              "text": "圣 徒"
            },
            {
              "chord": "D",
              "text": "在 颂"
            },
            {
              "chord": "G",
              "text": "扬！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "全地这国到那国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无不由你来掌握！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万民都要来归依，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊你为王，事奉你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你这位王中王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万民有谁不颂扬！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的国度到永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的宝座永稳坚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你荣耀和国权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们永远要颂赞！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你这位王中王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千万圣徒要颂扬！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱救主、至高王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的尊名我爱唱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的统治何可亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你国度早降临！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但对你这王中王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此我们就颂扬！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
