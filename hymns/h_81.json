      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Although a man with men become,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou with God eternal art!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The same completeness Thou dost share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And infinite as God Thou art!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine origin, the same as God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before creation was decreed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the foremost, Thou art first,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None other doth Thyself precede!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou never changest thru all time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy years are to eternity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None is as lasting as Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor is there any after Thee!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just as the Father, diff’ring not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The same perfection Thou too hast!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Alpha and the First,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art Omega and the Last!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We praise Thee for Thine endless years,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Extol Thee for Thy perfectness!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Admiring all Thy fulness vast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We marvel at Thy boundlessness!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
