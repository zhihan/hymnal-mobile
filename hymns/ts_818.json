  "title": "人生意义",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "人 生"
            },
            {
              "chord": "F",
              "text": "意 义"
            },
            {
              "chord": "C",
              "text": "是 何"
            },
            {
              "chord": "G",
              "text": "在？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "答 案"
            },
            {
              "chord": "F",
              "text": "今"
            },
            {
              "chord": "E",
              "text": "已"
            },
            {
              "chord": "Am",
              "text": "找"
            },
            {
              "chord": "G",
              "text": "出"
            },
            {
              "chord": "C",
              "text": "来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喊 主 耶 稣 尝 尝 看！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "祂 是"
            },
            {
              "chord": "",
              "text": "实 际 真 无"
            },
            {
              "chord": "G7",
              "text": "限！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "祂 赐"
            },
            {
              "chord": "",
              "text": "丰 盛 的 生 命─"
            },
            {
              "chord": "F",
              "text": "活"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "水 江 河 流 不 停，"
            },
            {
              "chord": "C",
              "text": "新"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "的 生 命 今 开"
            },
            {
              "chord": "F",
              "text": "始，"
            },
            {
              "chord": "D7",
              "text": "喜"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乐 涌 出 永 无"
            },
            {
              "chord": "G",
              "text": "止；"
            },
            {
              "chord": "E",
              "text": "爱"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 里 面 时 增"
            },
            {
              "chord": "C",
              "text": "加。 这"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全"
            },
            {
              "chord": "F",
              "text": "都 是"
            },
            {
              "chord": "G",
              "text": "因 著"
            },
            {
              "chord": "C",
              "text": "祂！ 阿"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "利"
            },
            {
              "chord": "G7",
              "text": "路 亚！"
            },
            {
              "chord": "C",
              "text": "喊"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 耶 稣 尝 尝 看！"
            },
            {
              "chord": "Dm",
              "text": "祂 是"
            }
          ]
        }
