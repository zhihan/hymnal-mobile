    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Prophet raised from men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To speak with pow’r and light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, like Elisha, filled with love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy miracles in might."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, like Isaiah, full of grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s Christ dost e’er reveal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may share this Christ of all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As life both rich and real."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Priest from us to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The holy Priest for us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Aaron called of God from men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us Thou servest thus."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In love Thou bearest us to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The great High Priest to serve;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With love Thou intercedest there"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And dost with strength preserve."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Priest from God to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The royal Priest of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Salem’s King, Melchisedec,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The minister of God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With bread and wine Thou cam’st from God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us in time of need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou cam’st with God that we in Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Might fully share indeed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the King as David was,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s desire dost seek;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The battle fought, the foe subdued,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s heart Thou dost bespeak."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art empowered on the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not with a human rod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with authority divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To reign for us and God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the King like Solomon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose rule with peace was filled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With wisdom Thou dost reign in pow r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou God’s house dost build."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As King unseen Thou reignest now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Among Thy saints with love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One day, when Thou shalt reign with us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt Thy kingship prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As King and Priest and Prophet too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How precious, Lord, art Thou;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy worth to God, Thy worth to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all with love avow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O how we treasure what Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts are drawn by Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee we’ll give our thanks and praise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
