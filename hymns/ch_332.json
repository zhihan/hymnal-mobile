{
  "url": "https://www.hymnal.net/cn/hymn/ch/332",
  "title": "哦那不肯放我之爱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦， 那"
            },
            {
              "chord": "",
              "text": "不 肯 放"
            },
            {
              "chord": "Em",
              "text": "我 之"
            },
            {
              "chord": "D",
              "text": "愛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 將 疲 魂 安 息 於"
            },
            {
              "chord": "D7",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "B",
              "text": "把 所"
            },
            {
              "chord": "B7",
              "text": "欠 餘"
            },
            {
              "chord": "",
              "text": "生 歸"
            },
            {
              "chord": "G",
              "text": "來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好"
            },
            {
              "chord": "A7",
              "text": "使 它"
            },
            {
              "chord": "",
              "text": "在 你 這 深"
            },
            {
              "chord": "G",
              "text": "海，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得 更 豐"
            },
            {
              "chord": "D7",
              "text": "滿 洋"
            },
            {
              "chord": "G",
              "text": "溢。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，那照耀我路之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我将残灯带来交你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心因得你光复亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它的日子借你太阳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得更光明美丽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，那苦中寻我之乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心不能向你关闭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在雨中彩虹寻得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知你应许不会空说，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天亮便无泪涕。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，那使我抬头十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不敢求与你稍离；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今生虚荣死葬土下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那土长出生命红花，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远开放不已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
