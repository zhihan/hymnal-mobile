{
  "url": "https://www.hymnal.net/cn/hymn/h/733",
  "title": "In Eden's garden fair we see",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "In Eden's"
            },
            {
              "chord": "",
              "text": "garden"
            },
            {
              "chord": "G",
              "text": "fair we"
            },
            {
              "chord": "D",
              "text": "see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God be"
            },
            {
              "chord": "A",
              "text": "fore two"
            },
            {
              "chord": "A7",
              "text": "trees placed"
            },
            {
              "chord": "D",
              "text": "man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The trees of life, and"
            },
            {
              "chord": "A",
              "text": "knowledge"
            },
            {
              "chord": "D",
              "text": "too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Which for"
            },
            {
              "chord": "",
              "text": "the"
            },
            {
              "chord": "D",
              "text": "Lord and"
            },
            {
              "chord": "A",
              "text": "Sa"
            },
            {
              "chord": "A7",
              "text": "tan"
            },
            {
              "chord": "D",
              "text": "stand."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The tree of life the center is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God's eternal, perfect plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Denoting God in Christ as life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be received as all by man."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The tree of knowledge standing there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bespeaks a sure and warning voice:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Outside of God there is a source"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of death to all who make this choice."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If man would eat the tree of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then God as life he will receive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be transformed to precious stones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's will and Purpose to achieve."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If man the tree of knowledge takes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then Satan enters into man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As sin, which brings him into death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That he may not fulfill God's plan."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This signifies that only God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is our full source of life and breath;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To touch ought else is but to touch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The source of knowledge and of death."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For knowledge only bringeth death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though evil or though good it seem;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For any thing apart from God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is but the fruit of Satan's scheme."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not only evil, but the good"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is contradictory to Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not only knowledge of the bad,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But even good is versus Christ."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, teach us only Thee to touch,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That with Thy life we filled may be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And not to touch the good or bad,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or anything apart from Thee."
            }
          ]
        }
      ]
    }
  ],
