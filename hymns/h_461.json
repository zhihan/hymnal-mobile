        {
          "segments": [
            {
              "chord": "",
              "text": "With His hand to lead me I will never, never fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dangers cannot fright me if my Lord is near."
            }
