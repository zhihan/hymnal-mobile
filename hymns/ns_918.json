    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the splendor of our consecration"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy willing host, Lord, Behold!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Under Thy perfecting hands committed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foll’wing the vision we hold!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the age today be consummated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom brought, and Christ extolled!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy life we’d grow, e’ermore advancing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Under Thy dispensing daily be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thorough dealings work Thou in our being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deepening our roots and love for Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us hunger so on Thy word to feed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That high peak truth be stored in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lab’ring on the riches of Thy speaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’d share the good deposit thus."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Vessels with humanity uplifted;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tempered, balanced, to Thy mold conformed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live reality which is in Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To express the Christ within us formed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the self deny, in the Body serve,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Invest our talents faithfully."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the morn revived, o’ercoming daily;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Outflow of life our work shall be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
