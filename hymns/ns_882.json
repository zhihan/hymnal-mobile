    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are not apart from Me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This broken world tries to deceive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just believe into your Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your seeking heart will be restored in Me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here I am still asking why"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As moments come and years go by."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will I ever come to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What You desire or will I flee from You?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn your eyes on Me this day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And take more time to call and pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are joined in spirit now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is an everlasting vow from Me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, when I am looking back,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that I see are things I lack."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help me cast these doubts aside"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While knowing that Your life resides in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t look back! The past is dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re with Me now, just look ahead."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep Me in your faithful gaze"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grow in life through all your days with Me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
