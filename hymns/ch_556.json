      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵就是至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主在里面今住着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要回到灵里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就与主得相见。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活基督的馨香，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "调在灵里来发放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里面我祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就借此得发表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着灵里的基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必饱尝祂丰富："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命亮光、生命粮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加上复活的馨香。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "越摸越深越丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着深处的基督："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着生命的律法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着隐藏的吗哪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着复活蒙悦纳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同枯杖发了芽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此才有施恩座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩惠流出如江河。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们聚集同祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵得释放并相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是进入至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此能将主摸着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在这至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同过祭司的生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多方摸主施恩座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到活水全流过。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
