{
  "url": "https://www.hymnal.net/cn/hymn/ch/152",
  "title": "主你于我何其丰富",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主，"
            },
            {
              "chord": "D",
              "text": "你 於"
            },
            {
              "chord": "G",
              "text": "我 何"
            },
            {
              "chord": "D7",
              "text": "其 豐"
            },
            {
              "chord": "G",
              "text": "富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 愛 說"
            },
            {
              "chord": "A7",
              "text": "出 其"
            },
            {
              "chord": "D",
              "text": "度 量！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D7",
              "text": "的 自"
            },
            {
              "chord": "Em",
              "text": "己 無"
            },
            {
              "chord": "B",
              "text": "限 富"
            },
            {
              "chord": "Em",
              "text": "有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今"
            },
            {
              "chord": "G",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "靈 給"
            },
            {
              "chord": "D7",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "享。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃是话，也就是神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "太初就与神同在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为肉身，与人同处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神向人说出来。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃是神真的帐幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我见神荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是神真的圣殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面神住着。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃是神独生爱子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远将父来表明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能有神的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且有分神性情。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是人子，与我一样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "确有我们的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能作神的儿子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到满有你荣形。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是基督，有的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神所膏弥赛亚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是万有，又在万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人所赖，无限大！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是救主，钉死十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你流出血和水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得蒙神的救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有神生命，成宝贵！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你今是那得荣耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你降下生命灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是包罗万有的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来使我享你丰盛。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神圣生命之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗之中来照亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我心中，带神照亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到充满我心房。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神圣永远生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "点活我们死的灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我们脱离死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受生命的丰盛。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你乃是神的实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟你能使神喜悦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这实际使我知道"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是如何用不竭。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是惟一道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我进入神自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之道，实际之路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我带进荣耀里。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你又是奇妙复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有死亡全胜过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我借你复活大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同死并同活。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的无瑕羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎为我来作成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是那赐圣灵者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着使我得生命。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是杆上所挂铜蛇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救我脱离致死罪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在十架被人举起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "掌死魔鬼为我毁。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是牧人，又是羊门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离律法圈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你我今已得自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "青草地上尝甘甜。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的洗涤使我洁净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "功能如同洗濯盆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我保守在你交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享你恩爱无穷尽。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是磐石为我裂开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出生命的活水；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饮于你这常新水流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得脱一切的困惫。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是属天永生泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水藏在你里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喝了你这永生活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再干渴到永远。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是天降生命的粮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣、丰富又盛旺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着你的无限丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时将我灵来餧养。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们生命之气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我灵中来呼吸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你生活，凭你行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得享受你自己。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是一粒神圣麦子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘愿落到死地里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结出我们许多子粒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你奥秘的身体。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是属天真葡萄树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你的枝子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在你里，与你联结，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受一切你所是。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是宇宙真的新郎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你的新妇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里与你成为一体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得享你爱的丰富。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是雅各所见天梯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你天向地而开；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你我们作神圣殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地联于天无阻碍。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你是那‘我是’的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应付我们所需要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你作一切一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神就因你得荣耀。"
            }
          ]
        }
      ]
    }
  ],
