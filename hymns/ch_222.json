  "raw_sections": [
    "有 福的 事实，",
    "主 话已 启 示，",
    "我 在圣 灵 里 面 已 受浸；",
    "接 受这 事实，",
    "毋 须再 延 迟，",
    "我 在圣 灵 里 面已受浸。",
    "接 受！接 受！",
    "凭 信接 受 勿 再 延迟；",
    "接受！接 受！",
    "凭 信接 受 这 已成事实。",
    "新约的话语，",
    "清楚已言明，",
    "我在圣灵里面已受浸；",
    "只需我持守，",
    "不需我何行，",
    "我在圣灵里面已受浸。",
    "持守！持守！",
    "凭信持守不稍松弛；",
    "持守！持守！",
    "凭信持守这已成事实。",
    "基督向召会，",
    "已浇下圣灵，",
    "我在圣灵里面已受浸；",
    "分享这福分，",
    "分享得丰盛，",
    "我在圣灵里面已受浸。",
    "分享！分享！",
    "凭信分享已得恩赐；",
    "分享！分享！",
    "凭信分享这已成事实。",
    "在身体里面，",
    "与身体和谐，",
    "凭这已成事实而行动；",
    "罪恶都认清，",
    "疑惑全拒绝，",
    "因信凭这事实就行动。",
    "行动！行动！",
    "因信行动在身体中；",
    "行动！行动！",
    "因信凭这事实而行动。"
  ]
