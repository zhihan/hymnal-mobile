            {
              "chord": "",
              "text": "无须忧虑，无须怀疑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟寻求祂的国和祂的义，"
            }
          ]
        },
        {
          "segments": [
            {
