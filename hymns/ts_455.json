            {
              "chord": "D",
              "text": "為 這"
            },
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "A",
              "text": "天，"
            },
            {
              "chord": "Bm",
              "text": "我 獻"
            },
            {
              "chord": "",
              "text": "感"
            },
            {
              "chord": "F♯m",
              "text": "謝，"
            }
          ]
        },
        {
          "segments": [
