              "text": "Having the preeminence in life, work and home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church life is a life-flow from which we never roam."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
