            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Pay the price, extra portion buy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wedding dress prepare;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A full-grown bride Christ’s longing satisfies."
            }
          ]
        },
        {
          "segments": [
