              "chord": "",
              "text": "Hallelu, Hallelujah!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what joy! What deep delight!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Bridegroom meets His bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both God and man are satisfied!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelu, Hallelujah!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Will you an overcomer be?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will you heed this cry?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Come, freely drink!” say the Spirit and the bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelu, Hallelujah!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll be the overcomers God desires!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will heed this cry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink! Overflow! Living waters, men supply!"
            }
          ]
        },
        {
