    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "靠着你恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你分别我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从此专一事奉你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我灵望你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有坚定把握，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我志消失你旨里。"
            }
          ]
