{
  "url": "https://www.hymnal.net/cn/hymn/ch/585",
  "title": "求主静中发言",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "求 主"
            },
            {
              "chord": "A",
              "text": "静 中"
            },
            {
              "chord": "D",
              "text": "发 言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当 我"
            },
            {
              "chord": "E7",
              "text": "在 等"
            },
            {
              "chord": "A",
              "text": "候；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 心"
            },
            {
              "chord": "",
              "text": "在 此"
            },
            {
              "chord": "G",
              "text": "静 听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "望 允"
            },
            {
              "chord": "A7",
              "text": "我 所"
            },
            {
              "chord": "D",
              "text": "求。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，求来发言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这安静时；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我见你荣面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感到你所指。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你所说的话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是灵、是生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上来的活粮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我灵供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切全都归你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再属自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘心乐意降服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我只属于你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请说，仆人敬听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，勿静默；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵向你仰望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活话愿得着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "用你丰富话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我心充满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你一切心愿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我得成全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "像一灌溉花园，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满了香气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给你进来欣赏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你心意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
