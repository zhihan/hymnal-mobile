    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I’ve truly seen You, but"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The vision fades;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I look away to other things."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remind me, Lord, reveal Yourself to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That from my idols I would be set free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little more, each day, I want to see."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, my mind"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is occupied with many things—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This thorny age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all of its anxieties."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My faith is weak; I’m caught up in my cares."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need to learn to tell it all to You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little more, each day, my mind renew."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, my will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is resistant to Your touch."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Disarm me, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t let me win against Your grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I turn my eyes and see Your patient love—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What can I do but stop and come to You?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little more, each day, my will subdue."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me desperate for You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep drawing me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And training me to hear Your voice."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, even though my progress is so slow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re by my side; You will not let me go."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little more, each day, I’d love You so."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little more, each day, and I will grow."
            }
          ]
        }
      ]
    }
