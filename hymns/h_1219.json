    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What I never could do God is doing in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to His Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the change is so real all the brothers can see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to God’s Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have ceased from my wandering and going astray"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to God’s Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my old inclinations are passing away"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the secret of faith in the Lord I can see—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s saying Amen to His Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is more real and precious than all things to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now my love for the brothers abounds more and more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to God’s Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I’m being related as never before"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now my hope in the Lord’s soon return groweth bright"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to His Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am ready to see Him, my Lord, my delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By saying Amen to His Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, Amen to Your Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, Amen to Your Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are coming again—all my heart says Amen!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, Amen to Your Word!"
            }
          ]
        }
