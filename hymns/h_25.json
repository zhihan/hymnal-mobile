    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“In mercy I delight, not sacrifice,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast declared;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru this Thy mercy, favor in Thine eyes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all have shared."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not of them that will nor them that run,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But of Thee showing mercy as was done."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, Thy mercy with Thy love and grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did we obtain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy mercy, with Thee face to face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll e’er remain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for Thy mercy we would worship Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all our days and through eternity."
            }
          ]
        }
