    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱主！宝贝主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我怎能再顽固？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我将刚硬投你脚旁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "领首诗歌回家去唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢喜作你奴仆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢喜向你屈服。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱主！宝贝主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我拣选你道路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一面顺服，一面流泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我不肯改变地位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要讨你喜悦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羡慕爱的暴虐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱主！宝贝主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自从你去天府，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我脸好像不能再笑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我天好像不能再晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我只想你回来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我只想你同在。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱主！宝贝主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我来向你诉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我所朝夕思慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有你能使我满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得你甚么都有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你外无所要求。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
