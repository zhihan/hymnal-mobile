    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him, keep deep'ning our roots; life blossoms, sends forth shoots;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each morn, we rise, gain manna new, His word afresh pursue."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We offer ceaseless prayer, as simple lilies fair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New wine and olive oil we bear, Christ's glory to declare."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "New dawn draws near, revival's here;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I consecrate afresh today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your life renewed, o'ercoming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we see Your dear face."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord will surely restore the locust-eaten years;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By resurrection's mighty pow'r, all failure disappears."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Appearing constantly, our Songs of Steps* He leads;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No care for earthly fame have we; we share God's history."
            }
          ]
        }
      ]
    },
