    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Revival's law operates in cycles, night and day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rise, preach always, in every place, till earth resounds with praise."
            }
          ]
