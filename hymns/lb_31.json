        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, of them that seek Your face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A remnant for You"
            }
          ]
        },
        {
          "segments": [
