      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "King of glory come in!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, open wide to Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O, lift up Your gate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s not too late."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the King come in."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A generation..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a goal to bring You back."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their treasure is You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re their future too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They care for only You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This goal is deep within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A fire that’s burning in them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They’re consumed by this zeal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This only is real,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, to bring You back."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A generation..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, by You they are possessed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have captured their heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world has no part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their joy is only You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They’re virgins pure and wise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just You are in their eyes."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their hearts make full room"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For You, dear Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your coming soon."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, generation..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit and Bride say come —"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit’s calling you."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Bride is calling too!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take heed to this mingled cry!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, oh seekers, come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our Groom, most pleasant Person."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s eternal plan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to mingle with man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This His satisfaction."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh come, Lord Jesus..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this cause, Lord, strengthen us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep us faithful to stand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the way to the end."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Uphold us in Your hands."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, Lord Jesus, come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your Bride, New Jerusalem."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we meet face to face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill us daily with grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For that day make haste."
            }
          ]
        }
      ],
      "type": "chorus"
    }
