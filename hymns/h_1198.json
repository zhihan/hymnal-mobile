    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the beginning we can see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as a flowing river,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The river to convey the tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself as life deliver."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And at the end the same,"
            }
          ]
