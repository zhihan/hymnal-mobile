              "chord": "",
              "text": "But out came blood and water!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The blood and water flowed from Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In streams of pure salvation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blood brings cleansing from all sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Water, regeneration."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now the Spirit flows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brings God where’er He goes."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All he could do, the foe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was just release the flow."
            }
          ]
        },
        {
