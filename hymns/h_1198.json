          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The man we call Christ Jesus."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gave up His own life for man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s own life releases."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though Satan did his best"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To put God’s flow to rest—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He had Him crucified"
            }
          ]
        },
        {
          "segments": [
