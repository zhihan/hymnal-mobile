  "raw_sections": [
    "为 主打美 好胜 仗，",
    "凭 主而 活 著，",
    "站 住立 场！",
    "不 怕仇 敌的 攻击，",
    "靠 主践 踏 在 它 的头上！",
    "为 强 的 召会 生活 祷告，",
    "圣 徒 个 个在 灵里焚烧，",
    "在 新 人里 面争 战，",
    "达 到神的 目标！",
    "（荣 耀，阿 利路 亚！）为 主"
  ]
