  "raw_sections": [
    "為 主打美 好勝 仗，",
    "憑 主而 活 著，",
    "站 住立 場！",
    "不 怕仇 敵的 攻擊，",
    "靠 主踐 踏 在 它 的頭上！",
    "為 強 的 召會 生活 禱告，",
    "聖 徒 個 個在 靈裡焚燒，",
    "在 新 人裡 面爭 戰，",
    "達 到神的 目標！",
    "（榮 耀，阿 利路 亞！）為 主"
  ]
