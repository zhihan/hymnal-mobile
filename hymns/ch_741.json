  "raw_sections": [
    "基 督死 葬我 随同，",
    "走 进 死 水中，",
    "与 祂同 归终；",
    "世 界、撒 但 势 虽凶，",
    "到 此便 消踪，",
    "不 能再 追攻。",
    "基 督复 活我 与共，",
    "走 出死 水中，",
    "与 祂 同 行动；",
    "生 命圣 灵力 无穷，",
    "使 我 蒙 恩宠，",
    "荣 上又 加荣。"
  ]
