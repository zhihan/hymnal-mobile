  "title": "结束流浪的生活",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "聽 這"
            },
            {
              "chord": "",
              "text": "流 浪 者 的 歌 聲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把 他 經 歷 道"
            },
            {
              "chord": "G",
              "text": "出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 他 已"
            },
            {
              "chord": "G7",
              "text": "過 的"
            },
            {
              "chord": "C",
              "text": "年 日"
            },
            {
              "chord": "",
              "text": "裡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他"
            },
            {
              "chord": "F",
              "text": "總 常"
            },
            {
              "chord": "G7",
              "text": "感 不"
            },
            {
              "chord": "C",
              "text": "足。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "讚 美"
            },
            {
              "chord": "G7",
              "text": "主！ 讚"
            },
            {
              "chord": "",
              "text": "美"
            },
            {
              "chord": "C",
              "text": "主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讚 美"
            },
            {
              "chord": "G7",
              "text": "主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿 利"
            },
            {
              "chord": "C",
              "text": "路 亞，"
            },
            {
              "chord": "",
              "text": "阿 利 路 亞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讚 美"
            },
            {
              "chord": "G7",
              "text": "主！ 讚"
            },
            {
              "chord": "",
              "text": "美"
            },
            {
              "chord": "C",
              "text": "主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "F",
              "text": "永 不"
            },
            {
              "chord": "G",
              "text": "再"
            },
            {
              "chord": "G7",
              "text": "那"
            },
            {
              "chord": "C",
              "text": "樣！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "流浪奔波在世界里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寻求快乐满足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我的肉体心灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍然虚空痛苦。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "昼夜劳苦为着自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我房建在沙地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但赞美主！祂来拆毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我更好豫备。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如今找到地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作一喜乐肢体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结束流浪者的生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安居在神家里。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主！赞美主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主！赞美主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我永活在召会！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（四至七节）"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前的我乖僻孤独，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活在自己里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但如今我与众圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主里同被建。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我被吸引到召会中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受甜蜜交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并学习在任何场合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从别人接受主。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "流荡止息，安家召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活在祂心意里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是我的喜乐秘诀："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受神的安息。"
            }
          ]
        }
      ]
    }
  ],
