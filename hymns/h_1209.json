        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To rise from earth to heav’n,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A deeper turn we need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be where Christ is now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the throne indeed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re gathered at the throne of grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beholding Jesus face to face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re being turned as one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not individually;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not private Christians now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Body Christians we."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As members here in one accord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the Body of the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Body Christians now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have a higher word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foundation’s word we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis altar, cross, and blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfection’s word is little known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis fellowship around the throne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is objective too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But subjective are we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our experience;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit is the key."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, throne, and holiest—we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit now contains all three."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Leviticus is past,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Aaron’s work is o’er;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Melchisedec is here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "High Priest forevermore;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His ministry is now so fine:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes to feed us bread and wine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
