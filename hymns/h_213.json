    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The depth of all Thy suffering"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No heart could e’er conceive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cup of wrath o’erflowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us Thou didst receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, oh, of God forsaken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the accursed tree;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With grateful hearts, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We now remember Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We think of all the darkness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which round Thy spirit pressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all those waves and billows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which rolled across Thy breast."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, there Thy grace unbounded"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And perfect love we see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With joy and sorrow mingling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We would remember Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We know Thee now as risen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Firstborn from the dead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We see Thee now ascended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church’s glorious Head."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee by grace accepted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The heart and mind set free"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To think of all Thy sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus remember Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou shalt come in glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And call us hence away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To rest in all the brightness"
            }
          ]
        },
        {
          "segments": [
