            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "We adore"
            },
            {
              "chord": "",
              "text": "Thee!"
            },
            {
              "chord": "D",
              "text": "we adore"
            },
            {
              "chord": "",
              "text": "Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "With such"
            },
            {
