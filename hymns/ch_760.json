    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱主，自从当年你上升之后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这里都变何等枯燥无味；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们时在祈求，又时在看守，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每一动静，都疑是你已回。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你来！就来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们呼求你快来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的心所有盼望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们等候你快来！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "景色虽美，你我何日才相聚？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "山水虽佳，你今在天何方？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "花香鸟语不能使我有情绪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我正在思念你的容光。"
            }
          ]
        }
      ],
