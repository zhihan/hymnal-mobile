    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not for the lip of praise alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor e’en the praising heart,"
            }
