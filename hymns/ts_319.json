  "raw_sections": [
    "你， 你，你 常 在 我 心 中，",
    "梦， 梦，梦 里萦绕；",
    "你， 你， 你 爱 情 何 其 甜，",
    "你 是比一 切都好。",
    "耶稣！耶稣！",
    "你 是比一 切都好。",
    "耶稣！耶稣！",
    "你 是比一 切都好。",
    "爱，爱，爱是丰盛无边，",
    "甜，甜，甜过蜂蜜；",
    "流，流，流遍我的心田，",
    "饱尝你爱情新鲜。",
    "耶稣！耶稣！",
    "饱尝你爱情新鲜。",
    "耶稣！耶稣！",
    "饱尝你爱情新鲜。"
  ]
