              "chord": "G",
              "text": "heavens"
            },
            {
              "chord": "D",
              "text": "far a"
            },
            {
              "chord": "G",
              "text": "bove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crowned with glory and with honor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "By the"
            },
            {
              "chord": "",
              "text": "Father God in"
            },
            {
              "chord": "D",
              "text": "love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He hath made Him"
            },
            {
              "chord": "G",
              "text": "Head of"
            },
            {
              "chord": "",
              "text": "all things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "His suprema"
            },
            {
              "chord": "D7",
              "text": "cy to"
            },
            {
              "chord": "G",
              "text": "prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From this Christ to God ascended"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hath the Spirit been outpoured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Poured upon the Church, His Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His members be empow’red;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the Lord of all in heaven"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru His Church will be adored."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the flesh by incarnation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into man He God hath brought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His death and resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into God He man hath brought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God and man together mingled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Himself is fully wrought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in heaven by ascension"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is seated on the throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the lordship, all the headship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He Himself doth fully own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by pouring out His Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He as such might be made known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By this outpour, His descension"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the Church was realized;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this, that in His Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Church He hath baptized;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the baptism of the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was forever actualized."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, ’tis accomplished,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And accomplished once for all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, we’re included,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All included, great or small!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise Him, He hath sent the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And baptized the Church withal!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
