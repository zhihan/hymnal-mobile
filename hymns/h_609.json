{
  "url": "https://www.hymnal.net/en/hymn/h/609",
  "title": "I praise Thee for Thy mystery",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "I praise"
            },
            {
              "chord": "",
              "text": "Thee for Thy"
            },
            {
              "chord": "D",
              "text": "myste"
            },
            {
              "chord": "G",
              "text": "ry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That"
            },
            {
              "chord": "A",
              "text": "I may"
            },
            {
              "chord": "",
              "text": "truly con"
            },
            {
              "chord": "A7",
              "text": "tact"
            },
            {
              "chord": "D",
              "text": "Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "In unap"
            },
            {
              "chord": "C",
              "text": "proachable"
            },
            {
              "chord": "",
              "text": "light Thou"
            },
            {
              "chord": "D",
              "text": "wast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But"
            },
            {
              "chord": "G",
              "text": "now as"
            },
            {
              "chord": "",
              "text": "Spirit"
            },
            {
              "chord": "D",
              "text": "nigh to"
            },
            {
              "chord": "G",
              "text": "me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father, Son, and Spirit, Thou,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The triune God, my life fore’er;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In me Thou art the full supply"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I Thy holy nature share."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The triune God the Spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And comes as breath and wind to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis thus I may experience"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Godhead’s wondrous mystery."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All that the Father is and has"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His beloved Son doth rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the riches of the Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are by the Spirit now possessed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit doth descend on me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to my spirit enters in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He, the Father in the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My blessed portion be within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father is the fountainhead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son expression gives to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit is His very flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As my reality within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father in the Son has come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God to man Himself may show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son as Spirit enters me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God I inwardly may know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father purposed that the Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should be the first in everything;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son the Father takes as Head"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And over all His headship brings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit perfectly desires"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Christ, the Son, be glorified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He reveals Him unto me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He be fully testified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy final form the Spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our worship to receive within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I Thy riches would enjoy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit I must contact Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If I in spirit worship Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit live, in spirit pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Holy Spirit I will touch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thee enjoy in every way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    }
  ],
