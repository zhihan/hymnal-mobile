    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, purify us, Lord, by speaking in our heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy living, spoken word this washing will impart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase Thy speaking, Lord, and cleanse our every part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, purify us, Lord, we pray."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, purify us, Lord, today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash all our natural life away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak now Thy words in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make us glorious."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do speak in us today."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do nourish us; You are the food we need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we are eating You, we’ll be transformed indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re fully satisfied as on Yourself we feed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So nourish us, O Lord, we pray."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do nourish us today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As all our self You wash away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not only purify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But fill and satisfy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do nourish us today."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do cherish us, as on Thyself we feed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Warm us so tenderly and meet our every need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hardness soften, Lord, till we are Yours indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, cherish us, dear Lord, we pray."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do cherish us today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until our coldness flees away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, hold us close to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And cherish tenderly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do cherish us today."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make us glorious, by all Your inner work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not glory for ourselves, but glory for the church;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You may have Your Bride, thus ending all Your search."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do work on us, we pray."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, do work on us today!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To form the church Your glorious way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, spread Yourself in us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we are glorious;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, make us glorious, Lord, today."
            }
          ]
        }
      ]
