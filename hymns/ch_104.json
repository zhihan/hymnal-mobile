{
  "url": "https://www.hymnal.net/cn/hymn/ch/104",
  "title": "哦主死的领土你曾",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "死"
            },
            {
              "chord": "A",
              "text": "的 领"
            },
            {
              "chord": "",
              "text": "土"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你 曾"
            },
            {
              "chord": "",
              "text": "去"
            },
            {
              "chord": "D",
              "text": "走；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非 因 罪"
            },
            {
              "chord": "A",
              "text": "将 你"
            },
            {
              "chord": "",
              "text": "毒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E7",
              "text": "死 有"
            },
            {
              "chord": "",
              "text": "要"
            },
            {
              "chord": "A",
              "text": "求。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "掌 死"
            },
            {
              "chord": "",
              "text": "权"
            },
            {
              "chord": "D",
              "text": "的 魔"
            },
            {
              "chord": "",
              "text": "鬼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你 已"
            },
            {
              "chord": "",
              "text": "完"
            },
            {
              "chord": "D",
              "text": "全 摧"
            },
            {
              "chord": "",
              "text": "毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "B7",
              "text": "他 不"
            },
            {
              "chord": "Em",
              "text": "再 作"
            },
            {
              "chord": "",
              "text": "祟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "将"
            },
            {
              "chord": "A7",
              "text": "人 监"
            },
            {
              "chord": "D",
              "text": "囚。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已冲破坟墓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从死复活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死难将你拘束，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反被胜过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已得胜走出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "幽冥、黑暗之墓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死荫全都破除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从死超脱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等大能得胜"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已得到！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结果何其丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神荣耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你死中生出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无数活的信徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给你安家居住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭你活着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是初熟果子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们爱戴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作神心爱长子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我领率。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事你居首位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我永远所归，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得荣耀、尊贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
