        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without, without;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Wind blows where it wills, it wills,"
            }
          ]
        },
        {
