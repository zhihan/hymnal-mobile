              "chord": "",
              "text": "Hallelujah, Amen."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, hail! Thy glory brightens"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All above and gives it worth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord of life, Thy smile enlightens,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cheers, and charms Thy saints on earth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we think of love like Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we own it love divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
