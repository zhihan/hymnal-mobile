    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sing how Jesus came from heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How He bore the cross below,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How all power to Him is given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How He reigns in glory now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis a great and endless theme—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, ’tis sweet to sing of Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Hallelujah,"
            }
          ]
        },
        {
          "segments": [
