          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Amen."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "King of glory, reign forever!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine an everlasting crown."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing from Thy love shall sever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those whom Thou hast made Thine own:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Happy objects of Thy grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Destined to behold Thy face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
