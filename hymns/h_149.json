      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, hasten Thine appearing:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring, oh, bring the glorious day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When, the awful summons hearing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heav’n and earth shall pass away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then with raptured hearts we’ll sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Glory, glory to our King!”"
            }
