    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What punishment so strange is suffered yonder?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The shepherd dies for sheep that loved to wander;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Master pays the debt His servants owe Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who would not know Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The sinless Son of God must die in sadness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sinful child of man may live in gladness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man forfeited his life and is acquitted—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is committed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O mighty King, no time can dim Thy glory!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How shall I spread abroad Thy wondrous story?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How shall I find some worthy gift to proffer?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What dare I offer?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll think upon Thy mercy without ceasing;"
