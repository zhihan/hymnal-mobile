    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sun of our life, Thy quickening ray"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sheds on our path the glow of day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Star of our hope, Thy softened light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cheers the long watches of the night."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our midnight is Thy smile withdrawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our noontide is Thy gracious dawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our rainbow arch Thy mercy’s sign;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All, save the clouds of sin, are Thine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord of all life, below, above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose light is truth, whose warmth is love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before Thy ever-blazing throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We ask no luster of our own."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant us Thy truth to make us free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And kindling hearts that burn for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till all Thy living altars claim"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One holy light, one heavenly flame."
            }
          ]
        }
      ],
