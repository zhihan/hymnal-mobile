    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, deep within, I’ve still so many things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hidden in the chambers of my inner being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I hear Thy call—Thy voice, Thy knock—a song."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, come in; hast Thou been kept too long?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Search my heart! There’s nothing I desire to keep."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All is Thine! Do then what Thou, Thy heart, doth please."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in return"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For what Thou take from me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill me Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw me, Beloved into Thy presence dear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would kiss Thy feet and wash them with my tears."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My love I pour, my life I waste on Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seize this precious opportunity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I gave all, and yet the gain was so much more:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own person in exchange for love outpoured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis ne’er a loss"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To lose myself to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Beloved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternally."
            }
          ]
        }
