              "text": "My cleverness"
            },
            {
              "chord": "",
              "text": "no"
            },
            {
              "chord": "F",
              "text": "match had"
            },
            {
              "chord": "G7",
              "text": "met"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In"
            },
            {
              "chord": "C",
              "text": "Esau,"
            },
            {
              "chord": "F",
              "text": "Isaac"
            },
            {
