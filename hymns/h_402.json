    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I want every moment to feel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit indwelling my heart,"
            }
          ]
        },
        {
