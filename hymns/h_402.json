          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy seal on my forehead to wear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And have that new name on the mystic white stone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which none but Thyself can declare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I want, and this sums up my prayer,"
