        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今仰望我主‘同在’，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不敢懈怠一点；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今等候我主再来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得着所天。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除了我主此刻就来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接我与祂同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除了这件美事以外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心别无所爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我眼专看我的救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心已经在天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我口不说别的题目，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只说与主相见。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主的再临已经紧近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主来原是为我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主的应许永远坚定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从来没有空说。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的救主，你的圣言"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无可惑，无可减；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今忠诚不顾脸面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你圣言自勉。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你荣耀早日显现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌败，阴府陷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你应许早日应验，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接我们到那边。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的膀臂是逃避所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣救主我神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你像天父一样保妥"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切靠你的人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羊和牧者同样轻重，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身和头同境遇！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁也不能从你手中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "夺去你的儿女。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "千人的手不能阻我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万人的眼也不；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "路上荆棘，不过助我"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠勇进前得福。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心！我灵！今当复兴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让这世界过去；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的主！求你快临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接我进入天域。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "医治的日！人的盼望！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我真爱你光线；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公义的主！荣耀的王！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今伏你面前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你自己快登宝座！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你脸面快显！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你伸手建立天国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向万民赐恩典！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "真理本当得胜为王！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自由本当为后！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是谎言竟然猖狂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为这世界元首！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以真理求你快来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着天光而来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使仇敌遇见失败，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众子投入你怀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
