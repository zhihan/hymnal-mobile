  "title": "我王必定快要再临",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 王"
            },
            {
              "chord": "",
              "text": "必"
            },
            {
              "chord": "C",
              "text": "定 快"
            },
            {
              "chord": "G",
              "text": "要 再"
            },
            {
              "chord": "",
              "text": "临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天"
            },
            {
              "chord": "A",
