            },
            {
              "chord": "A7",
              "text": "满 了"
            },
            {
              "chord": "D7",
              "text": "祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "待"
            },
            {
              "chord": "G",
              "text": "赎 宇"
            },
            {
              "chord": "C",
              "text": "宙 快"
            },
            {
              "chord": "G",
              "text": "得 复"
            },
            {
              "chord": "",
              "text": "兴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主"
            },
            {
              "chord": "C",
              "text": "要 完"
            },
            {
              "chord": "D7",
              "text": "成 救"
            },
            {
              "chord": "G",
              "text": "法！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "B7",
              "text": "已 听"
            },
            {
              "chord": "",
              "text": "见 祂"
            },
            {
              "chord": "Em",
              "text": "的 脚"
            },
            {
              "chord": "",
              "text": "声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "D",
              "text": "那 彩"
            },
            {
              "chord": "A7",
              "text": "云 中"
            },
            {
              "chord": "D7",
              "text": "间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "已 看"
            },
            {
              "chord": "C",
              "text": "见 祂"
            },
            {
              "chord": "G",
              "text": "的 荣"
            },
            {
              "chord": "",
              "text": "身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隐"
            },
            {
              "chord": "C",
              "text": "约 显"
            },
            {
              "chord": "D7",
              "text": "露 在"
            },
            {
              "chord": "G",
