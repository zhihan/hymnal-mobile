    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Verily God, yet become truly human,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lower than angels to die in our stead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How has that long promised “Seed of the woman”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trod on the serpent and bruised his head!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art worthy: Lord, Thou art worthy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art worthy, and worthy alone!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blest in Thy presence, we worship before Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Own Thou art worthy, and worthy alone!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How didst Thou humble Thyself to be taken."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Led by Thy creatures and nailed to the cross."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hated of men, and of God too forsaken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shunning not darkness, the curse, and the loss."
            }
          ]
        }
      ],
