              "text": "樣"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Gm",
              "text": "沒"
            },
            {
              "chord": "Dm",
              "text": "有"
            },
            {
              "chord": "A",
              "text": "力"
            },
            {
              "chord": "Dm",
              "text": "量。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我生活世人中间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就不觉自己亏欠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只觉自己如何奋勉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何上前。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我住在黑暗里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就不知自己肤浅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以为自己何等无限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不必虚谦。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我来到你的面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亮光刺破遮蔽幕帘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就看见前所未见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全露现。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你面前我只萎缩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切萎缩、一切消没，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有骄傲都变软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都变赤裸。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "没有可骄，没有可傲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有可倚，没有可靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有自惭，只有自懊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能否祷告？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "幸有你血免我定罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的生命免我销毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我真是何等污秽、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等惭愧。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有骄傲都是愚昧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看见实在何必谦卑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有自恃都是因为"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心中墨黑。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "静我也错，动我也错，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不说不安，说又太过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是失败、都是软弱、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是不妥。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我要祷告，没有信心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要倚靠，如何求寻？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知如何方能重新…"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，怜悯！"
            }
          ]
        }
      ]
    }
