    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By this Person being formed in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll a member of His Body be,"
            }
