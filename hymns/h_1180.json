              "text": "Only Christ, our Person, must remain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From our aims, our goals we must refrain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the church be only Christ Himself"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built up as the one new man,"
            }
          ]
