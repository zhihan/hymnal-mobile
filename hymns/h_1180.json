              "text": "But with the saints."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More and more our Person He must be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That our natural personality"
            }
          ]
        },
        {
