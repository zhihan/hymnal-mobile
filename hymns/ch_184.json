    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "怒气的杯何等苦！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你为我们茹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡的浸何等深！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你为我们沉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可怜你在髑髅地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟被父神离弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们满心感激，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能不记念你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我想当日的幽冥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎样攻逼你灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又想洪涛和波澜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎样将你冲漫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但在那里，我看见"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的恩爱无限；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们忧喜交集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在来记念你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们知你已复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作死人初熟果；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们见你坐父右，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作召会荣耀头。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们因你蒙悦纳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身、心都得救拔；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不然怎会想慕你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这样来记念你？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你若尚未得荣来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接我免去大灾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我与你永同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安息直到万代；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我还要效法你死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要表明你死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要竭力敬爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要来记念你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
