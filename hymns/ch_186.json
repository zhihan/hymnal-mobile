  "title": "神圣爱的珍馐",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 圣、"
            },
            {
              "chord": "",
              "text": "爱"
            },
            {
              "chord": "A7",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "珍"
            },
            {
              "chord": "A",
              "text": "馐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃"
            },
            {
              "chord": "Bm",
              "text": "是 出"
            },
            {
              "chord": "A",
              "text": "于 恩"
            },
            {
              "chord": "D",
              "text": "典；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "G",
              "text": "著 享"
            },
            {
              "chord": "",
              "text": "受"
            },
            {
              "chord": "D",
              "text": "这"
            },
            {
              "chord": "A",
              "text": "饼 与"
            },
            {
              "chord": "D",
              "text": "酒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我"
            },
            {
              "chord": "Bm",
              "text": "们 将"
            },
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "记"
            },
            {
              "chord": "D",
              "text": "念。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此我们都愿"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你得以看见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你父对你所有心愿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并你所赐恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵今已满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心今作见证："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之饼，甜美、丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我生命供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "良心不再定罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信心欢乐宣告："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赎罪之血何其宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神之所要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今享这个筵席，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此神圣、甜美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等到那日与你再席，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甜美岂只万倍！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时得见你面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "穿上你的荣形；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有你的奇妙恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要永远见证。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
