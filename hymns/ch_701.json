    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人生的经验是苦难："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多有了智慧，多愁烦！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "增加了知识，增悲叹！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚空的虚空！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "富有与享受，有何效？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵你有妻子与财宝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也一样连累你烦恼！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚空的虚空！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "劳苦成愁苦，夜不安："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你所得，即使不遭患，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死来了，一切也是完！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚空的虚空！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "趁幼年，当念造你主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬爱祂，才是乐与福！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有了祂，心满意也足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟祂不虚空！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "没有主，就虚空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有了主，就不空！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事都虚空！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有主，不虚空。"
            }
          ]
        }
      ],
