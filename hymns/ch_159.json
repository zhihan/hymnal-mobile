{
  "url": "https://www.hymnal.net/cn/hymn/ch/159",
  "title": "主你乃是那生命树",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "乃 是 那"
            },
            {
              "chord": "A",
              "text": "生 命"
            },
            {
              "chord": "D",
              "text": "樹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "E",
              "text": "命 惟"
            },
            {
              "chord": "E7",
              "text": "一 出"
            },
            {
              "chord": "A",
              "text": "處；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "的 果"
            },
            {
              "chord": "A",
              "text": "子 富"
            },
            {
              "chord": "A7",
              "text": "有 生"
            },
            {
              "chord": "D",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作"
            },
            {
              "chord": "G",
              "text": "我 最"
            },
            {
              "chord": "A",
              "text": "美"
            },
            {
              "chord": "A7",
              "text": "食"
            },
            {
              "chord": "D",
              "text": "物。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是属天真葡萄树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命供应源头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在你里，靠你生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得享你的富有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是那苹果树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我享受欣赏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的果子滋味甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你荫下得尝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你更是医治之树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "曾经为我受死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挂在木上为我被杀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得到医治。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的独一枝子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藏着神的丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我们得享神作"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无限实际、恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是大卫之枝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借成肉身而成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我们得以领略"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何为真实人性。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的发芽之杖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "含有无穷生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡永远不能胜过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那复活大能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那根漂起之木，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是沉水‘斧头；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你生命超越大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得从死水起浮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是如此‘有名植物，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得丰富分享；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，当我们在此记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿将你颂扬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
  "metadata": {
    "category": "赞美主",
