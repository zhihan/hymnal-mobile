      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的大能将我释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离烦扰俗务；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的大能为我开广"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入召会路途。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今进入地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿以你为人位；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "外面旧人日渐销毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心向你能绝对。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我接受你作人位主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同钉十架；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面之人得着恢复，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在我心安家。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当众肢体都愿舍己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀身体得显；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人数虽多，人位同一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新人在地出现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会生活─一个新人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显于各地召会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的身体是团体人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出一个人位。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
