            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life is"
            },
            {
              "chord": "G",
              "text": "God's one"
            },
            {
              "chord": "D",
              "text": "empha"
            },
            {
              "chord": "A7",
              "text": "sis,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Showing"
            },
            {
              "chord": "A",
              "text": "Christ sub"
            },
            {
              "chord": "A7",
              "text": "jective"
            },
            {
              "chord": "D",
              "text": "ly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Step by"
            },
            {
              "chord": "G",
              "text": "step He"
            },
            {
              "chord": "A",
              "text": "grows"
            },
            {
              "chord": "A7",
              "text": "in"
            },
            {
              "chord": "D",
              "text": "me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just as earth became a waste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death and darkness once I faced."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God had judged, no light did shine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hollowness and void were mine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan’s fall had filled the seas"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With corruption, sin, disease."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet the Spirit brooded o’er"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The abyss: chaos no more!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God then spoke: the air was cleared!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Darkness which I once had feared"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was dispelled by God’s own light."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A new day! No longer night!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the light began to shine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His discernment became mine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I began to see aright;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God divided dark from light."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the waters He did split;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An expanse between them fit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earthly things from heavenly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Separated hence they’d be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On the third day God designed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the waters be confined."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our lives dry land must be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more death and no more sea!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God commands: death’s water halt!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the good land, we exalt!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Separated from all strife"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We enjoy Christ as our life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Growing in us inwardly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grass, then herb, then fruitful tree."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We begin as but a blade;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon our being He’ll pervade."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the fourth day lights He set;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearers these, more definite."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Richer light to radiate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Higher life to generate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sun, the greater light we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ruling day triumphantly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet when darkness fills the skies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Waxing moon is on the rise!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the Church she typifies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For her light on Christ relies."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His image meant to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She reflects Christ perfectly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lastly, precious stars He placed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strong in spirit, full of grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining when the moon seems faint,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These are overcoming saints."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What a glorious picture here:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sun and moon and stars appear!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, our prayer is that we’d be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of light and life in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    }
  ],
