{
  "url": "https://www.hymnal.net/cn/hymn/ch/84",
  "title": "哦主甚么使你头",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "甚 么 使"
            },
            {
              "chord": "A",
              "text": "你 头"
            },
            {
              "chord": "Bm",
              "text": "垂？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "罪 压"
            },
            {
              "chord": "A7",
              "text": "你 身"
            },
            {
              "chord": "D",
              "text": "上！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "是 站"
            },
            {
              "chord": "A",
              "text": "在 罪"
            },
            {
              "chord": "Bm",
              "text": "人 地"
            },
            {
              "chord": "D",
              "text": "位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将"
            },
            {
              "chord": "A",
              "text": "我 罪"
            },
            {
              "chord": "E7",
              "text": "孽 担"
            },
            {
              "chord": "A",
              "text": "当。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "作"
            },
            {
              "chord": "D",
              "text": "我 祭"
            },
            {
              "chord": "A",
              "text": "牲， 流"
            },
            {
              "chord": "D",
              "text": "血 赎"
            },
            {
              "chord": "G",
              "text": "罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "D",
              "text": "我 得"
            },
            {
              "chord": "A7",
              "text": "著 释"
            },
            {
              "chord": "D",
              "text": "放。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我杯满了咒诅、死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我应得之分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而其中每滴苦汤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你都为我喝尽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "苦杯你爱为我尽尝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "福杯我今得饮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶和华曾举起祂杖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，向你打下！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你被你神痛苦击伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我免受刑罚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的宝血因此流淌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作了我的赎价。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "狂风大起，怒涛骇浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，向你进迫！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的胸怀为我抵挡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我安息之所。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你为我受死受伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "平安我今得着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶和华曾吩咐祂刀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，向你兴起！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的残酷火刃闪耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "须将你血饮吸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "既已满足神之所要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的要求遂息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你曾为我受死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也在你死了；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已复活，将我开释，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今在我里活着。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过炼净、纯洁、无疵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得进你荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
