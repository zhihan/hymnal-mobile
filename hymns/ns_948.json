  "title": "Look Away unto Jesus",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I just don’t know where’d the hours go?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never meant to click on so many videos."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Scrolling, swiping, endless liking."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clock’s tik-tokking; God is calling:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Look away, look away unto Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t let this world deceive us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stuck again, my friend?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Look away unto Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Look away, look away unto Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the eyes of the One who frees us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeem the time."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renew your mind."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Look away unto Jesus!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What I behold is what I reflect."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What do I reflect if it’s Jesus I reject?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God wants us to share His story"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By reflecting Him in glory."
            }
          ]
        }
      ],
