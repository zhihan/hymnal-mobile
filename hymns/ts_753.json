        {
          "segments": [
            {
              "chord": "A7",
              "text": "主，"
            },
            {
              "chord": "D",
              "text": "我 爱"
            },
            {
              "chord": "",
              "text": "你 国"
            },
            {
              "chord": "A",
              "text": "度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "D",
              "text": "是 你"
            },
            {
              "chord": "G",
              "text": "的 住"
            },
            {
              "chord": "A",
              "text": "处；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "D",
              "text": "你 召"
            },
            {
              "chord": "A",
              "text": "会， 你"
            },
            {
              "chord": "D",
              "text": "血 所"
            },
            {
              "chord": "Bm",
              "text": "赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "将 重"
            },
            {
              "chord": "A7",
              "text": "价 已"
            },
            {
              "chord": "D",
              "text": "付。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神，我爱你召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她与世俗分别；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你眼中惟一至美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "手中惟一宝贝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为她祷告不歇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为她昼夜流泪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "补满基督患难缺欠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至与你相会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她的属天行径，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我珍爱歌颂："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "相交甘甜，相许贞坚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱戴、赞美无终。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "正如你的真理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必定屹立不已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日锡安必得荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光辉无比、至极。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
