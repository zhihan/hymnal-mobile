        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "G",
              "text": "神 所"
            },
            {
              "chord": "",
              "text": "悦、 所"
            },
            {
              "chord": "A",
              "text": "选！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
