        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍"
            },
            {
              "chord": "G",
              "text": "赏 你"
            },
            {
              "chord": "",
              "text": "的 美"
            },
            {
              "chord": "D",
              "text": "善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍 赏 你"
            },
            {
              "chord": "G",
              "text": "是 何"
            },
            {
              "chord": "D",
              "text": "馨"
            },
            {
