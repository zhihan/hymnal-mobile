      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你比世人更秀美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是全然可爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的口中有恩惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们满心爱戴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
