              "text": "珍赏你的甘甜。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你生，博士来献宝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自始人就爱戴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你死，贵人裹香料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "至终仍然可爱。"
            }
          ]
        }
