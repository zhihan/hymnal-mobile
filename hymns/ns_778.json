      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God is longing for His ultimate move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He and we would be one eternally."
            }
