      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Holiness by faith in Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by effort of thine own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sin’s dominion crushed and broken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the power of grace alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the holiness within thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His own beauty on thy brow:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This shall be thy pilgrim brightness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This thy blessed portion now."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
