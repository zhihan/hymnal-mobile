              "text": "By His will He sanctifieth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Spirit’s power within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the loving hand that chasteneth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fruits of righteousness to win;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His truth and by His promise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Word, His gift unpriced,"
            }
          ]
        },
        {
          "segments": [
