    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A wonderful Savior is Jesus my Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He taketh my burden away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He holdeth me up and I shall not be moved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He giveth me strength as my day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He hideth my soul in the cleft of the rock"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That shadows a dry, thirsty land;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He hideth my life in the depths of His love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And covers me there with His hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And covers me there with His hand."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With numberless blessings each moment He crowns,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, filled with His fulness divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I sing in my rapture, oh, glory to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For such a Redeemer as mine!"
            }
          ]
        }
