      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas after we believed in Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The word of truth, the gospel, heard,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Holy Spirit us did seal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To show that we belong to God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This Spirit as the living seal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us God’s image now imparts;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conforming us unto the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He stamps His image in our hearts."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This Spirit also is the pledge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our earnest and our foretaste true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He witnesses that we are sons,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God’s inheritance in view."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this Spirit God does spread"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into our mind, emotion, will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By sealing every inward part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will our very being fill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, we would cooperate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all Thy Spirit’s inward move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we’d become Thy masterpiece,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th’ eternal purpose thus to prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
