    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, magnify the Lord with me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With me exalt His name;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When in distress to Him I called,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He to my rescue came."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The hosts of God encamp around"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The dwellings of the just;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deliverance He affords to all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who on His succor trust."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, make but trial of His love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Experience will decide"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How blest they are, and only they,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who in His truth confide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fear Him, ye saints, and you will then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have nothing else to fear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make you His service your delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your wants shall be His care."
            }
          ]
        }
      ],
