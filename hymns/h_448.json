    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Would you walk with the Lord in the light of His Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And have peace and contentment alway;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You must do His sweet will to be free from all ill;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the altar your all you must lay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Is your all on the altar of sacrifice laid?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your heart, does the Spirit control?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You can only be blest and have peace and sweet rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As you yield Him your body and soul."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, we never can know what the Lord will bestow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the blessings for which we have prayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till our body and soul He doth fully control,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our all on the altar is laid."
            }
          ]
