    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our mouth shut up defeats us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And wins the Devil’s smile;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So why not open battle"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And chase him all the while."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By “sacrifice of praises”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shouts of victory—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twill cost us but our faces"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s chosen fools to be!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The world has never helped us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To shout our Savior’s praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor given Him the glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor lent one thankful phrase;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So need we ask permission"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To praise th’ ascended Lord?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cry out! Release your spirit!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Much grace He does afford!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O brothers, be not silent!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O sisters, cry aloud!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sound shall tell God’s triumph"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And blessings far abroad."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now is the time to praise Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes now, at any cost!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O joy in your salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in His mercy boast."
            }
          ]
        }
      ],
