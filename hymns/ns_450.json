    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy person, Lord, alone can bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My jaded heart to cheer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy smile gladdens my heart strings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whene’er Thou dost appear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus gloom becomes triumphant song"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And darkness turns to light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My valley’s shades to inundate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With beams of sweet delight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy presence meaneth everything;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art my secret, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I welcome Thee into my boat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True rest Thou dost afford."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though bitterness surround my soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy sweetness I can taste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in life’s storms in Thee I find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The eye wherein I’m graced."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy visitation, gracious, sweet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In trials comforts me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In tribulation’s form to bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine all-sufficiency;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While journeying along life’s stream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should I, by boulders, be fazed?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For thornless grace I would not seek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But water’s level raised."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When in the index of Thine eyes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart’s joy is maintained;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee alone I’m occupied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by Thy love constrained."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s naught on earth that can frustrate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The man enjoying Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now all else from my vision fades;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Lord, alone, I see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
