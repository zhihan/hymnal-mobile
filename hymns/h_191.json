    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Seed of Abraham,” Thou art, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By God’s promise Thou hast come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the blessing He hath promised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On all people thus might come."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abraham Thou hast preceded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou art the great “I AM,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou cam’st to be his offspring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And become God’s promised “Lamb.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art the “Seed of David,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the kingdom Thou wast raised;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God’s glory and His building"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the throne Thou hast been placed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Truly Thou art “David’s offspring,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet “my Lord” he calleth Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou art his “root” and fountain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Lord of all” eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though “a child” born with our nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the “Mighty God” art called;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, “a son” to us art given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Everlasting Father” called."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the blessings God hath promised,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With our faith on Thee depend;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art “Yea” and “Amen” for them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the content and the end!"
            }
          ]
        }
      ],
