    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If my faith makes mountains move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And loveless works my power prove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would it ever mean a thing?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I dole out all I own"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feed the hungry in lands unknown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would my boast a profit bring?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love is patient; love is kind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jealous boasting, love declines."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On account of evil love is blind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For only love prevails."
            }
          ]
        }
