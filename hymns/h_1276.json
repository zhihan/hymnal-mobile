          "segments": [
            {
              "chord": "D",
              "text": "Oh, the"
            },
            {
              "chord": "",
              "text": "Lord is quickly"
            },
            {
              "chord": "A",
              "text": "coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has spoken"
            },
            {
              "chord": "A7",
              "text": "in His"
            },
            {
              "chord": "D",
              "text": "Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And confirmed it"
            },
            {
              "chord": "G",
              "text": "by the"
            },
            {
              "chord": "D",
              "text": "churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His"
            },
            {
              "chord": "A",
              "text": "Spirit"
            },
            {
              "chord": "A7",
              "text": "we have"
            },
            {
              "chord": "D",
              "text": "heard."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to all the seven churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did the Lord speak in this way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the church in Philadelphia"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did He choose these words to say."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Philadelphia, Philadelphia,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Church so full of brotherly love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the church to bring the Bridegroom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Back to earth from heav’n above."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He that hath the key of David,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He that shuts and opens too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knows thy works, O Philadelphia;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why you’re His Bride so true."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not so strong by worldly standards,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hidden from religion’s fame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus loves you, Philadelphia,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For you’re faithful to His name."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By His Word you’re overcoming—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How the Amen does resound!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just hold fast to what you’ve gotten,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That no man may take your crown."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You have kept His Word of patience;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will keep you from that hour"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which upon the whole world cometh"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Lord comes in His power."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“I come quickly,” Philadelphia,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks the Lord to none but you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Amen! Quickly come, Lord Jesus,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Answer back His faithful few."
            }
          ]
        }
      ]
    }
  ],
