          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a nameless dread and fear?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the daylight fades"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into deep night shades,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Does He care enough to be near?"
            }
          ]
        }
