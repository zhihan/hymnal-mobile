    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Going to receive the Kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From His God, the Ancient of Days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now He cometh with the Kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And its glorious, ruling rays."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s “the Stone” which breaks the nations"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into pieces lowliest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which “a mountain great” becometh"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Kingdom manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, the earth, all lands and kingdoms,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Lord and Christ possessed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth beneath their sovereign ruling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will be full of peace and rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more war and no more hatred"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twixt the nations will there be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But God’s knowledge shall suffuse them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the waters fill the sea."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Christian overcomers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall with Christ in glory reign,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the remnant saved of Israel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then God’s priesthood shall obtain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As God’s people shall the nations"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Neath their rule and teaching be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And a glorious restoration"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All creation then shall see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan will be bound and banished;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From his rule will earth be freed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ’s sovereign reign and headship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth will then be blessed indeed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All to Christ will then be subject,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His pow’r and to His will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Head and Center glorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He God’s purpose will fulfill."
            }
          ]
        }
