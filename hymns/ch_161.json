      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是先知，神所兴起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "富有神的权能；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同摩西，指明神意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们得以照行。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又像约拿，被神差遣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过死而复活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借这死与生的表记，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我相信悔过。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是先知，人间兴起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有亮光、能力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像以利沙，充满爱心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对人广行神迹。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像以赛亚，满有恩惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启示神的基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得享祂作一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实际而又丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是祭司，人间选出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我圣洁祭司；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像亚伦，蒙神所召，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代人神前服事。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭爱将我带到神前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像大祭司一般；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱在彼为我代祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的软弱承担。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是祭司，神所差来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作神君尊祭司；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像撒冷王，麦基洗德，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神前来服事。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带饼和酒从神而来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我应时供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神带来，使我得享"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的所有丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是君王，如同大卫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "体贴神的心愿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神争战，征服仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的心愿成全。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着权柄，登上宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非凭人手掌管；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是运用神圣权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神作王掌权。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是君王，像所罗门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着和平执政；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭着智慧作王治理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建神殿经营。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今在你圣徒中间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭爱隐着掌权；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来要同我们作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "王权显于众前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是祭司、先知、君王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所是何其丰美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神、对人，你的价值，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们凭爱宝贵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们珍爱你之所是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人受你吸引；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你献上敬拜、赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远感激不尽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
