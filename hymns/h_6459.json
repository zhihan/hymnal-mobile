      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I choose Thy way to follow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though stormy blasts surround;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though there be troubles, sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace is more profound."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life’s pursuit I lack, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not minding things above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, keep me, bring me back, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Immerse me in Thy love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy cross I’m gladly bearing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face for Thy kingdom set;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though suff’ring, tears, I’m sharing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy hand upholds me yet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life’s journey soon is ending;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That City soon I’ll see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Father’s bosom resting—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How full that joy will be!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy glory, soon unveiled, Lord—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, ’tis for this I yearn!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy promises ne’er fail, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou swiftly wilt return."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let me press e’er higher,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not ling’ring here below,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My gaze transfixed e’er skyward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart with Thee aglow!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
