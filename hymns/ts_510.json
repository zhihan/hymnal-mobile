    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，你曾呼召召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发光为你作见证；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们愿意成就你意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除去所有的瑕疵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世代虽然弯曲悖谬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "极其黑暗无生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会却是照耀明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你自己全表明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我们喜乐赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会也是你新妇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从她你能得男孩子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借以打败你仇敌。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们要作得胜者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你权柄得恢复，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界罪恶一扫而空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上建立你国度！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，你的所是所作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全在地方召会中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自从看见召会异象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们此心再不移，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因得启示心被吸引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "渴慕奔跑到路终。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着启示录的异象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，荣耀全归你！"
            }
          ]
        }
      ],
