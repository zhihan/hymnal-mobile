{
  "url": "https://www.hymnal.net/en/hymn/ns/505",
  "title": "God Needs the Overcomers",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God used John, the Baptist,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who left his home and good past;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Left the religion of his age."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He turned from the oldness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And spoke the Word with boldness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Repent and leave this crooked age.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God needs the overcomers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Our dear Lord Jesus’ lovers!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us those who live to turn the age!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God needs the overcomers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Our dear Lord Jesus’ lovers!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us those who consummate the age!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God called Saul of Tarsus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His own plan and purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who became Paul, the apostle;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He saw a heav’nly vision,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where there is no division,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the one Body of the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God called Timothy, now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like-souled with Paul, who knew how"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To pray and be soaked in the Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His spirit fanned into flame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make my spirit the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An overcoming man of God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us the overcomers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s Bride, and God’s age-turners."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us those who consummate the age!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
