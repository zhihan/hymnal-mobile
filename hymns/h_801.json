    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No man has e’er seen God, apart from Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without the Scripture Thee we’d hardly see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou to the human race God hast declared,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thru the Scripture Thou art shown to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfect embodiment Thou art of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A portrait full the Scripture gives of Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we comprehend God’s image true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thru the Scripture Thou art real to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life-giving Spirit Thou, as well as Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now e’en the Spirit in the Word Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When thru the Spirit giv’n, I touch the Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulness divine to me Thou dost impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee I may with God have fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thru the Scripture I on Thee may feed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru study of the Word with prayer to God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy glorious riches fully meet my need."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach me to exercise my spirit, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word to study, so to contact Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou, the living Word, with Scripture, too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As one my daily manna e’er may be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
