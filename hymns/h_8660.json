    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Diligent to serve Him here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Work and labor without fear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Cross, our self outpoured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willingly to serve the Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep on “trading,” He is near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our reward will soon appear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Face the evils forcefully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fight the evils ardently."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face the troubles, fight on through,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor withdraw till peace accrue."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Watching, praying day and night,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Standing firmly in the fight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Time is like an arrow bold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon we hope to be consoled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit, soul, and body must"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not throw off His ruling trust."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we always be aware,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for His return prepare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Be prepared though often shamed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be prepared though e’en defamed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be prepared through all of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Watching, praying in the strife:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, do come without delay!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even come, dear Lord, today!"
            }
          ]
        }
      ],
