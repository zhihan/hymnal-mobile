            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "裡 面 將"
            },
            {
              "chord": "B7",
              "text": "我 推"
            },
            {
              "chord": "Em",
