    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主已复活，桎梏全除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宗教事物已过时；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是活殿，是真供物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭祂敬拜才真实。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，同主复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等释放，何超脱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聚集过节，享受盛筵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "贫穷、老旧都消没。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "唉呀！宗教何其狡猾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "堕落血轮中藏着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主启示，大光照亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使那，恶魔无处躲。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，救我脱离宗教，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱开魂中的囚牢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每逢聚集将灵释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神、人的需要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "山上、海边，处处可聚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主作实际当持守；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活的基督，我们至爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂同在复何求？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "埋葬宗教，除去老旧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵中新样神所宝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非\"基督教，\"乃是基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才是实际神所要。"
            }
          ]
        }
      ],
