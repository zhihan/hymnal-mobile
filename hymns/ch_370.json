{
  "url": "https://www.hymnal.net/cn/hymn/ch/370",
  "title": "哦主耶稣当你在地",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "哦， 主"
            },
            {
              "chord": "G",
              "text": "耶"
            },
            {
              "chord": "Am",
              "text": "穌，"
            },
            {
              "chord": "C",
              "text": "當"
            },
            {
              "chord": "F",
              "text": "你"
            },
            {
              "chord": "G7",
              "text": "在"
            },
            {
              "chord": "C",
              "text": "地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "他"
            },
            {
              "chord": "Am",
              "text": "們 與"
            },
            {
              "chord": "D7",
              "text": "你 多"
            },
            {
              "chord": "Dm",
              "text": "年"
            },
            {
              "chord": "D7",
              "text": "同"
            },
            {
              "chord": "G",
              "text": "處；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "但"
            },
            {
              "chord": "F",
              "text": "是"
            },
            {
              "chord": "G7",
              "text": "他"
            },
            {
              "chord": "C",
              "text": "們 對"
            },
            {
              "chord": "Dm",
              "text": "你"
            },
            {
              "chord": "G7",
              "text": "自"
            },
            {
              "chord": "C",
              "text": "己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "似"
            },
            {
              "chord": "F",
              "text": "識"
            },
            {
              "chord": "G7",
              "text": "不"
            },
            {
              "chord": "Am",
              "text": "識，"
            },
            {
              "chord": "C",
              "text": "似"
            },
            {
              "chord": "Dm",
              "text": "悟"
            },
            {
              "chord": "G7",
              "text": "不"
            },
            {
              "chord": "C",
              "text": "悟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "他们听过你的声音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们见过你的丰姿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们挤过你的肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你是谁，似知不知。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们好像盖重幔子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仿佛知道，又不透明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说不认识，早已认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说已认识，认识不清。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但你今已化身那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为另一位保惠师，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着你的所有丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面将你启示。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你这灵浸透充满"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我全人每一角落，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一处不受你感，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一处不被你摸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你这灵向我显现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加倍实在，在我心怀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无耳所听，无目所见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无手所摸，如此实在。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你怜悯，肯来启示，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你自己给了我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世上有谁比你更实？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世上有何比你更真？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你这灵从我的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同洪水漫溢全人："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到处荣耀，到处光明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到处是你，到处是神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个生活何等亲近！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我已在地若天："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美满口，喜乐满心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同在满魂，一切甘甜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
