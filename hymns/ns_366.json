    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There is little willingness within me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To place all I am before Thy feet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So I lay my hands on Thy dear head, Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the burnt off’ring, perfect, complete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You are the only One who offered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yourself without reluctance unto God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full obedience to the Father given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Absolute, You sacrificed Your all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As this One, You’re dwelling in my spirit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Moving, spreading outward day by day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s a whisper of Amen within me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In response to all that You would say."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I say Yes and give You full permission"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To touch every corner of my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Break through all the barriers in my being;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do not let me withhold any part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis my joy to give You all the ground, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my heart a dwelling place for You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I want You to be at home within me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come and settle down in every room."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, do cleanse my heart from all self-seeking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I’d truly want nothing but Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let my soul be occupied, possessed, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You would be magnified in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
