    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我们唱诗祷告时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等愿说‘献所有！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但前面有更沉重的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十字架！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有更艰难的生涯！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是十架道路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你愿否走这个？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾否背十架为你主？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这奉献一切给神的人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神你是否全贞？"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你要变节；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或忠心到死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让一切完全损失，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直等到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永活主的丰盛生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天充满在你灵？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
