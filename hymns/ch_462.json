    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的救法是由死得生"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "－你与主合为一人－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在十架你因信"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已与祂同钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你身活出祂命。"
            }
          ]
        }
