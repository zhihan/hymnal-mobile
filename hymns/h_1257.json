              "text": "Do you see them in the meetings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lifting up their voice on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every brother, sister sharing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ the Lord to magnify?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you hear them all pray-reading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breathing in the living Word?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praying, praising, drinking, feeding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How they all enjoy the Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you hear them call, “Lord Jesus“?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How they love that blessed name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the more their joy increases"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As His Lordship they proclaim."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Have you heard their hallelujahs,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like a mighty thunder blast?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Down the enemy is cast!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you see the saints migrating?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord the move is on"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the church in every city"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That our blessed Lord may come!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you see the Lord is coming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the church for whom He died?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the churches He’s preparing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now His holy, chosen Bride."
            }
          ]
