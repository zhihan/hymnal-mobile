{
  "url": "https://www.hymnal.net/cn/hymn/ch/33",
  "title": "父神阿你在羔羊里",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父 神"
            },
            {
              "chord": "",
              "text": "阿，"
            },
            {
              "chord": "C",
              "text": "你 在"
            },
            {
              "chord": "D",
              "text": "羔 羊"
            },
            {
              "chord": "G",
              "text": "里"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 我 的 希 望 和 安"
            },
            {
              "chord": "D",
              "text": "息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 名 所"
            },
            {
              "chord": "G",
              "text": "表 一"
            },
            {
              "chord": "C",
              "text": "切 慈"
            },
            {
              "chord": "D",
              "text": "仁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都"
            },
            {
              "chord": "C",
              "text": "是 为"
            },
            {
              "chord": "",
              "text": "著 赐"
            },
            {
              "chord": "D",
              "text": "福"
            },
            {
              "chord": "D7",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "们。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你大而智、你公而仁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我父、又是我神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们属你，是借宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你儿女，永远联结。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今带疲倦的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来到你前仰望你名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "烦闷艰苦，寻求恩惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同困鹿渴慕溪水。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "既是这样，愿你施恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫我们亲近你身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的同在作我居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的大爱作我喜乐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这叫我们永远欢腾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这叫黑夜变为光明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若有微息尚能称颂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必引弱声向你歌诵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
