              "chord": "",
              "text": "Living for Jesus, oh, what rest!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pleasing my Savior, I am blest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only to live for Him alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doing His will till life is done."
            }
          ]
        }
