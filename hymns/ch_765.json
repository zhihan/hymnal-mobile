      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我亲眼见我救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂荣中永远同住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心快乐，我口欢呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！赞美主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我见主在那空中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我十字架就不苦重，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等畅乐与主相逢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！赞美主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当那时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要证明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能胜主的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离地上升何等欢腾！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！赞美主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿我们隐主肋畔！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "合而为一不再离散，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫耶稣意足心满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂来时！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢我王，愿你就来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接等你者与你同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使爱你者得你赏赉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，快来！"
            }
          ]
        }
      ],
