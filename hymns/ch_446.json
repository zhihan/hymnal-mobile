    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "夜以继日走过漫长的路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己里面想要找到一途；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一无所成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也无任何进步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己努力不过全是失误，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而后得知主是惟一道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我当借祂到神里面居住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙住处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣荣美之家！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安稳无以复加。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你我既是互为居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你使我只是向你活着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这最美之家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得享安康，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随事随在将你与人分享。"
            }
          ]
        }
