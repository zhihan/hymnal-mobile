            {
              "chord": "C",
              "text": "过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将 你 圣 洁 的"
            },
            {
              "chord": "F",
              "text": "膏 油，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重"
            },
            {
              "chord": "C",
