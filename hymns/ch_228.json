      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心何等的冷淡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺服何等迟慢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿主圣灵充满我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我不再背叛。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今躺卧在祭坛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不敢稍为动弹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主烈火从天降，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把我所有烧干。"
            }
          ]
        }
