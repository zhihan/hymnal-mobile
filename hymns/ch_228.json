      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心何等的干旱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常为软弱悲叹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是何等的盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能被圣灵充满。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主让我今隐藏"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你击伤石磐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主今听我呼求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你活水泛滥。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，求主救我脱离"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个可怜的自己！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我从今后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全充满了你。"
            }
          ]
        }
