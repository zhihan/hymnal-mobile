            },
            {
              "chord": "C",
              "text": "抹。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 认 自 己 的"
            },
            {
              "chord": "G",
              "text": "生 活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真 是 失"
            },
            {
              "chord": "G7",
              "text": "败、 软"
            },
            {
              "chord": "C",
              "text": "弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 望 充 满 你"
            },
            {
              "chord": "F",
              "text": "的 灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完"
            },
            {
              "chord": "C",
              "text": "全 为"
            },
            {
              "chord": "G7",
              "text": "你 而"
            },
            {
              "chord": "C",
              "text": "活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
