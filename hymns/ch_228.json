  "title": "哦求主救我脱离这",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "求 主"
            },
            {
              "chord": "",
              "text": "宝 血 洁"
            },
            {
              "chord": "G",
              "text": "净 我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗 尽 所"
            },
            {
              "chord": "G7",
              "text": "有 罪"
