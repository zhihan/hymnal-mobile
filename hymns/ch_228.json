              "text": "这"
            },
            {
              "chord": "D",
              "text": "个 可"
            },
            {
              "chord": "D7",
              "text": "怜 的"
            },
            {
              "chord": "G",
              "text": "自 己！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "求"
            },
            {
              "chord": "C",
