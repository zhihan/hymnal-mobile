    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Golgotha! Good Golgotha!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I died there with my Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His crucifixion has released"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The burden I once bore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Therefore I pray, my Lord, reveal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Golgotha's mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So I may know that I am one"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee in certainty."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Golgotha! That empty tomb"
