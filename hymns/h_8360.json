          "segments": [
            {
              "chord": "",
              "text": "Included me as well;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His resurrection too I share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I hear no deathly knell."
            }
          ]
        }
      ],
      "type": "verse",
