    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here rejoicing in Thy nearness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly by Thy Spirit led;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calmly in the blest remembrance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thyself, Thy blood once shed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we take each simple token"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fond memory of Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Muse upon Thy body broken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy blood shed on the tree."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what joy it is to see Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In these chosen emblems here;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the bread and wine of blessing—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bread to strengthen, wine to cheer!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, behold us met together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in Thee, our risen Head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we take the cup of blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we share the broken bread."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we know how true Thy promise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be with us where we meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When in Thy loved name we gather"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To enjoy communion sweet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dearer still that looked-for promise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To each waiting, yearning heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That with Thee we soon shall be, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, “forever” where Thou art."
            }
          ]
        }
      ]
    }
