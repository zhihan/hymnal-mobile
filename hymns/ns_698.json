    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy blood, Lord, I’ve been purchased;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast paid the highest price;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘Tis the basis of my offering"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a living sacrifice."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love Thee, for Thou first loved me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As more love I daily see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love greatly motivates me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willingly to live for Thee!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, the service Thou desirest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must not from my self be brought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst have me open to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy love’s work to be wrought."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my heart, Thy home establish;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reproduce Thyself in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built with others in Thy Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy service meet I’d be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, like Mary, to Thee listening,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thy feet, so lovingly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hearing Thy dear heart’s intention,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Revelation I’ll receive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I break my flask, most precious;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart’s treasury outpour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill Thy house with sweetest fragrance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A memorial evermore!"
            }
          ]
        }
