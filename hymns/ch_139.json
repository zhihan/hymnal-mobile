            {
              "chord": "G",
              "text": "『甜 美』"
            },
            {
              "chord": "",
              "text": "登"
            },
            {
              "chord": "D",
              "text": "極 救"
            },
            {
              "chord": "G",
              "text": "主 額"
            },
            {
              "chord": "",
              "text": "上， 神"
            },
            {
              "chord": "C",
              "text": "聖、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊 貴、 莊"
            },
            {
              "chord": "G",
              "text": "嚴； 祂"
            },
            {
              "chord": "",
              "text": "頭"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "披"
            },
            {
              "chord": "D",
              "text": "戴 榮"
            },
            {
              "chord": "G",
              "text": "耀 之"
            },
            {
              "chord": "",
              "text": "光， 祂 口"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "溢"
            },
            {
              "chord": "D7",
              "text": "出 恩"
            },
            {
              "chord": "G",
              "text": "典。 祂"
            },
            {
              "chord": "",
              "text": "口"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "溢"
            },
            {
              "chord": "D7",
              "text": "出 恩"
            },
            {
              "chord": "G",
              "text": "典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地上所有必死之人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂相比，谁配？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上所有天使天军，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有谁比祂更美？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我的生命、气息、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的所有喜乐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我胜过死的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离坟墓幽所。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "向着父神－我的居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂带我的脚步；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神荣耀指示与我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我喜乐满足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我从祂的神圣厚恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得知祂爱之大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倘若我有千万的心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也必全都归祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
