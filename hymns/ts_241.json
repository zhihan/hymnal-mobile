              "text": "非你建造的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "房屋满美物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非你装满的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凿成的水井，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非你凿成的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄，橄榄非你栽的。"
            }
          ]
        }
