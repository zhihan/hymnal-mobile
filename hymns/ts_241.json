      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有河有泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谷中有水溪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有小麦、大麦、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "果树、油和蜜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "居住在这地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必永不缺食；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "山可挖铜，地有铁石。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同欢乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "歌唱于锡安；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同向前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入祂美善；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新酒和五谷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出产肥而甘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这地实在又丰又满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是我的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是你的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们分享祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不分彼此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，我们产业，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "广大达四极；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地是为着我们的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这广大享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这丰盈之地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "路上滴脂油，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到处是乳蜜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩重重四溢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，尝尝便知，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是我们的美地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂道成肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受尽人欺厌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由死而复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "升上了高天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得荣耀尊贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂的冠冕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美地今在我们里面。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同经营内住的基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将丰馀收获献上作食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此献基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人得饱足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们歌颂永不止住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美神使祂成为我美地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美神使祂成为你美地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀的美地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今住基督美地！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
