  "title": "Living Christ is by loving Him",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, if we do not love Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we surely cannot live Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving Him is the best way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To concentrate our being on Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Repeat)"
            }
          ]
        }
      ],
