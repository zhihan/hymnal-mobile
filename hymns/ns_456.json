{
  "url": "https://www.hymnal.net/en/hymn/ns/456",
  "title": "Lord Jesus Christ my sole desire",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lord Jesus"
            },
            {
              "chord": "G",
              "text": "Christ my"
            },
            {
              "chord": "",
              "text": "sole de"
            },
            {
              "chord": "A",
              "text": "sire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "My heart"
            },
            {
              "chord": "",
              "text": "is fixed, alone, on"
            },
            {
              "chord": "A",
              "text": "Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Among"
            },
            {
              "chord": "",
              "text": "ten"
            },
            {
              "chord": "G",
              "text": "thousand"
            },
            {
              "chord": "",
              "text": "Thou art"
            },
            {
              "chord": "A",
              "text": "peerless;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Chiefest"
            },
            {
              "chord": "",
              "text": "of all art"
            },
            {
              "chord": "A7",
              "text": "Thou to"
            },
            {
              "chord": "D",
              "text": "me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy matchlessness and worth surpassing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transcend all else exceedingly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how supreme and prepossessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Thine unrivaled love to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My life-long quest is just to know Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till more and more subjectively,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would arrive at the full knowledge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all the excellence of Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the first day that I beheld Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve longed to know Thee ever more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart doth love Thee most supremely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy preciousness, Lord, I adore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lost in Thee, Lord, I gaze intently"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drawn from all else to look away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Magnet of my soul, hast charmed me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Far more today than yesterday."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m captivated by Thy beauty,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incomp’rable Thou art to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Counting all things as loss and refuse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d pay the price of gaining Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My daily goal and aim—to win Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this I press on desperately,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forgetting all that is behind me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And stretching forward earnestly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Toward this goal I’m pressing onward"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may lay hold of the Prize,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain me in full that I may gain Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy peerlessness to realize."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not I alone; we in the Body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strive to delve into and explore"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The rich dimensions of Thy vastness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine endless wealth and treasure store."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou, our Christ, so all-inclusive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We apprehend, know, and possess"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine attributes divine, our virtues"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will all Thy fullness thus express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine excellency may we know, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou, Thy home in us, may make"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we arrive at Thy full knowledge"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, of Thy riches full, partake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    }
  ],
