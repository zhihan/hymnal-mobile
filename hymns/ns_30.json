    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take time to absorb Him, to gain the supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be watered and nourished thereby;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The deeper the roots spread, the deeper the flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And richer and higher within us He’ll grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take time to inhale Him—His Word we may breathe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By breathing it, God’s very life we receive—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He breathes Himself out so that we may breathe in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life, the reality, fullness of Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take time to enjoy Him, our portion is He:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our present, available reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our practical, real, and enjoyable Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is everything to us through His living Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take time to behold Him, gaze oft on His face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Receiving His Person, and grace upon grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His pleasant shining, infused we will be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our faces will glow with His light, radiantly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
