{
  "url": "https://www.hymnal.net/cn/hymn/ch/47",
  "title": "阿爸我们进前来",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "阿 爸，"
            },
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "C",
              "text": "進"
            },
            {
              "chord": "G",
              "text": "前 來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由 你"
            },
            {
              "chord": "Am",
              "text": "愛 子"
            },
            {
              "chord": "D7",
              "text": "領"
            },
            {
              "chord": "G",
              "text": "率，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "獻 上 讚 美 和"
            },
            {
              "chord": "D",
              "text": "敬 拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "B7",
              "text": "並 享"
            },
            {
              "chord": "Em",
              "text": "父 親"
            },
            {
              "chord": "A7",
              "text": "慈"
            },
            {
              "chord": "D",
              "text": "愛。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 在"
            },
            {
              "chord": "D7",
              "text": "寶 座"
            },
            {
              "chord": "",
              "text": "心"
            },
            {
              "chord": "G",
              "text": "歡 樂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永 世"
            },
            {
              "chord": "Am",
              "text": "計 畫"
            },
            {
              "chord": "D7",
              "text": "成"
            },
            {
              "chord": "G",
              "text": "功－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死 而 復 活、"
            },
            {
              "chord": "C",
              "text": "失"
            },
            {
              "chord": "Bm",
              "text": "又 得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "我 們"
            },
            {
              "chord": "G",
              "text": "已 成"
            },
            {
              "chord": "D7",
              "text": "聖"
            },
            {
              "chord": "G",
              "text": "眾。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "桌上陈设杯和饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已同领过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个表记是说明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的爱子工作。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的身体被擘开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "辟成新活道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们借此得前来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "称你作阿爸父。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的宝血已流出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "涂抹我们罪愆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的公义和忿怒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再追我亏欠。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂血永在你面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我说出美言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但控告无效验，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不再自谴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人比天使更微小，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你前算得甚么？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你竟眷顾如珍宝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寻他与你复和。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天使堕落你不寻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟人蒙你赦免！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美，哦父，赞不尽"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这逾格恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
  "metadata": {
    "category": "敬拜父",
