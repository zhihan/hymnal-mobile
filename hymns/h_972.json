{
  "url": "https://www.hymnal.net/en/hymn/h/972",
  "title": "Lo, the central thought of God",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lo, the"
            },
            {
              "chord": "",
              "text": "central thought of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "Is that"
            },
            {
              "chord": "",
              "text": "He be"
            },
            {
              "chord": "A7",
              "text": "one with"
            },
            {
              "chord": "D",
              "text": "man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He to man is everything"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He"
            },
            {
              "chord": "A",
              "text": "might fulfill"
            },
            {
              "chord": "",
              "text": "His"
            },
            {
              "chord": "D",
              "text": "plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Earthen vessel man was made—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Body, soul, and spirit too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as life that he may take"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Him have oneness true."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By the flow of life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man becomes a precious stone"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fit for building God’s abode,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His glory might be known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the city God hath built,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the dwelling God requires,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the new Jerusalem"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which fulfills His heart’s desires."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the building of the saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the blend of God and man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purposed by the Father’s will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Long before the world began."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In its center, as its pow’r,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the throne of Christ and God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whence doth flow the stream of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit’s living flood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the tree of life, is there"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the flowing of the stream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yielding fruit of life divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the food of life supreme."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God in Christ, the glorious light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru the city brightly shines,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Scattering all the deathly night"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With its light of life divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God in man and man in God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mutual dwelling thus possess;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God the content is to man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the man doth God express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
