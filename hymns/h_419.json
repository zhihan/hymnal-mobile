    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As women take unbroken flax,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As molders take unshapen wax,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As smith, the iron, rough and cold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A useful instrument to mold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So in Thy skillful hands, O take me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And never let Thy love forsake me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Like rock uncrushed, the stubborn will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though bearing gold is barren still;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like marble in the quarry rough,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The natural heart is useless stuff;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And so, I pray—\"Do not forsake me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with Thy hand, O Savior, break me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As mortars crush the hardest rock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As hammers break the stony block,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As millstones bruise the finest wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As nuts are broken for their meat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So with Thy mighty hand, O break me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And never let Thy love forsake me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though crushed and broken, yet I'm nought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But fragments to the furnace brought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though bruised, I have no worth to feed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The multitudes that die in need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And so, I pray—\"Do not forsake me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But meet for service, Savior, make me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As into useful forms the ore"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From molten scraps the molders' pour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As fire doth make the bruised wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When mixed and molded, fit to eat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So, fit for use by fire, O make me,"
            }
          ]
        },
        {
          "segments": [
            {
