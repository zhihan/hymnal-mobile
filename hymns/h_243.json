          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Christ is God's embodiment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expressing God as life divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So is the Spirit unto Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Revealing Him in life sublime."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The fulness of the Father God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ the Son dwells bodily;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the riches of the Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are Spirit, our reality."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh in the Son the Father is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now the Spirit is the Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father with the Son is joined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit with the Son is one."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis when the Spirit strengthens us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Christ His home makes in our hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father's fulness with His love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will fill us in our inward parts."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, the Father we possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Receiving Him for all our need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Spirit we experience Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As life and everything indeed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy divine reality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, fill us by Thy Spirit now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may all be full of Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thy riches thus avow."
            }
          ]
        }
      ]
    }
