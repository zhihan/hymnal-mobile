        {
          "segments": [
            {
              "chord": "",
              "text": "释放、释放、释放祂的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让祂生命的一切丰富都流出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能力、智慧都在这生命里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无时无刻不豫备从我里显出。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不需尽力喊叫才能释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不需维持宗教里的安静；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的一切都在这生命里，"
            }
          ]
        },
        {
          "segments": [
