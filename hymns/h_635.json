{
  "url": "https://www.hymnal.net/en/hymn/h/635",
  "title": "Let us contemplate the grape vine",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Let us"
            },
            {
              "chord": "",
              "text": "contem"
            },
            {
              "chord": "G",
              "text": "plate the"
            },
            {
              "chord": "D",
              "text": "grape vine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From its"
            },
            {
              "chord": "A",
              "text": "life now"
            },
            {
              "chord": "A7",
              "text": "let us"
            },
            {
              "chord": "D",
              "text": "learn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How its growth is"
            },
            {
              "chord": "G",
              "text": "fraught with"
            },
            {
              "chord": "D",
              "text": "suff'ring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Midst en"
            },
            {
              "chord": "A",
              "text": "viron"
            },
            {
              "chord": "A7",
              "text": "ment so"
            },
            {
              "chord": "D",
              "text": "stern;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "How un"
            },
            {
              "chord": "G",
              "text": "like the"
            },
            {
              "chord": "",
              "text": "untamed"
            },
            {
              "chord": "D",
              "text": "flowers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growing"
            },
            {
              "chord": "E7",
              "text": "in the"
            },
            {
              "chord": "",
              "text": "wilder"
            },
            {
              "chord": "A",
              "text": "ness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "In a"
            },
            {
              "chord": "D",
              "text": "maze of"
            },
            {
              "chord": "G",
              "text": "wild con"
            },
            {
              "chord": "D",
              "text": "fusion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making"
            },
            {
              "chord": "A",
              "text": "patterns"
            },
            {
              "chord": "A7",
              "text": "number"
            },
            {
              "chord": "D",
              "text": "less."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But the blossoms of the grape vine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without glory are and small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though they do have some expression,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They are hardly seen withal."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But a day since they have flowered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into fruit the blooms have grown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never may they wave corollas"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With luxuriant beauty shown."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To a post the vine is fastened;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus it cannot freely grow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When its branches are extended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the trellis tied they go."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the stony soil committed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drawing thence its food supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It can never choose its own way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or from difficulty fly."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how beautiful its verdure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which in spring spreads o’er the field."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From life’s energy and fulness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growth abundant doth it yield."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till it’s full of tender branches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Twining freely everywhere,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stretching ’gainst the sky’s deep azure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tasting sweetly of the air."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But the master of the vineyard"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not in lenience doth abide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with knife and pruning scissors"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then would strip it of its pride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Caring not the vine is tender,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with deep, precision stroke"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the pretty, excess branches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the vine are neatly broke."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In this time of loss and ruin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dare the vine self-pity show?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nay, it gives itself more fully"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the one who wounds it so,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the hand that strips its branches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till of beauty destitute,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That its life may not be wasted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But preserved for bearing fruit."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Into hard wood slowly hardens"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every stump of bleeding shoot,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each remaining branch becoming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clusters of abundant fruit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, beneath the scorching sunshine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leaves are dried and from it drop;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the fruit more richly ripens"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the harvest of the crop."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bowed beneath its fruitful burden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loaded branches are brought low—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Labor of its growth thru suff’ring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many a purposed, cutting blow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now its fruit is fully ripened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Comforted the vine would be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the harvest soon is coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And its days of comfort flee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hands will pick and feet will trample"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the riches of the vine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till from out the reddened wine-press"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flows a river full of wine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the day its flow continues,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bloody-red, without alloy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gushing freely, richly, sweetly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filling all the earth with joy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In appearance now the grape vine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Barren is and pitiful;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Having given all, it enters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into night inscrutable."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No one offers to repay it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the cheering wine that’s drunk,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But ’tis stripped and cut e’en further"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To a bare and branchless trunk."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet its wine throughout the winter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Warmth and sweetness ever bears"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto those in coldness shiv’ring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pressed with sorrow, pain, and cares."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet without, alone, the grape vine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Midst the ice and snow doth stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Steadfastly its lot enduring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though ’tis hard to understand."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Winter o’er, the vine prepareth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fruit again itself to bear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Budding forth and growing branches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beauteous green again to wear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never murmuring or complaining"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the winter’s sore abuse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or for all its loss desiring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its fresh off’ring to reduce."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Breathing air, untainted, heavenly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As it lifts its arms on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth’s impure, defiled affections"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er the vine may occupy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Facing sacrifice, yet smiling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And while love doth prune once more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strokes it bears as if it never"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Suffered loss and pain before."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From the branches of the grape vine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sap and blood and wine doth flow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Does the vine, for all it suffered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lost, and yielded, poorer grow?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drunkards of the earth and wanderers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From it drink and merry make."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From their pleasure and enjoyment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do they richer thereby wake?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by gain our life is measured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by what we’ve lost ’tis scored;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not how much wine is drunken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But how much has been outpoured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the strength of love e’er standeth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the sacrifice we bear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who has the greatest suff’ring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever has the most to share."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He who treats himself severely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the best for God to gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who hurts himself most dearly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Most can comfort those in pain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who suffering never beareth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is but empty “sounding brass”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who self-life never spareth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has the joys which all surpass."
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "The Way of the Cross",
    "time": "3/2",
    "hymn_code": "345565533352123",
    "related": [
      {
        "url": "https://www.hymnal.net/en/hymn/ch/465",
        "language": "en",
