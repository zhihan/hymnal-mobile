{
  "url": "https://www.hymnal.net/cn/hymn/ts/17",
  "title": "乐！乐！乐",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "乐，"
            },
            {
              "chord": "D",
              "text": "乐，"
            },
            {
              "chord": "G",
              "text": "乐， 我"
            },
            {
              "chord": "",
              "text": "心 充 满"
            },
            {
              "chord": "D",
              "text": "喜 乐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乐， 乐， 乐，"
            },
            {
              "chord": "D7",
              "text": "耶 稣"
            },
            {
              "chord": "",
              "text": "使 我"
            },
            {
              "chord": "G",
              "text": "唱 歌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "唱 祂"
            },
            {
              "chord": "",
              "text": "奇 妙 大 爱"
            },
            {
              "chord": "C",
              "text": "为 著"
            },
            {
              "chord": "",
              "text": "我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说 祂 如 何 受 死"
            },
            {
              "chord": "G",
              "text": "释 放"
            },
            {
              "chord": "",
              "text": "我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 全 人 自 由"
            },
            {
              "chord": "C",
              "text": "且 超"
            },
            {
              "chord": "",
              "text": "脱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心"
            },
            {
              "chord": "G",
              "text": "乐，"
            },
            {
              "chord": "D7",
              "text": "乐，"
            },
            {
              "chord": "G",
              "text": "乐！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，主，主，在我灵中流通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，主，主，在我魂中扩充；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我里面陈旧全烧尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我全人变化且更新，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我成熟迎接祂再临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我主，主，主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞，赞，赞，将神心意发表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞，赞，赞，使我灵里发烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美满心满口满全人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神计画到处告诉人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将流荡者带回归向神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高声赞，赞，赞！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会，一地一个出现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会，分裂何等可怜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大巴比伦今正在倾倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主在耶路撒冷为至高；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们站住立场同建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方的召会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会，我们已经看见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会，我们已在里面。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光明的城造在圣山上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督、召会同得着显彰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终于完成了神的愿望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在地方召会！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "赞美的话",
    "time": "4/4",
    "hymn_code": "321332172432221231",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/6017",
