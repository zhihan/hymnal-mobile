{
  "url": "https://www.hymnal.net/cn/hymn/ch/750",
  "title": "神子来作生命种子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 子"
            },
            {
              "chord": "",
              "text": "来"
            },
            {
              "chord": "C",
              "text": "作 生"
            },
            {
              "chord": "D",
              "text": "命 种"
            },
            {
              "chord": "G",
              "text": "子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将"
            },
            {
              "chord": "C",
              "text": "祂 自"
            },
            {
              "chord": "",
              "text": "己 种"
            },
            {
              "chord": "D",
              "text": "人 心"
            },
            {
              "chord": "D7",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "G",
              "text": "此 从"
            },
            {
              "chord": "C",
              "text": "祂 长"
            },
            {
              "chord": "A7",
              "text": "出 国"
            },
            {
              "chord": "D7",
              "text": "度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完"
            },
            {
              "chord": "G",
              "text": "成 神"
            },
            {
              "chord": "C",
              "text": "的 永"
            },
            {
              "chord": "D7",
              "text": "远 旨"
            },
            {
              "chord": "G",
              "text": "意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是惟一生命麦种，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从祂生出许多子粒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配作诸天国度之子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进神的掌权治理。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是撒但，神的仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却将稗子撒在麦里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要扰乱国度之子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "造出可怕败坏事迹。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着他这奸狡工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "稗子、麦子混杂一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度外表变为反常，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "庞大惊人，丑形离奇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "诸天国度该像芥菜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "青嫩、微小，可供人食，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但却变成一棵大‘树’，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不伦不类、庞大组织。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不再能作神、人食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反成‘飞鸟’栖身之所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恶人、恶事以及恶灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都能在此得到寄托。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "它这外表给人看见"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一个属世伟大宗教；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "容纳外邦邪恶事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如细面搀上面酵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "既成这种属世组织，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "外表遂即改变形状；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借其所容邪恶事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面充满败坏、淫荡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但神寻找隐藏珍物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘珍珠’和那‘藏地"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贝；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主要将我全然变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同珠宝一样宝贵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "隐自庞大基督教国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隐自国度属世外表；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却有国度丰满实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "具有基督和神相貌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我脱离‘稗子’，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救我脱离宗教大‘树’；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我除去所有面酵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我像你纯洁不俗。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求借生命变化我魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我变成宝贵材料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着你的国度实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "适合于你灵宫建造。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    }
  ],
  "metadata": {
