{
  "url": "https://www.hymnal.net/cn/hymn/h/11",
  "title": "Thou, Father, who art Spirit true",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Thou, Father,"
            },
            {
              "chord": "",
              "text": "who art"
            },
            {
              "chord": "Am",
              "text": "Spirit"
            },
            {
              "chord": "",
              "text": "true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "C",
              "text": "holiest"
            },
            {
              "chord": "",
              "text": "of"
            },
            {
              "chord": "D",
              "text": "all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "G",
              "text": "worship"
            },
            {
              "chord": "",
              "text": "in the"
            },
            {
              "chord": "C",
              "text": "spirit"
            },
            {
              "chord": "",
              "text": "now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In"
            },
            {
              "chord": "G",
              "text": "truth up"
            },
            {
              "chord": "D7",
              "text": "on Thee"
            },
            {
              "chord": "G",
              "text": "call."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A spirit Thou hast made for us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may worship Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That echoing in spirit thus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One spirit we will be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father in the Son has come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son the Spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That to our spirit God may come."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a grace is this!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son is Thine eternal Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word is Spirit too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit as our life has come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit to renew."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit in our spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus in unity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit witnesseth with ours"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we are born of Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In everything Thy Spirit leads"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may follow Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We thus may spiritual become,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life and peace within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit we would worship Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit Thee address,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until our spirit is released"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine image to express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Father, we would praise Thee now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou the Spirit art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit and in truth to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True worship we impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
