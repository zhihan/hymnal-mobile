    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们过节，要来到耶路撒冷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶路撒冷是我们合一见证！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的脚一站在你的门内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就情不自禁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主荣耀的名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看！耶路撒冷联络整齐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看！真正合一多美丽！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡爱你的人必然兴旺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因神的荣耀在这里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "难怪过节要来到耶路撒冷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶路撒冷是我们合一见证！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的脚一站在你的门内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就情不自禁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主荣耀的名！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们前来朝见神，不能空手；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "牛、羊、鸽子或斑鸠，大小皆可，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无酵薄饼、新穗子、细面调油…"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当献上你的礼物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与人才得饱足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看！琳琅满目，尽是基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看！美不胜收，好丰富！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若我们想要得着饱足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "须首先让神得饱足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "难怪前来朝见神，不能空手；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "牛、羊、鸽子或斑鸠，大小皆可，"
            }
          ]
        },
