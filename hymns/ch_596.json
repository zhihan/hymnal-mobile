{
  "url": "https://www.hymnal.net/cn/hymn/ch/596",
  "title": "教会乃是精金灯台",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "召 会"
            },
            {
              "chord": "",
              "text": "乃 是 精"
            },
            {
              "chord": "D",
              "text": "金 灯"
            },
            {
              "chord": "G",
              "text": "台，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基"
            },
            {
              "chord": "C",
              "text": "督 是"
            },
            {
              "chord": "",
              "text": "灯， 神"
            },
            {
              "chord": "D",
              "text": "是 其"
            },
            {
              "chord": "",
              "text": "光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "G",
              "text": "圣 之"
            },
            {
              "chord": "",
              "text": "光 由"
            },
            {
              "chord": "D",
              "text": "主 照"
            },
            {
              "chord": "G",
              "text": "出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召"
            },
            {
              "chord": "C",
              "text": "会 托"
            },
            {
              "chord": "",
              "text": "住， 荣"
            },
            {
              "chord": "D",
              "text": "耀"
            },
            {
              "chord": "D7",
              "text": "辉"
            },
            {
              "chord": "G",
              "text": "煌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灯中照出神圣之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是神作生命照亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此灯台须属精金，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配合神的圣别荣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这黑暗时代之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣生命之光照亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照在许多人群中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将主见证向人释放。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要作这个纯洁见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘起初的爱’必须保守；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此，那得胜者之分－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘生命树果，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得享受。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "必须忍受苦难、逼迫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能得着‘生命冠冕；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属灵淫乱也要胜过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘隐藏吗哪’始得饱餐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "弃绝‘耶洗别’之所为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就能得着辖管之权；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死的玷污要全胜过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洁义‘白衣’就必得穿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "必须如同‘非拉铁非，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遵守主话，不弃主名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘温水’自满，尽都胜过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主同筵，享祂丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会必须如此纯洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为明净精金灯台，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配合主的纯洁见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照明基督，荣光满载。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地上各处地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这时代作这灯台；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来圣城耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作这灯台直到万代。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城宝贵如同精金，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主灯台最终出现；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远托着基督作灯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神圣光照耀灿烂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
