      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱重所是，光重所为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱是借光而释放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光显于外，爱在于内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光是带爱而照亮。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱的显明就是恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光的照亮是真理；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱叫我们享你肥甘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光叫我们认识你。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱叫你在子里来死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我借祂得生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光叫我能有所认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我借血得洁净。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱叫我们得着生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有分于你的交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光叫我们得着洁净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能以活在交通中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "光的照亮、血的洗净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来膏油的涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的成分、爱的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面就加多。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱叫我们成为儿女，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常称你作阿爸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光叫我们不洁全去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到见主得像祂。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何荣耀！何福气！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱已显明，光已亮！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢不尽，赞美不已！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父，你是爱又是光！"
            }
          ]
        }
      ]
    }
