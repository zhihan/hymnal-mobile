    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How can the widow put off mourning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her love not miss?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not seeing him can she stop weeping"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And no more reminisce?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can the bride before her wedding"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not lovesick be?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will not that day’s prolonged postponement"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make her sigh constantly?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If a few more years I wander,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shed a few more tears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And think of You a little longer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, Lord, will You appear?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since she began, the church has waited—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thousands of years;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Long ages she’s endured in patience;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still You have not appeared."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since I was young, I too have waited"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my whole life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My comrades all grew old, were taken;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still You have not arrived."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
