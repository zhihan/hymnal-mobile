            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, note how long and hard I’ve waited,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And persevered;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If You cannot return so quickly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, let me go to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So long You have concealed Your glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hidden above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Already, heartless people mock me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saying You will not come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
