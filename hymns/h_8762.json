              "text": "Then, Lord, will You appear?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m weary, Lord, of all this waiting—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remember me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s getting harder not to murmur,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stray from my vow to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So, Lord, I pray, delay no longer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make haste, O Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till now I’ve been exceeding patient;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can’t endure much more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
