          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No comfort’s found."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No human hand can ease my sorrows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When You are not around."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take me to Your eternal dwelling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll be content;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All thought of this hard path will vanish"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your bright countenance."
            }
          ]
