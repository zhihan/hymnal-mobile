    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how great the work David faced;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not man’s but God’s dwelling place."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this cause prepared he abundantly—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gold and silver, and timber aplenty."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, like him we too must prepare"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thine house; this burden we bear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In affliction, comfort—in any state—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always ready Thine high call to obey."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From his private chest of great wealth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "David brought forth, nothing withheld."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His own gold and silver and precious things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He surrendered in off’ring so freely."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our own wealth, our comfort and ease,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en our youth, bright future and dreams,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the altar lay we most cheerfully;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None’s more worthy all our best to receive!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who are we that we’d dare to boast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of whate’er on Thee we’d bestow?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All’s from Thee; from Thine hand we give them back,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Borrowed treasures returning most gladly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who shall then to Thee consecrate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willingly his being today—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His whole heart and soul, his whole mind and strength?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, our life we now present unto Thee!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how glorious! God’s people, arise!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Join the great throng who’ll pay the full price!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With our spirit strengthened, our praise we sing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our God who will the building complete."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how worth it! We’ve counted the cost;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Boldly offer; ’tis never a loss!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, man as one mingled—our destiny;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mutual rest and satisfaction complete!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
