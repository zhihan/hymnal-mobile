    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与你合一，化身之子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你奥秘的肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你诞生与你连枝，"
            }
          ]
