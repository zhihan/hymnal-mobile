    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Shepherd is the Lamb of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He calls to me each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To drink the waters flowing free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From His pierced side of grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet when I stray or choose my way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He still would search for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bring me home on shoulders strong."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do I not His love see?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Shepherd’s face is how I live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love to look at Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though He might lead through shearing trial,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But still I follow Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just as the Father’s presence cheered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him through each suffering day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis once I saw His tender care"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That here I want to stay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Father thank You for Your Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He shares Your heart for us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That gladly He would bear us to"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The bosom of Your love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No greater Shepherd could there be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He would not lose one!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lead us all to dwell with You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweet Pasture, Living Stream."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
