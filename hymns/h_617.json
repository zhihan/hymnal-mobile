    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Will, that willest good alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lead Thou the way, Thou guidest best;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little child, I follow on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, trusting, lean upon Thy breast."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s will doth make the bitter sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all is well when it is done;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unless His will doth hallow it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory of all joy is gone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy beautiful sweet will, my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holds fast in its sublime embrace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My captive will, a gladsome bird,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prisoned in such a realm of grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Within this place of certain good"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love evermore expands her wings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or nestling in Thy perfect choice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abides content with what it brings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, lightest burden, sweetest yoke;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It lifts, it bears my happy soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It giveth wings to this poor heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My freedom is Thy grand control."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon God’s will I lay me down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As child upon its mother’s breast;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No silken couch, nor softest bed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could ever give me such deep rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy wonderful grand will, my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With triumph now I make it mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And faith shall cry a joyous Yes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To every dear command of Thine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
