    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though dark be my way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since He is my Guide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis mine to obey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis His to provide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though cisterns be broken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And creatures all fail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The word He hath spoken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall surely prevail."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His love, in time past,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forbids me to think"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll leave me at last"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In trouble to sink:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each sweet Ebenezer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have in review"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Confirms His good pleasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To help me quite through."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Why should I complain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of want or distress,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Temptation or pain?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He told me no less;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The heirs of salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know from His Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through much tribulation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must follow their Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How bitter that cup"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No heart can conceive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which He drank quite up,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That sinners might live!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His way was much rougher"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And darker than mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did Christ, my Lord, suffer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shall I repine?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since all that I meet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall work for my good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The bitter is sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The medicine, food;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though painful at present,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twill cease before long,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then, oh, how pleasant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The conqueror’s song!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
