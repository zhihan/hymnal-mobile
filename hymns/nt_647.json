      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him for the grace sufficient,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever equal to thy need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him always for the answer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When in His dear name you plead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him for the grace to conquer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is able to subdue;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him for the power for service;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him for the blessing too."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him when dark doubts assail thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him when thy strength is small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him when to simply trust Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seems the hardest thing of all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him; He is ever faithful;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him, for His will is best;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him, for the heart of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the only place of rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust Him, then, through cloud or sunshine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All thy cares upon Him cast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the storm of life is over,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the trusting days are past."
            }
          ]
        }
      ],
