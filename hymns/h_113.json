    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him Who washed us in His blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us our sweetest songs prepare;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He sought us wandering far from God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now preserves us by His care."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One string there is of sweetest tone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reserved for sinners saved by grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis sacred to one class alone"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And touched by one peculiar race."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though angels may with rapture see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How mercy flows in Jesus’ blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not theirs to prove, as we,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cleansing virtue of this flood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though angels praise the heavenly King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And worship Him as God alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can with exultation sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“He wears our nature on the throne.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we adore Thy wondrous love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which brought Thee here to bleed and die"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou lost sinners may restore"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to the Father bring them nigh."
            }
          ]
        }
