      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是亮光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭祂而行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由祂来照亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是灵粮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喝祂并吃祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从祂得餧养。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是真理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是恩主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所称誉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是元首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所高举。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对神或对人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人的需要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全由祂解决；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是召会的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实际与内容，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命与人数"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都借祂而增。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所献上一切"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "诗歌和祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要叫基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借灵得发表；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有灵中的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通和事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都该是基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彰显的运行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奉祂名聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随祂灵活动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂恩膏"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告并赞颂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是动头脑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仪式得成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是运用灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂得彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切全忘掉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只忠于基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事应用祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直到成熟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂将万事"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都当作损失，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让祂作一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直到永世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
