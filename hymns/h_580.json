    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting ’neath His guiding hand for untrack’d days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting ’neath His shadow from the noontide rays,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting at the eventide beneath His wing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the glorious presence of our Savior King."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting in the fortress while the foe is nigh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting in the lifeboat while the waves roll high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting in His chariot for the swift, glad race,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting, always resting, in His boundless grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting in the pastures and beneath the Rock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting by the waters where He leads His flock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting, while we listen, at His glorious feet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting in His very arms, oh, rest complete!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting and believing, let us onward press;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting on Himself, the Lord our righteousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting and rejoicing, let His saved ones sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory, glory, glory be to Christ our King!"
            }
          ]
