    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们受浸归入圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸于灵中，饮于灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会全然出于那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宗教、规条尽除摒。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活在灵里，照灵而行，"
