    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m dry but I long to be swallowed by life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m weak but am coming and opening wide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spring up well! Spring up in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spring up well! Unto eternity!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The wells of salvation are flowing and free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thirsty and weary, just open and see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They are free! Come and see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They are free! Open your mouth and you’ll see!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I open a little and in comes the tide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more that I drink, the more I’m satisfied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So I come—desperate for life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I come—Lord, give me life or I die!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Zoe’s the answer and Zoe’s the key."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Zoe’s my goal and Zoe’s my need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need God’s life—to flood o’er my soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need God’s life—to fill me within and o’er flow!"
            }
          ]
        }
