    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Far below the storm of doubt upon the world is beating,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sons of men in battle long the enemy withstand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe am I within the castle of God’s word retreating,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing then can reach me, ’tis Beulah Land."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m living on the mountain, underneath a cloudless sky,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m drinking at the fountain that never shall run dry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O yes, I’m feasting on the manna from a bountiful supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I am dwelling in Beulah Land."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the stormy breezes blow, their cry cannot alarm me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am safely sheltered here, protected by God’s hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here the sun is always shining, here there’s naught can harm me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am safe forever in Beulah Land."
            }
          ]
        }
