{
  "url": "https://www.hymnal.net/cn/hymn/ch/196",
  "title": "今日我们神的灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "今 日"
            },
            {
              "chord": "",
              "text": "我 們 神 的 靈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成"
            },
            {
              "chord": "A",
              "text": "了 耶"
            },
            {
              "chord": "",
              "text": "穌"
            },
            {
              "chord": "A7",
              "text": "基 督"
            },
            {
              "chord": "D",
              "text": "靈；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死 而 復 活 的 神"
            },
            {
              "chord": "A",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "G",
              "text": "榮 升"
            },
            {
              "chord": "",
              "text": "天，"
            },
            {
              "chord": "A7",
              "text": "此 靈"
            },
            {
              "chord": "D",
              "text": "成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从那升天的耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这灵降到我灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂一切的实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都成我们的经历。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个耶稣基督灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "包含一切的成分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人二性其中存，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人生、神荣也藏隐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "死的功能及受苦、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活大能并升天、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝座、权柄和国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都在这灵中含。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凭这一切的成分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这灵运行在我灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂膏油的涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得享受主丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个包罗万有灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我一切的秘诀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多方作工在我里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神作我的一切。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "圣灵的丰满",
    "time": "4/4",
    "hymn_code": "511112321"
  },
  "raw_sections": [
    "今 日我 們 神 的 靈，",
    "成了 耶穌基 督靈；",
    "死 而 復 活 的 神人，",
    "得榮 升天，此 靈成。",
    "从那升天的耶稣，",
    "这灵降到我灵里，",
    "使祂一切的实际，",
    "都成我们的经历。",
    "这个耶稣基督灵，",
    "包含一切的成分；",
    "神、人二性其中存，",
    "人生、神荣也藏隐。",
    "死的功能及受苦、",
    "复活大能并升天、",
    "宝座、权柄和国度，",
    "全都在这灵中含。",
    "凭这一切的成分，",
    "这灵运行在我灵；",
    "借祂膏油的涂抹，",
    "我得享受主丰盛。",
    "这个包罗万有灵，",
    "是我一切的秘诀；",
    "多方作工在我里，",
    "使神作我的一切。"
  ]
}