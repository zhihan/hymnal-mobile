        {
          "segments": [
            {
              "chord": "Amaj7",
              "text": "I never"
            },
            {
              "chord": "",
              "text": "thought that God would"
            },
            {
              "chord": "D",
              "text": "be enjoyable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Amaj7",
              "text": "And my"
            },
            {
              "chord": "",
              "text": "exp'rience of Him is"
            },
            {
              "chord": "D",
              "text": "indescribable;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When first I opened up my"
            },
            {
              "chord": "E",
              "text": "heart to"
            },
            {
              "chord": "",
              "text": "Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "He came"
            },
            {
              "chord": "",
              "text": "in me and filled me"
            },
            {
              "chord": "E",
              "text": "to the"
            },
            {
              "chord": "",
              "text": "brim."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, You're"
            },
            {
              "chord": "Amaj7",
              "text": "wonder"
            },
            {
              "chord": "D",
              "text": "ful."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You're"
            },
            {
              "chord": "Amaj7",
              "text": "wonder"
            },
            {
              "chord": "D",
              "text": "ful."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I never sought Him nor I ever asked for Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometimes I wonder, am I in a heavenly dream;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I don’t deserve Him, oh, a sinner like me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My explanation, friends, it’s just His mercy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, Your mercy reached me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your mercy reached me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My friends they tell me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Don’t be too much for Him.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Just be so normal and not go to the extreme.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But I can’t help it, there is no one like Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love has touched me, so I now have meaning."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, Your love has touched me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love has wrecked me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My every moment is to live unto You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In everything dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You must now break through."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m just a vessel, You’re my treasure within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, keep spreading in my entire being"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By calling, O Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That name most precious."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I’m waiting for Your coming again."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, keep me faithful to You unto the end."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To see You face to face on that great day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis my desire that I’d go all the way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, You’re coming soon."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O lovely Bridegroom."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus."
            }
          ]
        }
      ],
      "type": "chorus"
    }
