    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在今天，更新奉献，一生随主往前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂计画实现，是我心愿。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿一生儆醒主前，等候晨星出现；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永远，同祂作王掌权！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在身体里向前迈进，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宣扬禧年遍全地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "陈明真理、涌流生命，"
            }
          ]
