        {
          "segments": [
            {
              "chord": "",
              "text": "与新约职事是一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "突破文化、语言、国籍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将人迁到基督里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各地圣徒同心合意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "齐显出新人实际！"
            }
          ]
        }
