    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then take with rejoicing from Jesus at once"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life everlasting He gives;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And know with assurance, thou never canst die"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Jesus, thy Righteousness, lives."
            }
