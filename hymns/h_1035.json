            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then doubt not thy welcome, since God has declared"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There remaineth no more to be done;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That once in the end of the world He appeared,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And completed the work He begun."
            }
          ]
        }
      ]
    },
