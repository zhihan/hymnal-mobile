{
  "url": "https://www.hymnal.net/cn/hymn/ts/512",
  "title": "七个召会真相",
  "lines": [
    {
      "segments": [
        {
          "chord": "D",
          "text": "在 啟"
        },
        {
          "chord": "",
          "text": "示 錄 第 三 章，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "顯 出 七 個 召 會 真 相；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "A",
          "text": "其 中"
        },
        {
          "chord": "",
          "text": "教 訓"
        },
        {
          "chord": "G",
          "text": "為 著"
        },
        {
          "chord": "",
          "text": "你 我，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "D",
          "text": "在 恢"
        },
        {
          "chord": "",
          "text": "復 中"
        },
        {
          "chord": "A7",
          "text": "切 莫"
        },
        {
          "chord": "",
          "text": "錯 過。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不但她们需要细听，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们更有留心必要；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为祂旨意，主发警告，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "使祂召会圣洁荣耀。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "对以弗所，主有呼召："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "起初的爱你已失去；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "只顾工作，却忘了主；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "快快悔改，恢复当初。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "必须转向主的自己，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "其他的爱都要丢抛；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "哦让我们听祂呼召，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "切勿失去宇宙至宝。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "对士每拿，受苦之子："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你曾被试，但不仅此；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "至死忠心，不可怕死，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "甘愿牺牲魂与身子。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "忠心直到天然除净，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不能看轻一切环境；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主让它们临到你身，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "有祂美意，试你爱情。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "到别迦摩，堕落更深，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "基督教与世界通婚；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "忠心的安提帕殉道，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "惟有他才敢反宗教。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们必须恐惧战兢，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "小心勿与世界行淫；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "惟有主话，能救我们，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "只要对它不断经营。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "推雅推喇跟在后面，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "她的能力并非属天；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "细面与酵混成一片，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "淫妇和兽联成一线。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们搀杂，求主光照，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主来显明所有假冒；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "除去一切或坏或好，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "直至绝对被你得着。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "从撒狄中看得清楚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "生命乃是惟一道路；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "她说她活，其实是死，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "撒狄必须接触活主。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主，引我们摸着生命，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "胜过所有死的情形；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "脱离一切宗教背景，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "满足你心，充满生命。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "非拉铁非最终出现："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "应当守住她的冠冕；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主名主话，弟兄相爱，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如此召会，为主所爱。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "弟兄姊妹完全是一，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "借着生命才有实际；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "单单持守祂的自己，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如此通行神的旨意。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "对老底嘉应当留心，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "她的堕落大有原因；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "皆因她说我富足了，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "却不知道主离开了。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们不能再像温水，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "灵要火热，一直跟随；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "丰富进入生命经历，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "得主称许同祂坐席。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主阿，今天求你光照，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "使你道路给我看见；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "擦我眼睛使我富足，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你的恢复快快实现。"
        }
      ]
    }
  ],
