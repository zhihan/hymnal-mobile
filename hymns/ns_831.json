    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Father Thou art shown to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life’s source, origination,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost beget, and propagate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy multiplication."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of Thy life are seen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In children without number;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we, as those whom Thou brought forth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise Thee: “How great a Father!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To us the Son has made Thee known"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not in a teaching; rather,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His imparting of Thy life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We know Thee as our Father."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though still we’re living in the world,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As long as we remain here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep, guard, and sanctify us in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name, O Holy Father."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We many sons in life as one"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoy Thy name’s sweet flavor;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“O Father” is our corporate cry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such sweetness now we savor!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now by Thy life and nature we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are one with one another;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our inner joy here overflows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In praises to Thee, Father!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
