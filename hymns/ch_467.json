    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你怎没有伤痕？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是受迫、孤独、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挂在树上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "四围无情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是残忍、狂妄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是受了鞭伤、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刺伤、钉伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你怎没有伤痕？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能你无伤痕？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仆人不比主人更有希望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "先生蒙羞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学生何能堂皇？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而你却是容易、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完整、无恙！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能你无伤痕？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能你无伤痕？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们为我缘故"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受人捆绑、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "枷锁、监禁、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "焚烧或是流放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或是舍身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "𫗪狮在于广场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能你无伤痕？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是没有伤痕！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是被人摧残，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饮人锋铓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们忍受忌恨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍受刀棒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却平安无事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不缺宁康，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却没有伤痕！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你却没有伤痕！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能否是因你向世俗依傍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因你怕自己利益失丧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你远远跟随，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不甚明朗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以没有伤痕？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你怎没有伤痕？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有疲倦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有安然受享？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能否有人忠心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受人奖赏？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能否有人彻底跟随羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而他没有伤痕？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
