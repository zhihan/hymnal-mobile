    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We have left captivity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s redemption’s set us free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gone are Satan, world, and sin!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From their slav’ry we’ve been freed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a new life we begin!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All our roaming days are done!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God’s people we are one!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For a home we’ve always yearned!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s the Church, God’s family!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our kinfolk we’ve returned!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Echo now that awesome sound:"
