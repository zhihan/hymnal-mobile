              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spread the news across the land!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go announce in ecstasy!"
            }
          ]
        },
        {
          "segments": [
