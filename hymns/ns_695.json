    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God is man’s appointed share!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s our lot divinely fair!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jubilee! Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once we lived a life that’s vain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we’re full, with Christ replete!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a portion we’ve regained!"
            }
          ]
        },
        {
