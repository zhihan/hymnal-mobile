            },
            {
              "chord": "A7",
              "text": "认 出"
            },
            {
              "chord": "D",
              "text": "来。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "夕 阳 早"
            },
            {
              "chord": "D7",
              "text": "西 沉，"
            },
            {
              "chord": "D",
              "text": "风 暴"
            },
            {
              "chord": "",
              "text": "已 来"
            },
            {
              "chord": "D7",
              "text": "临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "这 是"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "时 候，"
            },
            {
              "chord": "G",
              "text": "哦"
            },
            {
              "chord": "C",
              "text": "救"
            },
            {
              "chord": "G",
              "text": "主，"
            },
            {
              "chord": "D7",
              "text": "请"
            },
            {
