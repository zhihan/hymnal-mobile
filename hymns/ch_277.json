        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "這"
            },
            {
              "chord": "F♯",
              "text": "是 你"
            },
            {
              "chord": "Bm",
              "text": "聲"
            },
            {
              "chord": "E",
              "text": "音，"
            },
            {
              "chord": "D",
              "text": "我 能"
            },
            {
              "chord": "A7",
              "text": "認 出"
            },
            {
              "chord": "D",
              "text": "來。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "夕 陽 早"
            },
            {
              "chord": "D7",
              "text": "西 沉，"
            },
            {
              "chord": "D",
              "text": "風 暴"
            },
            {
              "chord": "",
              "text": "已 來"
            },
            {
              "chord": "D7",
              "text": "臨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "這 是"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "時 候，"
            },
            {
              "chord": "G",
              "text": "哦"
            },
            {
              "chord": "C",
              "text": "救"
            },
            {
              "chord": "G",
              "text": "主，"
            },
            {
              "chord": "D7",
