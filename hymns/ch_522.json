    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "再会！你这虚空欢娱："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无味消遣，儿戏乐趣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你我失口味。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真实快乐乃在十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其他娱乐尽是虚假－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主是如此定规。"
            }
          ]
        }
