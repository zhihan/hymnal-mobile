        {
          "segments": [
            {
              "chord": "",
              "text": "背起十架将你跟随，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因着你爱时常赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是我的福分。"
            }
          ]
        }
