    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship and testimony,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ministry and worship too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all helps and ministrations"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is all our service true."
            }
          ]
        }
      ]
