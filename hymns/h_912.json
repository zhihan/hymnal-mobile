    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Israelites did offer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the surplus of their land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus some produce reaped of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must be in our serving hand."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to minister is service"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both to God and others too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the surplus, e’er supplying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Off’ring Him as service true."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We on Christ, as land, must labor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Harvest Him for all our fare;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tasting Him to overflowing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ with others we may share."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to minister is service"
            }
          ]
        },
