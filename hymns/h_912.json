            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Off’ring Him as service true."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Holding Christ, as members growing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each his function must observe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ receiving, Christ partaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His Body Christ we serve."
            }
          ]
        }
      ]
    },
