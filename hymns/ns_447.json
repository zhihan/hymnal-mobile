      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a wondrous existence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all which is most blessed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You see, Lord, I am now softened"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take from You what’s best."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s not my fervent resolve, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor e’en my love untrue."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s You in me Who is doing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What I for You couldn’t do."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From every other attraction—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be faithful, break me free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though smarting, Lord, from Love’s action,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each wound draws me to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You see each end from beginning;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take me through each dark phase;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As long, Lord, as love conforms me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fits me to meet You that day."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So here we are, dear Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And may Your precious hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Accomplish all that You’ve purposed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that You’ve for us planned."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are our one destination,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are our destiny."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These days, just for our preparing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will leave what in memory?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In us, Lord, gain all You’re after,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us, Lord, gain Your Bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us, be so very blessed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us, be satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As we, Lord, become Your fullness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And You in us reside,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep us, dear Lord, in Your love-bonds,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As mutually we abide."
            }
          ]
        }
      ],
      "type": "chorus"
    }
