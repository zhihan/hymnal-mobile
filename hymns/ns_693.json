    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O, selfless love! ’Tis never unbecoming;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purest affection “seeks not its own things;”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never provoked, not counting evil doing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let this love echo forth from my heart’s strings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O noble love! In righteousness rejoicing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A love that cheers whenever truth is king;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It covers all things, and believes it all things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It hopes all things, and will endure all things."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O lasting love! It fades not, ne’er abating;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Timeless and strong, prevails o’er everything;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When knowledge fails, and gifts are unavailing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May I be found in its eternal spring."
            }
          ]
        }
