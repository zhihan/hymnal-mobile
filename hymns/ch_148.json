      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你真是配！主，你真是配！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美，因为惟有你真是配！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因着蒙福，我敬拜，我也述说"
            }
          ]
