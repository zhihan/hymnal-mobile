        },
        {
          "segments": [
            {
              "chord": "",
              "text": "女人后裔，曾如何亲临嚣尘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "败坏古蛇，伤其头，踏其身！"
            }
          ]
        }
      ],
