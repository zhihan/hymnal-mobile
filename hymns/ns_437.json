          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I consecrate myself unto You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My time, my life, my riches; future too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the One on whom I’ll pour everything,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s because I love You..."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I see..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the only One who’s within my view."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I see..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the One who I will give myself to."
