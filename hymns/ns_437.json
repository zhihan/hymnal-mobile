          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I see..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You loved me before time ever began."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I see You really love me."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the One inside who cherishes me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feeding me with milk from Your holy Word,"
