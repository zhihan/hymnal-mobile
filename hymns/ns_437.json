          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pressing onward just to fulfill Your dream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And may I nevermore turn my head back,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Cause I am just for You..."
            }
          ]
        }
