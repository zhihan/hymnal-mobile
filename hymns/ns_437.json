          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You shed Your blood that I might be redeemed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You loved me more than my words can ere tell,"
