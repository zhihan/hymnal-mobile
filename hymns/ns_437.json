    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I see..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You died and rose to save me to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I see..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A divine romance with us human beings."
