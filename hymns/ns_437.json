          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am absolutely for Your purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I know why I live..."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I see..."
