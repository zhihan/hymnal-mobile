{
  "url": "https://www.hymnal.net/cn/hymn/ts/601",
  "title": "建造是神的目标",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的生命，是人需要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的建造是神的目标。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督得胜，魔鬼蒙羞；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的计画不久要成就！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "建造我，主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不愿再我行我素。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘活在灵中，经常祷读，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多祷告。’阿们，主！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的主，满有个性；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富是我们供应。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着建造，需要生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命、建造，原相辅相成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
