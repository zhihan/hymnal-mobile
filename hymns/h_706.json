        {
          "segments": [
            {
              "chord": "",
              "text": "In holy contemplation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We sweetly then pursue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The theme of God’s salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And find it ever new;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set free from present sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We cheerfully can say—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en let the unknown morrow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring with it what it may."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It can bring with it nothing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But He will bear us through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who gives the lilies clothing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will clothe His people too:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beneath the spreading heavens"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No creature but is fed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He, who feeds the ravens,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will give His children bread."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though vine nor fig tree neither"
