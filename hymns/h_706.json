          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their wonted fruit shall bear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though all the fields should wither"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor flocks nor herds be there;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet God the same abiding,"
            }
          ]
        },
        {
