    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的疾病归耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我祂受鞭伤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的软弱祂背负，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得医治、健康。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的忧患归耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我祂全担当；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的愁苦祂消除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得平安、欢畅。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今安息于耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我的义皇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂死已使神满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂血洗我天良。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今所靠惟耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我的力量；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂活彰显神丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂生使我刚强。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我将我心归耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿祂来为王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我生命，为我主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远居我心房。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿我能像耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活出祂的模样；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我态度和步武，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远将祂显扬。"
            }
          ]
        }
      ],
