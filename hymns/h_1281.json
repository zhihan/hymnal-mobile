    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Lord was resurrected,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All religious things were through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is now our living temple,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is all our offerings too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With our Lord in resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, we’re released!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pity all the old religion—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our meetings are a feast!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet religion—oh, how subtle—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our blood is hiding out;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God must give us revelation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that unseen monster rout."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we still are too religious—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Down with our religious soul!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We would all release our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let each meeting reach the goal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the meetings, in the meetings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the mountain, at the shore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus, living Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is here—what want we more?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bury all the old religion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even Christianity—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Jesus, we have Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is our reality!"
            }
          ]
        }
