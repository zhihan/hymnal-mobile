{
  "url": "https://www.hymnal.net/cn/hymn/ch/162",
  "title": "我主你是女人后裔",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 主，"
            },
            {
              "chord": "",
              "text": "你 是 『女 人 后 裔，』"
            },
            {
              "chord": "D",
              "text": "诞 生"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为 毁"
            },
            {
              "chord": "D7",
              "text": "那 仇"
            },
            {
              "chord": "",
              "text": "敌；"
            },
            {
              "chord": "G",
              "text": "你 曾"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "取 了 人 的 性 情，"
            },
            {
              "chord": "D",
              "text": "为 藉"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受 死"
            },
            {
              "chord": "G",
              "text": "得"
            },
            {
              "chord": "D7",
              "text": "胜"
            },
            {
              "chord": "G",
              "text": "利。"
            },
            {
              "chord": "D",
              "text": "你 乃"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 神"
            },
            {
              "chord": "D7",
              "text": "成 了"
            },
            {
              "chord": "",
              "text": "肉 身，"
            },
            {
              "chord": "G",
              "text": "穿 上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "血 肉"
            },
            {
              "chord": "C",
              "text": "的 身"
            },
            {
              "chord": "D",
              "text": "体；"
            },
            {
              "chord": "G",
              "text": "你 已"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 死 毁 坏 魔 鬼，"
            },
            {
              "chord": "D",
              "text": "消 除"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死 亡"
            },
            {
              "chord": "G",
              "text": "的"
            },
            {
              "chord": "D7",
              "text": "势"
            },
            {
              "chord": "G",
              "text": "力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照神应许，你已来作"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘亚伯拉罕的后裔，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为使万人都能得到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所应许的福气。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在亚伯拉罕之先，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你是那‘我是’的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但为成就神的应许，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你竟作了他后裔。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是‘大卫后裔，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神国度被兴起；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神荣耀和神建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝座已经归于你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然你是‘大卫后裔，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他却称你为‘我主，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你原是‘大卫的根、’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘万有之主’到永古。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽‘一婴孩’生有人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘全能之神’被称呼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽是‘一子’赐给我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却被称为‘永远父。’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所应许一切福气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全在我们相信你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应许在你都是是的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是应许的实际！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
