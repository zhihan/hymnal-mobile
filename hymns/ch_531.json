        {
          "segments": [
            {
              "chord": "G",
              "text": "字 句"
            },
            {
              "chord": "",
              "text": "律 法 是"
            },
            {
              "chord": "D",
              "text": "神 见"
            },
            {
              "chord": "G",
              "text": "证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说 明 神"
            },
            {
              "chord": "D",
              "text": "是 如"
            },
            {
              "chord": "A7",
              "text": "何 的"
            },
            {
              "chord": "D",
              "text": "神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "C",
              "text": "何 圣"
            },
            {
              "chord": "G",
              "text": "洁， 如"
            },
            {
              "chord": "",
              "text": "何 公 义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "C",
              "text": "何 光"
            },
            {
              "chord": "G",
              "text": "明， 如"
            },
            {
              "chord": "D",
              "text": "何 慈"
            },
            {
              "chord": "G",
              "text": "仁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的律法是要我们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照神所是行事为人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神可来称义、悦纳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并按公义赐以福分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "律法不能赐人生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任何能力不能供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只向我们有所要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显明我们软弱无能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "律法并非神的心愿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃为显明罪过而添，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给人干犯，向人证明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人是满了罪恶过犯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "律法塞住众人之口，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并将众人圈在罪中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为将我们带到基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面蒙神恩宠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "律法乃是基督小影，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是神实际见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰满表明神是如何"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣洁、公义、仁爱、光明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是神的这位基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应我们以神生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使律法所有要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都在我们得以完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督，神这活的见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分大能生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂我向律法已死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂灵中得以成圣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
