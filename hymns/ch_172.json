{
  "url": "https://www.hymnal.net/cn/hymn/ch/172",
  "title": "哦主你是人心之乐",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 是 人"
            },
            {
              "chord": "A",
              "text": "心 之"
            },
            {
              "chord": "",
              "text": "乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "生 命"
            },
            {
              "chord": "",
              "text": "之"
            },
            {
              "chord": "D",
              "text": "源， 人"
            },
            {
              "chord": "E7",
              "text": "们 之"
            },
            {
              "chord": "A",
              "text": "光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从 地 所"
            },
            {
              "chord": "D",
              "text": "给 最"
            },
            {
              "chord": "",
              "text": "佳 福"
            },
            {
              "chord": "G",
              "text": "乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "空 心 转 来 向"
            },
            {
              "chord": "A7",
              "text": "你 仰"
            },
            {
              "chord": "D",
              "text": "望。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的真实永存不变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡求你者，你都提挈："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对寻求者，你是慈善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对寻得者，你是一切。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的粮，我已尝过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是切慕尝食不已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水的泉，我饮虽多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是渴望更多饮你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当那易变之福改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不安的灵对你渴慕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢喜，因见你的笑脸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有福，凭信将你抓住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你作我力量、维持！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我时时宁静、明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "驱尽黑暗罪恶之思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我倒下你的圣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "赞美主",
