      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Were my transgressions, sins, too great?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sins too many to forgive?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was His dear blood inadequate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Too limited to clearance give?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejoice! For Jesus rose again!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unharmed! His glory was increased!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His passage through the dark domain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could not affect Him in the least!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ's resurrection surely shows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's righteousness is satisfied!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What mercy God's great love bestows!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeeming work has been applied!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Christ His own blood shed for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God raised Him, showing His accord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Affirming Christ's work righteously!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm cleansed! Forgiven! Praise the Lord!"
            }
          ]
