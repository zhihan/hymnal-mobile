    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How real that He is coming—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come quickly, Lord, again!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We watch for His appearing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His precious Word amen."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, don’t delay His coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pray without ceasing, pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s eagerly awaiting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That coming wedding day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He longs to hear our voices,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He longs to see our face—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our voices filled with sweetness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our countenance with grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Arise, My love, My fair one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We long to hear Him say."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The voice of our Beloved—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Arise and come away!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The winter rain is over,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The flowers appear on earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The rising sun of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fills all our hearts with mirth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the time of singing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The turtle dove is heard;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our Beloved’s coming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sweetest chords are stirred."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us take the foxes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That spoil the blooming vine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our vineyards are in blossom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all, Beloved, is Thine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The day is quickly dawning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The shadows flee away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the mount of spices"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Lord may come today."
            }
          ]
        }
      ],
