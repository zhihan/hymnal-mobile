    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀盼望是基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是神的奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分神丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神带到我里。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来使我能与神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在各方面相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分祂荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂返照。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来，祂来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来将我荣耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我身体改变形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和祂身体相肖。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来，祂来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我身体需要！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我们荣耀盼望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来将我们荣耀。"
            }
          ]
        }
      ],
