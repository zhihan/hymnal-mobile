          "segments": [
            {
              "chord": "",
              "text": "在各方面相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分祂荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂返照。"
            }
          ]
        }
