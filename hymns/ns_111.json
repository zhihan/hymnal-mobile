    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But the gospel is to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God within humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit reaching me to be in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The one reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love untold—Gospel theme"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never getting old—story told eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Left the ninety-nine behind—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You searched until the lost sheep You did find,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Laid me on Your shoulders there, You bore me in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your tender loving care;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejoicing—You found me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though a small lost sheep—You gave all to come find me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweeping in my deepest parts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You lit a lamp and searched my inward heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sanctifying deep within You shined in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exposed me of my sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Repenting—now I see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’re sprinkling me—with the blood You shed for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eagerly awaiting me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I the slightest turn to Thee would make"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my life had been a wreck, You ran to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fell upon my neck"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kissing me, affectionately;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Killed the calf for me—“Let us eat and be merry.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
