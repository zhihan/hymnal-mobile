    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As it came in days of old,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the deepest hearts of men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thy martyrs died for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it come, O God, again."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Tyrant thrones and idol shrines,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let them from their place be hurled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter on Thy better reign,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wear the crown of this poor world."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what long, sad years have gone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thy Church was taught this prayer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what eyes have watched and wept"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the dawning everywhere."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Break, triumphant day of God!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Break at last our hearts to cheer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throbbing souls and holy songs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wait to hail Thy dawning here."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Empires, temples, scepters, thrones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May they all for God be won;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, in every human heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, let Thy kingdom come."
            }
          ]
