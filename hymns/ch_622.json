  "raw_sections": [
    "弟 兄和 睦 同 居，",
    "何 等 美善：",
    "像 油從 亞 倫 頭，",
    "流到衣衫；",
    "又 像露從 黑門，",
    "降在 錫安；",
    "在 此有生 命福，",
    "直到永遠！",
    "心存欢喜诚实，",
    "来赴爱筵；",
    "借此饱尝主恩，",
    "满心感赞！",
    "弟兄彼此交通，",
    "何等甘甜；",
    "盼望那日快到，",
    "不再离散。"
  ]
