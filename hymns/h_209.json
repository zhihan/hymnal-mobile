            },
            {
              "chord": "G",
              "text": "Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With sweetness fills my"
            },
            {
              "chord": "D",
              "text": "breast;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "But sweeter"
            },
            {
              "chord": "",
              "text": "far Thy"
            },
            {
              "chord": "D",
              "text": "face to"
            },
            {
              "chord": "D7",
              "text": "see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "And in"
            },
            {
              "chord": "",
              "text": "Thy"
            },
            {
              "chord": "D",
              "text": "pre"
            },
            {
              "chord": "D7",
              "text": "sence"
            },
            {
              "chord": "G",
              "text": "rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor voice can sing, nor heart can frame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor can the memory find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A sweeter sound than Thy blest Name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Savior of mankind!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Hope of every contrite heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Joy of all the meek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those who fall, how kind Thou art!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How good to those who seek!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But what to those who find? Ah, this"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor tongue nor pen can show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love of Jesus, what it is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None but His loved ones know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus! light of all below!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou fount of life and fire!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surpassing all the joys we know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all we can desire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No other source have we but Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soul-thirst to satisfy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exhaustless spring! the waters free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All other streams are dry."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, our only Joy be Thou,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Thou our Prize wilt be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, be Thou our Glory now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And through eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
