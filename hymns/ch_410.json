              "chord": "",
              "text": "得听隐密的话语。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我已看见基督荣面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "别事请勿向我题；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已听见祂的恩言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这已够使我满意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂荣耀所发光辉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有福荣面我已见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个荣耀且要成为"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的住处到永远。"
            }
          ]
        }
      ]
