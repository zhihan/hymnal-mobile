    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世人乃靠属地之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "艰苦疲困度人生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我见之光来自天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远胜午日放光明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫无遮蔽，永不衰亏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得见祂荣面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和祂爱的无限宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并祂恩典的丰满。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得见祂的奇妙荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并祂更妙的奇爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何为我已经得到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
