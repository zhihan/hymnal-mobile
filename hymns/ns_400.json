    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bit by bit, day by day, I His grace receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grief and fears, pass away! How He cares for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In petition and prayer, tell Him everything"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the peace, peace of Christ, passes all we think."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pursue towards the goal, run to gain the prize;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to know my treasured Christ, all else I’d despise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bit by bit, day by day, pow’r of God is shown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What is seen’s temporal, what’s unseen we’d know;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Treasure in jars of earth, show God’s pow’r divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sharing in Jesus’ death, that His life may shine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We do not proclaim ourselves, Christ do we proclaim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ourselves as His bondslaves, this is all our aim."
            }
          ]
        }
      ],
