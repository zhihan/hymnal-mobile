        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Love divine first drew us to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our sin and need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our sin, in deep compassion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst bleed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Risen Lord, in glory seated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are one with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast snapt the chains that bound us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are free."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Gratefully we Thee remember"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we break the bread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Symbol of Thy body given"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our stead."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink we too “the cup of blessing”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which Thy love has filled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Thy blood we have redemption"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fears are stilled."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Backward look we, drawn to Calv’ry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Musing while we sing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forward haste we to Thy coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord and King!"
            }
          ]
        }
      ]
    }
