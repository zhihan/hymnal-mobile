          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "金银、宝石、珍珠。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们接受主作人位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "占有我们全人生活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此生命长大而变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度就能显现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "珍珠性质纯洁又完美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "达到最高境界；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然经历百般的痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命却更长成。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主作我们生命、人位─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度原是主的自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在里面不断的增长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到神人合一。"
            }
          ]
        }
