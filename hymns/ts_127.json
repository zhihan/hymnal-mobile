            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不能作路旁硬地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿祂落在好土。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在好土里麦苗快生长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "果实麦子结出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而麦子须成为细面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好作神人食物。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若要成就神这心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得接受一切磨炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为一个圣洁的素祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主里紧紧相联。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从磨炼中变化成活石，"
