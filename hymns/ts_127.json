    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的国度是基督扩展："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "种子已撒我里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣就是那生命种子─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生长须加留意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "石头地乃是魂生命，"
            }
          ]
        },
        {
          "segments": [
