    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Morning Star still burning bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set aflame my inward being;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill my heart with radiant light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rays of love as Spirit bring!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sure faith when none is there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shepherd, Thou dost truly care;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living in me, Thou would’st move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my heart spread everywhere."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Morning Star—arise and shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lead my path, direct my way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the guiding cloud of yore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fire by night and cloud by day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Thy word e’er open be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through each line, shine into me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the day dawns—Thee to see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face to face—no veil between."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Morning Star, Thou dost appear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever brighter, ever near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rising, beaming, in my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a joy, this sight so clear!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy presence darkness flees;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy light, how glad are we,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Waiting, watching, seeking Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy dear coming hastening."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
