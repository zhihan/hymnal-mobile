    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You've been wandering, wand'ring for some ways,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinking in the grip of sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet He's patient still, patient as He sways,"
            }
          ]
        },
