    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "殿宇今已完全奉献，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已除所有的不洁，"
            }
          ]
        },
        {
          "segments": [
