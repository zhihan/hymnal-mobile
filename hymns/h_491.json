      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In flesh Redeemer mine Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Spirit now my Comforter."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The outward touch has passed away"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For inward union worthier."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thou art the Spirit now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself revealing ceaselessly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within my spirit I may know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy presence and reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I know Thy life surpassing far"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The knowledge Thy disciples had,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Although they walked and lived with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou on earth in flesh wast clad."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thy Spirit dwells within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How real, O Lord, Thou art to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not touched, yet more reliable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not seen, yet loved more fervently."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Holy Spirit deep within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supplies Thyself as righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As holiness, redemption full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As wisdom and as fruitfulness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit in my spirit now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supplies Thyself, unites with me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus I am all the time myself"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And constantly am also Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
