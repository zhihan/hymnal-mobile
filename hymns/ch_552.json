    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告乃是恩典所产香料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信心、爱心、苦难之花所调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藏在满了香气的话里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给神吸入，欣赏其味之甜。"
            }
