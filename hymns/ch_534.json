{
  "url": "https://www.hymnal.net/cn/hymn/ch/534",
  "title": "任何生命具有意义",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "任 何"
            },
            {
              "chord": "",
              "text": "生 命 具"
            },
            {
              "chord": "A",
              "text": "有 意"
            },
            {
              "chord": "D",
              "text": "识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都 有 生"
            },
            {
              "chord": "E7",
              "text": "命 感"
            },
            {
              "chord": "A",
              "text": "觉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "G",
              "text": "我 里"
            },
            {
              "chord": "",
              "text": "的 神 圣 生"
            },
            {
              "chord": "A",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感"
            },
            {
              "chord": "D",
              "text": "觉 更"
            },
            {
              "chord": "A",
              "text": "为"
            },
            {
              "chord": "A7",
              "text": "超"
            },
            {
              "chord": "D",
              "text": "越。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命性质越是高超，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命感觉越好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的生命最为超特，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它的感觉最高。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个神的生命感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是神的感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是在我重生灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远胜善的感觉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这一里面生命感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我最深感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我里面分辨一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "指明神之所悦。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借这里面生命感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神我有认识；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是外面挣扎所得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是自发启示。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们越在生命长大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命感觉越敏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们越凭生命行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命感觉越紧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命感觉若肯操练，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就能使灵刚强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借这里面神的感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通得以增长。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
