        {
          "segments": [
            {
              "chord": "",
              "text": "让我心切羡慕早日会见你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今日所希望只有你再来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我那日所快乐只有你同在。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，求你教训我活在你面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在早晨，在晚上，只有一世间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不让我心快乐，若我在爱慕、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在感觉、或思想无你的事物。"
            }
          ]
        }
