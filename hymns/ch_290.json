    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我每次如梦想人生的善美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱主，我求你，必须也在内！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不让我离开你去寻求快乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不让我凭自己去单独选择！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当每夜万籁静，孤单自处时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我求你，仍与我同止；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当每晨未破晓，我仍蒙昧中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你来低声唤，将我耳开通。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当每次我虔读你圣洁话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你用你荣耀照亮每一句；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我能明看见：这宝贵救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和祂的大救恩，无一不我属。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我正无倚靠跪到你座前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求垂听我祷告，赐够用恩典；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有时候因有错，祷告你不听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "别收回你同在，使我感不宁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当每次我想到属天的福气，"
