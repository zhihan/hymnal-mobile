{
  "url": "https://www.hymnal.net/cn/hymn/h/153",
  "title": "O blessed Savior, is Thy love",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "O bless"
            },
            {
              "chord": "D",
              "text": "ed"
            },
            {
              "chord": "G",
              "text": "Savior,"
            },
            {
              "chord": "D",
              "text": "is Thy"
            },
            {
              "chord": "Em",
              "text": "love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "So"
            },
            {
              "chord": "G",
              "text": "great! so"
            },
            {
              "chord": "",
              "text": "full! so"
            },
            {
              "chord": "D",
              "text": "free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fain"
            },
            {
              "chord": "Em",
              "text": "would"
            },
            {
              "chord": "B",
              "text": "we"
            },
            {
              "chord": "Em",
              "text": "have"
            },
            {
              "chord": "D",
              "text": "our"
            },
            {
              "chord": "G",
              "text": "thoughts, our"
            },
            {
              "chord": "D",
              "text": "hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "Our"
            },
            {
              "chord": "C",
              "text": "lives,"
            },
            {
              "chord": "Am",
              "text": "en"
            },
            {
              "chord": "D",
              "text": "gaged with"
            },
            {
              "chord": "G",
              "text": "Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We love Thee for the glorious worth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which in Thyself we see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We love Thee for that shameful cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Endured so patiently."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No man of greater love can boast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than for his friend to die;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou for Thine enemies wast slain!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What love with Thine can vie?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though in the very form of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With heav'nly glory crowned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst a servant's form assume,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beset with sorrow round."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst like wretched man be made"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In everything but sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we as like Thee might become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we unlike had been:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Thee in strength, in meekness, love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life in ev'ry phase;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From glory into glory changed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we behold Thy face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, we treasure in our hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The mem'ry of Thy love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ever shall Thy name to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A grateful odor prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "Praise of the Lord",
