    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，这样的神、人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生、死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真是奇中之奇！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是中心！两个永世"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "莫不举目而顾、而视"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这当受赞的！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主耶稣，你十字架"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是我的永远美家！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，当我们看那木头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心中何等感动；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱的化身死在髑髅！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，怎能不又喜又愁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看你这样苦痛！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们心裂听你呼祈："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘以利，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拉马撒巴大尼！’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我们真是该死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "该受神的忿怒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但神使你－祂的爱子－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我受苦、担罪、忍耻；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公义杀我救主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已与你同被钉钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已与你在彼丧命。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与你一同得生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你从死同甦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你是头，我们是身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同你都是属神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一同蒙神赐福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们原来只配受罚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今却同你呼喊阿爸。"
            }
          ]
        }
      ]
