    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the Spirit of Reality."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the secret. He is one with me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s in my spirit. God dispensed in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my spirit, soul and then, body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Producing reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t be fooled by outward circumstance."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, do grant us visions and a trance:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, a mingling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A mutual dwelling place of God and man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’re reality!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
