    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Way to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy blood our ransom paid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we face our Judge"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Maker unafraid."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the Throne absolved we stand:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love has met Thy law’s demand."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the living Truth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All wisdom dwells in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Source of every skill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal Verity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou great I Am! In Thee we rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True answer to our every quest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou only art true Life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To know Thee is to live"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more abundant life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That earth can never give:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Risen Lord! We live in Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou in us eternally!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We worship Thee Lord Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Savior and our King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee our youth and strength"
            }
          ]
        },
        {
          "segments": [
