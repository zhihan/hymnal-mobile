    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "苏合香与香螺，白松香与乳香─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你成分何包罗，耶稣我主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命产生众子，救赎使罪脱落，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "驱逐死亡鬼魔，功效全足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分量各相等，复活里调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加盐制成香物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "捣细置于柜前，供神圣火焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "至纯至圣之香，耶稣我主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "膏油是为我们，馨香完全为神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人神同享基督，荣耀丰富！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏油流至我们，带来福分全备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "馨香升达宝座，使神满足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "先涂抹膏油，后焚烧馨香，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此经历基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告赞美高举，出自我们经历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍贵蒙神悦纳─全是基督！"
            }
          ]
        }
      ],
