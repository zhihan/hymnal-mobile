    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你看见别人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属世的亨通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若念主应许，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心就不会动；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你所受的祝福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原来无处买，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你有了父的家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又有主的爱。"
            }
          ]
        }
