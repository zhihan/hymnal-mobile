    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My friend, I can’t explain..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How excellent His name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lovely Jesus, precious Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His name of greatest worth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As ointment sweet, poured forth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lovely Jesus, precious Jesus!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The cup of salvation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is calling on His name."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord Jesus, precious Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, He is rich to all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t wait; it’s time to call."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink in Jesus, precious Jesus."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Lamb of God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All problems He has solved."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thank You Savior, precious Savior!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your sins He took away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t wait another day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious Savior, full of mercy!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He took your sins away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t wait another day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call on Jesus, He will save you!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Impossible it seems."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But nothing’s hard for Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call on Jesus, He will save you!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Spirit too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So He can get in you."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious Spirit, call on Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Obey your being to Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just call and let Him in."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, Jesus, breathe in Jesus!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s very close to you."
