          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s nothing you must do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But call on Jesus, He’s the Spirit!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit as the air,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just call He’s everywhere."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord Jesus, breathe in Jesus!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
