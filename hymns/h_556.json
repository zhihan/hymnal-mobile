    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s my Beloved, I am His own love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He draweth me, pursue I after Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fragrant as myrrh, I’d hide Him in my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beauteous as henna*, I’d be clothed with Him;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bathe in His love, and of His fatness taste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lie on His breast, His sweetness there enjoy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love the banner, His affection shown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tenderly soothes my heart to purest joy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, my Beloved’s mine, and I am His;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am a lily and my Shepherd He;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May daybreak come, the shadows flee away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him on the mountains as a hart I’d see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Myrrh of the death with Him and frankincense,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The resurrection, permeate my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "North wind awake, and let the south wind blow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my heart’s garden pleasure to His heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d be to Him a dove that’s undefiled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a pure lily in His presence be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His, wholly His, the joy of all His joys,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He wholly mine, the Song of songs to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fair as the moon, conformed to Him I’d be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clear as the sun, unto His stature grown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my Beloved, all to please His heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my Beloved, that His life be shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art my life, and I Thine image real;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love in such union is as death most strong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er can it be destroyed or e’er replaced"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou on spices mountains come ere long."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
