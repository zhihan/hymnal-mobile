      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Amid Thy loneliness below,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What scorn and outrage Thee befell:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep shame and woe, rude blow on blow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Endured for us, Immanuel!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But oh, what grief, what agony,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When wrathful judgment’s awful spell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burst over Thee on Calv’ry’s tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s Lamb for us, Immanuel!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Arisen radiant from the dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy sorrow’s scars forever tell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Creation’s Head is He who bled—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still Jesus, still Immanuel!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en now from saints, in concord sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Celestial strains of worship well;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For, O, ’tis meet glad songs should greet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heart of love, Immanuel!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But when Thy glorious face we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How shall the bursting paean swell!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our souls shall be outpoured for Thee—"
            }
          ]
        },
        {
          "segments": [
