    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis mystery all! The Immortal dies!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can explore His strange design?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In vain the firstborn seraph tries"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To sound the depths of love Divine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis mercy all! let earth adore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let angel minds inquire no more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis mercy all! let earth adore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let angel minds inquire no more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He left His Father’s throne above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So free, so infinite His grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Emptied Himself of all but love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bled for Adam’s helpless race:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis mercy all, immense and free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For, O my God, it found out me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis mercy all, immense and free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For, O my God, it found out me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Long my imprisoned spirit lay"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fast bound in sin and nature’s night;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine eye diffused a quickening ray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I woke, the dungeon flamed with light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My chains fell off, my heart was free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I rose, went forth, and followed Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My chains fell off, my heart was free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I rose, went forth, and followed Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No condemnation now I dread;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, and all in Him, is mine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Alive in Him, my living Head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And clothed in righteousness Divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bold I approach the eternal throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And claim the crown, through Christ my own."
            }
          ]
        },
        {
