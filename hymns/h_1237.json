    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not a school or fact’ry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or a chapel in the air;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But a garden where our Lord can plant and sow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So He’s placed us all here corporately"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be His garden fair,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where He’s free to cultivate and make us grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m so happy in this lovely place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the garden growing in His grace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is no finer pleasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than to eat the living tree"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to get the living water into me."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus within the church-life garden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s a fruit-producing tree"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of life and so available to eat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So be simple, don’t be hardened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drop your concepts—eat that tree!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take in Jesus every moment—He’s so sweet!"
            }
          ]
        }
      ],
