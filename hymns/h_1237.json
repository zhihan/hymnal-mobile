            {
              "chord": "",
              "text": "Flowing God in Christ to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Quenching all our dryness, ending all our strife."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! In His garden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus flows Himself to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the full supply for us to grow in life."
            }
