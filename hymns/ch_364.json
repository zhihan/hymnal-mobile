{
  "url": "https://www.hymnal.net/cn/hymn/ch/364",
  "title": "与主同葬也一同复",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "与 主"
            },
            {
              "chord": "",
              "text": "同 葬， 也"
            },
            {
              "chord": "G7",
              "text": "一 同"
            },
            {
              "chord": "",
              "text": "复"
            },
            {
              "chord": "C",
              "text": "活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还 有 甚"
            },
            {
              "chord": "A",
              "text": "么 留"
            },
            {
              "chord": "",
              "text": "给 我 去"
            },
            {
              "chord": "D",
              "text": "作？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "只 要"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "不 再"
            },
            {
              "chord": "",
              "text": "奋 斗 击"
            },
            {
              "chord": "C",
              "text": "空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 要 我"
            },
            {
              "chord": "G",
              "text": "照 新"
            },
            {
              "chord": "D7",
              "text": "生 而"
            },
            {
              "chord": "",
              "text": "举"
            },
            {
              "chord": "G",
              "text": "动。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "荣 耀"
            },
            {
              "chord": "",
              "text": "归 于"
            },
            {
              "chord": "G",
              "text": "神！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与主我的元首同复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今在圣洁路上走着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我向前时，我就想到："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘死的人脱罪’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是何其好！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归于神！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与主同活，祂永不再死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主同行，祂永不会迟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我天天算自己已经死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以我就从捆绑得释。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归于神！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为主活着，我献上肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远归神，作祂的奴隶。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今在恩下，不在法下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪已失势，主代兴管辖。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归于神！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "靠主长大，我今真惭愧"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再题到我的已往宝贵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿意结出成圣果子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神心意，遵行神旨。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归于神！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
