    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s th’ embodiment of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him all God’s fulness dwells;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His unique supremacy"
            }
          ]
        },
        {
          "segments": [
            {
