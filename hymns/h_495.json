              "text": "And His Godhead none excels."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All God’s purpose is for Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He might be all in all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the things in heav’n and earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Himself are made withal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All creation is for Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything was made by Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by Him all things subsist,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the hub and He’s the rim."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In redemption He is all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All through Him is reconciled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His blood all things with God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in peace are domiciled."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He the great beginning is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Church’s living Head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He her life and content too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the firstborn from the dead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In God’s Kingdom He’s the King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the pow’r to Him is giv’n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His glory He shall rule"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Over all in earth and heav’n."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In new heaven and new earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Center of all things He’ll be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the Godhead and for man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout all eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God intends in everything"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ should have preeminence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And that such a Christ of all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We should now experience."
            }
          ]
        }
