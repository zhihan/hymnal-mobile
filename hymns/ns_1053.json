      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make us like Daniel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And his companions to turn this age."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your chosen ones have been taken captive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled up with worldly food"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And loving other things."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord Jesus! Make us Your overcomers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Men of prayer who live under Your rule,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejecting every idol,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled up with Your Word as food,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrated unto You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, through every fire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re with us, in us unto the end."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined to Your Word and Your heart’s desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supplied and strengthened we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pursue You with our friends."
            }
          ]
        }
