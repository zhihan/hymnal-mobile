{
  "url": "https://www.hymnal.net/en/hymn/ns/664",
  "title": "Lord, Bring Forth the One New Man",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lord, bring"
            },
            {
              "chord": "A",
              "text": "forth the"
            },
            {
              "chord": "A7",
              "text": "one new"
            },
            {
              "chord": "D",
              "text": "man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant this"
            },
            {
              "chord": "G",
              "text": "vision"
            },
            {
              "chord": "D",
              "text": "now to"
            },
            {
              "chord": "A7",
              "text": "us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Gain in"
            },
            {
              "chord": "A",
              "text": "us Thy"
            },
            {
              "chord": "A7",
              "text": "heart's de"
            },
            {
              "chord": "D",
              "text": "sire—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine ex"
            },
            {
              "chord": "G",
              "text": "pression"
            },
            {
              "chord": "A",
              "text": "glo"
            },
            {
              "chord": "A7",
              "text": "ri"
            },
            {
              "chord": "D",
              "text": "ous."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou first didst man create,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own likeness to possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine intention was that he"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take Thee in and Thee express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But, instead, man was deceived,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the knowledge-tree misled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, Thy plan he did forsake;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the self he’d live instead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So, Thou in the flesh didst come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingling with humanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living to the Father’s will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s intent accomplishing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "First, Thou to the cross didst go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our old man to terminate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, in resurrection, come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy new man to germinate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Thou in our spirit art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the inner man within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As our heart becomes Thine home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost live and rule therein."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Spread within us, Lord, we pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain the ground in all our heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’d the self deny always,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thyself Thou wouldst impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’d allow Thy peace to reign,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Body-life we’d live;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more self-directed be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy church our all we’d give."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Be the person of our heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Manifest Thyself through us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Build the saints into Thine house"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we’d bear Thine image thus."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Consummate Thy central work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we’d match Thee perfectly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus, the church would builded be—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One new man eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
