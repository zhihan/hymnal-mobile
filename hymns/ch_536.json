  "title": "神成肉身神圣的原则",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 成"
            },
            {
              "chord": "",
              "text": "肉"
            },
            {
              "chord": "A",
              "text": "身 神"
            },
            {
              "chord": "D",
              "text": "聖 的"
            },
            {
              "chord": "G",
              "text": "原 則，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃"
            },
            {
              "chord": "D",
              "text": "是 神"
            },
            {
              "chord": "",
              "text": "人 互"
            },
            {
              "chord": "E7",
              "text": "相 調"
            },
            {
              "chord": "A",
              "text": "和；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二"
            },
            {
              "chord": "D",
              "text": "者 調"
            },
            {
              "chord": "A",
              "text": "成 一"
            },
            {
              "chord": "D",
              "text": "個 奧"
            },
            {
              "chord": "G",
              "text": "祕 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照"
            },
            {
              "chord": "D",
              "text": "神 計"
            },
            {
              "chord": "",
              "text": "畫， 共"
            },
            {
              "chord": "A",
              "text": "同"
            },
            {
              "chord": "A7",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人是神在外面的表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是人里面的生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人是完全为神所占有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是借人得着显明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎乃是在人得完成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要显明神的智慧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救恩乃是借人来传扬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为使造物全都领会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这时代属灵的事工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都该是人与神合作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神与人紧密的联结，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此倚赖，互相调和。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "并非是神单独的工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也非是人单独事奉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是神、人绝对的合作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神计画得以完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个神成肉身的原则，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "须应用于一切事工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也须用于恩赐和功用，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就能共同事奉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
