    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can tell of all the wonders"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which Thy love for me has wrought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet the greatest of these wonders"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is that Thou to me art brought."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! to me Thy love has given"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thou art as my supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As true life I now may share Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy riches e’er enjoy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thy love is the expression"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy loving self divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making life so full of meaning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Harmonized with God’s design."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace of life, how all-sufficient,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is my portion day by day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m the object of Thy favor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy sweetness taste alway."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What from Thee can separate me?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt love me to the end!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! Thy love is so prevailing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en Thyself with me to blend!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We two one will be for ever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am Thine and Thou art mine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This will be my testimony:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy love we’ll ever twine!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
