    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As priestly army we are formed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To fight for Him, journey with Him, able;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whether trouble rise up or raging storm,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll care for us; we’re His numbered people."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Waters of death we fain would pass;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Defeat the foes: they are food for us!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, we now lay all aside:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self-choice, own cares, and all self-love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Christ, the meaning of our life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our goal and aim, there’s none beside;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Toward the good land, we now are poised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take, possess, Your perfect choice."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Unlike the two and one-half tribes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which settled on the land “good for cattle”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our own ease and comfort can never bribe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s choice in sight, we will enter in full!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For east of Jordan’s not our rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll cross, not settling for second-best."
            }
          ]
        }
      ],
