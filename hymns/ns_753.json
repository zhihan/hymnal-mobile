    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stretch forward! Christ we now lay hold."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Called upward to pursue goal eternal;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we take His cross and be in His mold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Body’s built; Christ is all and in all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We press on to prepare His Bride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He chose us to be His heart’s delight."
            }
          ]
