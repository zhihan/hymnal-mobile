{
  "url": "https://www.hymnal.net/cn/hymn/ts/7",
  "title": "荣耀的召会与荣耀的王",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "王 后"
            },
            {
              "chord": "",
              "text": "戴"
            },
            {
              "chord": "G",
              "text": "俄 斐"
            },
            {
              "chord": "D",
              "text": "金 饰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "站 在 你 右 手"
            },
            {
              "chord": "A",
              "text": "边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有"
            },
            {
              "chord": "D",
              "text": "君 王"
            },
            {
              "chord": "G",
              "text": "女 儿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "列 在"
            },
            {
              "chord": "",
              "text": "你 尊 贵"
            },
            {
              "chord": "E7",
              "text": "妇 女"
            },
            {
              "chord": "A",
              "text": "间。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣"
            },
            {
              "chord": "D",
              "text": "耀 的"
            },
            {
              "chord": "",
              "text": "召 会"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "将"
            },
            {
              "chord": "D",
              "text": "与 她"
            },
            {
              "chord": "",
              "text": "荣 耀 王 相"
            },
            {
              "chord": "A",
              "text": "配，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "D",
              "text": "有 妇"
            },
            {
              "chord": "G",
              "text": "女 （圣"
            },
            {
              "chord": "D",
              "text": "徒 们），"
            },
            {
              "chord": "",
              "text": "彰"
            },
            {
              "chord": "A",
              "text": "显"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "的 荣"
            },
            {
              "chord": "D",
              "text": "美。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "女子阿，你当思想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你当侧耳而听；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不要记念你的民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和父家的事情。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的美丽就显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必为王所羡慕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你当亲近敬拜祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂是你的主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "王女的华贵衣服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是用金线绣的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她在王的内宫里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实是荣华无比！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神本性一切荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐给她为穿戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她所有生活行为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神发表出来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她要被引到王前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身穿刺绣衣服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洁白美丽细麻衣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将她义行显出。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借圣灵针针刺绣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督作到身上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "穿上这荣耀衣服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得蒙君王称赏！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我们见王丰采，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将是何等喜乐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要大声赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高唱永远乐歌。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在此敬拜王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也因王后而夸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这一切享受中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀完全归祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
