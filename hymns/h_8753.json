{
  "url": "https://www.hymnal.net/en/hymn/h/8753",
  "title": "Lord Jesus, I am waiting",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lord Jesus,"
            },
            {
              "chord": "",
              "text": "I"
            },
            {
              "chord": "G",
              "text": "am waiting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To"
            },
            {
              "chord": "D",
              "text": "meet You"
            },
            {
              "chord": "A7",
              "text": "in the"
            },
            {
              "chord": "D",
              "text": "air;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Apart from Your"
            },
            {
              "chord": "G",
              "text": "soon advent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There"
            },
            {
              "chord": "D",
              "text": "is no"
            },
            {
              "chord": "A7",
              "text": "other"
            },
            {
              "chord": "D",
              "text": "prayer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "My hope"
            },
            {
              "chord": "",
              "text": "is Your"
            },
            {
              "chord": "D",
              "text": "returning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "Your nearness"
            },
            {
              "chord": "E7",
              "text": "I can"
            },
            {
              "chord": "A",
              "text": "feel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "I feel"
            },
            {
              "chord": "",
              "text": "Your 'bid"
            },
            {
              "chord": "G",
              "text": "ing presence"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In"
            },
            {
              "chord": "D",
              "text": "spirit"
            },
            {
              "chord": "A7",
              "text": "now so"
            },
            {
              "chord": "D",
              "text": "real."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in my deepest being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your speaking I can hear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your plan revealed in secret"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thankful heart does cheer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are a moment nearer!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I sense Your coming face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The day of grace now shorter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon Satan to displace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sever all cares that bind me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may be so free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll be with You transcendent;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Begone captivity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From things permissive loose me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lax snares that in me grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lest when You come to greet me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot freely go."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each hour watching, ready,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is my heart’s desire;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So not to miss that rapture,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit set afire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lest by my slumber taking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not ready for Your call,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I miss Your face, unworthy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To leave this earthly ball."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto this heart speak freshly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A warning serious:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why trade the kingdom’s glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For things not glorious?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love Him with heart o’erflowing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His coming fully mind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn loose at every moment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The earthly things you find."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though fierce might be the fighting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vile spirits all around,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fear not such threat; be ready"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To leave this foreign ground."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though darkness is increasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption’s day is near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lift up your head, for surely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Lord will soon appear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, may I love You only,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, be my only thought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejecting this world’s bribing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One in heaven sought."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All earth’s attachments loosen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, delay no more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I long to greet Your coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One whom I adore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
