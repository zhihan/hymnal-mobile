            },
            {
              "chord": "G",
              "text": "of the"
            },
            {
              "chord": "A",
              "text": "life divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He"
            },
            {
              "chord": "D",
              "text": "quickens"
            },
            {
              "chord": "",
              "text": "us and"
            },
            {
              "chord": "A",
