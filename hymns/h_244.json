              "chord": "A7",
              "text": "God's de"
            },
            {
              "chord": "D",
              "text": "sign."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As living water quenching thirst"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The stream of life He e'er supplies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Imparting Christ as life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My hungry heart He satisfies."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enlight'ning with the light of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He chases darkness far away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Imparting Christ as light divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He turns for us the night to day."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He strengthens with the pow'r of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To energize our inner man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Imparting Christ as strength divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He moves within us for God's plan."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By law of life He liberates,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And frees us from the law of sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with the nature all divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He regulates us from within."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Spirit of the life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru us abundant fruit He bears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expressing God-like attributes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To others Christ in life He shares."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit ever giving life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transforms me thus with life divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renewing all my inward parts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life He makes Christ's image mine."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, by Thy Spirit, fill me, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of Thy life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And saturate me thoroughly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till all my life is filled with Thine."
            }
          ]
        }
      ]
    }
