    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once as prodigals we wandered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our folly, far from Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thy grace, o’er sin abounding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rescued us from misery."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clothed in garments of salvation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thy table is our place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We rejoice, and Thou rejoicest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the riches of Thy grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the prodigal hast pardoned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Kissed us” with a Father’s love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Killed the fatted calf,” and made us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fit Thy purpose to approve."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“It is meet,” we hear Thee saying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“We should merry be and glad;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have found My once-lost children,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now they live who once were dead.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Abba, Father,” we adore Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While the hosts in heaven above"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en in us now learn the wonders"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy wisdom, grace, and love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon before Thy throne assembled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy children shall proclaim"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abba’s love shown in redemption,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And how full is Abba’s name!"
            }
          ]
