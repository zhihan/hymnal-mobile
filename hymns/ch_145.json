  "title": "耶稣奇妙救主",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "耶 稣，"
            },
            {
              "chord": "",
              "text": "奇 妙"
            },
            {
              "chord": "A",
              "text": "救 主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "基 督，"
            },
            {
              "chord": "",
              "text": "王 中"
            },
            {
              "chord": "D",
              "text": "王！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天 使"
            },
            {
              "chord": "A",
              "text": "敬 拜"
            },
            {
              "chord": "D",
              "text": "俯 伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们"
            },
            {
              "chord": "A",
              "text": "也"
            },
            {
              "chord": "A7",
              "text": "颂"
            },
            {
              "chord": "D",
              "text": "扬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "他 们"
            },
            {
              "chord": "",
              "text": "在 天"
            },
            {
              "chord": "E",
              "text": "承 认"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E7",
              "text": "你 乃"
            },
            {
              "chord": "",
              "text": "美 至"
            },
            {
              "chord": "A",
              "text": "极；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 们"
            },
            {
              "chord": "A",
              "text": "也 在"
            },
            {
              "chord": "D",
              "text": "爱 吟"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是"
            },
            {
              "chord": "A",
              "text": "最"
            },
            {
              "chord": "A7",
              "text": "美"
            },
            {
              "chord": "D",
              "text": "丽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地上所有安逸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽都是空穴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上缺少了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也变成黑夜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督，你的荣耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是天上光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣，你的荣耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使地也明亮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如果与你分开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命变死亡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若是有你同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死中生仍旺。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙、人类、天使，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全由你造成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而你肯降世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "穿上人性情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣！一切美善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "始终全在你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀光线，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是你自己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人若得见你面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是蒙了奇恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿你这恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也满有分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
