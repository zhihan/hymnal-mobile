    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Spirit of this Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is His human life so fine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Human virtues have been added"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Spirit all divine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What abundance in this Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rich supply for all mankind!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How mysterious! Yet how real!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such a man now lives in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into all my heart He’s spreading—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He, my human life, to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will praise unceasingly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what wonder! Oh, how glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in flesh is manifest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We the members of His Body"
            }
          ]
        },
        {
          "segments": [
