              "chord": "",
              "text": "His humanity express."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the building of God’s dwelling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We His human life possess."
            }
          ]
