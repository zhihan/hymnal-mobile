        {
          "segments": [
            {
              "chord": "",
              "text": "You who’ve given yourself, your all to God!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God are you wholly true?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you falter then, or, true to death,"
