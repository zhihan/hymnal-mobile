    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the voice of song and prayer we raise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How easy to say, We give all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till some rougher cross lies just before,"
            }
          ]
