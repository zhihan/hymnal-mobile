      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the way of the Cross, are you willing for this?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What does bearing the Cross mean to you?"
