    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I, once Thine enemy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was captured, Lord, by Thee;"
            }
          ]
        },
        {
          "segments": [
            {
