    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His life with His authority"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enthrones Him now within our hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To govern all our words and deeds"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And regulate our inward parts."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord enthroned within our hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Kingdom doth establish there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Assuring His full right to reign"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for God’s purpose to prepare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by His reign within our hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That life to us He e’er supplies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When taking Him as Lord and King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His wealth our being satisfies."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by His ruling from within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His fulness vast is testified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis when His inner kingdom rules"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Body’s blessed and edified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by His heav’nly rule within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As heav’nly citizens we live;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by submission to His rule"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expression of His reign we give."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here in this heav’nly realm we live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with this heav’nly pow’r possessed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We walk and fight in heav’nly light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the Kingdom’s manifest."
            }
          ]
        }
      ],
