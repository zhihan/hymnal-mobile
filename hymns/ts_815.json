{
  "url": "https://www.hymnal.net/cn/hymn/ts/815",
  "title": "瞧！我是人",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "瞧！我是人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是这个宇宙的意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对，我是人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是这个宇宙的意义！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神造了我，神造了我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身分崇高，身分崇高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我成为"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个宇宙中心和意义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我有基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃是我人生的意义！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这位基督，是我一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃是我人生内容、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实际和意义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会乃是─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督在这地上的彰显！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这团体人，能代表神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "管理、征服全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神的计画实现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才是真正的团体生活！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今天生活有路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着吃喝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同被建造成地方召会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当怎么办？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当赶快去告诉别人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使万民作主的门徒。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们都去把这消息"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传扬到各地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "事奉与福音",
