{
  "url": "https://www.hymnal.net/cn/hymn/ts/815",
  "title": "瞧！我是人",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "瞧！ 我"
            },
            {
              "chord": "",
              "text": "是 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 是 這 個 宇 宙"
            },
            {
              "chord": "C",
              "text": "的 意"
            },
            {
              "chord": "G",
              "text": "義，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "對， 我 是 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 是 這 個 宇 宙"
            },
            {
              "chord": "A",
              "text": "的 意"
            },
            {
              "chord": "D",
              "text": "義！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 造 了"
            },
            {
              "chord": "G",
              "text": "我， 身"
            },
            {
              "chord": "",
              "text": "分 崇"
            },
            {
              "chord": "C",
              "text": "高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我"
            },
            {
              "chord": "G",
              "text": "成 為"
            },
            {
              "chord": "",
              "text": "這 個"
            },
            {
              "chord": "D",
              "text": "宇 宙"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "中 心"
            },
            {
              "chord": "D7",
              "text": "和 意"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "義。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我有基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃是我人生的意义！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这位基督，是我一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃是我人生内容、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实际和意义。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会乃是─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督在这地上的彰显！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这团体人，能代表神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "管理、征服全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神的计画实现。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才是真正的团体生活！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今天生活有路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着吃喝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同被建造成地方召会。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当怎么办？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当赶快去告诉别人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使万民作主的门徒。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们都去把这消息"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传扬到各地。"
            }
          ]
        }
      ]
    }
  ],
