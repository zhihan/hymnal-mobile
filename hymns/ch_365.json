              "chord": "",
              "text": "脱世界、自己、罪恶！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与基督同活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的超脱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂生我里，供应我。"
            }
          ]
        }
