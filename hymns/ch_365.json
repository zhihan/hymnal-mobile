    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "历世历代所藏奥秘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今借信心可知悉："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀盼望－基督居衷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当无时不歌颂。"
            }
          ]
