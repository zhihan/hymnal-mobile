    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The birds, without barn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or storehouse, are fed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From them let us learn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To trust for our bread;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His saints what is fitting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall ne’er be denied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So long as ’tis written,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“The Lord will provide.”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His call we obey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Abram of old,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not knowing our way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But faith makes us bold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For though we are strangers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have a good Guide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And trust in all dangers:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“The Lord will provide.”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Satan appears"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To stop up our path,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fills us with fears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We triumph by faith;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He cannot take from us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though oft he has tried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The heart-cheering promise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“The Lord will provide.”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He tells us we’re weak,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hope is in vain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The good that we seek"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We ne’er shall obtain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when such suggestions"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our faith thus have tried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This answers all questions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“The Lord will provide.”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No strength of our own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor goodness we claim;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our trust is all thrown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Jesus’ dear name."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this our strong tower"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For safety we hide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is our power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“The Lord will provide.”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When life sinks apace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And death is in view,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The word of His grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall comfort us through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not fearing or doubting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ on our side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We hope to die shouting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“The Lord will provide.”"
            }
          ]
        }
      ]
    }
  ],
