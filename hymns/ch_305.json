{
  "url": "https://www.hymnal.net/cn/hymn/ch/305",
  "title": "父我知道我的一生",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "父， 我"
            },
            {
              "chord": "",
              "text": "知 道 我"
            },
            {
              "chord": "G",
              "text": "的 一"
            },
            {
              "chord": "A",
              "text": "生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "已 替"
            },
            {
              "chord": "E7",
              "text": "我 分"
            },
            {
              "chord": "A",
              "text": "好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "Em",
              "text": "有 必"
            },
            {
              "chord": "A7",
              "text": "須 發"
            },
            {
              "chord": "D",
              "text": "生 變"
            },
            {
              "chord": "G",
              "text": "更，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "不 害"
            },
            {
              "chord": "A7",
              "text": "怕 看"
            },
            {
              "chord": "D",
              "text": "到；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "求 你"
            },
            {
              "chord": "A",
              "text": "賜"
            },
            {
              "chord": "A7",
              "text": "長"
            },
            {
              "chord": "D",
              "text": "久 忠"
            },
            {
              "chord": "G",
              "text": "誠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "存"
            },
            {
              "chord": "D",
              "text": "心 討"
            },
            {
              "chord": "A7",
              "text": "你 歡"
            },
            {
              "chord": "D",
              "text": "笑。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我求要得‘有意’的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常儆醒的慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常以笑容欢迎事态，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "擦干不禁眼泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心能与它自己合拍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好来同情、安慰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我不要有不安意志，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "急忙到东到西，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要求要作几件大事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或要明白秘密；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要被待如同孩子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所往都是受意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无论我在世界何地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是有何种景况，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我与人心有个交契，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要保守发旺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要为爱出我微力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着事奉我王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我求你赐每日恩泽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能常受教；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心能从里与外调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我与你契交；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满意只占微小旁侧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若你能得荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每条路上都有虚假，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你要我忍耐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每种境遇都有十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你引我倚赖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但心靠你若是卑下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论那里可爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如果在我幸福之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何尚未求祈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是渴慕我的内衷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你能满爱意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宁愿不多为你作工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全使你欢喜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱所定我的选择，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是我的捆绳；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在暗中受你领帅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已识你的见证："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一生充满舍己的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是自由一生。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "羡慕",
