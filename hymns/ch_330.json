{
  "url": "https://www.hymnal.net/cn/hymn/ch/330",
  "title": "主爱长阔高深",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主 爱"
            },
            {
              "chord": "",
              "text": "长"
            },
            {
              "chord": "Am",
              "text": "阔 高"
            },
            {
              "chord": "D",
              "text": "深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "实"
            },
            {
              "chord": "G",
              "text": "在 不"
            },
            {
              "chord": "Am",
              "text": "能"
            },
            {
              "chord": "D7",
              "text": "推"
            },
            {
              "chord": "G",
              "text": "测；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "然， 像"
            },
            {
              "chord": "C",
              "text": "我 这"
            },
            {
              "chord": "A7",
              "text": "样 罪"
            },
            {
              "chord": "D7",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎"
            },
            {
              "chord": "G",
              "text": "能"
            },
            {
              "chord": "C",
              "text": "满"
            },
            {
              "chord": "Am",
              "text": "被"
            },
            {
              "chord": "D7",
              "text": "恩"
            },
            {
              "chord": "G",
              "text": "泽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我主出了重价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "买我回来归祂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今愿意背十字架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠心一路跟祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今撇下一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要得着基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生也、死也，想都不屑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何使我回顾？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲友、欲好、利名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "于我夫复何用？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主为我变作苦贫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今为主亦穷。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱我的救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我求祂的称是；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为祂之故，安逸变苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "利益变为损失！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的安慰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的恩主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除你之外，在天何归？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在地何所爱慕？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "艰苦、反对、飘零，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今一起不理；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只求我主用你爱情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "绕我灵、魂、身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我今求你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "施恩引导小子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立在我旁，常加我力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "过此黑暗罪世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但、世界、肉体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常试探、欺凌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若不加小子能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恐将贻羞你名！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现今时候不多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我脱尘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你一再来，我即唱说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿们！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
  "metadata": {
    "category": "奉献",
