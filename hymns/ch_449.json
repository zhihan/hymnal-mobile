{
  "url": "https://www.hymnal.net/cn/hymn/ch/449",
  "title": "灵是神的荣耀本质",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "靈 是"
            },
            {
              "chord": "",
              "text": "神 的 榮"
            },
            {
              "chord": "A",
              "text": "耀 本"
            },
            {
              "chord": "D",
              "text": "質，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也 是 神 的 神"
            },
            {
              "chord": "E",
              "text": "聖"
            },
            {
              "chord": "E7",
              "text": "所"
            },
            {
              "chord": "A",
              "text": "是；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "與 神"
            },
            {
              "chord": "",
              "text": "接 觸， 享"
            },
            {
              "chord": "B7",
              "text": "神 豐"
            },
            {
              "chord": "Em",
              "text": "富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "必 須"
            },
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "D",
              "text": "靈， 捨"
            },
            {
              "chord": "A",
              "text": "此 無"
            },
            {
              "chord": "D",
              "text": "路。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灵也是人最深部分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人里面灵是最真；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要作真人，要摸着神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须从灵，才能入门。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神是要人以灵拜灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受祂作一切供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂灵要进人灵里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人与祂灵里相联。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灵灵相交，灵灵响应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二灵调和成为一灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人灵作了神灵居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神灵成为人灵生活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "须凭人灵接触神灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能得享神的丰盛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在人灵里神灵同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能向神献上敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "福音、造就、聚会、交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都该将人带进灵中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "读经、听道或听见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都该化祷，灵中响应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里祷告，灵里事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里摸着神圣生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里长进，灵里建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里显出基督荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我愿回到灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学习摸着你的自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵、我灵不断交流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "涌流生命直到永久！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
