              "text": "我心今正住在所有"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘甜事物之源；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣，耶稣，"
            }
          ]
        },
