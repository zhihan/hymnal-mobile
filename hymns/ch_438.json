    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我已拣选主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拣选祂作喜乐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂，我心虽痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "依然会唱诗歌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂，我无别原因，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也发喜乐声音；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我所有的欢欣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是在祂心。"
            }
          ]
        }
      ],
