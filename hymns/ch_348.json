    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让这世界弃我、嫌我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主也曾被弃嫌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人面、人心，欺我、骗我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟你永远不欺骗。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你向我显出笑脸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "友虽生疏敌虽险，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我心安，处之泰然，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我得见你欢颜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "去罢！今世名利福乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！痛苦和嘲讥；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为主活着苦是喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有主喜悦损是益。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我既称祂阿爸父亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我既将心注于你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怒吼暴风、密集厚云，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都该效力成我益。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人虽逼我使我苦痛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过驱我到你前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世间苦难压我越重，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上平安越甘甜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何忧苦能将我袭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你荣面向我显？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何快乐能将我迷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若你不在它里面？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "向前！由恩进入荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信当藤牌，求当翼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永世日子就要破晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主必领我直到底。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上职事就要停止，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作客旅程就要完，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盼望就要变成事实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信变眼见，求变赞。"
            }
          ]
        }
      ],
