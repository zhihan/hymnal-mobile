    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once I yielded all my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not serving for reward;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the world has used me now;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm with the worldly horde."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once I worshipped, now I roam,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Indulging to amuse;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wasting days, repenting not;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I precious grace refuse."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once my heart loved only Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And time with Him would keep;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ardently I thought of Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In waking and asleep."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worldly favor then I shunned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The things did disregard;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now those worldly things I seek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By earth I now am marred."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At His throne I knelt each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And glory filled my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Union to His will I vowed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor wanted to depart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Happily my choice I'd lose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None else but His to seek."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But much time has passed since then;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My zeal for God is weak."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lab'ring vainly 'neath the sun"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like shadow and like wind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Far from His directed flock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To vanity did tend."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Things of earth will soon be gone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why let them rule my soul?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once I watched for His return;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why take the wav'ring role?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon the Morning Star appears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All life on earth grows short."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This foul place I then must leave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto His arms resort."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan and his world reject,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Taste new grace once again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now regain my long lost love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Refuse my shameful stain."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To His path returning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the world ignoring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory soon appearing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'd suffer willingly."
            }
          ]
        }
      ]
    }
  ],
