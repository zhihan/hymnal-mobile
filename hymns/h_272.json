      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, baptize us with Thy Spirit!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is what we need today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clothe us with Thy heav’nly power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring us under its full sway."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, baptize us in this hour!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is all our earnest cry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now on us repeat Thine answer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clothe with power from on high."
            }
          ]
