              "text": "On the day when we believe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And of Him we now are drinking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we daily Him receive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet we also must be baptized"
            }
          ]
        },
        {
          "segments": [
