        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Failure in my walk and witness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Failure in my work I see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fruitless toil, un-Christlike living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling forth no praise to Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now to Thee my soul confesses"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All its failure, all its sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the pride, the self-contentment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the \"secret faults\" within."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Save me from myself, my Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From each subtle form of pride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lead me now with Christ to Calvary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Show me I with Him have died."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No more let it be my working,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor my wisdom, love, or power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the life of Jesus only,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Passing through me hour by hour."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the fulness of Thy Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting on Him cover me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the witness borne to others."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May bring glory, Lord, to Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, in Thy Son's Name pleading."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I believe my prayer is heard;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I praise Thee for the answer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resting simply on Thy word."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praising now, praising now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast answered, Lord, I know."
            }
          ]
        }
      ]
    }
