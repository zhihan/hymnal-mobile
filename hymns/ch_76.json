{
  "url": "https://www.hymnal.net/cn/hymn/ch/76",
  "title": "主温柔所留印记",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "溫 柔 所"
            },
            {
              "chord": "G",
              "text": "留 印"
            },
            {
              "chord": "C",
              "text": "記，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照 耀 神 聖， 何"
            },
            {
              "chord": "F",
              "text": "其 美"
            },
            {
              "chord": "G",
              "text": "麗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 你 所 行 孤"
            },
            {
              "chord": "D7",
              "text": "單 路"
            },
            {
              "chord": "G7",
              "text": "中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "愛 留"
            },
            {
              "chord": "F",
              "text": "下 希"
            },
            {
              "chord": "G",
              "text": "奇"
            },
            {
              "chord": "G7",
              "text": "行"
            },
            {
              "chord": "C",
              "text": "蹤。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你这人子，光中之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有谁像你柔细、明亮？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有谁像你如此忍耐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经过这一艰苦尘埃？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "被人辱骂向不还口，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遭受苦害从无怨尤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何其和善、何其谦卑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谦和之中又何荣美！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为使罪囚得着自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "囚犯之死甘愿忍受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此你爱显明无留，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怜悯随着你血涌流。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "希奇的主，我何愿望："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更多模成你的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学你式微，像你谦卑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的脚踪终生跟随。"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
