{
  "url": "https://www.hymnal.net/en/hymn/h/197",
  "title": "How all-inclusive, Lord, Thou art",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "How all-"
            },
            {
              "chord": "",
              "text": "inclusive,"
            },
            {
              "chord": "G",
              "text": "Lord, Thou"
            },
            {
              "chord": "D",
              "text": "art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God we are in"
            },
            {
              "chord": "A7",
              "text": "Thee—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "D",
              "text": "portion"
            },
            {
              "chord": "",
              "text": "God pre"
            },
            {
              "chord": "G",
              "text": "pared for"
            },
            {
              "chord": "D",
              "text": "us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our"
            },
            {
              "chord": "G",
              "text": "all in"
            },
            {
              "chord": "A",
              "text": "all"
            },
            {
              "chord": "A7",
              "text": "to"
            },
            {
              "chord": "D",
              "text": "be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art to us God’s wisdom true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all are saved through Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art God’s only way to save,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art our only plea."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art to us our righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God requires to meet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we all are justified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we are complete."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art to us our holiness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be transformed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we all are sanctified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee we’ll be conformed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art to us redemption too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we Thy likeness bear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transfigured will our bodies be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy liberty to share."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, while we remember Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying all Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We thus would hasten Thy return"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ne’er from Thee depart."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How sweet to have this foretaste here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A taste so wonderful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet still we fain would be with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And share Thyself in full."
            }
          ]
        }
      ]
    }
  ],
