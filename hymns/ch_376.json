{
  "url": "https://www.hymnal.net/cn/hymn/ch/376",
  "title": "神所赐恩典",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神"
            },
            {
              "chord": "A",
              "text": "所 赐"
            },
            {
              "chord": "D",
              "text": "恩 典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "最 高"
            },
            {
              "chord": "A7",
              "text": "的 定"
            },
            {
              "chord": "D",
              "text": "义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E7",
              "text": "是 神"
            },
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "A",
              "text": "子 里"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E7",
              "text": "所 给"
            },
            {
              "chord": "",
              "text": "的 自"
            },
            {
              "chord": "A",
              "text": "己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 重 在 事 物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐 于"
            },
            {
              "chord": "A7",
              "text": "古 或"
            },
            {
              "chord": "D",
              "text": "今，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃"
            },
            {
              "chord": "A",
              "text": "是 神"
            },
            {
              "chord": "D",
              "text": "自 己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "作 我"
            },
            {
              "chord": "A7",
              "text": "的 永"
            },
            {
              "chord": "D",
              "text": "分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神成为肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来与人调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为给人接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而将祂得着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人借主从神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所得的恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是主自己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来住我心间。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在使徒保罗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万事如粪土，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典之于他，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只是神基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃借这恩典－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他所经历主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他为主劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "超过众使徒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督在我里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是真恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "够为我赖倚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这够用恩典"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我的灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常加我力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完成神旨意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这恩典就是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那活的基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我的一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时将我眷顾。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿我认识"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这真恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享你作恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直的增添。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
