    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主教我如何祷告！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "明白神的最好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何祷告摇动天地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着血下权利。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
