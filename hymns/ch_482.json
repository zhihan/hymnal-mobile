{
  "url": "https://www.hymnal.net/cn/hymn/ch/482",
  "title": "神的应许不能废去",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "應"
            },
            {
              "chord": "D",
              "text": "許 不"
            },
            {
              "chord": "",
              "text": "能"
            },
            {
              "chord": "Em",
              "text": "廢"
            },
            {
              "chord": "G",
              "text": "去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "句 句"
            },
            {
              "chord": "",
              "text": "都 是 堅"
            },
            {
              "chord": "G",
              "text": "定；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信 心 從"
            },
            {
              "chord": "D",
              "text": "來 不"
            },
            {
              "chord": "",
              "text": "用"
            },
            {
              "chord": "Em",
              "text": "憑"
            },
            {
              "chord": "G",
              "text": "據，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "因 神"
            },
            {
              "chord": "",
              "text": "言 出 必"
            },
            {
              "chord": "D",
              "text": "行。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "天 地"
            },
            {
              "chord": "",
              "text": "雖 能 被"
            },
            {
              "chord": "C",
              "text": "焚"
            },
            {
              "chord": "G",
              "text": "燒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小 山 大 山 雖 傾"
            },
            {
              "chord": "D",
              "text": "倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 那 相 信 主"
            },
            {
              "chord": "C",
              "text": "的 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "必 見"
            },
            {
              "chord": "",
              "text": "主"
            },
            {
              "chord": "D7",
              "text": "話 得"
            },
            {
              "chord": "G",
              "text": "成。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你心应该像亚伯兰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那样举目望天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "数算众星，轻看艰难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信心越久越坚。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天地虽能被焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小山大山虽倾倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但那相信主的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必见主话得成。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "即使黑云暂时浓厚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "云上太阳未变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要再过一点时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阳光就要显现。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天地虽能被焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小山大山虽倾倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但那相信主的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必见主话得成。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽遇试炼，仍要镇定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为在火窑中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有荣耀的神子同行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌终要击空。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天地虽能被焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小山大山虽倾倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但那相信主的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必见主话得成。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "纵然朋友都辜负你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你还当信神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为耶稣你的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍然亲近施恩。"
            }
          ]
        }
      ]
    },
