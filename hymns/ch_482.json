          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必见主话得成。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事倚赖神的大力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到被提上天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在所望所深信的，"
            }
          ]
        },
        {
          "segments": [
