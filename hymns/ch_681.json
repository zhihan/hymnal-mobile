          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在十架，我因信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "眼明亮，心平康，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从今后，我终日能欢乐！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神将人罪归祂身上，"
