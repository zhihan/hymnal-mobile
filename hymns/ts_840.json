  "title": "大好信息",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "聽！ 大"
            },
            {
              "chord": "",
              "text": "好 信 息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "驚 天"
            },
            {
              "chord": "D",
              "text": "又 動"
            },
            {
              "chord": "",
              "text": "地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是"
            },
            {
              "chord": "D7",
              "text": "神 容"
            },
            {
              "chord": "",
              "text": "器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 裝"
            },
            {
              "chord": "G",
              "text": "祂 自"
            },
            {
              "chord": "",
              "text": "己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 不 僅 造 了"
            },
            {
              "chord": "G7",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更 要"
            },
            {
              "chord": "C",
              "text": "來 充"
            },
            {
              "chord": "",
              "text": "滿"
            },
            {
              "chord": "Am",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作 你"
            },
            {
              "chord": "D",
              "text": "生 命"
            },
            {
              "chord": "D7",
              "text": "住 你"
            },
            {
              "chord": "G",
              "text": "裡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 你 享 受"
            },
            {
              "chord": "D",
              "text": "祂 實"
            },
            {
              "chord": "",
              "text": "際，"
            }
