        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "使 你"
            },
            {
              "chord": "",
              "text": "人 生"
            },
            {
              "chord": "G",
              "text": "變 美"
            },
            {
              "chord": "",
              "text": "麗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "使 你"
            },
            {
              "chord": "",
              "text": "活 著"
            },
            {
              "chord": "C",
              "text": "滿 意"
            },
            {
              "chord": "Am",
              "text": "義，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 要"
            },
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "D7",
              "text": "願"
            },
            {
              "chord": "G",
              "text": "意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "过去永远里祂早拣选你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱的催逼为你亲来地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架上被举起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经死亡祂复起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今特地来寻找你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将活神带给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将生命分给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将恩典赐给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你心满意！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你有了祂─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一神自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你全人会有生命的奇迹："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵会有活力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你魂会真欢喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你身安居指望里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要将心全开启，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要主名一呼吸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要一刹那而已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂、你就是一！"
            }
          ]
        }
