              "text": "三一神自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你全人会有生命的奇迹："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵会有活力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你魂会真欢喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你身安居指望里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要将心全开启，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要主名一呼吸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要一刹那而已，"
            }
          ]
        },
