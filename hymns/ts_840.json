      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "过去永远里祂早拣选你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱的催逼为你亲来地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架上被举起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经死亡祂复起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今特地来寻找你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将活神带给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将生命分给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将恩典赐给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你心满意！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你有了祂─"
