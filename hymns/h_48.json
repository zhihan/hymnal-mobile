    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His Father and our Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His God and ours Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He is Thy Beloved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The gladness of Thy heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re His, in joy He brings us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To share His part and place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To know Thy love and favor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The shining of Thy face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love that now enfolds us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can ne’er wax cold or dim;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him that love doth center,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we are loved in Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him Thy love and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Find their eternal rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The many sons—His brethren—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him, how near, how blest!"
            }
          ]
        }
      ],
