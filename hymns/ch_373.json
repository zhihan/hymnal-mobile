{
  "url": "https://www.hymnal.net/cn/hymn/ch/373",
  "title": "基督是神真实见证",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "基 督"
            },
            {
              "chord": "",
              "text": "是 神 真"
            },
            {
              "chord": "G",
              "text": "实 见"
            },
            {
              "chord": "D",
              "text": "证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或 在 本 质、 或 在 言"
            },
            {
              "chord": "A",
              "text": "行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "完 满"
            },
            {
              "chord": "",
              "text": "显 出 神"
            },
            {
              "chord": "G",
              "text": "的 荣"
            },
            {
              "chord": "A",
              "text": "耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "使 人"
            },
            {
              "chord": "",
              "text": "看 见 神"
            },
            {
              "chord": "A",
              "text": "的"
            },
            {
              "chord": "A7",
              "text": "性"
            },
            {
              "chord": "D",
              "text": "情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督作神完满见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远胜律法为神所作；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "律法不过只用字句，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非用生命，将神述说。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神性丰满住在基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作了祂的内容成分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是神的具体化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的住处、神的器皿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀、神的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督全都彰显展览；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的心意、神的道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也都在祂给人看见。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督现今住在我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为作我分直到永久；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在灵中将祂分享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神性一切全归我有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "经历基督",
    "time": "4/4",
    "hymn_code": "1345671765",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/494",
        "language": "cn",
        "category": "h",
        "number": "494",
        "title": "E494"
      }
    ]
  },
  "raw_sections": [
    "基 督是 神 真实 见证，",
    "或 在 本 质、 或 在 言行；",
    "完 满显 出 神的 荣耀，",
    "使 人看 见 神的性情。",
    "基督作神完满见证，",
    "远胜律法为神所作；",
    "律法不过只用字句，",
    "非用生命，将神述说。",
    "神性丰满住在基督，",
    "作了祂的内容成分；",
    "祂是神的具体化身，",
    "神的住处、神的器皿。",
    "神的荣耀、神的形像，",
    "基督全都彰显展览；",
    "神的心意、神的道路，",
    "也都在祂给人看见。",
    "基督现今住在我灵，",
    "为作我分直到永久；",
    "我在灵中将祂分享，",
    "神性一切全归我有。"
  ]
}