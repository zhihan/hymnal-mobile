{
  "url": "https://www.hymnal.net/cn/hymn/ts/719",
  "title": "新酒灌满",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "与 偶 像， 不 再"
            },
            {
              "chord": "Am",
              "text": "有 关"
            },
            {
              "chord": "",
              "text": "涉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "D7",
              "text": "是 我"
            },
            {
              "chord": "",
              "text": "们 惟 一"
            },
            {
              "chord": "G",
              "text": "的 享"
            },
            {
              "chord": "",
              "text": "受！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 不 再 受 世 界"
            },
            {
              "chord": "Am",
              "text": "的 迷"
            },
            {
              "chord": "",
              "text": "惑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召 会"
            },
            {
              "chord": "D7",
              "text": "是 我"
            },
            {
              "chord": "",
              "text": "们 实 际"
            },
            {
              "chord": "G",
              "text": "的 生"
            },
            {
              "chord": "",
              "text": "活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦， 对"
            },
            {
              "chord": "C",
              "text": "付 以"
            },
            {
              "chord": "",
              "text": "后， 何 等"
            },
            {
              "chord": "G",
              "text": "的 享"
            },
            {
              "chord": "",
              "text": "受！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高 山 上 滴 酒、 滴 酒、 滴 酒、 滴 甜 酒！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！ 当"
            },
            {
              "chord": "C",
              "text": "赞 美"
            },
            {
              "chord": "",
              "text": "主， 何 等 的 丰 富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小 山 上"
            },
            {
              "chord": "G",
              "text": "流 奶、"
            },
            {
              "chord": "",
              "text": "流 奶、"
            },
            {
              "chord": "D",
              "text": "流 奶"
            },
            {
              "chord": "G",
              "text": "子！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不再有形式，不再有老套，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新酒灌满了，自然有高潮！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "老年作异梦，少年见异象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何比聚集，更令人向往？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，对付以后，何等的享受！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高山上滴酒、滴酒、滴酒、滴甜酒！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！当赞美主，何等的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小山上流奶、流奶、流奶子！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "活在灵里面，恢复真是快，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多年被吃去，统统补回来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人人都活跃，来供应基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的聚集，越过越丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
