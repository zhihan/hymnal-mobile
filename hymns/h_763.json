    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the Omega of prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father’s great Amen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That rounds our halting periods"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To sense beyond our ken."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But in the little space between"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He lets us make the links,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with our slow and stammering speech"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Interpret what He thinks."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O First and Last, take Thou the prayers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of every trusting soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And weld them to Thine own desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To make a perfect whole."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou great Beginning of that Word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We cannot speak or spell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the short syllable we lisp"
            }
          ]
        },
        {
          "segments": [
