  "raw_sections": [
    "十架 永远得胜，",
    "阿 利路亚！ 阿利路 亚！",
    "十架 将敌除净，",
    "阿 利路 亚！阿 利路亚！",
    "阴 府 虽 极 凶 猛，",
    "世 界 虽在 翻腾，",
    "肉体 虽也 逞能，",
    "十 架使 我仍 夸胜！",
    "阿 利 路 亚！ 阿 利路 亚！",
    "基 督十 架永 得胜！",
    "阿 利路 亚！阿 利路 亚！",
    "仗 这十 架我 夸胜！",
    "十架是我生命，",
    "阿利路亚！阿利路亚！",
    "十架赐我权柄，",
    "阿利路亚！阿利路亚！",
    "胜过人情、自己，",
    "胜过世界势力，",
    "胜过一切仇敌，",
    "十架使我胜无已！",
    "阿利路亚！阿利路亚！",
    "基督十架永得胜！",
    "阿利路亚！阿利路亚！",
    "仗这十架我夸胜！",
    "十架是我旌旗，",
    "阿路利亚！阿利路亚！",
    "我要永远举起，",
    "阿路利亚！阿利路亚！",
    "软弱变为刚强，",
    "下沉变为高昂，",
    "黑暗变为明亮，",
    "十架使我得释放！",
    "阿利路亚！阿利路亚！",
    "基督十架永得胜！",
    "阿利路亚！阿利路亚！",
    "仗这十架我夸胜！"
  ]
