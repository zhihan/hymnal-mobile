    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My sickness laid on Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lash for me endured;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My weaknesses He carried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I be fully cured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I lay my griefs on Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He bears them all for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sorrows, pains, abolished;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What joy and peace I see!"
            }
          ]
        }
      ],
