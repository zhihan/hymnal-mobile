              "chord": "",
              "text": "His blood my conscience cleansed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now all my trust's in Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My strength for ev'ry hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His living shows God's riches;"
            }
          ]
        },
        {
          "segments": [
