          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果祂是从来也未"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "责备祂所见的罪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这隐密处如何美佳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果你也愿知晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请去住在祂的荫下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必尝到这味道；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若你的灵与祂相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安静住于祂荣光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的脸面就必返照"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂那荣美的形像。"
            }
          ]
        }
