      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但有一事是我所知："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我向祂诉苦情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就耐心听我心事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且鼓舞我萎灵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你想从来祂不责备？"
