    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我带着疲倦、干渴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来到祂的翅膀间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得荫庇、凉爽、快乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活泉清澈而新鲜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此投身救主胸怀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此交通满香甜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我虽尝试，也说不来"
