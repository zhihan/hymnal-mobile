    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the name to sinners dear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The name to sinners giv’n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It scatters all their guilty fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It brings them peace of heav’n."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus the prisoner’s fetters breaks,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bruises Satan’s head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pow’r into strengthless souls He speaks,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And life into the dead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, that the world might taste and see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of His grace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The arms of love that compass me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would all mankind embrace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Him as my righteousness I show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His saving truth proclaim:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis all my business here below,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To cry, Behold the Lamb!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Happy, if with my latest breath"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I may but gasp His name:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Preach Him to all, and cry in death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Behold, behold the Lamb!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
