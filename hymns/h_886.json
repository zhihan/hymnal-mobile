    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Did we in our own strength confide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our striving would be losing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were not the right Man on our side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Man of God’s own choosing:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dost ask who that may be?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ Jesus, it is He;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Sabaoth His Name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From age to age the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He must win the battle."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And though this world, with devils filled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should threaten to undo us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will not fear, for God hath willed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His truth to triumph through us:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Prince of Darkness grim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We tremble not for him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His rage we can endure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For lo! his doom is sure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One little word shall fell him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That Word above all earthly powers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No thanks to them, abideth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit and the gifts are ours"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Him who with us sideth:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let goods and kindred go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This mortal life also;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The body they may kill:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s truth abideth still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Kingdom is forever."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
