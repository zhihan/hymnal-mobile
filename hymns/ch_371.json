        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何"
            },
            {
              "chord": "G",
              "text": "其 榮"
            },
            {
              "chord": "C",
              "text": "耀、 何"
            },
            {
              "chord": "D7",
              "text": "其 神"
            },
            {
              "chord": "G",
              "text": "聖！"
            }
