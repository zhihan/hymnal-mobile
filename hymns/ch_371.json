      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你今乃是那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你大能将我释放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之律，规律、节制，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我自由、使我刚强。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你今乃是那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我变化、使我透亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我模成你的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我返照你的荣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你今乃是那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "居住、生活在我灵里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵借着我灵行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二灵相调，化合为一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主教我如何操练、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "运用我灵与你接触；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活在你的灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭你实际将你活出。"
            }
          ]
        }
      ],
