              "chord": "G",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "今 乃"
            },
            {
              "chord": "D",
              "text": "是 那"
            },
            {
              "chord": "G",
              "text": "靈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將"
            },
            {
              "chord": "C",
              "text": "我 點"
            },
            {
              "chord": "",
              "text": "活、 賜"
            },
            {
              "chord": "D",
              "text": "我 生"
            },
            {
              "chord": "D7",
              "text": "命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用"
            },
            {
              "chord": "G",
              "text": "你 豐"
            },
            {
              "chord": "C",
              "text": "富 將"
            },
            {
              "chord": "A7",
              "text": "我 供"
            },
            {
              "chord": "D7",
              "text": "應，"
            }
