    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "也许今天就有神恩言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是主要我去呼喊；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也许现在罪恶途径间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有人要我去追还；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主，你若亲自来带领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "道路虽然暗无光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的声音要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "响应你的佳音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我怎讲，我就讲。"
            }
          ]
        }
      ],
