{
  "url": "https://www.hymnal.net/cn/hymn/ch/315",
  "title": "嘴唇不洁心意不洁",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "嘴 唇"
            },
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "A7",
              "text": "洁、"
            },
            {
              "chord": "D",
              "text": "心"
            },
            {
              "chord": "A",
              "text": "意"
            },
            {
              "chord": "A7",
              "text": "不"
            },
            {
              "chord": "D",
              "text": "洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "都 是"
            },
            {
              "chord": "",
              "text": "失"
            },
            {
              "chord": "D",
              "text": "败、 都"
            },
            {
              "chord": "E7",
              "text": "是 污"
            },
            {
              "chord": "A",
              "text": "秽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "前"
            },
            {
              "chord": "A7",
              "text": "所 希"
            },
            {
              "chord": "D",
              "text": "望 今"
            },
            {
              "chord": "A",
              "text": "已"
            },
            {
              "chord": "D",
              "text": "销"
            },
            {
              "chord": "G",
              "text": "灭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "主，"
            },
            {
              "chord": "G",
              "text": "你 是"
            },
            {
              "chord": "D",
              "text": "否"
            },
            {
              "chord": "Bm",
              "text": "仍"
            },
            {
              "chord": "G",
              "text": "有"
            },
            {
              "chord": "A7",
              "text": "恩"
            },
            {
              "chord": "D",
              "text": "惠？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣洁里面仍有行为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谦卑时候仍凭自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "连我流泪为罪懊悔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都需你血把它洗涤。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "最好存心仍存自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最大舍己仍有动机，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心就是我的仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我希望可否在你？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "事奉神中，有己意思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱别人中，有己兴趣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不能动，我不敢止，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "事事处处有己寄寓。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的所有难脱旧造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要一动就有自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等羡慕你的荣耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全充满蒙福心地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不敢祈求、不敢应许，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我只能向你注视；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可否差遣你的话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你荣耀向我启示。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
