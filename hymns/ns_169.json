    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To his young men he said then,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Stay and we’ll return to you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Moriah he led him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His son Isaac, just them two."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just the son and the father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaking with one another."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Isaac said, “My father!” Abraham"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "said, “Here I am.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As You spoke with Your Father"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You bore the wood God laid on You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a lamb to the slaughter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Obedient to the death were You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious blood of a Lamb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Slain from when earth began,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Laid Your life down for Your sheep, in love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "that I might live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man of sorrows, I love You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From You men did hide their face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With no majesty to You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Despised, forsaken, and disgraced."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my sins You were crushed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love You so much."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chastened, scourged and then pierced through, my griefs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "and sorrows bore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dead in sins and offenses,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m a bruised reed—smoking flax."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet to death You were given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For of Your sheep, You’d not lose one."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like the woman, I’d weep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flow my tears at Your feet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, I just love You—dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus my Lord."
            }
          ]
        }
      ],
