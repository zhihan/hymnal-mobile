      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我性、我行，都远离神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哎哟，离神何等远！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今因我信血受恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再两下隔天渊。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我极近神，近到如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经不能再相近；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我因借着祂的儿子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得像子那么亲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神极爱我，爱到如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经不能再珍爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是如何爱祂儿子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照样爱我不稍改。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我既得着这样的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心为何仍畏避？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂之于我一往情深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂对我说：‘我属你！’"
            }
          ]
        }
      ],
