    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we would be as Abel, fully contacting You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by knowledge or concept, but by life fresh and new."
