  "title": "恩主耶稣我敬拜你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "恩 主"
            },
            {
              "chord": "",
              "text": "耶 稣， 我 敬"
            },
            {
              "chord": "A",
              "text": "拜 你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 曾"
            },
            {
              "chord": "A",
              "text": "成 为"
            },
            {
              "chord": "A7",
              "text": "『女 人"
            },
            {
              "chord": "D",
              "text": "裔；』 为"
            },
            {
              "chord": "",
              "text": "一"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "贞 洁 童 女"
            },
            {
              "chord": "A",
              "text": "所 生，"
            },
            {
              "chord": "D",
              "text": "使 神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "与 人"
            },
            {
              "chord": "",
              "text": "成 为"
            },
            {
              "chord": "D",
              "text": "一。"
            },
            {
              "chord": "A",
              "text": "有 了"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "我 们"
            },
            {
              "chord": "D",
              "text": "人 的"
            },
            {
              "chord": "",
              "text": "性 情，"
            },
            {
              "chord": "A",
              "text": "以 人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "身 分"
            },
            {
              "chord": "D",
              "text": "毁 古"
            },
            {
              "chord": "",
              "text": "蛇； 藉 著"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十 架"
            },
            {
              "chord": "G",
              "text": "击 伤"
            },
            {
              "chord": "D",
              "text": "他 头，"
            },
            {
              "chord": "G",
              "text": "为 神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "计 画"
            },
            {
              "chord": "A7",
              "text": "胜 利"
            },
            {
              "chord": "D",
              "text": "得。 主，"
            },
            {
              "chord": "",
              "text": "我"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "见 你 荣"
            },
            {
              "chord": "A",
              "text": "耀， 在"
            },
            {
              "chord": "",
              "text": "人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "美 丽"
            },
            {
              "chord": "D",
              "text": "显 照，"
            },
            {
              "chord": "",
              "text": "神 性"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣 美"
            },
            {
              "chord": "G",
              "text": "显 于"
            },
            {
              "chord": "",
              "text": "人 性，"
            },
            {
              "chord": "D",
              "text": "配 永"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "远 称"
            },
            {
              "chord": "D",
              "text": "道！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "道成肉身，来成为人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "穿上血肉的身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要毁坏魔鬼、撒但，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作了我们的代替。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神命为你起名‘耶稣，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘以马内利’人竟称；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此成为宝贵救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救恩为我全作成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我见你荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在人美丽显照，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神性荣美显于人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配永远称道！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你被称为‘末后亚当，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也被称为‘第二人；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作新造的万有元首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过旧造第一人。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这地上生活、行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "确是人子人共见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今在天上带着人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是一人显神前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
