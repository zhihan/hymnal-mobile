              "text": "配永远称道！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在神所定荣耀日子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，你要再降临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着父神丰满荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显于人前仍是人。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚至在那审判宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仍是人行审判；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且你要将这人性"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直带着到永远。"
            }
          ]
        }
      ],
