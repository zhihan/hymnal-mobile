    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已将我救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你的子民，"
            }
          ]
        },
        {
          "segments": [
