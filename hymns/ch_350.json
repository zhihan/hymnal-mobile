              "chord": "",
              "text": "凡来跟从你者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得福都无限；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我们甘愿"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且自由向前。"
            }
          ]
        }
      ],
