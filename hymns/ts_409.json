      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主阿！更多来涌流！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们生活意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你进我们里面用意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是为这流！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主转我，转更多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着生命你才能得着召会"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你心所渴慕的家。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿！使我更深转向你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生活行动说话"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "工作全凭你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放弃所有老观念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "绝对照你生命，给我恩典"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每时每刻转更多。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我转到灵里享安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一天比一天更新；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我全人最深处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来安家，主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深愿你的同在"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "包围"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我全人。"
            }
          ]
        }
      ],
