    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂召会我们同明白，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂那丰盛生命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我们里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是外面的挣扎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃深处的平安，漫溢全人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并流出活水江河。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同众圣徒我就能放胆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "追求享用持定"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这丰盛生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主外一切的事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丢背后全弃绝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到召会"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全充满神生"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "命。"
            }
          ]
        }
