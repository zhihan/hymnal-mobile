{
  "url": "https://www.hymnal.net/en/hymn/h/975",
  "title": "It was a garden in the primal age",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "It was"
            },
            {
              "chord": "",
              "text": "a"
            },
            {
              "chord": "G",
              "text": "garden"
            },
            {
              "chord": "A",
              "text": "in the"
            },
            {
              "chord": "A7",
              "text": "primal"
            },
            {
              "chord": "D",
              "text": "age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But at the"
            },
            {
              "chord": "G",
              "text": "end it"
            },
            {
              "chord": "",
              "text": "is a city"
            },
            {
              "chord": "A",
              "text": "square;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Creation's"
            },
            {
              "chord": "",
              "text": "center in the"
            },
            {
              "chord": "E7",
              "text": "garden"
            },
            {
              "chord": "A",
              "text": "was,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "God's building"
            },
            {
              "chord": "G",
              "text": "issues"
            },
            {
              "chord": "",
              "text": "in the"
            },
            {
              "chord": "A",
              "text": "ci"
            },
            {
              "chord": "A7",
              "text": "ty"
            },
            {
              "chord": "D",
              "text": "fair."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Both in the garden and the city fair"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A river and the tree of life are seen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ typifying as the life supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit showing as the living stream."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Both in the garden and the city bright"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Three kinds of precious substances are found;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There are the gold, the pearls, and precious stones"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which for the building work of God abound."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But in the garden all these precious things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are just materials lying in the earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in the city all are builded up"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And form that dwelling of transcendent worth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man in the garden of the clay was formed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In nature as the Lord created him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The tree of life was then without the man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not having yet become his life within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But in the city glorious the tree"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the corporate “man” doth grow, thereby"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Revealing Christ Himself as life divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Being to man his inward life supply."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis for the city man is wrought upon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Therefore regenerated and transformed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To purest gold, to pearls and precious stones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Christ’s own Body, to Himself conformed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the garden also was a bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who was to Adam as his counterpart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lastly, the city is itself the bride"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Christ’s own fulness, precious to His heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The city is God’s building work replete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A composition of the justified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A habitation it affords to God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And is to Christ His own beloved bride."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis God’s expression, ultimate and full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Corporate and universal, marvelous;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s glory it completely manifests,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And is Christ’s counterpart most glorious."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
