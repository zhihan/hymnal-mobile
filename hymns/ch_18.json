{
  "url": "https://www.hymnal.net/cn/hymn/ch/18",
  "title": "父神为着你的公义",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "父 神，"
            },
            {
              "chord": "",
              "text": "为 著"
            },
            {
              "chord": "G",
              "text": "你 的"
            },
            {
              "chord": "A",
              "text": "公"
            },
            {
              "chord": "D",
              "text": "义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "俯 伏"
            },
            {
              "chord": "E7",
              "text": "敬 拜"
            },
            {
              "chord": "A",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 既"
            },
            {
              "chord": "",
              "text": "因 主"
            },
            {
              "chord": "G",
              "text": "称 我"
            },
            {
              "chord": "A",
              "text": "为"
            },
            {
              "chord": "D",
              "text": "义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "谁 能"
            },
            {
              "chord": "",
              "text": "将 我"
            },
            {
              "chord": "E7",
              "text": "良 心"
            },
            {
              "chord": "A",
              "text": "抑？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 既 公 义， 你 又 信 实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "靠 你"
            },
            {
              "chord": "",
              "text": "公 义"
            },
            {
              "chord": "E7",
              "text": "我 站"
            },
            {
              "chord": "A",
              "text": "立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "在 你"
            },
            {
              "chord": "",
              "text": "永 无"
            },
            {
              "chord": "G",
              "text": "半 点"
            },
            {
              "chord": "D",
              "text": "不 义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "谁 能"
            },
            {
              "chord": "D",
              "text": "转 动"
            },
            {
              "chord": "A",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "义"
            },
            {
              "chord": "D",
              "text": "臂？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你将我罪已归耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的公义将祂诛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的律法所有要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂照你义全满足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从祂你已得到赎价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我已得释放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这极公至义的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能向我再讨偿？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "公义父神，你已接受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣作我的代替；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是义的受你审判，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代替我这不义的。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今坐在你的右边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你公义的明证；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已使你完全满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你义使你难变更。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着基督赎罪宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着你的义；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你这义遮护之下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能将我摇移。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你且使我成为你义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何人能再定我罪？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来在那圣城撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我这见证永不颓！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
