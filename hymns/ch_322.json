{
  "url": "https://www.hymnal.net/cn/hymn/ch/322",
  "title": "求主把我捆绑",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "求 主"
            },
            {
              "chord": "",
              "text": "把 我 捆"
            },
            {
              "chord": "G",
              "text": "绑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "才 得"
            },
            {
              "chord": "",
              "text": "著 释"
            },
            {
              "chord": "A",
              "text": "放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿"
            },
            {
              "chord": "D",
              "text": "主 迫"
            },
            {
              "chord": "",
              "text": "我 向"
            },
            {
              "chord": "E7",
              "text": "主 缴"
            },
            {
              "chord": "A",
              "text": "械，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 才 得"
            },
            {
              "chord": "E7",
              "text": "胜 奏"
            },
            {
              "chord": "A",
              "text": "捷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "当"
            },
            {
              "chord": "D",
              "text": "我 倚"
            },
            {
              "chord": "",
              "text": "靠 自"
            },
            {
              "chord": "G",
              "text": "己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "E7",
              "text": "就 失"
            },
            {
              "chord": "",
              "text": "败 危"
            },
            {
              "chord": "A",
              "text": "亟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "当"
            },
            {
              "chord": "D",
              "text": "主 膀"
            },
            {
              "chord": "",
              "text": "臂 将"
            },
            {
              "chord": "A",
              "text": "我 监"
            },
            {
              "chord": "D",
              "text": "禁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "手 就"
            },
            {
              "chord": "A7",
              "text": "更 有"
            },
            {
              "chord": "D",
              "text": "劲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心未交主时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真是软弱愚痴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己所愿自己不行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万事漂流无定；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主若未加锁链，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就难自由进前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主慈爱将它奴隶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它才会得能力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的生命未死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终身总是丧失："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜少败多，实无能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时为肉体叹息。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我若没有死过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就难以活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我脱离自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才会完全得你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今认识了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也略知道自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以今后真不愿意"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再借天然能力。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主永远的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我生命全钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我治死肉体行为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主兴盛，我衰微。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
