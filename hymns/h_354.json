    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Alas, ill-ordered shows the dreary room;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The household stuff lies heaped amidst the gloom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The table empty stands, the couch undressed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ah, what a welcome for th' Eternal Guest!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet welcome, and tonight; this doleful scene"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is e'en itself my cause to hail Thee in;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This dark confusion e'en at once demands"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own bright presence, Lord, and ord'ring hands."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I seek no more to alter things, or mend,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the coming of so great a Friend;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All were at best unseemly; and 'twere ill"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond all else to keep Thee waiting still."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, not to find, but make this troubled heart"
