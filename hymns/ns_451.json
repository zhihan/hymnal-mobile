      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So also deeper into Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d make my home, my rest in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A pillar in Thy temple be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And stay in Thee eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precious blood was shed that we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could closer, closer, closest be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection brought to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we might be as one as Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My lovely Lord, my dear Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In trust I open ev’ry room;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This mind, emotion, will be Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou hast rest, that rest is mine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh mystery of mysteries—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou in me and I in Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church, Thy tabernacle, we;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our temple, Thou eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make Thy home more ev’ry day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til one with Thee in ev’ry way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til on me write Thy holy name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til on me write Thy city’s name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art me and I am Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As lovers coinhering, we;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon then shall come eternity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When God and man dwell mutually."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
