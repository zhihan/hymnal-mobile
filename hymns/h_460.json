      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the world despise and leave me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They have left my Savior, too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Human hearts and looks deceive me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art not, like man, untrue;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, while Thou shalt smile upon me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God of wisdom, love, and might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foes may hate, and friends disown me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Show Thy face, and all is bright."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man may trouble and distress me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twill but drive me to Thy breast;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life with trials hard may press me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ will bring me sweeter rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O ’tis not in grief to harm me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While Thy love is left to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O ’twere not in joy to charm me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were that joy unmixed with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Haste then on from grace to glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Armed by faith and winged by prayer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s eternal day’s before thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s own hand shall guide thee there."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon shall close thy earthly mission,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Swift shall pass thy pilgrim days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hope shall change to glad fruition,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith to sight, and prayer to praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
