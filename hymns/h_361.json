    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Light divine, by Christ displayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Source of all light, who flesh became,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shed Thy bright beams upon my head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burn in my heart a constant flame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Truth divine, by Christ made known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All truth must Thy reflection be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within my heart set up Thy throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy freedom make me free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Cross divine, by Christ endured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou cross on which He groaned and died,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And man’s redemption thus secured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy blest shadow let me hide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Peace divine, by Christ bestowed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heavenly dove to earth come down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May He within make His abode,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My life with His dear presence crown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Joy divine, by Christ possessed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For which He did the cross endure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill with Thyself and make me blest,"
            }
          ]
        },
        {
          "segments": [
            {
