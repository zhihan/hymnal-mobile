    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The whole creation now beneath"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The weight of bondage sore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In seeing God’s sons manifest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is freed forevermore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th’ eternal purpose of our God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will be full manifest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The hope of glory now concealed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is then to all expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The briars will be myrtle trees,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thorn will be no more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And peace will reign where war did rage,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The curse will then be o’er."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis then the trees shall clap their hands,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the hills shall sing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This glorious freedom shall God’s sons"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus manifested bring."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s deepest work of grace goes on"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day, though hidden, small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until that day, when manifest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is revealed to all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By then God’s wrought His finished work:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself dispensed to us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all creation ’round admires"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His product, glorious."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The angels that before our God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In brightest splendor stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will join the universal praise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him for all He’s planned."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And of the devil, of his end . . . ?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll praise the Lord for how"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just distant smoke is all that’s left"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all that troubles now."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So shall we not delight to give"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ourselves in every way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And let the Lord dispense Himself"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into us more each day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The grace that we receive each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though hidden oft, and small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is God Himself wrought into us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That day to shine o’er all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
