    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He came from His blest throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation to bestow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But men made strange, and none"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The longed-for Christ would know:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But oh, my Friend,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Friend indeed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who at my need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life did spend."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometimes they strew His way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His sweet praises sing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resounding all the day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hosannas to their King:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then “Crucify!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is all their breath,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for His death"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They thirst and cry."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They rise and needs will have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My dear Lord made away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A murderer they save,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Prince of life they slay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet cheerful He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To suffering goes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He His foes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From thence might free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In life, no house, no home"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord on earth might have;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In death, no friendly tomb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But what a stranger gave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What may I say?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heav’n was His home;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But mine the tomb"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherein He lay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here might I stay and sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No story so divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never was love, dear King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never was grief like Thine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is my Friend,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In whose sweet praise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I all my days"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could gladly spend."
            }
          ]
        }
      ],
