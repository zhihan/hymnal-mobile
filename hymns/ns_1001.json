{
  "url": "https://www.hymnal.net/en/hymn/ns/1001",
  "title": "Lord, Grant Me a Willing Heart",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grant me a willing heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To love You without reserve;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always open to You within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all of Your riches I may gain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rekindle my love for You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fan it with burning flame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, it’s just by Your mercy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have not been consumed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my love for You burn brightly anew"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each moment Your name I call;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the dawn of the morning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I long to be in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your presence, dear Lord."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sanctify me, O Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the tides of the world;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me an open vessel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Useful to the Master."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hide not Thy face from me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I shall surely seek Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From this day until eternity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your countenance I’ll behold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
