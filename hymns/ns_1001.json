    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bridge:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my heart constantly fails,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Lord, Your grace still sustains;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love constraining forever will prevail."
            }
          ]
        }
