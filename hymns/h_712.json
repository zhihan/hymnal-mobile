              "text": "cares"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To thee are burdens,"
            },
            {
              "chord": "E",
              "text": "thorns"
            },
            {
              "chord": "E7",
              "text": "and"
            },
            {
              "chord": "A",
              "text": "snares;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "They cast"
            },
            {
              "chord": "",
              "text": "dishonor"
            },
            {
              "chord": "B7",
              "text": "on the"
            },
            {
              "chord": "Em",
              "text": "Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "And contra"
            },
            {
              "chord": "D",
              "text": "dict His"
            },
            {
              "chord": "A",
              "text": "gracious"
            },
            {
              "chord": "D",
              "text": "word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought safely by His hand thus far,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why wilt thou now give place to fear?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How canst thou want if He provide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or lose thy way with such a Guide?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When first before His mercy-seat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst to Him thine all commit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gave thee warrant from that hour"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To trust His wisdom, love, and power."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Did ever trouble yet befall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He refuse to hear thy call?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And has He not His promise passed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That thou shalt overcome at last?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He who has helped me hitherto"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will help me all my journey through,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And give me daily cause to raise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Ebenezers to His praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though rough and thorny be the road,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It leads thee on, apace, to God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then count thy present trials small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God will make amends for all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
