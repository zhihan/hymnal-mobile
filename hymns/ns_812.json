  "title": "Don’t Say, “Oh No!”",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Time to get up, but you want to sleep;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Test is tougher than you thought it would be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bus runs early when you’re running late;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feels like there’s too much on your plate."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But you can"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Call on Jesus! (Call on Jesus!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord Jesus! (O Lord Jesus!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t say, “Oh no!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call, “O Lord!”"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Homework to do, and essays to write;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seems like every little thing is a fight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Car’s not starting and the outlook’s bleak;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t know how you’ll get through the week."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But you can"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
