    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bridge (after Chorus 2):"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Any situation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can turn out to your salvation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As long as you’re exclaiming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life-giving exclamation! (O Lord Jesus!)"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Call on Him softly, call right out loud;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call alone, or you can call with a crowd."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call His name and make His riches yours;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t confuse “Oh no!” and “O Lord!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve got to"
            }
          ]
