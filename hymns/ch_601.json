              "chord": "",
              "text": "来实行合一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在基督那灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们确是一；"
            }
