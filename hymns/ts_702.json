{
  "url": "https://www.hymnal.net/cn/hymn/ts/702",
  "title": "是你吗？",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "Am",
              "text": "为 何"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "Dm",
              "text": "常 是"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "F",
              "text": "没 有"
            },
            {
              "chord": "",
              "text": "喜"
            },
            {
              "chord": "Em",
              "text": "乐，"
            },
            {
              "chord": "Am",
              "text": "天 天"
            },
            {
              "chord": "",
              "text": "都"
            },
            {
              "chord": "Dm",
              "text": "平 淡"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "缺"
            },
            {
              "chord": "Am",
              "text": "少 音"
            },
            {
              "chord": "E7",
              "text": "乐？"
            },
            {
              "chord": "Am",
              "text": "是 否"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "自 己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把"
            },
            {
              "chord": "Em",
              "text": "你 捆"
            },
            {
              "chord": "Am",
              "text": "绑，"
            },
            {
              "chord": "Dm",
              "text": "生 活"
            },
            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "G7",
              "text": "圈 子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "窄"
            },
            {
              "chord": "C",
              "text": "小 无"
            },
            {
              "chord": "E7",
              "text": "望，"
            },
            {
              "chord": "Am",
              "text": "所 以"
            },
            {
              "chord": "",
              "text": "才"
            },
            {
              "chord": "Dm",
              "text": "这 样"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惆"
            },
            {
              "chord": "E7",
              "text": "怅？ （哎"
            },
            {
              "chord": "Am",
              "text": "阿！） 我"
            },
            {
              "chord": "",
              "text": "心 所 爱， 我 心 所"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱，"
            },
            {
              "chord": "Dm",
              "text": "快 快"
            },
            {
              "chord": "",
              "text": "前"
            },
            {
              "chord": "Am",
              "text": "来！ 享"
            },
            {
              "chord": "",
              "text": "受 我 们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享 受 我 们，"
            },
            {
              "chord": "Dm",
              "text": "就 是"
            },
            {
              "chord": "",
              "text": "现"
            },
            {
              "chord": "Am",
              "text": "在！ 神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "的 需 要， 你 的 需 要， 都 得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "著 满"
            },
            {
              "chord": "F",
              "text": "足。"
            },
            {
              "chord": "Am",
              "text": "当 你"
            },
            {
              "chord": "",
              "text": "投 流"
            },
            {
              "chord": "Dm",
              "text": "中， 只"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为 著 召"
            },
            {
              "chord": "E7",
              "text": "会，"
            },
            {
              "chord": "Am",
              "text": "必 得"
            },
            {
              "chord": "",
              "text": "著"
            },
            {
              "chord": "Dm",
              "text": "荣 耀"
            },
            {
              "chord": "",
              "text": "冠"
            },
            {
              "chord": "E7",
              "text": "冕。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿 利"
            },
            {
              "chord": "Am",
              "text": "路 亚！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你常对别人诉说愁苦："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何我常是走投无路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总不能冲破愁云惨雾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奋斗又挣扎却不明朗。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！何日方能刚强！（哎阿！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因你不知何为自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常常把自己陷在泥淖！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因你不知宝贵生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因你不肯把祂释放！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以才凄凄凉凉！（哎阿！）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "（二）追寻"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你常在那里寻寻觅觅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也曾觉主是那样甜蜜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却不让主占你心房，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总要留一点为你着想。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以才时变刻翻！（哎阿！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也在主前立定心志，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除了祂之外别无所知，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但当祂向你有所要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就觉为难畏缩退后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "担不起损失剥夺！（哎阿！）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是常常感到困惑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何你自己这样软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是因你羡慕得些‘权能，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还是你只望为祂‘工作，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失去了单纯生活！（哎阿！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你或有‘得胜’你就骄傲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不然就满了灰心叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只因你仍要自己属灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忘却了来向‘他们’投依，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失去了供应能力！（哎阿！）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "（三）生活"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你也曾多次向主说过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不来是不安，来又不妥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盼望在会中得点甚么，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "补满自己的贫穷软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却不知如何得着！（哎阿！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也许你却是逢会必到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也跟着别人‘阿们’喊叫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你确又是虚空无聊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只因你是在履行‘宗教，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知道生命逍遥！（哎阿！）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你见别人投身流中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也曾多次隔岸观望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见主在祝福你就拍掌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见别人失败你也失望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你却总是这样！（哎阿！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你私下盼望多些责任，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫你名声远播四方，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常给人‘帮助’得着‘赞赏，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常流出‘关切’得着‘颂扬，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的主却不这样！（哎阿！）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    }
  ],
