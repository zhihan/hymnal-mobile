{
  "url": "https://www.hymnal.net/cn/hymn/ts/921",
  "title": "成为神的杰作",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 在"
            },
            {
              "chord": "",
              "text": "子"
            },
            {
              "chord": "C",
              "text": "里 成"
            },
            {
              "chord": "G",
              "text": "为 肉"
            },
            {
              "chord": "",
              "text": "身， 乃"
            },
            {
              "chord": "A",
              "text": "神 所"
            },
            {
              "chord": "A7",
              "text": "赐 宏"
            },
            {
              "chord": "D7",
              "text": "恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基"
            },
            {
              "chord": "G",
              "text": "督 丰"
            },
            {
              "chord": "C",
              "text": "富 享"
            },
            {
              "chord": "G",
              "text": "受 不"
            },
            {
              "chord": "",
              "text": "尽， 供"
            },
            {
              "chord": "C",
              "text": "应 全"
            },
            {
              "chord": "D7",
              "text": "备 常"
            },
            {
              "chord": "G",
              "text": "新。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此"
            },
            {
              "chord": "B7",
              "text": "恩 浩"
            },
            {
              "chord": "",
              "text": "大， 超"
            },
            {
              "chord": "Em",
              "text": "人 能"
            },
            {
              "chord": "",
              "text": "度， 奇"
            },
            {
              "chord": "D",
              "text": "妙， 难"
            },
            {
              "chord": "A7",
              "text": "尽 述"
            },
            {
              "chord": "D7",
              "text": "说；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "否"
            },
            {
              "chord": "G",
              "text": "则 灭"
            },
            {
              "chord": "C",
              "text": "亡 之"
            },
            {
              "chord": "G",
              "text": "子 如"
            },
            {
              "chord": "",
              "text": "我， 怎"
            },
            {
              "chord": "C",
              "text": "能 成"
            },
            {
              "chord": "D7",
              "text": "神 杰"
            },
            {
              "chord": "G",
              "text": "作？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "受造之物受缚被囚，殷殷热切等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的众子显现时候，得享永远自由。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我神定旨永远深广，就要完全明朗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀盼望如今隐藏，那时全得显彰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "番石榴树代替蒺藜，松树顶替荆棘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和平掌权，战争消弭，咒诅再无踪迹。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大山小山发声欢呼，树木拍掌鼓舞；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀自由得以进入，当神众子显出。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的深恩细致陶甄，每日作工我身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分赐之工今虽隐藏，那日要显无尽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的自己在我加添，神圣分赐无间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受造万有无不赞叹，当神杰作展现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得赎宇宙欢呼颂称，神圣计画成功！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千万天使和声歌颂，无边荣耀之中。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恶者虽曾肆无忌惮，终如烟消云散；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟主智慧卓越超凡，配得永远称赞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为此我们欣然奉献，配合主的心愿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接受祂的分赐、充满，逐日让祂扩展。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿今日生活点滴，尽是恩典滴沥；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神自己加添我里，那日光荣无比。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
