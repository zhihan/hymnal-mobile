    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Brother’s inherited all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God made Him to rule His affairs"
            }
          ]
