              "text": "之 主，"
            },
            {
              "chord": "Am",
              "text": "向 我"
            },
            {
              "chord": "",
              "text": "吹"
            },
            {
              "chord": "Dm",
              "text": "气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将 你 活 泉"
            },
            {
              "chord": "F",
              "text": "向 我"
            },
            {
              "chord": "G",
              "text": "开"
            },
            {
              "chord": "A7",
              "text": "启，"
            }
