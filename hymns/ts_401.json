    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，何希奇，你在我里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不必天上阴间寻你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一回灵里就得见你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵灵接触毫无距离。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的在天中保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是我的灵中恩膏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡你神前为我所作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都在我灵给我摸着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我心何等不忠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常虽深感仍不顺从；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主眷怜、吹气、推动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我全人都尽功用。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我灵里憋气，下沉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "难将你恩向人言陈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你从我里面吹气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我完全充满了你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
