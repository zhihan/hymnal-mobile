{
  "url": "https://www.hymnal.net/cn/hymn/ch/302",
  "title": "主阿何等奥秘",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主 阿，"
            },
            {
              "chord": "C",
              "text": "何 等"
            },
            {
              "chord": "G",
              "text": "奧 祕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 靈"
            },
            {
              "chord": "A7",
              "text": "在 我"
            },
            {
              "chord": "D",
              "text": "靈！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "也 是"
            },
            {
              "chord": "D",
              "text": "何 等"
            },
            {
              "chord": "Em",
              "text": "實"
            },
            {
              "chord": "G",
              "text": "際，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "二 靈"
            },
            {
              "chord": "D7",
              "text": "成 一"
            },
            {
              "chord": "G",
              "text": "靈！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我能靠灵行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因灵而属灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也能凭灵事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以灵敬拜灵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里接触相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵就刚强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里读经、祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵就高昂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你使我灵强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "点活别人灵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我灵能高昂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放别人灵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "使我每一出声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就能推动灵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论有何动静，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都能供应灵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿我灵一动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人灵就开启！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿我灵一冲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人灵就提起！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，求你垂顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多用灵来吹！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人人灵都丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人人灵加倍！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "羡慕",
    "time": "4/4",
    "hymn_code": "55661177165",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/782",
        "language": "cn",
