      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "里面意思虽要神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "外头行为总可恨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱莫能助将奈何！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "事与愿违真束缚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神律才显罪便在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "善念一动恶也来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肢体的律掳了我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挣扎奋斗终难脱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "多次跌倒多次起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时而立志时而遗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要求得胜反退溃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿意成圣倒污秽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我实已是卖给罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我真已经无能为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的肉体没良善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的自己乃黑暗。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今已略识自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实在没有一点力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的性情真古怪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的生命全败坏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己诡诈不可靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉体软弱不能保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今所有的盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都在耶稣我的王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主十架治死我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我靠主而生活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主圣灵充满我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我凭主而工作；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿主的死在我身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天作工比前深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我自己全消灭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让主生命来提挈。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的光景真是苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能使我不为奴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救我脱离取死身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能够常得胜？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣为我流宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督作我的圣洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今接祂为生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今服祂的号令。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "完全圣洁无恶意！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全顺服无自己－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再觉羞到父前！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再难过见主面！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，这生命何等高！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一信主恩即临到！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢主今听呼求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我完全得自由。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
