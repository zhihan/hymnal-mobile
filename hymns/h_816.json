    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is only knowledge to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If we in the letter read,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when reading in the spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is truly life indeed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the knowledge in the letter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only brings us into death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the Word in spirit taken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gives to us the quickening breath."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If we miss the Lord in Scripture,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is just as knowledge vain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when Christ we touch within it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then His life we may obtain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we read, the Lord not touching,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis but mental stimulus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when Christ we touch by reading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It becometh life in us."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the knowledge of the Scriptures"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into life must be transformed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the mental understanding"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the spirit must be formed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Scriptural understanding"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must become the life received,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the knowledge of the letters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the spirit be conceived."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to touch the Word for knowledge"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to take the very way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By which Eve was lured by Satan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by knowledge led astray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But as life to take the Scripture"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the tree of life to eat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the Word we must be taking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the spirit as our meat."
            }
          ]
        }
      ]
