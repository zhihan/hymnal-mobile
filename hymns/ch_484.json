  "title": "当向标竿力前",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "當 向"
            },
            {
              "chord": "",
              "text": "標"
            },
            {
              "chord": "C",
              "text": "竿 力"
            },
            {
              "chord": "G",
              "text": "前！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "雖"
            },
            {
              "chord": "C",
              "text": "然 孤"
            },
            {
              "chord": "D7",
              "text": "單， 不"
            },
            {
              "chord": "G",
              "text": "變；"
            }
          ]
