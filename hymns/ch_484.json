        {
          "segments": [
            {
              "chord": "",
              "text": "那 開 路"
            },
            {
              "chord": "C",
              "text": "者 現"
            },
            {
              "chord": "G",
              "text": "在 召"
            },
            {
              "chord": "Em",
              "text": "你，"
            }
