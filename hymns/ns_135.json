    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily I come to be supplied by Your word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s by this supply that I’m richly satisfied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s here that I’m strengthened to live the Christian life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s nothing I do, but Your overflowing grace to me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, I love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re precious to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s here in Your presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve seen Your beauty."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re matchless, You’re priceless,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re everything to me."
            }
          ]
