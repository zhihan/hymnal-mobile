        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll love You forever—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are the only One for me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day as I wake up I come to You, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our fellowship sweet must be daily restored."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Void of offense, keep my conscience so pure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soften me, Lord, so that You alone may have my heart."
            }
          ]
        }
