            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The world I have forever left"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And severed all its ties;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The way may yet more narrow grow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all against me rise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But though the worldlings glare in rage;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I seek His smiling face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though outward glory others choose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I, His “well done” through grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart’s desire is not for fame"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor profit in these days;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I humbly wish to serve my Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And gain that day His praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto the judgment seat of Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I daily look away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May all my living and my work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide the fire that day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You may your reputation hold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wealth, friends, and glory gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You may win all success and praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A following great obtain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But I would be but lonely, poor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With no prosperity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart desires to follow Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And finish faithfully."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord, when here on earth, I know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gained nothing but the cross."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I only hope to be like Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for Him suffer loss."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My glory’s in the coming age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Today I’ll patient be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d ne’er enjoy ahead of Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This world’s prosperity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That day I shall receive the crown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll wipe away my tears."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So faithfully I’ll journey on"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till He at length appears."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
