    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Loved with love which knows no measure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save the Father’s love to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessed Lord, our hearts would treasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Father’s thoughts of Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All His joy, His rest, His pleasure—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All His deep delight in Thee—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thy heart alone can measure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What Thy Father found in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How He set His love upon Thee—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Called Thee His beloved Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet for us He did not spare Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy death our life was won."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O the joy, the wondrous singing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we see Thee as Thou art!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy blest name, Lord Jesus, bringing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweetest music to God’s heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Notes of gladness, songs unceasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hymns of everlasting praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Psalms of glory, joy increasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through God’s endless day of days."
            }
          ]
        }
