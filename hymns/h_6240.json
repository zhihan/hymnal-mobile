              "text": "God has given unto us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Milk and honey without money—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a bargain, glorious!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What a good land, what a rich land,"
