              "text": "God has given unto us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vines and fig trees, all our hearts please—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rich supplies, and all for us."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What a good land, what a rich land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God has given unto us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grain and oil, for our toil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a prospect, glorious!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us labor, let us labor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the land He's given us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Labor hourly, labor pow'rfully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reap the produce glorious!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the meetings, in the meetings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At the feast so glorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a full heart, share the best part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the harvest gained by us."
            }
          ]
        }
      ]
    },
