              "text": "God has given unto us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Valleys, mountains, springs and fountains—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, glorious!"
            }
          ]
        }
      ]
    },
