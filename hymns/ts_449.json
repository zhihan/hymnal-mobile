{
  "url": "https://www.hymnal.net/cn/hymn/ts/449",
  "title": "称义，圣别，得荣耀",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "作 為"
            },
            {
              "chord": "G",
              "text": "公 義、"
            },
            {
              "chord": "A",
              "text": "公"
            },
            {
              "chord": "D",
              "text": "平，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "道 路、"
            },
            {
              "chord": "",
              "text": "法 則"
            },
            {
              "chord": "E7",
              "text": "皆 完"
            },
            {
              "chord": "A",
              "text": "備；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 的"
            },
            {
              "chord": "",
              "text": "行 動"
            },
            {
              "chord": "G",
              "text": "全 然"
            },
            {
              "chord": "A",
              "text": "正"
            },
            {
              "chord": "D",
              "text": "直，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "配 得"
            },
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "E7",
              "text": "的 讚"
            },
            {
              "chord": "A",
              "text": "美。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 的 定 罪、 祂 的 要 求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "無 一"
            },
            {
              "chord": "",
              "text": "不 顯"
            },
            {
              "chord": "E7",
              "text": "祂 公"
            },
            {
              "chord": "A",
              "text": "義；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "律 法"
            },
            {
              "chord": "",
              "text": "已 將"
            },
            {
              "chord": "G",
              "text": "我 們"
            },
            {
              "chord": "D",
              "text": "判 罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "審 判"
            },
            {
              "chord": "D",
              "text": "座 前"
            },
            {
              "chord": "A",
              "text": "誰"
            },
            {
              "chord": "A7",
              "text": "能"
            },
            {
              "chord": "D",
              "text": "立？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "律法虽定我们死罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神爱始终未遗弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公义审判归神儿子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂作了我代替。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！我们今享"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督救赎的功绩："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "买回我们归神自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚至成为祂的义。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的性情圣别超凡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂之所是乃至圣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要圣化我们全人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使其合乎祂性情。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我灵中向外扩展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要安家我心房；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全人内里各部，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽得更新像祂样。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生机拯救过程奇妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全由生命来效力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每日每时都可经历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主的救恩何实际。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常思念那灵的事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心思就成为生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主在我里得着地位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得变化成神圣。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀乃是神的彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂之所是显无尽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是救赎终极一步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "具体显明于我身。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀乃是神圣生命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣别过程的完成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是生命供应目的─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体变像显殊荣。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为此，我们热切等待"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得赎、被提、得荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的丰满显明于地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣见证全显照。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就要完全像主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远彰显祂荣形；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的众子显于荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙万有共欢腾。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因神怜悯，蒙神选召，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀定命得有分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非借人的定意奔跑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是神主宰怜悯。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "野橄榄枝竟得联于"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "栽种橄榄的丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生机联结，分享肥汁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长成荣耀的国度。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这美妙过程之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "日日因生命成圣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满心感谢祂所赐与，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会生活的供应。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此全享神的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实际、真切、又富饶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同作众子，同为后嗣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会生活何荣耀！"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "追求与长进",
