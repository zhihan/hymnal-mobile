{
  "url": "https://www.hymnal.net/cn/hymn/ch/198",
  "title": "世人看你不过仍是",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "世 人"
            },
            {
              "chord": "",
              "text": "看 你"
            },
            {
              "chord": "C",
              "text": "不 過"
            },
            {
              "chord": "G",
              "text": "仍 是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "平 常"
            },
            {
              "chord": "D",
              "text": "的 拿"
            },
            {
              "chord": "A7",
              "text": "撒 勒"
            },
            {
              "chord": "D",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活 在 地 上"
            },
            {
              "chord": "G",
              "text": "常 受"
            },
            {
              "chord": "",
              "text": "輕 視，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十 字 架 上"
            },
            {
              "chord": "D",
              "text": "終"
            },
            {
              "chord": "A7",
              "text": "捨"
            },
            {
              "chord": "D",
              "text": "身。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "從 人"
            },
            {
              "chord": "D",
              "text": "眼 光"
            },
            {
              "chord": "C",
              "text": "你 的"
            },
            {
              "chord": "G",
              "text": "歷 史"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到 此"
            },
            {
              "chord": "C",
              "text": "已 經"
            },
            {
              "chord": "G",
              "text": "無"
            },
            {
              "chord": "D7",
              "text": "下"
            },
            {
              "chord": "G",
              "text": "文。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天上情形何等不同！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你升天的时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀的神因你顺从，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已命宇宙在等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "准备迎接、准备歌颂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你作宇宙的元首。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已设立你为基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已设立你为主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上地下已经无处"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知你今的特独，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一个能不俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一个不顺服。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "远在天上发生的事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今如何能知情？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因神要证此事属实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就从天降圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我身上成为恩赐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来证耶稣得权柄。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我身所显圣灵停驻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "证明耶稣是基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神立基督若是耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我身必有圣灵注；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远真实、永远坚固，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拿撒勒人已是主。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣是主！耶稣是主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不改变的事实！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我被圣灵已经灌注，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是事实的恩赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今只能赞美称祝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵恩赐已开始。"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "圣灵的丰满",
    "time": "4/4",
    "hymn_code": "12321765511",
