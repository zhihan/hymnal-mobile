    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "速兴起传福音！尽你我本分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主工，靠主恩，不畏艰辛！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命路将人引，不吝惜耐心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使罪人都听闻：神爱世人！"
            }
          ]
        }
