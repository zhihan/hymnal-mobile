    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人虽藐视真神，祂仍不灰心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要向人施怜悯，等待殷殷。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人只要肯相信，必得享救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "速前去向罪人劝诲谆谆！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "速兴起传福音！速抢救灵魂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你为何仍忍心，看人沉沦！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但虽将人掳，使人心麻木，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神恩典能眷顾，将人恢复。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心弦断祂修复，用恩慈复苏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱之乐又发出，远胜当初！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "速兴起传福音！速抢救灵魂！"
            }
          ]
        },
        {
