{
  "url": "https://www.hymnal.net/cn/hymn/ch/272",
  "title": "旷野之中为着神",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "旷 野"
            },
            {
              "chord": "A",
              "text": "之 中"
            },
            {
              "chord": "A7",
              "text": "为 著"
            },
            {
              "chord": "D",
              "text": "神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一 丛"
            },
            {
              "chord": "G",
              "text": "荆 棘"
            },
            {
              "chord": "D",
              "text": "在 火"
            },
            {
              "chord": "A7",
              "text": "焚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "愿 我"
            },
            {
              "chord": "A",
              "text": "如 此"
            },
            {
              "chord": "A7",
              "text": "蒙 你"
            },
            {
              "chord": "D",
              "text": "恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 你"
            },
            {
              "chord": "G",
              "text": "荣 耀"
            },
            {
              "chord": "A",
              "text": "显"
            },
            {
              "chord": "A7",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "身。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "仅是平常的荆棘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神能在它显为奇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神能凭它显能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神能借它行神迹。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不是用它作燃料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃神自己来燃烧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在它身无所要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仅要借它显荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神借荆棘来显现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无他只见神火焰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我如此，借恩典"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你荣耀显完全！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
