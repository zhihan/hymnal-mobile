    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once we were in old Chaldea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worshipping the idols there;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the God of glory called us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saved us all from Satan’s snare."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Get out, get out, from Chaldea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From that evil foreign land."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come in, come in, to the good land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the church, the one new man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With the calling comes the promise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the kingdom life on earth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This becomes our strength and motive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To get out of all the dearth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we’re crossing every river—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this You must call us on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Your kingdom and expression"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On this earth are fully come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is now the highest gospel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those still in Chaldee’s land—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leave the fallen situation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve been chosen for God’s plan."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God of glory, God of glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do appear to us each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call us out into Your building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your desire on earth today."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
