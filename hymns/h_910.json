    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The work must be the fruit of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Born thru the Spirit’s flowing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As branches of the Lord, the vine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fruit bearing, life bestowing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Christ Himself thru us to work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself as life expressing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the riches of His life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To others manifesting."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not a movement borne of man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by His power moving;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not the deeds done outwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But inward action proving."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not the work of enterprise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But ’tis His life confessing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not to toil for our success,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But ’tis Himself expressing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our plans, our aims, our energy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must abandon wholly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He may work His plan thru us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His aim and object solely."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ourselves, with all we are and have,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To death we must surrender,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Christ may live Himself thru us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With riches and with splendor."
            }
          ]
        }
      ],
