            },
            {
              "chord": "Am",
              "text": "hast be"
            },
            {
              "chord": "D7",
              "text": "come my"
            },
            {
              "chord": "",
              "text": "life and"
            },
            {
              "chord": "G",
              "text": "peace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Jesus, Lord, my"
            },
            {
              "chord": "B7",
              "text": "future"
            },
            {
              "chord": "",
              "text": "is with"
            },
            {
              "chord": "Em",
              "text": "Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father"
            },
            {
              "chord": "D",
              "text": "God I"
            },
            {
              "chord": "A7",
              "text": "now know"
            },
            {
              "chord": "",
              "text": "is for"
            },
            {
              "chord": "D7",
              "text": "me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of"
            },
            {
              "chord": "G7",
              "text": "Thee! Because"
            },
            {
              "chord": "",
              "text": "of"
            },
            {
              "chord": "Am",
              "text": "Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of"
            },
            {
              "chord": "G",
              "text": "Golgotha!"
            },
            {
              "chord": "D7",
              "text": "Because"
            },
            {
              "chord": "",
              "text": "of"
            },
            {
              "chord": "G",
              "text": "Thee!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once was a day, because I feared to die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I clothed myself in works, virtue to buy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tried to avoid God’s laws encompassing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now I know He is my righteous King."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though days may come when nations cry with pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy raptured church shall Thy true blessings gain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thine own blood sprinkled inside the veil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She conquers all the violence of hell."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lamb of God indeed my sorrows bore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lamb of God has saved me evermore;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cup of righteousness He drank for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The taste of death is gone eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In pastures green Thou caused me to recline,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou leadest me, the God of peace is mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of grace I lie upon Thy breast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I taste of love the highest and the best."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each hour sweetly keeps me by Thy life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though evil spirits threat with daring strife."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto my Father I may look always,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Learning to trust midst darkness as in days."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, teach me to refuse the worldly fames,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To waver not through water deep or flames,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willing to suffer shame and loss with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy name’s sake a martyr I may be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When I am raptured, brought before Thy face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Crucified shall be my song of grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From glory Thou didst come, didst suff’rings know:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Calvary poured out redemption’s flow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of me! Because of me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of sinful men! Because of me!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
