    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着灵中神圣重生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们得作神众子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我们必须成熟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能作神的后嗣。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着完全长大成人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "儿子名分我得享；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着长成丰满身量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "后嗣福分我饱尝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
