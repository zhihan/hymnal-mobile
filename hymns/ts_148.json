    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "子同著父並憑著靈而來，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由童女懷孕所生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶穌基督奇妙的神人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在他，神、人成一身。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的生活將父完全顯彰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是人，卻憑神生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是神無罪羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪、世界、撒但不能得逞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在人性裏，來救贖洗淨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神性裏，作救恩保證。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂血將我洗淨，祂又作保證─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神今是我保證。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂雖無罪，卻有分血肉之體，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這使撒但中計；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉體、罪、撒但與祂同釘一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，何等清理！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已了結舊造眾仇敵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已廢掉罪、撒但、肉體！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦應許的後裔，祂毁壞古蛇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "勝過魔鬼詭計。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在基督的復活裏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這位奇妙三一成為那靈；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如今三一之神己成那靈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂終極完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何親何近，賜生命的靈！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神己終極完成。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子與父是一靈，祂成為那靈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今內住於我靈。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "這奇妙人子在升天裏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是一人在神右邊；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已將人子升高至極，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂作王並掌權。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "萬主之主，是王中之王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督耶穌，遠超萬名上；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂登寶座為王，至高寶座上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得榮人子為王。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "經過種種過程，主今已登"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寶座，萬有祂治理；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作生命之靈分賜給人接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "產生祂身體。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神是三一，不是為道理；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是三一，分賜祂自己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分賜永不停息，我們可經歷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盡享祂的自己。"
            }
          ]
        }
      ],
      "type": "chorus"
    }
