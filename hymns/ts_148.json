        },
        {
          "chord": "G7",
          "text": "在 祂"
        },
        {
          "chord": "C",
          "text": "裏。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "C7",
          "text": "子 同"
        },
        {
          "chord": "",
          "text": "著"
        },
        {
          "chord": "F",
          "text": "父， 祂"
        },
        {
          "chord": "",
          "text": "何 等 奇 妙！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "子 憑 著"
        },
        {
          "chord": "C",
          "text": "靈， 祂"
        },
        {
          "chord": "",
          "text": "何 等 高 超！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "E",
          "text": "耶 穌"
        },
        {
          "chord": "",
          "text": "基"
        },
        {
          "chord": "E7",
          "text": "督 至"
        },
        {
          "chord": "C",
          "text": "寶，"
        },
        {
          "chord": "F",
          "text": "三 一"
        },
        {
          "chord": "",
          "text": "何"
        },
        {
          "chord": "C",
          "text": "深"
        },
        {
          "chord": "G",
          "text": "奧，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "F",
          "text": "三 一"
        },
        {
          "chord": "",
          "text": "神"
        },
        {
          "chord": "C",
          "text": "何"
        },
        {
          "chord": "G7",
          "text": "奇"
        },
        {
          "chord": "C",
          "text": "妙！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "子同着父并凭着灵而来，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "由童女怀孕所生；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "耶稣基督奇妙的神人，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在他，神、人成一身。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂的生活将父完全显彰，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "是人，却凭神生命；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂是神无罪羔羊，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪、世界、撒但不能得逞。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在人性里，来救赎洗净；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在神性里，作救恩保证。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂血将我洗净，祂又作保证─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神今是我保证。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂虽无罪，却有分血肉之体，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "这使撒但中计；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "肉体、罪、撒但与祂同钉一起，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "哦，何等清理！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂已了结旧造众仇敌！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂已废掉罪、撒但、肉体！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "哦应许的后裔，祂毁坏古蛇，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "胜过魔鬼诡计。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在基督的复活里，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "这位奇妙三一成为那灵；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如今三一之神己成那灵，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "作祂终极完成。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "何亲何近，赐生命的灵！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "三一之神己终极完成。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "子与父是一灵，祂成为那灵，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "今内住于我灵。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "这奇妙人子在升天里，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "仍是一人在神右边；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神已将人子升高至极，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "使祂作王并掌权。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "万主之主，是王中之王；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "基督耶稣，远超万名上；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂登宝座为王，至高宝座上，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "得荣人子为王。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "经过种种过程，主今已登"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "宝座，万有祂治理；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "作生命之灵分赐给人接受，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "产生祂身体。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神是三一，不是为道理；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神是三一，分赐祂自己。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "分赐永不停息，我们可经历，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "尽享祂的自己。"
        }
      ]
    }
  ],
