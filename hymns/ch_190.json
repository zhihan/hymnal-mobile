    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美！赞美！赞美耶稣，我救赎主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂为我罪受苦、流血、受刑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "称颂！称颂！称颂祂是磐石稳固，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为成永远救恩，十架被钉！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高声赞祂！主担当我的痛苦！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此爱奇妙，贞坚、绝顶、丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
