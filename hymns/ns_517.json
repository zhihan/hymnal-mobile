          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If nearer Thee, naught more would I desire."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pressure, persecutions, and wounds"
