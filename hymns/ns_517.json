    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh consecration! Wholly for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll closely follow, time redeem!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live Your transcendent life, Lord, through me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the treasure within be seen!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God of glory shines, drawing us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Goodbye world, our lives are for God’s purpose!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious vessels ready for using,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No matter where, as long as it’s with Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are washed and cleansed by Your word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unencumbered, holy, transparent, pure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mold us, Lord, conform us to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Your call, we’d rise up instantly!"
            }
          ]
        }
      ],
