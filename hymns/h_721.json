    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is sufficient to save me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And cleanse me from guilt and from sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sufficient to sanctify wholly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And give me His Spirit within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is sufficient for trials,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No matter how hard they may be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This promise stands over against them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My grace is sufficient for thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, over and over and over,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior keeps saying to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My strength is made perfect in weakness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My grace is sufficient for thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is sufficient for sickness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sustaining and making me whole;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is sufficient when sorrows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like billows roll over the soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is sufficient for service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It sets us from selfishness free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sends us to tell to the tried ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is sufficient for thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
