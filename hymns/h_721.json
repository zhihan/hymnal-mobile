    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not our grace that’s sufficient,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But His grace, it ever must be:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our graces are transient and changing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His grace is unfailing as He."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And so I am ever repeating"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His wonderful promise to me,"
            }
          ]
