        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "D",
              "text": "我 有"
            },
            {
              "chord": "",
              "text": "粮， 以"
            },
            {
              "chord": "A",
              "text": "此 试"
            },
