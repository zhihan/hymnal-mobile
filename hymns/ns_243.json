    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We need to see the House of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Assembly of called out ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s masterpiece and His Kingdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His counterpart; her purpose is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satisfaction and rest in love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s God’s desire that Christ may have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A bride, a wife, a bride, a wife"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternally. Eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The One New Man has Christ our Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a Person, expressing God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Subdues Satan for God’s purpose."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Body of Christ with Christ our Head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supplying us with His riches;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many members, all functioning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet all are one, yet all are one"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ as life. With Christ as life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! The two aspects:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Universal and the local church."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The local ground preserves oneness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Genuine oneness will be obtained."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One fellowship and one teaching"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout the earth, universal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Body expressed, body expressed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Locally. Locally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Learn the lesson from church hist’ry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the failures we must avoid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Degradation we fight against,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Recov’ring from divisive ground"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the oneness of the Body;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Returning to what God’s revealed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord build in us, Lord build in us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom life. The Kingdom life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We believers have been renewed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must grow in life and be matured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfected as overcomers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So that we as the builded church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The corporate Bride, will consummate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All in the New Jerusalem—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfilling God’s, fulfilling God’s"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal plan! Eternal plan!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
