          "segments": [
            {
              "chord": "A",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "希"
            },
            {
              "chord": "A7",
              "text": "奇， 我"
            },
            {
              "chord": "",
              "text": "們 都 能 像"
            },
            {
              "chord": "D",
              "text": "祂，"
            }
