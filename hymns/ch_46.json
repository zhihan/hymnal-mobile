            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 今 能 自"
            },
            {
              "chord": "A",
              "text": "由 坦"
            },
            {
              "chord": "",
              "text": "然 前"
            },
            {
              "chord": "D",
              "text": "來，"
            }
