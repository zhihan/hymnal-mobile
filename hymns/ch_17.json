{
  "url": "https://www.hymnal.net/cn/hymn/ch/17",
  "title": "当我有罪充满痛苦",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "當 我"
            },
            {
              "chord": "",
              "text": "有 罪 充"
            },
            {
              "chord": "D",
              "text": "滿 痛"
            },
            {
              "chord": "G",
              "text": "苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "公 義"
            },
            {
              "chord": "",
              "text": "要"
            },
            {
              "chord": "D",
              "text": "求 我"
            },
            {
              "chord": "A",
              "text": "受 審"
            },
            {
              "chord": "D",
              "text": "判；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "當"
            },
            {
              "chord": "G",
              "text": "主 流"
            },
            {
              "chord": "D7",
              "text": "血 為"
            },
            {
              "chord": "G",
              "text": "我 救"
            },
            {
              "chord": "",
              "text": "贖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公"
            },
            {
              "chord": "D",
              "text": "義 要"
            },
            {
              "chord": "",
              "text": "求 賜"
            },
            {
              "chord": "C",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "平"
            },
            {
              "chord": "G",
              "text": "安。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神，是你义将我救主"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带上十架忍受审判；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是你义将众罪徒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赦免、称义并赐平安。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "公义要求账须清偿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当账已经清偿之后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公义又要已偿的账，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不得再偿，不得再收。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "自从我主一次流血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你不能再要祂受钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也不能再要我解决，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只能将我赦免、洁净。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前我听你是公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我便害怕、逃匿不迨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今你义一被品题，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我反感觉宝贝可爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "自从我识你的公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我更明白你的恩惠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前者使我何等安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "后者使我充满安慰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
