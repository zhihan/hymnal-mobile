      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主灵借话与我交谈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我心发出颂赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命活泉，带着恩力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面涌流潺潺。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我发言、给我看见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富是为今天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "清爽、畅快，将祂欢饮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有干渴全都消减。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我欢留于祂面光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂以温情对付、指点；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂神圣、宝贵成分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸透全人、供应无限。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我发言、给我看见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富是为今天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多方、丰满将祂享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有问题全都逃窜！"
            }
          ]
        }
