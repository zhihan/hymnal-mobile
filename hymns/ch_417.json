              "text": "祂 的 豐 富"
            },
            {
              "chord": "D7",
              "text": "是 為"
            },
            {
              "chord": "",
              "text": "今"
            },
            {
              "chord": "G",
              "text": "天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甜 美、 歡"
            },
            {
              "chord": "B7",
              "text": "樂， 將"
            },
            {
              "chord": "Em",
              "text": "祂 享"
            },
            {
              "chord": "C",
              "text": "受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "有 飢"
            },
            {
              "chord": "",
              "text": "餓"
            },
            {
              "chord": "D7",
              "text": "全 變"
            },
            {
              "chord": "",
              "text": "飽"
            },
            {
              "chord": "G",
              "text": "滿。"
            }
