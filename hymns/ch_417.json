            {
              "chord": "G",
              "text": "夜 影"
            },
            {
              "chord": "",
              "text": "尚 存， 晨 光 未"
            },
            {
              "chord": "G7",
              "text": "现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重 新"
            },
            {
              "chord": "C",
              "text": "来 到"
            },
            {
              "chord": "",
              "text": "恩 主"
            },
            {
              "chord": "G",
              "text": "面 前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "D",
              "text": "在 里"
            },
            {
              "chord": "",
              "text": "面 放"
            },
            {
              "chord": "G",
              "text": "明、 照"
            },
            {
              "chord": "",
              "text": "耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "A",
              "text": "得 看"
            },
            {
              "chord": "A7",
              "text": "见 祂"
            },
            {
              "chord": "D",
              "text": "的 荣"
            },
            {
              "chord": "D7",
              "text": "颜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向"
            },
            {
              "chord": "G",
              "text": "我 发"
            },
            {
              "chord": "",
              "text": "言、 给"
            },
            {
              "chord": "D",
              "text": "我 看"
            },
            {
              "chord": "",
              "text": "见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 的 丰 富"
            },
            {
              "chord": "D7",
              "text": "是 为"
            },
            {
              "chord": "",
              "text": "今"
            },
            {
              "chord": "G",
              "text": "天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甜 美、 欢"
            },
            {
              "chord": "B7",
              "text": "乐， 将"
            },
            {
              "chord": "Em",
              "text": "祂 享"
            },
            {
              "chord": "C",
              "text": "受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "有 饥"
            },
            {
              "chord": "",
              "text": "饿"
            },
            {
              "chord": "D7",
              "text": "全 变"
            },
            {
              "chord": "",
              "text": "饱"
            },
            {
              "chord": "G",
              "text": "满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主灵借话与我交谈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我心发出颂赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命活泉，带着恩力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面涌流潺潺。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我发言、给我看见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富是为今天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "清爽、畅快，将祂欢饮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有干渴全都消减。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我欢留于祂面光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂以温情对付、指点；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂神圣、宝贵成分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸透全人、供应无限。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我发言、给我看见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富是为今天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多方、丰满将祂享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有问题全都逃窜！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
