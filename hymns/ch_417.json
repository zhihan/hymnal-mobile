            {
              "chord": "G",
              "text": "夜 影"
            },
            {
              "chord": "",
              "text": "尚 存， 晨 光 未"
            },
            {
              "chord": "G7",
              "text": "現，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重 新"
            },
            {
              "chord": "C",
              "text": "來 到"
            },
            {
              "chord": "",
              "text": "恩 主"
            },
            {
              "chord": "G",
              "text": "面 前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "D",
              "text": "在 裡"
            },
            {
              "chord": "",
              "text": "面 放"
            },
            {
              "chord": "G",
              "text": "明、 照"
            },
            {
              "chord": "",
              "text": "耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "A",
              "text": "得 看"
            },
            {
              "chord": "A7",
              "text": "見 祂"
            },
            {
              "chord": "D",
              "text": "的 榮"
            },
            {
              "chord": "D7",
              "text": "顏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向"
            },
            {
              "chord": "G",
              "text": "我 發"
            },
            {
              "chord": "",
              "text": "言、 給"
            },
            {
              "chord": "D",
              "text": "我 看"
            },
            {
              "chord": "",
              "text": "見："
