    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must preach both:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord Jesus loving us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we like Mary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving Him to the uttermost."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One is salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The other consecration."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we pour out"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our love offering."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As we pour upon Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is not just a waste"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But a fragrant testimony"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the sweetness of the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord loving us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we loving Him:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This the fragrance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of our love offering."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout the past centuries,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tens of thousands of precious lives,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heart treasures, golden futures"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have been wasted upon the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To such lovers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s altogether lovely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ultimately worthy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of their costly ointment."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must love the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grasp the opportunity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, love Him to the uttermost:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A fragrance sweet to God and man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord loving us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we loving Him:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This the fragrance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of our love offering."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, we just love You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life and all we pour on You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We waste ourselves upon You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this universe we just love You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We can’t help but love You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the greatest value."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our love is just an issue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of our seeing of You."
            }
          ]
        }
      ],
