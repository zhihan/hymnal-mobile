{
  "url": "https://www.hymnal.net/en/hymn/h/161",
  "title": "Praise the Savior, ye who know Him",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D7",
              "text": "Praise the"
            },
            {
              "chord": "G",
              "text": "Savior,"
            },
            {
              "chord": "",
              "text": "ye who"
            },
            {
              "chord": "D",
              "text": "know Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can"
            },
            {
              "chord": "G",
              "text": "tell how"
            },
            {
              "chord": "C",
              "text": "much we"
            },
            {
              "chord": "D",
              "text": "owe Him?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly"
            },
            {
              "chord": "G",
              "text": "let us"
            },
            {
              "chord": "",
              "text": "render"
            },
            {
              "chord": "C",
              "text": "to Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "All we"
            },
            {
              "chord": "G",
              "text": "are"
            },
            {
              "chord": "D7",
              "text": "and"
            },
            {
              "chord": "G",
              "text": "have."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is the name that charms us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He for conflicts fits and arms us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing moves and nothing harms us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we trust in Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust in Him, ye saints, forever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is faithful, changing never;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Neither force nor guile can sever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those He loves from Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep us, Lord, oh, keep us cleaving"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thyself and still believing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the hour of Thy receiving"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The victorious Bride."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we shall be where we would be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we shall be what we should be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Things which are not now, nor could be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then shall be our own."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
