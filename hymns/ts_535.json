{
  "url": "https://www.hymnal.net/cn/hymn/ts/535",
  "title": "基督心爱惟有召会",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "基 督"
            },
            {
              "chord": "",
              "text": "圣 心 深"
            },
            {
              "chord": "A",
              "text": "爱 慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无"
            },
            {
              "chord": "G",
              "text": "他， 惟"
            },
            {
              "chord": "A7",
              "text": "有 召"
            },
            {
              "chord": "D",
              "text": "会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "言 语、 计 画 并"
            },
            {
              "chord": "G",
              "text": "行 动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "皆 以 她"
            },
            {
              "chord": "D",
              "text": "为 依"
            },
            {
              "chord": "A",
              "text": "归。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此"
            },
            {
              "chord": "D",
              "text": "情 此"
            },
            {
              "chord": "",
              "text": "意 永"
            },
            {
              "chord": "G",
              "text": "坚"
            },
            {
              "chord": "D",
              "text": "定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无 何 能"
            },
            {
              "chord": "B7",
              "text": "以 摇"
            },
            {
              "chord": "Em",
              "text": "撼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召"
            },
            {
              "chord": "D",
              "text": "会 萦"
            },
            {
              "chord": "",
              "text": "绕 祂"
            },
            {
              "chord": "G",
              "text": "心 头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远"
            },
            {
              "chord": "A",
              "text": "在 创"
            },
            {
              "chord": "A7",
              "text": "世 之"
            },
            {
              "chord": "D",
              "text": "前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "万有尚都未开始，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已筹画全备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得祂心所钟爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂喜悦匹配。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万物受造虽奇妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非祂所专注；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深藏祂心难追测，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃一荣耀新妇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赢得佳偶相与共，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是祂所最心许；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美哉，此情永不移，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此意始终不渝。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人虽被罪深诱害，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无助、无望、无倚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂心所望从未弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恋慕之情依依。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂爱何广难估量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂怜悯临及；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲自施恩来找寻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深哉，智慧无匹。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倾注爱情得她心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此爱惟神尽知；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倾倒祂命作祭物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "馨香上扬不止。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今在复活荣耀里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与她亲近无距，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的笑脸时显露，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "情深，难以言喻。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "日近一日，祂新妇"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "单单将祂注视，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸沐新郎荣耀中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候被提之时。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
