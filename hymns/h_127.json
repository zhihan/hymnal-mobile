      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Praise the Lamb!” the chorus waking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All in heav’n together throng;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loud and far each tongue partaking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rolls around the endless song."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Grateful incense this, ascending"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever to the Father’s throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every knee to Jesus bending,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the mind in heav’n is one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Father’s counsels claiming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Equal honors to the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Son’s effulgence beaming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Makes the Father’s glory known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Spirit all pervading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hosts unnumbered round the Lamb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crowned with light and joy unfading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hail Him as the great “I AM.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Joyful now the new creation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rests in undisturbed repose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blest in Jesus’ full salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sorrow now nor thraldom knows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hark! the heavenly notes again!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loudly swells the song of praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through creation’s vault, Amen!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amen! responsive joy doth raise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
