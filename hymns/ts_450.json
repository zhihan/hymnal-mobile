{
  "url": "https://www.hymnal.net/cn/hymn/ts/450",
  "title": "盼望何等坚定",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 话"
            },
            {
              "chord": "",
              "text": "语 赐 盼 望 何 等"
            },
            {
              "chord": "Em",
              "text": "坚 定："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 来"
            },
            {
              "chord": "A",
              "text": "时， 我"
            },
            {
              "chord": "A7",
              "text": "全 人"
            },
            {
              "chord": "",
              "text": "必 得"
            },
            {
              "chord": "D",
              "text": "赎；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 患 难 带 来 疑 惑 与"
            },
            {
              "chord": "Em",
              "text": "忧 惧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盼 望"
            },
            {
              "chord": "A",
              "text": "隐， 异"
            },
            {
              "chord": "A7",
              "text": "象 逐"
            },
            {
              "chord": "",
              "text": "渐 糢"
            },
            {
              "chord": "D",
              "text": "糊。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "磨 难 间， 本 不 知 如 何"
            },
            {
              "chord": "G",
              "text": "祷 告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无 言"
            },
            {
              "chord": "A",
              "text": "中， 只"
            },
            {
              "chord": "A7",
              "text": "有 深"
            },
            {
              "chord": "",
              "text": "处 叹"
            },
            {
              "chord": "D",
              "text": "息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽 輭 弱， 有 那 灵 帮 同"
            },
            {
              "chord": "Em",
              "text": "担 负，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照 著"
            },
            {
              "chord": "A",
              "text": "神， 为"
            },
            {
              "chord": "A7",
              "text": "我 代"
            },
            {
              "chord": "",
              "text": "祷 求"
            },
            {
              "chord": "D",
              "text": "祈。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我是不敢求受苦更深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只望能免去试炼袭击；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若许，求将苦杯速撤去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但必须是你旨，非我意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真希奇！此时艰难虽四布，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深处竟安然一无罣虑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因有神大爱浇灌我心内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "溢我魂，驱尽所有疑惧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何稳妥！神主宰调度万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全为使爱祂者得益处；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "勿让我因眼瞎竟不知悉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无一事非祂爱所部署。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是父答应那灵的代求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐我以诸般试炼、煎熬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "患难中，愿主扩增我减少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我充满基督荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神儿女既有神儿子生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂岂不借管教施成全？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如器皿在窑匠甄陶手中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂不经琢磨使荣美现？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神衷心所渴望是得众子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "模成祂长子荣耀形像；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们既是基督许多弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂能不与祂一式一样？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何盼望！同基督作神后嗣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何辉煌！救恩要达至极。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今时的苦楚似沉痛难当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不配与将来荣耀相比。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事上，我们已得胜有馀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃借祂-那爱我们的主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀日，神众子就要显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受造物享自由何满足！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
