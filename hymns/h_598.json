    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To earthly eyes they are as Adam's race—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They wear the earthly form, and scars of pain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On them as on all sinners leave their trace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their outward needs are those of other men."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And theirs the forms of earthly life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Theirs sleeping, waking, want, and strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet this they have that they despise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What fairest seems to earthly eyes."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And inwardly their life is from above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord's Almighty Word hath quickened them;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flames kindled from the everlasting Love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The children of the New Jerusalem;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their brethren are the saints in light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And songs of sweetness infinite"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They sing with them to God Most High,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A deep and wondrous melody."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They walk upon the earth, and dwell in heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though pow'rless, guard the world with arms unseen;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep peace to them in midst of strife is given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all they wish they have, though poor and mean."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Storms beat them, but may not destroy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fast rooted in eternal joy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They walk as in the shade of death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet living on in silent faith."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Christ their Life shall be made manifest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When He shall come with all His pow'r to rule,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their glory, hidden long, shall be confessed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Arise and shine! O bright and beautiful!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ ye shall ascend on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Victorious in His victory—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The hidden light shall shine afar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each saint an everlasting star."
            }
          ]
        }
      ]
    }
