    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Vilest of the sinful race,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, I answer to Thy call:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meanest vessel of Thy grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace divinely free for all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, I come to do Thy will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy counsel to fulfil."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If so poor a worm as I,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May to Thy great glory live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my actions sanctify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my words and thoughts receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Claim me for Thy service, claim"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All I have, and all I am."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take my soul and body’s powers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take my mem’ry, mind, and will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my goods and all my hours,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All I know, and all I feel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All I think, or speak, or do;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take my heart, but make it new."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now, O God, Thine own I am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I give Thee back Thine own:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freedom, friends, and health, and fame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrate to Thee alone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine I live, thrice happy I;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Happier still when Thine I die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
