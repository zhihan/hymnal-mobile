{
  "url": "https://www.hymnal.net/cn/hymn/ch/114",
  "title": "看哪，冠冕已给羊羔",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "看 哪，"
            },
            {
              "chord": "",
              "text": "冠 冕 已 給"
            },
            {
              "chord": "G",
              "text": "羊 羔！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "榮 耀、"
            },
            {
              "chord": "",
              "text": "尊 貴 已 歸"
            },
            {
              "chord": "D",
              "text": "祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 祂 無 處 算 是"
            },
            {
              "chord": "Em",
              "text": "太 高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "天 上"
            },
            {
              "chord": "",
              "text": "無 處"
            },
            {
              "chord": "D",
              "text": "是 太"
            },
            {
              "chord": "G",
              "text": "大。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "天 上"
            },
            {
              "chord": "A7",
              "text": "無 處"
            },
            {
              "chord": "",
              "text": "是 太"
            },
            {
              "chord": "D",
              "text": "大。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂登宝座－天上宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂登宝座何豪迈！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是题目，圣徒所歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是珍物，父所爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂虽高大，却肯接受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在此的殷勤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所有微声弱讴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无一不入救主心。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的诗歌，惟独就是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高举被杀的羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并那坐在宝座上的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何应当受颂扬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前那受人藐视的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今得荣耀和尊贵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "冠冕、高位，原是祂的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂得这些真无愧！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
