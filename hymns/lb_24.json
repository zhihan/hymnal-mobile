    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, beware the knowledge tree"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Appearing so good; it’s even pretty."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its evil and good will open your eyes."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its issue, my friend: you’ll surely die."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The serpent, he crept in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Injected in man his death and sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man was seduced this knowledge to take."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My friend, that was the greatest mistake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Look, dear saints, in eternity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s just a river and a tree!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s life, life abundantly —"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eating and drinking our destiny."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s growing and flowing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re eating and drinking."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is our treasure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is our joy and pleasure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the tree of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eating Him always satisfies."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the river"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink Him, our joy and pleasure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eat Him and drink Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ our enjoyment."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is our treasure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is our joy and pleasure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear saints, just love Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surely you will enjoy Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is so enjoyable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So precious and so available."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God is dispensing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life into us, so refreshing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is so enjoyable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So precious and so available."
            }
          ]
        }
      ],
