        {
          "segments": [
            {
              "chord": "",
              "text": "供他们饱享。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是他们圣殿，"
            }
          ]
        },
        {
          "segments": [
