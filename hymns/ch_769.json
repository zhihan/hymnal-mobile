          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与圣徒相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "互居之所成。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作他们内容，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她作祂彰显，"
            }
          ]
