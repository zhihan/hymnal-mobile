    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we the universe behold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The work of Thy great hand—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The moon and stars which Thou ordained"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By lofty wisdom planned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what is man that Thou should’st care"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou should’st mindful be?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The son of man Thou visitest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thine economy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus Lord, Thou art that man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One who joined our race,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who put upon Himself the flesh"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And took a lower place."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now with glory Thou art crowned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With sovereignty complete."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now through Thy Body Thou dost rule"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all beneath Thy feet."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine incarnation, rising too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy transcendency,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Lordship, Headship, kingdom full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Body here we see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By all these steps of work divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast established praise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With overflowing hearts to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our joyful voice we raise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, soon that blessed day shall come—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All tongues these words shall peal!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in the local churches now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have a foretaste real."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, our Lord, how excellent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name in all the earth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let every people, tribe, and tongue"
            }
          ]
        },
        {
