    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你慈声是我所羡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "开启我耳使我听见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你声音绕我耳边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "消除恶者一切谎言。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，我今寻求你面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你不再向我隐瞒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "开启我耳，使我听见"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的圣言！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
