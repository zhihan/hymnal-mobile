    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，创造万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有独一的根源；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有主宰、万有元首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有之间祂居先；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂命令托住万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有靠祂而团结；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神早立祂承受万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有归祂为基业。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，道成肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "支搭帐幕在人间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "童女所生正式的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在肉身的显现。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神而人者自甘卑微，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "取了奴仆的形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神荣耀所发光辉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神本体的真像。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，钉死十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "替我担罪并成罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受神审判，被神所杀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尝尽死亡的苦味。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我旧人一同钉死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毁坏撒但和鬼魔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离罪的权势，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离一切的网罗。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，从死复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为复活初熟果；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂也使我同祂复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂生命分给我。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是一粒生命麦种，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生出我们许多粒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为祂的许多弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂同是出于一。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，化成圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到我灵里作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分神的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂同样的神圣。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面长大成形，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我变成祂形状；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我享受神的丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂丰满的身量。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，升上高天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超一切的首领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着尊贵、荣耀冠冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并得至高的尊名。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂也带我与祂同升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂一同坐天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我分享祂的权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同祂一样的高强。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，赐下圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会因此得成立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并赐恩赐，各尽功能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造召会作身体。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂爱召会，保养、顾惜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着召会得彰显；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会将祂延长、普及，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "延长、普及宇宙间。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，得国再临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "提接、救赎祂圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "践踏仇敌，审判万民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭祂权柄设国度。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着圣徒一同作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "执政掌权到地极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万国和平，万有歌唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地都得享安息。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀基督，永世中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着圣城为配偶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地一切全都更新，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱尽一切的陈旧。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是荣光，祂是明灯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在祂内得彰显；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城又是祂的显明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由祂充满到永远！"
            }
          ]
        }
      ]
    }
  ],
