    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the years, Thy saints have sought Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Longing for reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gazing upward, searching inward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thirsting for the sight of Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now reveal that Christ in heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Body manifest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Christ who dwells within us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Body is expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Prone to be misled, I know it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By my lofty thoughts of Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Easy ’tis for self to seek Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet not touch reality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how much I need to find Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy members here below."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God eternal dwells among us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Manifest in flesh to know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Limit, Lord, my independence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me to Thy Body turn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just seeking light from heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the church’s sense to learn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we be the stones for building"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the formless, useless clay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain in us Thy heart’s desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Corporately Thyself display."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
