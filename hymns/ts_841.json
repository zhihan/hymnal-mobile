              "chord": "",
              "text": "我热爱生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "举手叩求真理之门；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "第一声呼求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "冲出我心灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亮光之名，自由之名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我生命终于破晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亮光之名，自由之名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我生命开始有了日出。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
