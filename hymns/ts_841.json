      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命如此好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生存价值如此高，"
            }
          ]
        },
        {
          "segments": [
