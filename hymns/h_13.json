    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Love bespeaks Thy very being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What Thou dost is shown by light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love is inward, light is outward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love accompanies the light."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Love by grace is manifested,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the light by truth is shown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy love we may enjoy Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy light Thou, Lord, art known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Thy love, which led to Calvary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We receive the life of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Light our understanding opens,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may apply the blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Thy love, as life Thou enter’st"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship with Thee to give;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Thy light we take Thy cleansing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in fellowship may live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By the light and blood which cleanses,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The anointing we shall know;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the life of love Thine essence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More and more in us will flow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy love we are Thy children,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abba Father calling Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Light disperses all our darkness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till, like Him, Thy Son, we see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what grace! O what truth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love is seen and light is shown!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We would praise Thee never ceasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou by love and light art known!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
