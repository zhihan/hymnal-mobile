{
  "url": "https://www.hymnal.net/cn/hymn/ts/257",
  "title": "认识复活",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "求 主"
            },
            {
              "chord": "",
              "text": "赐 我 启 示"
            },
            {
              "chord": "C",
              "text": "的 灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "认 识"
            },
            {
              "chord": "A",
              "text": "复 活"
            },
            {
              "chord": "A7",
              "text": "的 大"
            },
            {
              "chord": "D",
              "text": "能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "这 大"
            },
            {
              "chord": "G",
              "text": "能 在"
            },
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "C",
              "text": "身 上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "运 行"
            },
            {
              "chord": "G",
              "text": "不 息"
            },
            {
              "chord": "D7",
              "text": "时 加"
            },
            {
              "chord": "G",
              "text": "增。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "不 单"
            },
            {
              "chord": "C",
              "text": "叫 祂"
            },
            {
              "chord": "",
              "text": "从 死"
            },
            {
              "chord": "G",
              "text": "复 活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更 叫"
            },
            {
              "chord": "A",
              "text": "我 因"
            },
            {
              "chord": "A7",
              "text": "祂 得"
            },
            {
              "chord": "D",
              "text": "生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浩 大"
            },
            {
              "chord": "G",
              "text": "能 力"
            },
            {
              "chord": "",
              "text": "藉 信"
            },
            {
              "chord": "C",
              "text": "经 历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我"
            },
            {
              "chord": "G",
              "text": "活 在"
            },
            {
              "chord": "",
              "text": "属"
            },
            {
              "chord": "D7",
              "text": "天"
            },
            {
              "chord": "G",
              "text": "层。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活乃是信徒经历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅历史一事实；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坟墓虽已千年空置，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活大能仍运施。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个大能不是神学，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅是理论而已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它使信徒天天实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "联于复活主自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活带进新造领域，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离旧自我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非如拉撒路之神迹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "苟延旧造并重活。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我所需要不是任何"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起死回生的经过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亦非任何工作能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃让复活将我摸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切死亡阴间经历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "皆为复活启生机；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生借死亡发动运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉体治死灵奋起。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡所设千万防线，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督走过何容易；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "畅游阴间乐园深渊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从未恐慌或逃离。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡对人最大威胁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无非惧怕与捆绑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当主打破死亡门槛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "粉碎限制与惊惶。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天然生命不再缠扰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活生命得显扬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最后仇敌既被吞灭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何能将生命挡？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督人性借着复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已被拔高并标出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从此堕落人类生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可望与主同前途。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历基督全备救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅那日体得赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人性更被拯救、拔高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "提升等同复活主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活并不改良旧造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "减轻旧造的折腾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也不加强旧造生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使之能以自逞能。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督虽曾肉体痛哭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里却是倚靠神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活不求改变环境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只在环境显效能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神借旧造产生新造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此为极大的奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪、死虽然污染肉体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经死一笔全清洗。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主将伊甸所造人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给予重整赋新机；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活原则永不改变─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新造取材旧造里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督复活生为长子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人性拔高至神性；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大卫后裔今日被生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此为真正的福音。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从此人类新生有望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活产生新族群─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同父同胎同命同性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同一源头同命运。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活大能使我重生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得有神圣诸供备；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有权成为儿女，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从神而生属神类─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命性情与神一样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只与神格无分位。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "第一神人我们长兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我原型并原胚。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我与基督已经联合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂我生命已接枝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活生命天天交流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时相调永无止。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂更成了赐生命灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作神终极的显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来神性人性丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活出子基督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们成了基督肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主成为一单元；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的经历成我履历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的一切祂成全。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活早晨新生男孩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是宇宙新生族；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神人互住父家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是生机葡萄树。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活实际-生命之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今已住在我灵中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我天天经历复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与我同活同行动；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远胜过罪与死律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作王生命来居衷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最终漫溢必死身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我贱身与祂同。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在复活里与祂同长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活出生命的新样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一举一动结出义果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主观称义得显彰。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "水浸埋葬旧人自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵浸引我奔义路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此赛程不偏左右，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至我被义构成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活彰显在我事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发芽枯杖作仲裁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只凭复活生命建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会必成杏树台。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "木草禾秸烧尽去净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只用复活作建材；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城撒冷神人合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我工作的赏赉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿我能深切认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何谓复活的大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天模成十架模型，"
            }
          ]
        },
        {
          "segments": [
            {
