    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O how loving! O how gracious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself is life to man!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He in man hath made a spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He might fulfill His plan."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis His heart’s delight and longing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’er to be received by man."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what love and grace unbounded!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as life to man doth flow!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He no more is hid in secret"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Himself to man doth show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "First in flesh and then as Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His life all men may know."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How approachable! How near us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in Christ our life to be!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is God in flesh incarnate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Manifest for man to see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Died and risen, now He enters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into man, his life to be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what wonder! As the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as life to man is shown!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis His other transformation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He as Spirit thus is known;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Men convicting and inspiring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He within them makes His home."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O how glorious! O how precious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the triune God to know!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "First the Father in the Son came,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the Son as Spirit flows."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When in man the Spirit enters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as life He doth bestow."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How mysterious, yet how real!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself now flows in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my heart, with me in oneness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has come my life to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will praise unceasingly!"
            }
          ]
        }
      ]
    }
