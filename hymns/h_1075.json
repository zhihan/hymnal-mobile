    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me the story softly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With earnest tones and grave;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remember I’m the sinner"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whom Jesus came to save;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me the story always,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If you would really be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In any time of trouble,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A comforter to me."
            }
          ]
        }
      ],
