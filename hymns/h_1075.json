      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me the story slowly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may take it in—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That wonderful redemption,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s remedy for sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me the story often,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I forget so soon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The “early dew” of morning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has passed away at noon."
            }
          ]
        }
      ],
