              "text": "That this world’s empty glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is costing me too dear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And when the Lord’s bright glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is dawning on my soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me the old, old story:"
            }
          ]
        },
