  "raw_sections": [
    "听 哪，天 上有 声喊 说：",
    "『已成了；』信 心",
    "立 即回 声答 说：『已成",
    "了。』 请听 宝 座",
    "的 话语，你 可来 领",
    "神 应许；神 口曾 说：",
    "『已 成了，』信",
    "心 也 说：『已 成",
    "了；』 祈祷已",
    "过赞美始，阿",
    "利路亚，『已成了。』",
    "接受主的完全救恩，",
    "‘已成了；’",
    "应当绝对奉献全身，",
    "‘已成了。’",
    "请听宝座的话语，",
    "你可来领神应许；",
    "神口曾说：",
    "‘已成了，’",
    "信心也说：",
    "‘已成了；’",
    "祈祷已过赞美始，",
    "阿利路亚，",
    "‘已成了。’",
    "领取神的医治恩约，",
    "‘已成了；’",
    "只要相信，不要感觉，",
    "‘已成了。’",
    "请听宝座的话语，",
    "你可来领神应许；",
    "神口曾说：",
    "‘已成了，’",
    "信心也说：",
    "‘已成了；’",
    "祈祷已过赞美始，",
    "阿利路亚，",
    "‘已成了。’",
    "对神应许应当说道：",
    "‘已成了；’",
    "对神话语应当认道：",
    "‘已成了。’",
    "请听宝座的话语，",
    "你可来领神应许；",
    "神口曾说：",
    "‘已成了，’",
    "信心也说：",
    "‘已成了；’",
    "祈祷已过赞美始，",
    "阿利路亚，",
    "‘已成了。’",
    "按祂所说来相信祂，",
    "‘已成了；’",
    "这个就是接受秘法，",
    "‘已成了。’",
    "请听宝座的话语，",
    "你可来领神应许；",
    "神口曾说：",
    "‘已成了，’",
    "信心也说：",
    "‘已成了；’",
    "祈祷已过赞美始，",
    "阿利路亚，",
    "‘已成了。’"
  ]
