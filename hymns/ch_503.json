            },
            {
              "chord": "G",
              "text": "语，"
            },
            {
              "chord": "C",
              "text": "你 可"
            },
            {
              "chord": "",
              "text": "来 领"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
