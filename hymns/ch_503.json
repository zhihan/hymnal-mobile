  "title": "听哪天上有声喊说",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "听 哪，"
            },
            {
              "chord": "G7",
              "text": "天 上"
            },
            {
              "chord": "C",
              "text": "有 声"
            },
            {
              "chord": "G",
              "text": "喊 说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "『已"
            },
            {
              "chord": "D7",
              "text": "成"
            },
            {
              "chord": "C",
              "text": "了；』"
            },
            {
              "chord": "G",
              "text": "信 心"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "立 即"
            },
            {
              "chord": "C",
              "text": "回 声"
            },
            {
              "chord": "G",
              "text": "答 说："
            },
            {
              "chord": "Am",
              "text": "『已"
            },
            {
              "chord": "D7",
              "text": "成"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "了。』 请"
            },
            {
              "chord": "",
              "text": "听 宝 座"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
