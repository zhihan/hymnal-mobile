            {
              "chord": "C",
              "text": "『已 成"
            },
            {
              "chord": "",
              "text": "了，』"
            },
            {
              "chord": "D",
              "text": "信"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心 也 说："
            },
            {
              "chord": "D7",
              "text": "『已 成"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "了；』 祈"
            },
            {
              "chord": "C",
              "text": "祷"
            },
            {
              "chord": "G",
              "text": "已"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "过"
            },
            {
              "chord": "Am",
              "text": "赞"
            },
            {
              "chord": "A7",
              "text": "美"
            },
            {
              "chord": "D",
              "text": "始，"
            },
            {
