              "text": "利"
            },
            {
              "chord": "G",
              "text": "路"
            },
            {
              "chord": "Em",
              "text": "亚，"
            },
            {
              "chord": "G",
              "text": "『已"
            },
            {
              "chord": "D7",
              "text": "成"
            },
            {
              "chord": "G",
              "text": "了。』"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "接受主的完全救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘已成了；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当绝对奉献全身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘已成了。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请听宝座的话语，"
            }
          ]
        },
        {
          "segments": [
