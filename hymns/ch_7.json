{
  "url": "https://www.hymnal.net/cn/hymn/ch/7",
  "title": "哦神你是永远父",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 神，"
            },
            {
              "chord": "",
              "text": "你 是 永 远 父，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "也 是"
            },
            {
              "chord": "",
              "text": "自 有"
            },
            {
              "chord": "A7",
              "text": "永 有"
            },
            {
              "chord": "D",
              "text": "主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 比 古 者 还 要 古，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 比"
            },
            {
              "chord": "A",
              "text": "初 者"
            },
            {
              "chord": "",
              "text": "还 要"
            },
            {
              "chord": "D",
              "text": "初！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是永远到永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "超过时间和空间！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永永远远的完满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无始无终的无限！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是万有的根源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "早过大地并诸天！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比先者还要先，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比前者还要前！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是生命永存留，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世世代代无尽休！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比久者还要久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比后者还要后！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "首先，你是阿拉法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "末后，你是俄梅嘎！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自始至终无所差，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全丰满无可加！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美你永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们称颂你无限！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美你是何丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "称颂你是何完全！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
