              "chord": "",
              "text": "Once I was foolish, and sin ruled my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Causing my footsteps from God to depart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus hath found me, happy my case;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I now am a sinner saved by grace!"
            }
          ]
        }
