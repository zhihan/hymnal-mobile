              "text": "It is a blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be satisfied with ordinary days"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "in the divine dispensing."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
