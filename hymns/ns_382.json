    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our inward parts are being renewed by the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh and rich supply to us He does afford."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is our destiny,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To live a normal life in the divine dispensing,"
            }
          ]
