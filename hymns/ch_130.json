{
  "url": "https://www.hymnal.net/cn/hymn/ch/130",
  "title": "哦主你爱何等深广",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "哦"
            },
            {
              "chord": "A",
              "text": "主， 你"
            },
            {
              "chord": "Dm",
              "text": "爱 何"
            },
            {
              "chord": "",
              "text": "等"
            },
            {
              "chord": "C",
              "text": "深"
            },
            {
              "chord": "Dm",
              "text": "广！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "过"
            },
            {
              "chord": "A",
              "text": "于"
            },
            {
              "chord": "Dm",
              "text": "我 所"
            },
            {
              "chord": "A",
              "text": "能 测"
            },
            {
              "chord": "",
              "text": "度！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 爱"
            },
            {
              "chord": "Dm",
              "text": "深 广，"
            },
            {
              "chord": "",
              "text": "远 超 海"
            },
            {
              "chord": "C",
              "text": "洋！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "这 爱"
            },
            {
              "chord": "",
              "text": "竟 然"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱所给、所作太多！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "过于我所能述说！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最大乃是与我联合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且与我相调和。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱叫你成为我的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我一切的供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我享受你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时以你为生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱就是你的自己－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那神圣的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作了我的人生意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活着就是你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的生命、力量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱给我所经历；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是你的恩、爱对象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所经、所历全是你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "甚么能使你我分离？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱就必爱到底！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你必与我永远合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱刚强无可比！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这爱使我感激不已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我赞美的目的！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你成为我，我成为你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是你爱的至极！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
