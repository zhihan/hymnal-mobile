{
  "url": "https://www.hymnal.net/cn/hymn/ch/280",
  "title": "哦主你是我的生命",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D7",
              "text": "是 我"
            },
            {
              "chord": "",
              "text": "的 生"
            },
            {
              "chord": "Em",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也 是 生"
            },
            {
              "chord": "G",
              "text": "命"
            },
            {
              "chord": "C",
              "text": "供"
            },
            {
              "chord": "D",
              "text": "应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求"
            },
            {
              "chord": "E",
              "text": "在 灵"
            },
            {
              "chord": "Am",
              "text": "中 眷"
            },
            {
              "chord": "D7",
              "text": "顾 我"
            },
            {
              "chord": "Em",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "A7",
              "text": "我 生"
            },
            {
              "chord": "G",
              "text": "命"
            },
            {
              "chord": "D7",
              "text": "丰"
            },
            {
              "chord": "G",
              "text": "盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将你自己于我应用，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我吹你圣灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我经历与你同钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "模成你死之形。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已胜过阴府、撒但，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但仍与我相争；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你工作在我里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "杀死并且供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我天然被你治死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就应用于我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我埋葬，永不再世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我同你活着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面掌权作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "征服倔强仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我显出你的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活出你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从我除去罪的馀烬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我作你居所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你荣耀浸透全人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在我身显著。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "羡慕",
    "time": "3/4",
