    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When such as we the King can choose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To share with Him His throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis passing strange that we refuse"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be our Lord's alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O never speak of sacrifice!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A privilege untold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to be His at any price,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Calv'ry's hosts enrolled."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Arise! the holy bargain strike—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fragment for the whole—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All men and all events alike"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must serve the ransomed soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are yours when you are His,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He and you are one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A boundless life in Him there is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whence doubt and fear are gone."
            }
          ]
        }
      ],
