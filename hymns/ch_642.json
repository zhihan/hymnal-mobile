{
  "url": "https://www.hymnal.net/cn/hymn/ch/642",
  "title": "当奉耶稣这名站住",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "當 奉"
            },
            {
              "chord": "",
              "text": "耶 穌 這 名 站 住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信"
            },
            {
              "chord": "A",
              "text": "祂 得"
            },
            {
              "chord": "A7",
              "text": "勝 站"
            },
            {
              "chord": "D",
              "text": "住；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 靠 自 己 力 量 站 住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "E7",
              "text": "靠 才"
            },
            {
              "chord": "",
              "text": "能 站"
            },
            {
              "chord": "A",
              "text": "住；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "不"
            },
            {
              "chord": "D",
              "text": "要 使"
            },
            {
              "chord": "",
              "text": "用 血"
            },
            {
              "chord": "A",
              "text": "氣 兵"
            },
            {
              "chord": "D",
              "text": "器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 用 聖 靈 寶"
            },
            {
              "chord": "A",
              "text": "劍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "穿"
            },
            {
              "chord": "D",
              "text": "上 神"
            },
            {
              "chord": "",
              "text": "的 軍 裝 服"
            },
            {
              "chord": "G",
              "text": "役，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "滅"
            },
            {
              "chord": "D",
              "text": "盡 仇"
            },
            {
              "chord": "A",
              "text": "敵"
            },
            {
              "chord": "A7",
              "text": "火"
            },
            {
              "chord": "D",
              "text": "箭。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，仇敌正在聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "故当守你地场！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "四面黑暗，争战紧急，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "故当靠主抵挡！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若退后，怕仇敌凶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一人牵动全军；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请你不要使你弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你缘故受窘。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但已知其时不久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以其气忿忿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要在争战尚未起首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就使你灵郁闷。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "诱惑、试探比前更多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "苦难比前更大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阴府权势攻逼你我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比前更为可怕。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对此情形，我们当有"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何种态度才可？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们可否因贪优游，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "便让仇敌宰割？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或者因着苦难加倍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更加忍耐、奋勇？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生死关头在此定规！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁要得主称荣？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，你当为主站住；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣是得胜者！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你当忍受一切痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到那日方舍。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣不久快要再临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "战事不久要停；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你今为主受难、受惊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日必得权柄。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
