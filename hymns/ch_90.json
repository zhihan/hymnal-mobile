  "raw_sections": [
    "讚 美不 盡 讚美，",
    "讚美 救主 恩深；",
    "感 佩 無 限 感佩，",
    "感佩 救主 捨身；",
    "看哪， 神子 在各 各他，",
    "為你 和我釘十字架。",
    "主爱远胜爷娘，",
    "远胜最好朋友；",
    "蒙恩罪人颂扬",
    "主爱，直到永久；",
    "看哪，神子在各各他，",
    "为你和我钉十字架。",
    "罪人今已蒙恩，",
    "魔鬼今已失败；",
    "谁能再使我们",
    "离开基督的爱？",
    "看哪，神子在各各他，",
    "为你和我钉十字架。"
  ]
