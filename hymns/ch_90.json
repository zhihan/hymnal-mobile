    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱远胜爷娘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远胜最好朋友；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙恩罪人颂扬"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱，直到永久；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，神子在各各他，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你和我钉十字架。"
            }
          ]
        }
