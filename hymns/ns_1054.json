    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, be my Amen;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Subdue my will, don’t let me win."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my feelings deceive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I stand by faith, Your grace I receive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, take captive my every thought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make Your home in all of my heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Strengthen my trust in You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all things work together for good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not according to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But so that You’d be wrought in my being."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though sometimes I don’t understand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I trust in Your loving hands."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Deepen my love for you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me a lily, simple and pure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Other things in my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Empty; unload me, Your love impart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw my eyes to see only You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord Jesus, how I love You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lift my eyes up to see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that You do is not just for me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s the church as Your bride"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who satisfies Your heart’s desire."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Your Body, grant me Your view."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw me, we will run after You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thank You for who You are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that we can’t be; Lord be our All."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise You, Lord, as the One"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who over all things is on the throne."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your mercy we’re justified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But much more, save us in Your life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, much more, save us in Your life."
            }
          ]
        }
