  "title": "Lord, there’s always been one person",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, there’s always been one person"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Abraham who ran to meet You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Samuel, he ministered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And David had a heart full of praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You want many more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we want to be that people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That minister and refresh You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meet Your need, and wash Your feet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That satisfy Your heart’s desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be a friend to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What can we do?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We can call O Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can praise Your name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn our heart to You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let You rule and reign."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, a single heart that’s true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s what we desire."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’ve shown You’re rich in mercy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those saints who stand together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your plan, one new man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So grant us all a single heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart that just loves You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart that’s true."
            }
          ]
        }
      ],
