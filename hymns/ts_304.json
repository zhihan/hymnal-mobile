  "title": "同往葡萄园去",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 属"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "A7",
              "text": "的 良"
            },
            {
              "chord": "D",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 也 是"
            },
            {
              "chord": "A7",
              "text": "恋 慕"
            },
            {
              "chord": "D",
              "text": "我。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来 罢， 我 们 同 往"
            },
            {
              "chord": "G",
              "text": "田 间"
            },
            {
              "chord": "A7",
              "text": "去；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "要 在 爱"
            },
            {
              "chord": "A",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同 在 村"
            },
            {
              "chord": "A7",
              "text": "庄 住"
            },
            {
              "chord": "D",
              "text": "宿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享 受 你"
            },
            {
              "chord": "G",
              "text": "我 之"
            },
            {
              "chord": "A",
              "text": "间"
            },
            {
              "chord": "A7",
              "text": "爱"
            },
            {
              "chord": "D",
              "text": "情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们早晨起来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同往葡萄园去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同享受我们劳苦果实；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄是否开花，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "石榴是否放蕊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在那里将爱给你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "风茄是在放香，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新陈果子佳美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良人哪！这是为你存留；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的爱都归你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也把你全享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱情是如死坚强。"
            }
          ]
        }
