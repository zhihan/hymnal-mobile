    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Under the shadow of Thy throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy saints have dwelt secure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sufficient is Thine arm alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our defence is sure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the hills in order stood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or earth received her frame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From everlasting Thou art God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To endless years the same."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A thousand ages in Thy sight"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are like an evening gone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Short as the watch that ends the night"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the rising sun."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Time, like an ever-rolling stream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bears all its sons away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They fly forgotten, as a dream"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dies at the opening day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, our help in ages past,"
            }
          ]
        },
        {
          "segments": [
