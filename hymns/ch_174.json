    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们记念你曾临世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成了奴仆历艰苦；"
            }
          ]
        },
        {
          "segments": [
