    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though many fail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fall to sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It doesn’t change—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s chosen them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re not a judge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But shepherds true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We overcome"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So they can too."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The world is but"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A glance away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It speaks to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To sin each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But I will flee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With others too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We reign as kings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lust subdue."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, I’ve seen the dream!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I live in Christ and He in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His word I believe!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The vision’s real and reigns in me."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We won’t be swayed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To love the world."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though ev’n betrayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll gain the Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Restricted now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
