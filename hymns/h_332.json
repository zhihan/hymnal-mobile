    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis everlasting peace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sure as Jehovah’s Name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis stable as His steadfast throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For evermore the same."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The clouds may go and come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And storms may sweep my sky;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This blood-sealed friendship changes not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Cross is ever nigh."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My love is ofttimes low,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My joy still ebbs and flows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But peace with Him remains the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No change my Savior knows."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I change, He changes not;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christ can never die;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love, not mine, the resting-place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His truth, not mine, the tie."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Cross still stands unchanged,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though heaven is now His home;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The mighty stone is rolled away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But yonder is His tomb!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And yonder is my peace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The grave of all my woes!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know the Son of God has come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know He died and rose."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I know He liveth now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At God’s right hand above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know the throne on which He sits,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know His truth and love!"
            }
          ]
        }
