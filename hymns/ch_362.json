          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以为你曾忠心顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直走十字架的路！"
            }
          ]
        }
      ]
