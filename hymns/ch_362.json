    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我何难与基督同死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因复活我已认识；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我何难与耶稣同苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因神旨我愿顺服。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主借着复活的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今生在我的灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我欢乐着举足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直走十字架的路。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一直走十架窄路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主是受死在那里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我能同你"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直走十架窄路！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同主死，就必同主生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同受苦，必同高升；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜者惟独照这样，"
