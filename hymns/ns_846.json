              "chord": "",
              "text": "Keep me growing, pursuing, in this way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain us, Lord, for Your building!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the Body, we’re willing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To fulfill Your heart’s longing we will say:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
