          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to me through Your Word more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have Your way in me; heav’nly Light, do shine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Search my heart, every chamber;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From each part, darkness scatter."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my whole body full of light divine!*"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your presence, I linger."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s Your beauty—I’m captured!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have won me with Your attractiveness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vanity I’m exhaling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Your fullness inhaling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deeply breathe into me Your holiness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Purify and make holy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And reconstitute fully—"
            }
          ]
        },
        {
          "segments": [
