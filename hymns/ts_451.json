{
  "url": "https://www.hymnal.net/cn/hymn/ts/451",
  "title": "神赐宝贵极大应许",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 已"
            },
            {
              "chord": "",
              "text": "賜、 神 已 賜， 神 今 已 賜"
            },
            {
              "chord": "Em",
              "text": "與；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寶 貴 信、"
            },
            {
              "chord": "Em7",
              "text": "神 能"
            },
            {
              "chord": "",
              "text": "力、"
            },
            {
              "chord": "A7",
              "text": "並 極"
            },
            {
              "chord": "",
              "text": "大 應"
            },
            {
              "chord": "D",
              "text": "許；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 信 而 領 受， 供 備 全 得"
            },
            {
              "chord": "G",
              "text": "著，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "就 能"
            },
            {
              "chord": "",
              "text": "憑 此"
            },
            {
              "chord": "D",
              "text": "長 大"
            },
            {
              "chord": "G",
              "text": "成 熟"
            },
            {
              "chord": "D",
              "text": "進"
            },
            {
              "chord": "A7",
              "text": "神"
            },
            {
              "chord": "D",
              "text": "國。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何宝贵、何宝贵，同样的宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信是神所分给，在众圣心内；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们虽会摇摆，此信不稍减，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且要逐日扶持、加强到永远。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神能力、神能力，如泉源丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "既刚强，又得胜，今在我运行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里赐生命，所需全供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活出敬虔，彰显神荣形。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借荣耀、借美德，神呼召我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又宝贵又极大应许作我分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱情欲、脱败坏，世界失权能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借应许我们得有分神性情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是神能力，在我灵里居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂又是神话语─神全备应许；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "读祂话，摸祂灵，天天当操练─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呼求、读经、祷告，生命时加添。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神能力、神应许，同宝贵的信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们既已得着，应用当殷勤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多供应、勤浇灌，生命日丰硕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信心种子必结出爱的美果。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要增长、要增长，主里要增长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "勿闲懒，结美果，丰富又多方；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们罪已得洁，救恩不该忘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再眼瞎，乃要天天让主长。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当殷勤、当殷勤，日日长生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神呼召和拣选因此得坚定；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与神种子配合使成长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必进入神国享丰富无量。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵信、神应许、神圣的能力─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神供备何充足，舍此不他依；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们献自己，愿与你合作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠恩长大，直至丰富进神国。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
  "metadata": {
    "category": "追求与长进",
    "time": "4/4",
    "hymn_code": "33333331432",
