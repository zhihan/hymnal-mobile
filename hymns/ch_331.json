              "chord": "",
              "text": "为你，我已带来："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救恩无以复加，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赦免陪同慈爱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你，为你，我带许多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我，你带甚么？’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘主，我献上生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并献所有时光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全听你使令，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离地上捆绑。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我，为我，你的全舍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你，我撇一切！’"
            }
          ]
        }
      ],
