    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我父光明之家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的荣耀宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你，我都撇下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来到苦地飘泊。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你，为你，我撇这些，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我你何所撇？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为你，我受多苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "过于你口能述，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受了极大痛楚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救你脱离阴府。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你，为你，我受多苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我，你肯何负？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从我天上之家，"
            }
          ]
        },
        {
          "segments": [
