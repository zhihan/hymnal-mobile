{
  "url": "https://www.hymnal.net/en/hymn/ns/958",
  "title": "Love Prevails, Never Fails",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Love is the most excellent way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Brothers) Love prevails! Never fails!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Sisters) Love prevails!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More than what we do or say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Brothers) Love prevails! Never fails!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Sisters) Love prevails!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love prevails when all else fails;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love never fails!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The love described by God’s own word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expresses God as life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life, a law, within God’s heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Spirit of Jesus Christ."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The love of God poured out from God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ into our hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is nothing less than Christ Himself"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who spreads through all our parts."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It covers, bends, endures all things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love’s strength to last is great;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love of God, like none on earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cannot discriminate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now let this love, the love of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Support, sustain the weak;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supply the love to build the church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And care for all God’s sheep."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
