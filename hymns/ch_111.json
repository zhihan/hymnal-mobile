  "title": "神的儿子亲爱救主",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "儿"
            },
            {
              "chord": "C",
              "text": "子、 亲"
            },
            {
              "chord": "G",
              "text": "爱 救"
            },
            {
              "chord": "",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "曾 用"
            },
            {
              "chord": "",
              "text": "你 宝"
            },
            {
              "chord": "D",
              "text": "血 救"
            },
            {
              "chord": "",
              "text": "赎"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "们 脱"
            },
            {
              "chord": "A7",
              "text": "死 和"
            },
            {
              "chord": "D7",
              "text": "罪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "的 圣"
            },
            {
              "chord": "",
              "text": "徒 欢"
            },
            {
              "chord": "C",
              "text": "乐 看"
            },
            {
              "chord": "",
              "text": "见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现"
            },
            {
              "chord": "Am",
              "text": "今 你"
            },
            {
              "chord": "",
              "text": "戴 荣"
            },
            {
              "chord": "D7",
              "text": "耀 冠"
            },
            {
              "chord": "",
              "text": "冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并"
            },
            {
              "chord": "G",
              "text": "登 天"
            },
            {
              "chord": "C",
              "text": "上 座"
            },
            {
              "chord": "G",
              "text": "位。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并"
            },
            {
              "chord": "Cm",
              "text": "登 天"
            },
            {
              "chord": "G",
              "text": "上"
            },
            {
              "chord": "D7",
              "text": "座"
            },
            {
              "chord": "G",
              "text": "位。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父的爱心将你高升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐你荣耀、尊贵、权能。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你坐祂右边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今颂赞、智慧、丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全属你，亲爱救主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的年日无限。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会的头，你坐那里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐福给你所有肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的是我们的："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们生命、能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我们坚定站立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过一切仇敌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀日子不久来临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的新妇就要上升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "鉴赏你的美丽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等可乐！看见了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听见你认我们属你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并永同你安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
