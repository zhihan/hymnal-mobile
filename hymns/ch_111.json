              "text": "兒"
            },
            {
              "chord": "C",
              "text": "子、 親"
            },
            {
              "chord": "G",
              "text": "愛 救"
            },
            {
              "chord": "",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "曾 用"
            },
            {
              "chord": "",
              "text": "你 寶"
            },
            {
              "chord": "D",
              "text": "血 救"
            },
            {
              "chord": "",
              "text": "贖"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "們 脫"
            },
            {
              "chord": "A7",
              "text": "死 和"
            },
            {
              "chord": "D7",
              "text": "罪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "的 聖"
            },
            {
              "chord": "",
              "text": "徒 歡"
            },
            {
              "chord": "C",
              "text": "樂 看"
            },
            {
              "chord": "",
              "text": "見："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "現"
            },
            {
              "chord": "Am",
              "text": "今 你"
            },
            {
              "chord": "",
              "text": "戴 榮"
            },
            {
              "chord": "D7",
              "text": "耀 冠"
            },
            {
              "chord": "",
              "text": "冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "並"
            },
            {
              "chord": "G",
              "text": "登 天"
            },
            {
              "chord": "C",
              "text": "上 座"
            },
            {
              "chord": "G",
              "text": "位。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "並"
            },
            {
              "chord": "Cm",
              "text": "登 天"
            },
            {
              "chord": "G",
              "text": "上"
            },
            {
              "chord": "D7",
              "text": "座"
            },
            {
              "chord": "G",
              "text": "位。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父的爱心将你高升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐你荣耀、尊贵、权能。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你坐祂右边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今颂赞、智慧、丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全属你，亲爱救主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的年日无限。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会的头，你坐那里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐福给你所有肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的是我们的："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们生命、能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我们坚定站立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过一切仇敌。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀日子不久来临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的新妇就要上升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "鉴赏你的美丽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等可乐！看见了你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听见你认我们属你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并永同你安息。"
            }
          ]
        }
      ]
    }
  ],
