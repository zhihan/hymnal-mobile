        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "你 已"
            },
            {
              "chord": "D7",
              "text": "得 消"
            },
            {
              "chord": "G",
              "text": "息！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主 留 我 们 今 日 在 世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原 是 为 争 战；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所 以 若 要"
            },
            {
              "chord": "C",
              "text": "成 功"
            },
            {
              "chord": "Am",
              "text": "神 旨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "就 须"
            },
            {
              "chord": "D7",
              "text": "上 疆"
            },
            {
              "chord": "G",
              "text": "场。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗军兵已经聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们已逼近；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从军的召会，当奋起！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是主亲兵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
