          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，分赐生命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，变化！"
            }
          ]
        },
