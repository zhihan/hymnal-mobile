    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里歌唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "末后亚当已经"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为赐生命的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与我合为一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，这是耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，那灵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，与祂联合！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二灵成一灵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里重生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
