      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "模成祂形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃借灵得餧养，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻吃喝生命主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂供应无量。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，完全救恩！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，属我！"
            }
          ]
        },
