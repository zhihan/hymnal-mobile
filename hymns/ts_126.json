{
  "url": "https://www.hymnal.net/cn/hymn/ts/126",
  "title": "我要让祂长大",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "生 命"
            },
            {
              "chord": "",
              "text": "的 种 子 撒 我 里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 要 让 祂 长 大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "F",
              "text": "生 命"
            },
            {
              "chord": "",
              "text": "的 种 子 撒 我 里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 要 让 祂 长"
            },
            {
              "chord": "C",
              "text": "大， 祂"
            },
            {
              "chord": "",
              "text": "长 大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 长"
            },
            {
              "chord": "G",
              "text": "大， 祂"
            },
            {
              "chord": "",
              "text": "长"
            },
            {
              "chord": "C",
              "text": "大！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不让魂生命挤住祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要让祂长大；…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祷读来浇灌祂，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天天呼喊‘哦，主耶稣，’…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同众圣徒一起交通，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要站起来为神说话，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当主说话我就阿们，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与众圣徒一起长大，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到长成基督身量，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到国度完全实现，…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
