      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不让魂生命挤住祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要让祂长大；…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祷读来浇灌祂，…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天天呼喊‘哦，主耶稣，’…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同众圣徒一起交通，…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要站起来为神说话，…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当主说话我就阿们，…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与众圣徒一起长大，…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到长成基督身量，…"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到国度完全实现，…"
            }
          ]
        }
      ]
    }
