    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art our true Passover,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God passed over us thru Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thyself and Thy redemption"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We with God have harmony."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, the Lamb of God, redeemedst us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thyself and with Thy blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We apply Thy blood, our ransom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eating Thee, our real food."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art the Bread from heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The unleavened Bread of life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eating Thee, with Thee we mingle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ceasing from our sin and strife."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lamb and Bread are both Thy figures,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Showing Thou art life to us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feasting on Thee at Thy table,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We enjoy Thy riches thus."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art the Heav’nly Manna,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As our daily food supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strengthening and energizing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our need to satisfy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living Rock Thou also art, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cleft for us with life to flow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drinking of this living water,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thirst is quenched, Thy life we know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art the Land of Canaan—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Elevated, rich and good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flowing with both milk and honey"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In a glorious plenitude."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy surplus God we worship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy fellowship we move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus in love we’re joined together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s building we will prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
