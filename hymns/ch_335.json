    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今永远不再返回"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "旧日愚昧的境地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟独在此才不定罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此才会有安息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今已经更换主人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对祂我要永伺候；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地的捆绑就此脱尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界已丢在背后。"
            }
          ]
        }
