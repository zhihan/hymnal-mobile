{
  "url": "https://www.hymnal.net/cn/hymn/ch/44",
  "title": "父阿儿女称颂你名",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父"
            },
            {
              "chord": "D",
              "text": "阿， 兒"
            },
            {
              "chord": "G",
              "text": "女 稱"
            },
            {
              "chord": "D7",
              "text": "頌 你"
            },
            {
              "chord": "G",
              "text": "名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 受 恩"
            },
            {
              "chord": "A7",
              "text": "典 的"
            },
            {
              "chord": "D",
              "text": "教 訓；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "們 歡"
            },
            {
              "chord": "Em",
              "text": "樂， 因"
            },
            {
              "chord": "B",
              "text": "你 生"
            },
            {
              "chord": "Em",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "G",
              "text": "使 我"
            },
            {
              "chord": "",
              "text": "們 歸"
            },
            {
              "chord": "D7",
              "text": "羊"
            },
            {
              "chord": "G",
              "text": "群。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你所给的得救证实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超我们的赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的心现在直指，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在天上的座位。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因在那里，祂作我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远不变的寄托。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将生命分给罪人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂为罪人谋解脱。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "永世虽久，不过就是："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显明你恩的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫那些因你儿子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为儿女者，来称祝。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现虽未见早晨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却仍安心历世途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候祂来提接我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离死亡和坟墓。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们欢乐，因你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是我们的‘永分，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像你儿子！同祂一起！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受光明的早晨！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，求圣父因祂慈名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "保守我们在这里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无忧无虑，随祂而行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到同乐在那地。"
            }
          ]
        }
      ]
    }
  ],
