              "text": "這 樣"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聽 主"
            },
            {
              "chord": "D",
              "text": "號 令，"
            },
            {
              "chord": "",
              "text": "求 主"
