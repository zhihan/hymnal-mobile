    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我对撒但总是说：‘不，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我对父神就说：‘是！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个是我永远态度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求神施恩加保护。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不然当我实行顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但就要拦去路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我正在听你吩咐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，求你看顾！"
            }
          ]
        }
      ],
