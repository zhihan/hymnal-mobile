            },
            {
              "chord": "D7",
              "text": "当 我"
            },
            {
              "chord": "G",
              "text": "这 样"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听 主"
            },
            {
              "chord": "D",
              "text": "号 令，"
            },
            {
              "chord": "",
              "text": "求 主"
            },
            {
              "chord": "A",
              "text": "赐 给"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "我 权"
            },
            {
              "chord": "D",
              "text": "柄，"
            },
            {
              "chord": "D7",
              "text": "使 我"
            },
            {
