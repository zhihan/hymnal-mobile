{
  "url": "https://www.hymnal.net/cn/hymn/ch/93",
  "title": "哎哟救主真曾流血",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哎 喲！"
            },
            {
              "chord": "",
              "text": "救 主 真"
            },
            {
              "chord": "D",
              "text": "曾 流"
            },
            {
              "chord": "G",
              "text": "血？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真 曾 捨 命 亡"
            },
            {
              "chord": "D",
              "text": "躬？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "祂"
            },
            {
              "chord": "G",
              "text": "肯 犧"
            },
            {
              "chord": "",
              "text": "牲 祂"
            },
            {
              "chord": "C",
              "text": "的 超"
            },
            {
              "chord": "",
              "text": "越，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為"
            },
            {
              "chord": "D",
              "text": "我 這"
            },
            {
              "chord": "",
              "text": "個"
            },
            {
              "chord": "D7",
              "text": "小"
            },
            {
              "chord": "G",
              "text": "蟲？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在木上那样哀叹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可是为我罪愆？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怜悯何满！慈爱何汎！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典何其无边！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "难怪太阳立变暗乌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隐藏一切荣光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当神基督造物的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为人担罪而亡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我看见祂十字架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也当隐藏羞脸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心当镕化，感激不暇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "眼当流泪自贬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但这满腔忧伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能稍还主爱的债；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我在此奉上一生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聊表此心感戴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
