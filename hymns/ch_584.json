{
  "url": "https://www.hymnal.net/cn/hymn/ch/584",
  "title": "主你没有一句为我",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "没 有 一"
            },
            {
              "chord": "A",
              "text": "句 为"
            },
            {
              "chord": "",
              "text": "我？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "使 我"
            },
            {
              "chord": "",
              "text": "更"
            },
            {
              "chord": "D",
              "text": "能 向"
            },
            {
              "chord": "E7",
              "text": "你 信"
            },
            {
              "chord": "A",
              "text": "托，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 更"
            },
            {
              "chord": "D",
              "text": "能 离"
            },
            {
              "chord": "",
              "text": "开 喜"
            },
            {
              "chord": "G",
              "text": "欲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一 句， 我 主， 求"
            },
            {
              "chord": "A7",
              "text": "赐 一"
            },
            {
              "chord": "D",
              "text": "句。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一句来显我的软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我欣赏自己工作；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我空劳碌，我空叹吁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一句，我主，求赐一句。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一句来示你的相亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你乃是住在我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的生命我也同豫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一句，我主，求赐一句。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一句，求将有力应许"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显在许多畏惧、罣虑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你微而清所说话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一句，我主，求赐一句。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一句最终得胜呼喊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得你应许甘甜盘桓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你永远快乐同居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一句，我主，求赐一句。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "读经",
