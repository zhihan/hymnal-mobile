        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "那"
        },
        {
          "chord": "Em",
          "text": "權 能"
        },
        {
          "chord": "B",
          "text": "者 恣"
        },
        {
          "chord": "C",
          "text": "意 背"
        },
        {
          "chord": "",
          "text": "判，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "先"
        },
        {
          "chord": "D",
          "text": "來 將"
        },
        {
          "chord": "D7",
          "text": "地 篡"
        },
        {
          "chord": "G",
          "text": "奪；"
        }
      ]
    },
    {
