        {
          "chord": "D7",
          "text": "又"
        },
        {
          "chord": "G",
          "text": "在 空"
        },
        {
          "chord": "",
          "text": "中 蓄"
        },
        {
          "chord": "C",
          "text": "勢 爭"
        },
        {
          "chord": "",
          "text": "戰，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "建"
        },
        {
          "chord": "Am",
          "text": "立 黑"
        },
        {
          "chord": "D7",
          "text": "暗 之"
        },
        {
          "chord": "G",
          "text": "國。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神的心意是要在地"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "建立祂的国度，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "好使祂能掌权治理，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "显明祂智丰足。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "地虽荒废，渊面黑暗，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神来恢复、再造，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "且按祂的神圣意念，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "造人与祂相肖。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "恶者撒但又将人骗，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "诱离神恩源头；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "亚伯拉罕见神显现，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "蒙召族类起首。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神领选民脱离埃及，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "经过红海、野疆，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "进入迦南应许美地，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神国在此彰显。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "以色列民竟弃神治，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "属地君主依恃；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神国彰显再次丧失，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "直至大卫之时；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "借他神得执政道路，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神国重新恢复；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "百姓终究仍是失误，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "被掳，失去国度。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "人虽不堪，神不失败，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "亲来成为肉身；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "向人宣告\"：应当悔改！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "因为国度临近。\""
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神人耶稣，完美绝佳，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为神权柄执掌；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "撒但将祂钉死十架，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不过显其愚妄。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "妙哉，耶稣救赎成就，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "复活胜过死亡，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为要使地得蒙拯救，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "脱离撒但捆绑；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "且成那灵进入人里，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "召会借此建立─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "生命洋溢，混乱消弭，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神旨通行于地。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如今召会在地显明，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神国丰满实际；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神圣权柄尽得通行，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "使地归神管理。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们在此为神执政，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "撒但只能逃遁；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如此召会作神见证，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "国度不再藏隐。"
        }
      ]
    }
  ],
