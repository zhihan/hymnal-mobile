{
  "url": "https://www.hymnal.net/cn/hymn/ch/42",
  "title": "父神我今敬拜你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "父 神，"
            },
            {
              "chord": "",
              "text": "我 今 敬 拜"
            },
            {
              "chord": "A",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恭 敬 向 你"
            },
            {
              "chord": "A7",
              "text": "來 頂"
            },
            {
              "chord": "D",
              "text": "禮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 著"
            },
            {
              "chord": "B7",
              "text": "基 督"
            },
            {
              "chord": "Em",
              "text": "作 我"
            },
            {
              "chord": "G",
              "text": "祭："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "父 阿，"
            },
            {
              "chord": "",
              "text": "我 敬"
            },
            {
              "chord": "A7",
              "text": "拜"
            },
            {
              "chord": "D",
              "text": "你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱浩大，何深阔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂死临及我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩、义，因此我全得："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，我敬拜你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "原是罪人何污秽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今成神子何尊贵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等丰厚的恩惠："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，我敬拜你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今在灵中敬拜你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并以基督为实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你，祂是馨香祭："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，我敬拜你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿向你再献上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深处感戴的颂扬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "颂扬你爱永无疆："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，我敬拜你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
