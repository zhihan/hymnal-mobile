    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "John wept as he considered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That none the right did own"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The scroll to take and open,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's myst'ry to make known;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No, none on earth nor heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor universe around—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we, too, would be weeping"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If none were worthy found."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The universe, mysterious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would be in darkness still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could none break through to open"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The scroll, to show God's will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, lo, the worthy Lion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Judah hath prevailed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The seven seals to open,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And have the scroll unveiled."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer now in darkness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's secret is enclosed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to our inner vision"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It's open, full, disclosed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts are for this purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our lives are for His plan;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for this revelation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We praise the Lion-Lamb!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The four-and-twenty elders"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All fall before that sight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The living creatures praise Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who rest not, day nor night."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So let us join their praises"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him who loosed God's plan;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We'll lift with theirs our voices"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To praise the Lion-Lamb!"
            }
          ]
        }
