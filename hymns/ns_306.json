    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In pastures green He makes me lie."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My soul He satisfies always,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The restful water leads me by,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship and perfect peace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I often stray; He seeketh me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To yield my heart to His control."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His name’s sake He leadeth me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shepherds my oft-shaken soul."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Incredible the thought beside—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pursuing Thee all care is stilled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy rod and staff support and guide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My way is with Thy presence filled."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Emboldened in Thy victory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I feast surrounded by my foes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My head anointed bountifully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My cup with blessings overflows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love the measure of my days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace a boundless treasure store;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Good Shepherd, may I sing Thy praise"
            }
          ]
        },
        {
          "segments": [
