      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They heard Thy voice, beheld Thy form,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy beauteous stature unforgot;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They crowded ’round Thee, met Thy gaze,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But who Thou art, they knew it not."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As they of old we too are veiled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve known Thee long apparently;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet if we say we know, at best"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We know Thee not transparently."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But as the Spirit now Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Another Comforter become;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reveal Thyself within my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since to Thy temple Thou hast come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy blest Spirit, Lord, fill me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill every corner of my soul;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thou inspire my every part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh may Thou touch, renew the whole."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit then revealing make"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself more real within my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That ear not hear, nor eye may see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How very real to me Thou art."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou in mercy dost reveal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And give Thyself as Spirit thus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What in the world can be more real,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More true than what Thou art to us?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit, Lord, in mine, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’erflow my being as a flood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That every part with glory shine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And everywhere be Thee and God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How close we are in such a life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In one is blended earth with heav’n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy presence sweetly fills our souls;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts are to Thy praises giv’n."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
