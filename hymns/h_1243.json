    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We are one in the spirit, yet it goes deeper still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this oneness is spreading to our mind, emotion, will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we all stand together that His purpose He fulfill."
            }
          ]
        }
