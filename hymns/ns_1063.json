      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy touch, O Lord, has healed me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart of stone replaced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart of flesh now in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To love Thee Lord always;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But still Thy life spreads in my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy flowing streams must reach each part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pour in Thy life—more love impart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O let Thy life renew each part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
