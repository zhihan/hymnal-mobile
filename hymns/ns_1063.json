    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And like that desperate woman,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I stretched my hand to grasp—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For nothing else could cure me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But lo, the One, at last!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy human virtues God reveals,"
            }
          ]
        },
        {
          "segments": [
            {
