{
  "url": "https://www.hymnal.net/cn/hymn/ts/604",
  "title": "我们手拿线铊",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "全 地"
            },
            {
              "chord": "",
              "text": "平 靜 安 息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 卻 為 著 祂"
            },
            {
              "chord": "Em",
              "text": "的 見"
            },
            {
              "chord": "",
              "text": "證，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心"
            },
            {
              "chord": "A",
              "text": "裡 火"
            },
            {
              "chord": "",
              "text": "熱 著 急，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "A7",
              "text": "是 何"
            },
            {
              "chord": "",
              "text": "等 著"
            },
            {
              "chord": "D",
              "text": "急！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟 兄 姊 妹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 不 能 只 顧 自 己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "依"
            },
            {
              "chord": "A",
              "text": "舊 貪"
            },
            {
              "chord": "",
              "text": "享 安 逸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安"
            },
            {
              "chord": "A7",
              "text": "逸 會"
            },
            {
              "chord": "",
              "text": "被 撇"
            },
            {
              "chord": "D",
              "text": "棄。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "定期已经到了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神要来再拣选我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复兴全地召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在正是时候！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄姊妹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们应当趁这关头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来与主配合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不容机会错过。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请听主的应许："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要回到耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍旧与你同住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你丰盛发达。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的城邑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要像无城墙的乡村，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为生养众多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚至容纳不下。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已开始作工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，祂正兴起环境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要来震动列国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使召会抬头。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们宣告："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个大地，乃至宇宙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是属于主的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但休要伸手，"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有主的话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不是依靠势力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是倚靠才能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是靠主的灵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，大山哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "别在我们面前作祟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你算不得甚么，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迟早要被铲平。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "七眼遍察全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看见我们手拿线铊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是何等欢喜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "别的祂不在意！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀！荣耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "殿的根基既然立了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣殿也必完成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成在我们手里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
