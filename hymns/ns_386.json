      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The world is longing, seeking for peace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet wars and rumors of wars still increase."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is no way for men to end all this fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All this pain, all this hate, all these tears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Jesus is here!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We are dwelling in the love of the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He our unity has now restored."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers, sisters in one family,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Father and the Son, always one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So are we!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How good and pleasant it can be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When brothers dwell in unity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like sweet anointing and the mountain dew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life eternal for me and for you—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are new!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
