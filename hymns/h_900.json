    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, to be nothing, nothing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only as led by His hand—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A messenger at His gateway,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only waiting for His command;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only an instrument ready"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His praises to sound at His will—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willing, should He not require me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In silence to wait on Him still."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, to be nothing, nothing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only to lie at His feet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A broken and emptied vessel—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the Master’s use made meet!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, to be nothing, nothing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Painful the humbling may be!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet low in the dust I’d lay me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the world might my Savior see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rather be nothing, nothing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him let their voices be raised!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the fountain of blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He only is meet to be praised!"
            }
          ]
        }
      ]
    },
