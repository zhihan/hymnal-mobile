{
  "url": "https://www.hymnal.net/cn/hymn/ch/626",
  "title": "哦神凭灵并凭实际",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦 神，"
            },
            {
              "chord": "",
              "text": "凭 灵 并"
            },
            {
              "chord": "Am",
              "text": "凭 实"
            },
            {
              "chord": "",
              "text": "际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "C",
              "text": "们 在"
            },
            {
              "chord": "",
              "text": "此 敬"
            },
            {
              "chord": "D",
              "text": "拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照"
            },
            {
              "chord": "G",
              "text": "著 你"
            },
            {
              "chord": "",
              "text": "子 基"
            },
            {
              "chord": "C",
              "text": "督 所"
            },
            {
              "chord": "",
              "text": "说，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "前 我"
            },
            {
              "chord": "D7",
              "text": "们 今"
            },
            {
              "chord": "G",
              "text": "来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢父神，你乃是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对我何亲何近！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我凭灵与你接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并凭实际敬尊。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾为我创造一灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为使我能拜你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不需外面挣扎事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只需回到灵里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已用灵重生我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且作我的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还在将我心思更新，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我真能事奉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们照着里面感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此向你敬拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你灵涂抹、运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你表明出来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凭着实际事奉敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再凭着影像；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭着基督，惟一实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们敬拜颂扬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们向你献上基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是我所经历；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同尝祂的甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欣赏祂的美丽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦神，凭灵并凭实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在此聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "围绕你的施恩宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬拜、感赞不已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "聚会",
