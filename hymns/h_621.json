    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, safe and happy shelter!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, refuge tried and sweet!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, trysting place where heaven’s love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And heaven’s justice meet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As to the holy patriarch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That wondrous dream was given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So is my Savior by the cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A ladder up to heaven."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There lies beneath its shadow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But on the farther side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The darkness of an awful grave"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That gapes both deep and wide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And there between us stands the cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Two arms outstretched to save,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like a watchman set to guard the way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From that eternal grave."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon that cross of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mine eye at times can see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The very dying form of One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who suffered there for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from my smitten heart, with tears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Two wonders I confess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wonders of His glorious love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my own worthlessness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take, O cross, thy shadow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my abiding place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I ask no other sunshine than"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sunshine of His face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Content to let the world go by,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To know no gain nor loss,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sinful self my only shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My glory all the cross."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
