{
  "url": "https://www.hymnal.net/en/hymn/h/813",
  "title": "I come before Thy throne of grace",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "I come"
            },
            {
              "chord": "",
              "text": "before Thy"
            },
            {
              "chord": "A",
              "text": "throne of"
            },
            {
              "chord": "D",
              "text": "grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With hungry heart on Thee to"
            },
            {
              "chord": "A",
              "text": "feed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace and"
            },
            {
              "chord": "A7",
              "text": "mercy"
            },
            {
              "chord": "D",
              "text": "to"
            },
            {
              "chord": "D7",
              "text": "re"
            },
            {
              "chord": "G",
              "text": "ceive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To"
            },
            {
              "chord": "A",
              "text": "help me"
            },
            {
              "chord": "D",
              "text": "in this"
            },
            {
              "chord": "A",
              "text": "hour"
            },
            {
              "chord": "A7",
              "text": "of"
            },
            {
              "chord": "D",
              "text": "need."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here I behold Thy radiant face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its light upon my heart doth shine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With healing rays consuming all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The weaknesses and faults of mine."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here Thy light illuminates"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My true condition unto me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here Thy blood’s effectiveness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To cleanse from sin I gladly see."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit too anoints me here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And makes Thy very substance mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy very self I thus enjoy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And know Thy very heart’s design."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word I read before Thee here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en as the priests the lamp did light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit is as oil to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To light Thy Word and give me sight."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en as the priests the incense burned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In prayer to Thee I persevere;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As incense Thou the Spirit art"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mixed with the prayer I offer here."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word is light, Thy Word is food;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which doth enlighten and supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I long to read and feed much more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For light and food to satisfy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the living water too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which full revival doth bestow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wish to pray and drink e’en more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That through me living rivers flow."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the incense unto God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee acceptance is complete;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I want to pray yet more and more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To offer up this fragrance sweet."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By reading I’m enlightened, filled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By prayer my thirst is quenched indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus Thou to me may be supplied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou through me may meet the need."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I long to have such fellowship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To read and pray and blend with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I long that Thou wouldst saturate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou may overflow from me."
            }
          ]
        }
      ]
    }
  ],
