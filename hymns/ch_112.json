      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是谁带着荣耀而来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配上禧年的号声？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "争战之主、万军之神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在战场已得胜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已忍受十架苦难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且从坟墓已复起；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已除灭罪与撒但，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着死，借着死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂死毁仇敌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "正在举手祝福之时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就离地往上升；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂门徒正在看祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就被接去天庭。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同行，使神喜悦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传过真理与审判；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的以诺被神取去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得进到，得进到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得以进到神面前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的亚伦进入圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着祂血进幔内；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我约书亚进入迦南，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众王祂前都败退；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂将我们神的选民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "栽植应许的美地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我以利亚现今赐下"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "双倍福，双倍福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "双倍属天的福气。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已提高我们人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将人带到神右边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与祂同坐天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂同在荣耀间。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣作王，天使敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人竟与神同宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大能的主，凭你升天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我相信，我相信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "相信升天必得着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
