      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "向前直跑！丢弃万事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看万物如粪土！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的基督，荣耀奖赏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吸引我的脚步！"
            }
          ]
