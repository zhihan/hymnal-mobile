    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To fulfill all the law, He took my place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He obeyed, e’en suffering, my sin to erase."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m redeemed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus has satisfied God’s heart, and set me free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I open my heart, to offer praise to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is an infinite gratitude"
            }
          ]
