              "chord": "",
              "text": "In all my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all You’ve done for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Wondrous news You’ve revealed—now I can see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what grace! Your love divine is flowing in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! That gaze!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eyes full of tenderness! Beholding face to face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I open my heart, to offer praise to Thee."
            }
          ]
        },
        {
