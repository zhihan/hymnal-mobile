              "text": "For all You’ve shown to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Riven veil—living way thus He affords."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He arose, the work completed! Oh, praise the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! What peace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I can boldly come into the holiest place!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I open my heart, to offer praise to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your name is infinite plenitude!"
