        {
          "segments": [
            {
              "chord": "",
              "text": "圣别烈火在焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不洁、不圣全烧掉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣火烧成圣别光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上下四方照明亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切行动在光中，"
            }
          ]
        },
        {
          "segments": [
