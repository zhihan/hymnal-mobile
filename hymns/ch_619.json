    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "随着活物的行踪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的大轮在转动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "动得可畏高而明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出恩主的荣形，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣的计画借此完成。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "随从圣灵光中行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天就清明如水晶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能从无亏的良心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发出见证的声音；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此发声并静听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的举动得推行。"
            }
          ]
        }
      ],
