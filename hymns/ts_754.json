{
  "url": "https://www.hymnal.net/cn/hymn/ts/754",
  "title": "为主见证移民开展",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "為 主"
            },
            {
              "chord": "",
              "text": "見 證 移 民"
            },
            {
              "chord": "D",
              "text": "開 展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "誰 願"
            },
            {
              "chord": "D7",
              "text": "蒙 恩"
            },
            {
              "chord": "",
              "text": "向 前"
            },
            {
              "chord": "G",
              "text": "走？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何 時？ 何 處？"
            },
            {
              "chord": "G7",
              "text": "照 主"
            },
            {
              "chord": "C",
              "text": "差 遣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩 主"
            },
            {
              "chord": "G",
              "text": "面 光"
            },
            {
              "chord": "D7",
              "text": "當 尋"
            },
            {
              "chord": "G",
              "text": "求。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为将圣殿、圣城建立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "扩展神国及全地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "背判征服，混乱消弭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心合意众如一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父乃源头，子作管道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那灵涌流为凭借；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "站住立场，灵中相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此乃得胜的秘诀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主所筹画伟大、完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "激动我们全奉献；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好让圣灵浸透、充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣定旨得实现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日在此学习多方："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配搭建造、灵刚强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日前往各城、各邦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建立灯台显荣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "诸天掌权需\"滩头堡\"─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会─先建立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主兴起各地建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实现国度为目的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时，全地荣耀归你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失败、羞辱归仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万民称颂你名不已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度掌权达至极。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有福之日不久就到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀经纶得成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐、赞美达到至高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣管治遍万有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美圣父，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美圣子，阿利路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美圣灵，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神旨得成，阿利路。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会荣耀，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众圣美善，阿利路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聚会美善，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁不受感来归服？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，高声唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，赞我王！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    }
  ],
  "metadata": {
    "category": "教会的生活",
