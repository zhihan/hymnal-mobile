      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宁舍世界而要基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂我就别无需；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着世界仍是缺如，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着基督就有馀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，祂丰满我不能言！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但这丰满我知道；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，祂甘甜真是超凡！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但这甘甜我尝到。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世界虽大，我心虽小，"
