              "text": "Lord, grow in us!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ will be the morning star to those eagerly waiting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Watching for Him everyday in darkness for His rising."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s dark and most are sleeping; I rise for Your appearing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reward me every morning; I want Your gentle shining."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is coming as a judge, all His people to meet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our work He’ll test through fire before His judgement seat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So burn in me today, Lord! I open to Your searching."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burn the wood and fill with gold; I’m desperate for Your purging!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s coming is His presence"
            }
          ]
        },
        {
