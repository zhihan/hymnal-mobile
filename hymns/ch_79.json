  "title": "哦主当我们想到你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "当 我 们"
            },
            {
              "chord": "G",
              "text": "想 到"
            },
            {
              "chord": "C",
              "text": "你"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 世 所"
            },
            {
              "chord": "D7",
              "text": "历 路"
            },
            {
              "chord": "G",
              "text": "程："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（你"
            },
            {
              "chord": "C",
              "text": "以 恩"
            },
            {
              "chord": "G",
              "text": "爱 对"
            },
            {
              "chord": "C",
              "text": "待 群"
            },
            {
              "chord": "F",
              "text": "黎， 你"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "以 忠"
            },
            {
              "chord": "G",
              "text": "诚 对"
            },
            {
              "chord": "C",
              "text": "神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱虽然被人辜负，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显为比死更强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刺你的枪，不过引出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "血水，洗人天良。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽自己常经忧患，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却到处行善；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然你的路途艰难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却不想怨叹。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "四围不忠，你却赤忠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗，你却光明。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父的喜乐，你心所重，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从未违祂命令。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不因撒但诡计摇动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不顾苦难、损失；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的行径，无人同情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "孤单一直到死。）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不禁奇你谦卑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盼望能以像你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们愿学你式微，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因这里有安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
