  "title": "何等权能耶稣尊名",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "权 能！ 耶"
            },
            {
              "chord": "A",
              "text": "稣 尊"
            },
            {
              "chord": "",
              "text": "名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天 使 全 都 俯"
            },
            {
              "chord": "D",
              "text": "伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献 上 冠 冕， 同 心 尊 敬"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 作 万"
            },
            {
              "chord": "E7",
              "text": "有 之"
            },
            {
              "chord": "A",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "献"
            },
            {
              "chord": "D",
              "text": "上 冠"
            },
            {
              "chord": "",
              "text": "冕， 同"
            },
            {
              "chord": "A",
              "text": "心 尊"
            },
            {
              "chord": "",
              "text": "敬"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "D",
              "text": "作"
            },
            {
              "chord": "G",
              "text": "万"
            },
            {
              "chord": "A7",
              "text": "有 之"
            },
            {
              "chord": "D",
              "text": "主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们历代殉道众圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要从祭坛欢呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同声高举耶西的根，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是万有之主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们被赎亚当后代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出身‘堕落’圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙恩得救，应当敬拜"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作万有之主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "罪人，你心永不能忘"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的苦胆、酸醋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今当到祂面前瞻望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂这万有之主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿地上万族万民"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都向救主欢呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀、尊贵，都归祂名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是万有之主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亿万群众歌声雷动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也一同俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永远敬拜称颂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作万有之主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
