    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Father loves man and chooses man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In eternity past, in His great plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "According to His purpose, and not of works"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But of Him, in the section of Jacob."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Father calls man and justifies man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In time, in the section of Abraham;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man may live by faith, know grace from within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man may live in fellowship with Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Son gives man His rich inheritance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And a life enjoying His abundance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And a life in peace, totally without lack—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully blessed, in the section of Isaac."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Spirit transforms man and causes man"
