    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Why restless, why cast down, my soul?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trust God, who will employ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His aid for thee, and change these sighs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To thankful hymns of joy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thee, my God, the living God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thirsty soul doth pine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, when shall I behold Thy face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Majesty Divine?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God of my strength, how long shall I,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like one forgotten, mourn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forlorn, forsaken, and exposed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To my oppressor’s scorn?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Why restless, why cast down, my soul?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hope still, and thou shalt sing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The praise of Him who is thy God,"
            }
          ]
        },
        {
