  "title": "看哪！主必快来！",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "今 日"
            },
            {
              "chord": "",
              "text": "争 战 凶"
            },
            {
              "chord": "G",
              "text": "猛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒"
            },
            {
              "chord": "D",
              "text": "但 尚"
            },
            {
              "chord": "",
              "text": "未 退"
            },
            {
              "chord": "A",
              "text": "败；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "战"
            },
            {
              "chord": "D",
              "text": "场 传"
            },
            {
              "chord": "",
              "text": "来 呼"
            },
            {
              "chord": "E7",
              "text": "喊 之"
            },
            {
              "chord": "A",
              "text": "声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比 前 更"
            },
            {
              "chord": "E7",
              "text": "加 澎"
            },
            {
              "chord": "A",
              "text": "湃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "阴"
            },
            {
              "chord": "D",
              "text": "府 背"
            },
            {
              "chord": "",
              "text": "叛 喧"
            },
            {
              "chord": "G",
              "text": "嚣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽"
            },
            {
              "chord": "E7",
              "text": "仍 强"
            },
            {
              "chord": "",
              "text": "悍 不"
            },
            {
              "chord": "A",
              "text": "衰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "请"
            },
            {
              "chord": "D",
              "text": "听 夜"
            },
            {
              "chord": "",
              "text": "半 主"
            },
            {
              "chord": "A",
              "text": "发 呼"
            },
            {
              "chord": "D",
              "text": "声："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"看"
            },
            {
              "chord": "G",
              "text": "哪， 我"
            },
            {
              "chord": "A7",
              "text": "必 快"
            },
            {
              "chord": "D",
              "text": "来！\""
            }
