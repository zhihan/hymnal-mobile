      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽有更苦试炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "争战不断接连；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗权势如同军队，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "集聚进逼无间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正当儆醒等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正逢艰苦试验；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却闻歌声喜乐、甘甜："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主已快显现！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当在末后年日，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "持守见证不移；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但无所不用其极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们仍需站立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当重新得力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能胜过仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到见主，何等欢喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叹息全都止息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁愿奋力进前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠主能力遮盖？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁愿坚定为主争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到那日奏凯？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜欢呼号声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "至终必定传开；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等喜乐，已先听见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"看哪，我必快来！\""
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁愿走上窄路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神旨意拣选？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "历经风暴，通过考验，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "绝不退后、心变？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁愿忠勇进前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍受痛苦、凶险？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众得胜者仿佛看见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"我主已快显现！\""
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "应当加紧脚步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽管黑暗四布；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "期待那日被提之福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀辉煌夺目；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终将撒但征服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迎接再临基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜者阿，扬声欢呼："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"看哪！耶稣，我主！\""
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
