    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今在异地作客飘泊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽受窘困仍欢畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我不久必到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更美的家乡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲朋虽以世福为上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我天天所仰望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是圣城在天上。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然道路崎岖难行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我腿酸手下垂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但一想到那城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全身力即回；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然我眼难免流泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我心永不灰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因有圣城为我备。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今斗拳，不是打空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奔跑不是无目标，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是照神心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "追求那上好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忘记背后，努力面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向着标竿一直跑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得圣城的荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱何丰，主恩何盛，"
            }
          ]
