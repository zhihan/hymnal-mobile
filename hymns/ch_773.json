        {
          "segments": [
            {
              "chord": "",
              "text": "使我得住那圣城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新耶路撒冷！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众圣欢腾，众圣和声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主恩颂主名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在那新耶路撒冷！"
            }
          ]
        }
