              "text": "Nor thinks of time or place:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I ask no more, in good or ill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But union with Thy holy will."
            }
          ]
        }
