{
  "url": "https://www.hymnal.net/cn/hymn/ch/590",
  "title": "基督是话，祂也是灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "基 督"
            },
            {
              "chord": "",
              "text": "是 话， 祂 也 是"
            },
            {
              "chord": "A",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且"
            },
            {
              "chord": "D",
              "text": "是 祂"
            },
            {
              "chord": "E",
              "text": "话 里"
            },
            {
              "chord": "",
              "text": "面"
            },
            {
              "chord": "E7",
              "text": "的"
            },
            {
              "chord": "A",
              "text": "灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "G",
              "text": "对 我"
            },
            {
              "chord": "",
              "text": "们 所 说 的 话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都"
            },
            {
              "chord": "D",
              "text": "是 灵，"
            },
            {
              "chord": "",
              "text": "也 都"
            },
            {
              "chord": "A",
              "text": "是"
            },
            {
              "chord": "A7",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神在外面赐我圣经，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也在里面赐我圣灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二者是神极大礼物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我享受神作供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣经乃借圣灵表明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵乃是圣经实际；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二者乃是一物两面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远不可彼此分离。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣经一经圣灵照亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到我灵中就是生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣经若与圣灵分开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立变虚空，毫无供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我用灵接触圣经，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它就变成灵作生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当灵从我发表出去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又成为话将人供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "必须运用我们的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深处接受神的圣经；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然后当灵释放出去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵、经乃一，在我证明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你话在我里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能成为灵作我生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并愿你灵在你话里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我的真实表明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
