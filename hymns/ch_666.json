  "raw_sections": [
    "去 採集 材 料，",
    "為 著神 的殿，",
    "去 勸告親 友",
    "向 神來 回轉；",
    "去 帶領 罪 人",
    "脫 罪免 沉淪，",
    "去 尋找 迷 羊",
    "來 歸主羊群。",
    "去采集材料，",
    "为着神的殿，",
    "去拯救世人",
    "脱世界纠缠；",
    "脱离撒但的",
    "黑暗与欺骗，",
    "脱离他一切",
    "诱惑的手段。",
    "去采集材料，",
    "为着神的殿，",
    "去引导浪者，",
    "来投主怀间；",
    "去打败魔鬼－",
    "害人的仇敌，",
    "去释放俘囚，",
    "来向主归依。",
    "去采集材料，",
    "为着神的殿，",
    "在身体立场，",
    "将基督宣传；",
    "与主众圣徒",
    "灵同魂也同，",
    "到处去吹响",
    "福音的号筒。"
  ]
