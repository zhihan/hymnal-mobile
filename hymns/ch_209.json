{
  "url": "https://www.hymnal.net/cn/hymn/ch/209",
  "title": "耶稣你的全胜的爱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "耶 稣，"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "的 全"
            },
            {
              "chord": "G",
              "text": "胜 的"
            },
            {
              "chord": "",
              "text": "爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "C",
              "text": "经 浇"
            },
            {
              "chord": "",
              "text": "灌 我"
            },
            {
              "chord": "G",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 就"
            },
            {
              "chord": "D",
              "text": "不 再"
            },
            {
              "chord": "G",
              "text": "会 摇"
            },
            {
              "chord": "",
              "text": "摆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就 能 生"
            },
            {
              "chord": "D7",
              "text": "根 于"
            },
            {
              "chord": "G",
              "text": "神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就 能 生"
            },
            {
              "chord": "D7",
              "text": "根 于"
            },
            {
              "chord": "G",
              "text": "神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿圣火今在我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就已发旺不休；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "烧掉所有卑情下品，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并使高山镕流。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾赐下祭坛火炭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你烧掉我罪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我向焚烧的灵呼喊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主灵，满我心内。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心要接锻炼的火，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我旧造烧绝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "散布生命在每角落，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并使全人圣洁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "摇动的心求你扶掖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使它变成坚崖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督成为我的世界，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的全心成爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
