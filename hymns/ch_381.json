{
  "url": "https://www.hymnal.net/cn/hymn/ch/381",
  "title": "主你是我生命",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "是 我"
            },
            {
              "chord": "Em",
              "text": "生 命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "活 在"
            },
            {
              "chord": "",
              "text": "我 裡"
            },
            {
              "chord": "D",
              "text": "面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "帶 著"
            },
            {
              "chord": "D7",
              "text": "神 的"
            },
            {
              "chord": "G",
              "text": "豐 盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "來 將"
            },
            {
              "chord": "A7",
              "text": "我 充"
            },
            {
              "chord": "D",
              "text": "滿。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 聖 別"
            },
            {
              "chord": "G",
              "text": "性 情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我"
            },
            {
              "chord": "C",
              "text": "能 成"
            },
            {
              "chord": "G",
              "text": "聖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 復 活 大 能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "使 我"
            },
            {
              "chord": "D7",
              "text": "能 得"
            },
            {
              "chord": "G",
              "text": "勝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你这生命流通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就蒙光照，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我活在光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你能相交；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来各种供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也有所要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得蒙洁净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你所有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那灵运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像膏油涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我心思、心、灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都浸润过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我全人变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到成熟长大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有你身量。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的生命成分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常将我滋润，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得复苏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命吞灭死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "软弱变刚强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放消除捆绑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "下沉变高昂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我将自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全献给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照着你的心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活在交通里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再立志挣扎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再改自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你受到打岔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫不能为力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是完全停下"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己的努力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你运行、变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与众圣徒配搭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你定居、安家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彰显你自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "经历基督",
