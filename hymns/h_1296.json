    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So God's intention was to gain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His kingdom on the earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The place where He could fully reign"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And show to all His worth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus He began in Genesis"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To forward His great plan."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of this darkened, lost abyss"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God created man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Satan caused the man to fall"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From God's eternal grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then Abraham received the call"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To head the chosen race."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Jews were led from Pharaoh's hand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through sea and wilderness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the promised Canaan land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's kingdom to express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Israelites refused God's reign,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Desired an earthly king;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom then was lost again"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till David was to bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's kingdom back to earth once more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God to rule through him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Israel failed as once before"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's kingdom to bring in."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Such was the situation when"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God became a man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Declaring to all men,\"Repent!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom is at hand.\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A perfect model of God's rule,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The King, full qualified!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Satan as a desperate fool"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Had Jesus crucified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This Jesus went into the grave"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And death He overcame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now resurrected He will save"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The earth from Satan's reign."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He as the Spirit enters man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To fill him with His life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These men, the church, fulfill His plan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To save the earth from strife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now on the earth the church we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's kingdom here expressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where He has full authority"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His rule to manifest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The place where Satan has to flee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our mighty conquering rod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom through the church will be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought to the earth for God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
