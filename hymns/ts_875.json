{
  "url": "https://www.hymnal.net/cn/hymn/ts/875",
  "title": "西布伦，扬帆起行",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "西 布"
            },
            {
              "chord": "",
              "text": "倫， 出 外 可 以 歡 喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隨 聖"
            },
            {
              "chord": "C",
              "text": "靈 大"
            },
            {
              "chord": "",
              "text": "風 揚 帆 起"
            },
            {
              "chord": "G",
              "text": "行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "福 音"
            },
            {
              "chord": "D",
              "text": "船 滿"
            },
            {
              "chord": "",
              "text": "載 基"
            },
            {
              "chord": "G",
              "text": "督 豐"
            },
            {
              "chord": "Em",
              "text": "富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "傳 揚"
            },
            {
              "chord": "C",
              "text": "基 督"
            },
            {
              "chord": "",
              "text": "復 活，"
            },
            {
              "chord": "D7",
              "text": "作 祂"
            },
            {
              "chord": "",
              "text": "見"
            },
            {
              "chord": "G",
              "text": "證。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "C",
              "text": "是 主"
            },
            {
              "chord": "",
              "text": "的 見 證"
            },
            {
              "chord": "G",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將 祂"
            },
            {
              "chord": "A7",
              "text": "繁 殖"
            },
            {
              "chord": "",
              "text": "達 四"
            },
            {
              "chord": "D",
              "text": "境；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 萬"
            },
            {
              "chord": "G",
              "text": "民 歸"
            },
            {
              "chord": "",
              "text": "順 作 主 門 徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "執 行"
            },
            {
              "chord": "C",
              "text": "我 主"
            },
            {
              "chord": "",
              "text": "偉"
            },
            {
              "chord": "D7",
              "text": "大 使"
            },
            {
              "chord": "G",
              "text": "命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活里，如母鹿得释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拿弗他利出嘉美言语；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满恩惠，蒙耶和华赐福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得海和南方为业无虞。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们涌流主生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强开拓无畏惧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以高品福音得人得地"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭主大能，照主应许。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看，全地尽是饥饿人群，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需你我分赐基督富馀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "速兴起，打开约瑟粮仓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "答应主的呼召，供人所需。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主神说，我可差遣谁？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁肯为我们前去？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主阿，是我，我在这里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请差遣我，照你所欲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜者─犹大支派狮子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "击败众仇敌，建立国度；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "权杖与国杖永不离开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到细罗来到，平安处处。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们展览主得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗权势尽驱除；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭那灵，在生命中作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使全地众民都蒙福。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "约瑟是多结果子树枝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "泉源旁结果累累下垂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能限制生命繁殖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "枝条探出墙外，延展加倍。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们住在主里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命流通益丰沛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "环境中总将基督显大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常结新果显主作为。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "以萨迦，羊圈间可躺卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得佳美之地，满享安息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "帐棚里，尽情享受快乐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "低肩背重，献贡物主所喜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们宗教尽脱落，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受基督作美地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会中作肢体尽功用，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生机建造基督身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "便雅悯，耶和华所亲爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "争战中，如同撕掠的狼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灭仇敌，早晨吃所掠夺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "晚上分所掳获，得胜刚强。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主所爱，必与主同居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得遮蔽，安息欢畅；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永世里，神人同得满足─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向此标竿，我们直往！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
