    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But how diff’rent the reaction"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the heav’ns, at Your ascent."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious God, for Your obedience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did the universe direct"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To prepare to welcome, praise You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the universe’s Head."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God already has appointed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You as Christ, as Lord of all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now all those in heav’n and Sheol"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your uniqueness know full well;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not a one can keep from bowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And submitting to Your will."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I be so familiar"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the scene so far on high?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, as proof, sent down His Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus this fact to verify;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s become the gift within me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s dominion proved thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit in me, manifested,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ Christhood proof affords;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If God’s Christ indeed is Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On me, too, the Spirit’s poured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fact eternal, fixed and constant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Nazarene is Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is Lord! The Lord is Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An eternal, changeless fact!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Spirit’s poured out on me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This gift also is a fact."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I can but praise and bless Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His gift that now does act."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
