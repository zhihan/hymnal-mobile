{
  "url": "https://www.hymnal.net/en/hymn/ns/890",
  "title": "Dear Jesus, save me this day",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Jesus, save me this day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need reminding always,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I’d gain You and enjoy Your grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, all throughout this day, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remind me, I’d live You always;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be one with You, I’ll run the race."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set my heart to You, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make it Yours, possess it fully."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m willing; make me Your possession."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, free me today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From world and sin—all vanity—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To pursue You, Your reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me say, “You now live in me”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And “It’s no longer I who live;”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But dear Jesus, grace me today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me live You out, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me magnify You through me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll let You; Lord, be my replacement."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, thank You for Your mercy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your grace, it’s true, sustains me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I realize I’m weak and faint."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need You, Jesus; speak today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come and infuse me more each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord I realize, I’m full of taint."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase more Your weight, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Your glory shine upon me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m open; Lord, make me Your treasure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now my daily life, I’ve seen;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s devoid of Your dear life, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need You, Lord. Oh! Jesus, do fill it."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, fill it—still I’m short of this—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until I’m full of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mature, and one with You eternally."
            }
          ]
        }
      ],
      "type": "verse"
    }
  ],
