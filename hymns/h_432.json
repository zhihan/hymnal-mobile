  "title": "O Love, that wilt not let me go",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "O Love,"
            },
            {
              "chord": "",
              "text": "that wilt not"
            },
            {
              "chord": "Em",
              "text": "let me"
            },
            {
              "chord": "D",
              "text": "go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I rest my weary soul in"
            },
            {
              "chord": "D7",
              "text": "Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I"
            },
            {
              "chord": "B",
              "text": "give Thee"
            },
            {
              "chord": "B7",
              "text": "back the"
            },
            {
              "chord": "",
              "text": "life I"
            },
            {
              "chord": "G",
              "text": "owe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That"
            },
            {
              "chord": "A7",
              "text": "in Thine"
            },
            {
              "chord": "",
              "text": "ocean depths its"
            },
            {
              "chord": "G",
              "text": "flow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May richer,"
            },
            {
              "chord": "D7",
              "text": "fuller"
            },
            {
              "chord": "G",
              "text": "be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Light, that followest all my way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I yield my flickering torch to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart restores its borrowed ray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That in Thy sunshine's blaze its day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May brighter, fairer be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Joy, that seekest me through pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot close my heart to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I trace the rainbow through the rain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And feel the promise is not vain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That morn shall tearless be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Cross, that liftest up my head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I dare not ask to fly from Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I lay in dust life's glory dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from the ground there blossoms red"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life that shall endless be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
