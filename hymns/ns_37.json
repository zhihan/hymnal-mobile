      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once I call His name there’s a flow within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It turns me from my day, makes Him Lord again."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As my spirit burns, Satan cannot win."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling, “Oh Lord Jesus,” keeps the flow within."
            }
          ]
        }
