      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve got a river of life flowing within me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It started gushing up when God set me free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I keep the flow is my only plea."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve got a river of life springing within me."
            }
          ]
        }
      ],
