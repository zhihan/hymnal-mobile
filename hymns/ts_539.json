{
  "url": "https://www.hymnal.net/cn/hymn/ts/539",
  "title": "爱的召会─非拉铁非",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "愛 的"
            },
            {
              "chord": "",
              "text": "召 會─"
            },
            {
              "chord": "G",
              "text": "非 拉"
            },
            {
              "chord": "A",
              "text": "鐵"
            },
            {
              "chord": "D",
              "text": "非，"
            },
            {
              "chord": "G",
              "text": "請"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聽 榮 耀"
            },
            {
              "chord": "E7",
              "text": "的 事"
            },
            {
              "chord": "A",
              "text": "實；"
            },
            {
              "chord": "D",
              "text": "天"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上 聖 別、"
            },
            {
              "chord": "G",
              "text": "真 實"
            },
            {
              "chord": "A",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "主，"
            },
            {
              "chord": "G",
              "text": "述"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "說 關 於"
            },
            {
              "chord": "E7",
              "text": "你 的"
            },
            {
              "chord": "A",
              "text": "事。 國"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "度 之 門 由 祂 掌 管，"
            },
            {
              "chord": "D",
              "text": "大"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "衞 鑰 匙"
            },
            {
              "chord": "E7",
              "text": "祂 手"
            },
            {
              "chord": "A",
              "text": "持；"
            },
            {
              "chord": "D",
              "text": "\"我"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已 開 門，"
            },
            {
              "chord": "G",
              "text": "無 人"
            },
            {
              "chord": "D",
              "text": "能 關\"─"
            },
            {
              "chord": "A",
              "text": "祂 話"
            },
            {
              "chord": "D",
              "text": "既 出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "必"
            },
            {
              "chord": "A7",
              "text": "如"
            },
            {
              "chord": "D",
              "text": "是。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！非拉铁非，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "行为、工作主悦纳；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，主赐敞开的门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人比你更通达。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你稍微有点能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也曾持守祂活话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未曾否认祂的圣名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠信见证殊可嘉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙爱召会，非拉铁非，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍耐的话既遵守，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主必保守，免你经过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地试炼的时候。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的仇敌终必俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知主爱你到永久；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"我必快来，你要持守，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得冠冕被夺走。\""
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！得胜信徒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必定从主得奖赏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神殿中不再出去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作为柱子显坚刚。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的圣名、主的新名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城之名写身上；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神与人联结，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "互住、调和显辉煌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶路撒冷从天而降，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣新城何荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍珠之门、碧玉城墙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍贵材料同建造。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非拉铁非─弟兄相爱─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜新妇主所要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众召会中，凡有耳者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当听那灵在呼召！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
