    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the light that fills the heavens"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining forth on earth beneath,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through His Spirit freely given"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Light of life ’midst shades of death;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Down from heaven’s unclouded glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself the treasure brought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Closing thus His love’s sweet story"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His sweetest, deepest thought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Earthen vessels, marred, unsightly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the treasure as of old,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh from glory, gleaming brightly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaven’s undimmed, unchanging gold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Vessels, broken, frail, yet bearing"
            }
          ]
        },
        {
          "segments": [
            {
