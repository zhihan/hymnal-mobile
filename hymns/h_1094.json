    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He who sitteth in the heavens"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In contempt will laugh at them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vex them in His fierce displeasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Terrifying all such men."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet upon the hill of Zion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God has His anointed King—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is God’s own declaration,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the kings admonishing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now ’tis Christ, ’tis God’s Anointed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who declares the Lord’s decree:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Thou’rt my Son (in resurrection),"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This day I’ve begotten Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the nations I will give Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thine own inheritance."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou shalt dash them into pieces"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy kingly excellence.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now be wise, O be instructed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All ye rulers of the earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fear the Lord, rejoice with trembling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Serve the only One of worth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kiss the Son, lest He be angry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ye perish in the way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“All who trust in Him are blessed,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All who trust in Him will say."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we praise Thee, we have seen Him—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy unique Anointed One—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from vanity repenting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We in love have kissed Thy Son."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“All who trust in Him are blessed”—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not “all those who keep the law.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In that risen One believing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are blest forevermore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
