    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From the day that I first met You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How could I help falling in love with You?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Emptiness turned life’s pleasures blue;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No earthly love ever could see me through."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til I turned one day"
            }
          ]
        },
        {
