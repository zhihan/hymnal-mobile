              "chord": "",
              "text": "Let Your love flow in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fill my deepest part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I know, Lord, You’re one with me;"
            }
          ]
