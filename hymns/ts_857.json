              "chord": "A",
              "text": "国 度"
            },
            {
              "chord": "D",
              "text": "临。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和 平 福"
            },
            {
              "chord": "G",
              "text": "音， 不"
            },
            {
              "chord": "",
              "text": "该 藏"
            },
            {
              "chord": "C",
              "text": "隐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应 当"
            },
            {
              "chord": "G",
              "text": "宣 扬，"
            },
            {
              "chord": "",
              "text": "宣 扬"
            },
            {
              "chord": "D",
              "text": "主 话"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直 到"
            },
            {
              "chord": "D7",
              "text": "国 度"
