            },
            {
              "chord": "G",
              "text": "宣 揚，"
            },
            {
              "chord": "",
              "text": "宣 揚"
            },
            {
              "chord": "D",
              "text": "主 話"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
