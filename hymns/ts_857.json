{
  "url": "https://www.hymnal.net/cn/hymn/ts/857",
  "title": "宣扬直到国度临",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "应当宣扬，宣扬主话使国度来临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽力宣扬，宣扬主话直到国度临。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和平福音，和平福音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不该藏隐；不该藏隐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当宣扬，宣扬主话直到国度临。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主话有能，尽管释放，必不归徒然；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭信撒种，必有结果，绝不归徒然。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "殷勤撒种，必得亨通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主话有能，尽管撒种，必不归徒然。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是时候！我们传扬福音遍人间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把握今日，传扬福音不怕人弃嫌。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不必畏缩，主已工作！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天程旅客与主合作，不怕人弃嫌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "只管传讲，基督必在人心作见证。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们传讲，基督就在人心作见证。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宣扬主恩，为主得人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们传讲，基督就在人心作见证。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "庄稼已熟！前去收割不必再等候！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "田已发白！前去收割不必再等候！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督、召会，丰满全备─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完满福音速速传扬，满足人所求。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
