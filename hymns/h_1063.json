          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only may I hearken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sitting at Thy feet."
            }
          ]
        }
      ],
