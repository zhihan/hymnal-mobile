              "chord": "",
              "text": "Jesus, I must trust Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pondering Thy ways;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of love and mercy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thine earthly days:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinners gathered round Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lepers sought Thy face:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None too vile or loathsome"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For a Savior’s grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
