{
  "url": "https://www.hymnal.net/cn/hymn/ch/441",
  "title": "我神我爱我的永分",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 神、"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "愛、 我"
            },
            {
              "chord": "G",
              "text": "的 永"
            },
            {
              "chord": "",
              "text": "分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "永 是"
            },
            {
              "chord": "",
              "text": "我 一"
            },
            {
              "chord": "G",
              "text": "切；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 外， 在"
            },
            {
              "chord": "D",
              "text": "天 我"
            },
            {
              "chord": "G",
              "text": "有 何"
            },
            {
              "chord": "",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 地 有"
            },
            {
              "chord": "D7",
              "text": "你 無"
            },
            {
              "chord": "G",
              "text": "缺！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 地 有"
            },
            {
              "chord": "D7",
              "text": "你 無"
            },
            {
              "chord": "G",
              "text": "缺！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天上一切尽都空虚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上更是如此！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并无一物值得欢娱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能与我神相似。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的财富、生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的安稳住处；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其他事物，我也感领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但非我神、我主。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "闪耀财富，与你相比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过虚空玩具！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何况其他人之所倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂不更将人愚？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "即使全地归我为业，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "群星也是我的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若无你作我的一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我仍可怜至极！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让人伸臂如同大海，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "笼罗一切财富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我只要你的同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此外无所爱慕。"
            }
          ]
        }
      ]
    }
  ],
