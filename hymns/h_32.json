{
  "url": "https://www.hymnal.net/cn/hymn/h/32",
  "title": "We bow and worship, Father, here",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "We bow"
            },
            {
              "chord": "",
              "text": "and worship,"
            },
            {
              "chord": "D",
              "text": "Father,"
            },
            {
              "chord": "G",
              "text": "here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And marvel"
            },
            {
              "chord": "D",
              "text": "at Thy"
            },
            {
              "chord": "A7",
              "text": "wondrous"
            },
            {
              "chord": "D",
              "text": "love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O"
            },
            {
              "chord": "C",
              "text": "what is"
            },
            {
              "chord": "G",
              "text": "man that"
            },
            {
              "chord": "",
              "text": "Thou shouldst deign"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To"
            },
            {
              "chord": "C",
              "text": "him such"
            },
            {
              "chord": "G",
              "text": "boundless"
            },
            {
              "chord": "D",
              "text": "grace to"
            },
            {
              "chord": "G",
              "text": "prove!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We praise Thee for Thy heart's intent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man Thy likeness should possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That with Thy life and nature filled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine image he should manifest."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man in Thine image Thou didst make,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To him authority didst give;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself presenting as his life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That by Thy riches he might live."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To enter man Thou dost desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With him to mingle thru Thy grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man may be transformed and built"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be Thy worthy dwelling place."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Tho' man did fall, Thou didst not leave"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heart's intent, but Thou didst move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeeming man to bring him back,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst Thy love and wisdom prove."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ Thou didst Thyself reveal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who died and rose, redemption wrought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Spirit Thou hast entered man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to him life and grace hast brought."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit is Thy holiest place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy throne of grace is founded there;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst that we in spirit come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To burn the incense thru our prayer."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Such grace is like a river full"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which from the throne of grace doth come;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It floweth thru, transforming us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And builds us up to be Thy home."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Receiving of Thy matchless grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We marvel at Thy gift so free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With grateful hearts for Thy great love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit now we worship Thee."
            }
          ]
        }
      ]
    }
  ],
