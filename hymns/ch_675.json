    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣乃是罪人之友，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今寻找你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来祂脚前认罪、祈求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必不丢弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必对你说出恩言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像祂在当年"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "曾对人说：‘你罪赦免，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可平安向前。’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
