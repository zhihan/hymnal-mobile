    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "像祂前曾与人同行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去以马忤斯；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照样祂在我的一生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与我永偕止。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久我就要再见祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂必快来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂必定一点不差，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像祂在离开。"
            }
          ]
        }
