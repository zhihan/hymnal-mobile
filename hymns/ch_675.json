      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂在世，曾医病痛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂大能手；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今仍施医与昔相同，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂话要接受。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "医治之能曾经显在"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一妇的一摸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今向信心此能不改，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要显同样多。"
            }
          ]
        }
      ],
