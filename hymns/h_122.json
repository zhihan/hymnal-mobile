    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thou hast burst the grave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Risen art Thou;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death could not Thee enslave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death had to bow!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Victorious hast Thou come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of the darksome tomb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Broken the bands of gloom:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond death now."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What mighty triumphs, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst achieve!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What fruitfulness doth God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Thee receive!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of Thy death has sprung"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A wondrous living throng:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All, all to Thee belong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thee live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Firstborn of all Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lowly we bow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chief in Thy Father’s heart—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chief to us now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art indeed supreme,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our great eternal theme,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worthy of all esteem:"
            }
          ]
        },
