{
  "url": "https://www.hymnal.net/cn/hymn/ts/624",
  "title": "你已显为身体基督",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "今 日"
            },
            {
              "chord": "",
              "text": "惟 有 識 你"
            },
            {
              "chord": "A7",
              "text": "身 體，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦 主，"
            },
            {
              "chord": "A",
              "text": "纔 是"
            },
            {
              "chord": "A7",
              "text": "認 識"
            },
            {
              "chord": "D",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 此"
            },
            {
              "chord": "G",
              "text": "我 求"
            },
            {
              "chord": "",
              "text": "得 蒙"
            },
            {
              "chord": "D",
              "text": "開 啟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "在 你"
            },
            {
              "chord": "A",
              "text": "肢 體"
            },
            {
              "chord": "A7",
              "text": "看 見"
            },
            {
              "chord": "D",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非 僅 識 你"
            },
            {
              "chord": "B7",
              "text": "元 首"
            },
            {
              "chord": "Em",
              "text": "身 分─"
            },
            {
              "chord": "",
              "text": "至"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高、"
            },
            {
              "chord": "A",
              "text": "個 別"
            },
            {
              "chord": "A7",
              "text": "救 贖"
            },
            {
              "chord": "D",
              "text": "主， 更"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "見 你 已"
            },
            {
              "chord": "D7",
              "text": "具 體"
            },
            {
              "chord": "G",
              "text": "化 身，"
            },
            {
              "chord": "Em",
              "text": "顯"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為"
            },
            {
              "chord": "D",
              "text": "身 體"
            },
            {
              "chord": "A7",
              "text": "的 基"
            },
            {
              "chord": "D",
              "text": "督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的圣徒多年追求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "渴慕寻得你实际；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "举目仰望，深处探求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无非要见你自己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂知天上荣耀基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今乃显为祂身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内住基督今正活出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂身体显无遗！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我自知易于受欺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仅识你崇高至极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却未摸着你的实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "暗中摸索，凭己意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂知在你地上肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就得见你自己！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远之神显于肉体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大哉，敬虔的奥秘！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主勿让我再单独，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "囿于个人的光照；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的身体促我投入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭\"身体感\"为引导。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再作那离散尘土，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是活石被建造；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此使你心满意足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "团体显明你荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
