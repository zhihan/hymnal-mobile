    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Arms of Jesus! fold me closer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thy strong and loving breast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till my spirit on Thy bosom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Finds its everlasting rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And when time’s last sands are sinking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shield my heart from all alarms,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Softly whispering, “Underneath thee,"
            }
          ]
        },
        {
          "segments": [
            {
