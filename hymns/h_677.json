    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Other arms grow faint and weary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These can never faint, nor fail;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Others reach our mounts of blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These our lowest loneliest vale."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O that all might know His friendship!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O that all might see His charms!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O that all might have beneath them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ everlasting arms."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Underneath thee, underneath thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are the everlasting arms,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everlasting, everlasting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are the everlasting arms."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Underneath us, O how easy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have not to mount on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to sink into His fulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in trustful weakness lie."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we find our humbling failures"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save us from the strength that harms!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may fail, but underneath us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are the everlasting arms."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
