              "text": "When the Lord descends from heaven, then the morning bright will dawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This dark night will pass, and weeping will be o’er."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Lord descends from heaven, days of glory will begin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sighing and corruption gone forevermore."
