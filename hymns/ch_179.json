  "title": "当我注视你这桌子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "當 我"
            },
            {
              "chord": "",
              "text": "注 視 你"
            },
            {
              "chord": "E",
              "text": "這 桌"
            },
            {
              "chord": "A",
              "text": "子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "表"
            },
            {
              "chord": "E",
              "text": "記 使"
            },
            {
              "chord": "B7",
              "text": "我 驚"
            },
            {
              "chord": "E",
              "text": "奇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "A",
              "text": "餅 一"
            },
            {
              "chord": "",
              "text": "杯 分"
            },
            {
              "chord": "D",
              "text": "別 陳"
            },
            {
              "chord": "E",
              "text": "列，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照"
            },
            {
              "chord": "A",
              "text": "神 所"
            },
            {
              "chord": "E",
              "text": "愛"
            },
            {
              "chord": "E7",
              "text": "心"
            },
            {
              "chord": "A",
              "text": "意。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这饼表明生命之粮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我属天食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你死给我分享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我尝你丰富。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这杯乃是神圣之分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你血为我成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们接受这一福杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得享神所有。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此借着分享这饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃你生命之粮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱如此将你记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得将你饱尝。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着同喝这一福杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得享神的福气；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此欢乐将你记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我们被提。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借吃这饼，并喝这杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你死我们陈列；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证你是我们生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每日取用不竭。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们等候那日来到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你一同坐席，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更多享受你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并要敬拜不已。"
            }
          ]
        }
      ]
    }
  ],
