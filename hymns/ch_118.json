{
  "url": "https://www.hymnal.net/cn/hymn/ch/118",
  "title": "从前那戴荆棘的头",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "从 前"
            },
            {
              "chord": "",
              "text": "那 戴 荆"
            },
            {
              "chord": "C",
              "text": "棘 的"
            },
            {
              "chord": "",
              "text": "头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今"
            },
            {
              "chord": "G",
              "text": "戴 荣"
            },
            {
              "chord": "",
              "text": "耀 冠"
            },
            {
              "chord": "D7",
              "text": "冕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救 主"
            },
            {
              "chord": "G",
              "text": "耶 稣，"
            },
            {
              "chord": "G7",
              "text": "我 们"
            },
            {
              "chord": "C",
              "text": "元 首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 今"
            },
            {
              "chord": "G",
              "text": "已 升"
            },
            {
              "chord": "D7",
              "text": "高 天。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是地上圣徒之乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是天上之光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你今领我饮于爱河，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我知其深广。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，将你的羞辱、权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一并赐给我们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地虽否认你的微名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神却使你高升。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凡肯与你在世同苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也要同荣在天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以求主使我坚固，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "鄙视世界恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "十架于你虽是辱、死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我却是生命！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是我的荣耀、权势！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的永远安宁！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "赞美主",
    "time": "3/4",
