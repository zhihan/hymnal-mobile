      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有新造要看见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在彼神光四布；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那个照耀的器皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是羔羊新妇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那个荣耀的金器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "令人向神敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在荣中羔羊里，"
            }
          ]
