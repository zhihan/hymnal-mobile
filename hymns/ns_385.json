{
  "url": "https://www.hymnal.net/en/hymn/ns/385",
  "title": "Lord, Refine My Heart",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In a world full of temptations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sorrows, and sins,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, do shine in me that You’re the way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only You can satisfy my deepest, inward part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cause Your love to grow within me each day."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, refine my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er to be apart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully trusting in Your love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Single and true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, refine my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spread Yourself in every part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Your life divine impart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til I’m filled with You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your Spirit in our spirit—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Working, breaking through,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Free us from the self and back to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We redeem each precious moment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spending time with You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To become the testimony of Christ."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, there is none whom I desire but You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would love You and give my all to You."
            }
          ]
        }
