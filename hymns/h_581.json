              "chord": "",
              "text": "Ah, this is rest indeed:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What else, Almighty Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can a poor sinner need?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through me, Thou gentle Master,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy purposes fulfil;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I yield myself forever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thy most holy will."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What though I be but weakness?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My strength is not in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The poorest of Thy people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has all things, having Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
