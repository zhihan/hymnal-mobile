            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Thou hast made me happy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Thou hast set me free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To whom shall I give glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever, but to Thee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of earthly love and blessing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should every stream run dry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace shall still be with me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace, to live and die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
