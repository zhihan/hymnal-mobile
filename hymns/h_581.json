            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can a poor sinner need?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When clouds are darkest round me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, art then most near,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My drooping faith to quicken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My weary soul to cheer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe nestling in Thy bosom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I gaze upon Thy face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In vain my foes would drive me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Thee, my hiding-place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
