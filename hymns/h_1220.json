    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By revelation I perceive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The power that raised Christ from the dead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I by faith this power receive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I to the church am led."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy mighty power has set me free"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all the world’s distracting things;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An entrance to the local church"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This mighty power brings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once in the local church, I need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take Thee as my person, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My outward man each day recede,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart is for the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take Thee as my person, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have been crucified with Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My inner man has been restored;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m now indwelt by Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When all Thy members self forsake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy glorious Body, Lord, is known;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When of Thy Person we partake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The one new man is shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The church life is the one new man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every local church expressed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Body is a corporate man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One Person manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
