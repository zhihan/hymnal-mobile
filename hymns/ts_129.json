  "raw_sections": [
    "耶 穌我 太 陽，",
    "惟 一 的 太陽，",
    "照 亮 我路 途，燦 爛 明亮；",
    "不 管 是陰 霾抑 或 是天晴，",
    "耶 穌， 耶穌，",
    "我惟 一太陽。",
    "耶稣我生命，",
    "美妙的生命，",
    "与我永联结，扶持供应；",
    "昨日今日到永远是一样，",
    "耶稣，耶稣，",
    "我惟一生命。"
  ]
