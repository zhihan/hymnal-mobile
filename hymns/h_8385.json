  "title": "Lord, You're the living Bread",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "Lord, You're"
            },
            {
              "chord": "",
              "text": "the living"
            },
            {
              "chord": "Dm",
              "text": "Bread"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From"
            },
            {
              "chord": "G",
              "text": "heaven's"
            },
            {
              "chord": "G7",
              "text": "store sup"
            },
            {
              "chord": "C",
              "text": "plied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I be"
            },
            {
              "chord": "C7",
              "text": "richly"
            },
            {
              "chord": "F",
              "text": "fed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "And"
            },
            {
              "chord": "C",
              "text": "fully"
            },
            {
              "chord": "G7",
              "text": "satis"
            },
            {
              "chord": "C",
              "text": "fied."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are the smitten Rock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whence living waters burst;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all my daily walk,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You're there to quench my thirst."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I now to You draw nigh;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm hungry, thirsty, dry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, be my sure supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thirst, do satisfy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I long to drink You more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to the full extent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit I'd absorb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink to my heart's content."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Without absorbing You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I sense just vanity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By eating, drinking You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How strong my life will be!"
            }
          ]
        }
      ]
    }
  ],
