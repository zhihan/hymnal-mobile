    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, most precious One to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I want to seek You constantly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So you can spread through me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would just call upon Your name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open to you; I have no shame"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving You, Jesus Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, precious One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be so real to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are all I want;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My full reality."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Oh living One in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open my eyes that I might see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that You are to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just let me enter in Your heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never from You would I depart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving You constantly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, living One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flood me thoroughly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take my willing heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And overcome in me."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord I want You to have Your way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save me from being Satan’s prey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am believing You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All I can give to You, my Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is my whole being, love outpoured;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I belong to You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, faithful God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain us through and through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Use us thoroughly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To see Your purpose through."
            }
          ]
        }
      ],
