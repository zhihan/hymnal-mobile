    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我羡慕你从我心流出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心永远不能装你之外事物。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我深处时刻向你呼求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满带饥渴羡慕，从我甜美流出。"
