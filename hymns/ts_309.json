      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的光天天照在我身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "参透虚假属灵，使我不再受欺。"
