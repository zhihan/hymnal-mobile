              "text": "Humanity, one entity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, the Shulammite, His bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His duplication, counterpart, stands by His side;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s lovers gained, rejoice in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wedding feast may now begin."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, the golden lampstand is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The aggregate of all the lampstands,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining ’tis."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lamb-Lamp-Light, expression of"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s glory for eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem portrays the Trinity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father, Son, and Spirit in eternity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God and man, the consummate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all the signs, the ultimate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, 12 gates, gates 3 x 4,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reveal to man the Triune God became the door;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All may go in; those chosen and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeemed, transformed and glorified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem show God is ent’rable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man enters into God, O how unfathomable!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To enter in: enjoy God’s love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s grace, and Spirit’s fellowship."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, a constituting work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just to edify but unto building up;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God is gold and pearls"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And precious stones built into man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem exists on earth today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One Body and one Spirit in one Lord and faith;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One God and Father, over all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all and Who exists in all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, a triune living, shows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Proceeding from the throne the living river flows;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit with our spirit mingled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in man and man in God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, triune enjoyment, brings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To man divine light shines and living water springs;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The tree of life! How beautiful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoyable, and wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, expression full and great,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of the Triune God, will consummate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Creating God, redeeming God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And flowing God is now our all!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    }
