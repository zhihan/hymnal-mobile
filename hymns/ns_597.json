    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, the corp’rate God-man is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s increase and expression, yet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "not Godhead, His."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Divinity is blended with"
            }
          ]
        },
        {
          "segments": [
            {
