  "raw_sections": [
    "長 似東 西無 終點，",
    "闊 似宇 宙無 邊岸，",
    "高 似高 天無 限量，",
    "深 似深 海無 底疆，",
    "基督大愛！",
    "大 哉，大 哉，大 哉，",
    "基督 大愛！",
    "長、 闊、高、 深不 能度，",
    "豐 滿、優 厚臨 及我，",
    "直到萬代！",
    "长得使祂来舍身，",
    "阔得使祂成救恩，",
    "高得使祂将我升，",
    "深得使祂临我生，",
    "基督大爱！",
    "大哉，大哉，大哉，",
    "基督大爱！",
    "长、阔、高、深不能度，",
    "丰满、优厚临及我，",
    "直到万代！",
    "长得使我得赦免，",
    "阔得使我蒙恩典，",
    "高得使我天上坐，",
    "深得在我里面活，",
    "基督大爱！",
    "大哉，大哉，大哉，",
    "基督大爱！",
    "长、阔、高、深不能度，",
    "丰满、优厚临及我，",
    "直到万代！",
    "长、阔，并非何尺度，",
    "高、深，也非何事物；",
    "‘长、’‘阔，’",
    "二形乃是指，",
    "‘高、’‘深，’",
    "二者也都是，",
    "基督大爱！",
    "大哉，大哉，大哉，",
    "基督大爱！",
    "长、阔、高、深不能度，",
    "丰满、优厚临及我，",
    "直到万代！"
  ]
