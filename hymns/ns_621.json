    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Architect and Builder too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God works to build His house;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The building is the mingling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Bridegroom with His spouse;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Eve was built from Adam’s rib,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church comes out from Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His wife prepares to marry Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By mingling in life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our entrance into God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our portal and our way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Pearl prepared by wounding sand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption made for aye."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s building is sustained by Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upheld victoriously;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s testimony He uplifts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His humanity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ also is the Man of bronze"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the building’s gate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whom God has judged on our behalf,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Most qualified His state."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He knows our real condition and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has paid our debt with blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He measures us, possessing us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To mingle us with God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When found in Christ, expressing God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We overcome with might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Protected by God’s holy fire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within us burning bright!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God in Christ will be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory at the heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all we are and all we do,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transparency our part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The element that builds the church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That constitutes the saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Christ the resurrected One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Blessing earth awaits!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of reality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Infuses us with Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We gain Him through our mingling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With resurrection life!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This mingling in glory is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Holy City, God’s elect,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yea, God built into man!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As God’s expression, we’ll be there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inwrought with Christ the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Co-kings with Him, those crowned with life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Matured and built as one!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
