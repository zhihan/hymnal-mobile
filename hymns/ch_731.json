            {
              "chord": "G",
              "text": "永 久"
            },
            {
              "chord": "",
              "text": "磐 石"
            },
            {
              "chord": "C",
              "text": "為 我"
            },
            {
              "chord": "G",
              "text": "開，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "讓 我"
            },
            {
              "chord": "G",
              "text": "藏 身"
            },
            {
              "chord": "D7",
              "text": "在 你"
            },
            {
              "chord": "G",
              "text": "懷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "願 你"
            },
            {
              "chord": "Am",
              "text": "所 流"
            },
            {
              "chord": "D",
              "text": "血 與"
            },
            {
              "chord": "Em",
              "text": "水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "解 決"
            },
            {
              "chord": "Am",
              "text": "我 的"
            },
            {
              "chord": "D7",
              "text": "雙 重"
            },
            {
              "chord": "G",
              "text": "罪："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "贖 我"
            },
            {
              "chord": "G",
              "text": "免 去"
            },
            {
              "chord": "C",
              "text": "它 永"
            },
            {
              "chord": "G",
              "text": "刑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "救 我"
            },
            {
              "chord": "G",
              "text": "脫 離"
            },
            {
              "chord": "D7",
              "text": "它 權"
            },
            {
              "chord": "C",
              "text": "能。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "纵我双手不罢休，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能满足你要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵我热心能持久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵我眼泪永远流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍不足以赎愆尤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须你来施拯救。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "空空两手无代价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "单单投靠你十架！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赤身，就你求衣衫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无助，望你赐恩典；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "污秽，飞奔你泉旁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，洗我，否则亡。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我此生年日逝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我临终闭目时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我飞进永世间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我到你宝座前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永久磐石为我开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我藏身在你怀。"
            }
          ]
        }
      ]
    }
