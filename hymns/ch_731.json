            },
            {
              "chord": "C",
              "text": "为 我"
            },
            {
              "chord": "G",
              "text": "开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "让 我"
            },
            {
              "chord": "G",
              "text": "藏 身"
            },
            {
              "chord": "D7",
              "text": "在 你"
            },
            {
              "chord": "G",
              "text": "怀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿 你"
            },
            {
              "chord": "Am",
              "text": "所 流"
            },
            {
              "chord": "D",
              "text": "血 与"
            },
            {
