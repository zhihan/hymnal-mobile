      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "纵我双手不罢休，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能满足你要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵我热心能持久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵我眼泪永远流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍不足以赎愆尤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须你来施拯救。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "空空两手无代价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "单单投靠你十架！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赤身，就你求衣衫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无助，望你赐恩典；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "污秽，飞奔你泉旁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，洗我，否则亡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我此生年日逝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我临终闭目时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我飞进永世间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我到你宝座前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永久磐石为我开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我藏身在你怀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
