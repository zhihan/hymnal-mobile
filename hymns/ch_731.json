        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "解 决"
            },
            {
              "chord": "Am",
              "text": "我 的"
            },
            {
              "chord": "D7",
              "text": "双 重"
            },
            {
              "chord": "G",
              "text": "罪："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "赎 我"
            },
            {
              "chord": "G",
              "text": "免 去"
            },
            {
              "chord": "C",
              "text": "它 永"
            },
            {
              "chord": "G",
              "text": "刑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "救 我"
            },
            {
              "chord": "G",
              "text": "脱 离"
            },
            {
              "chord": "D7",
              "text": "它 权"
            },
            {
              "chord": "C",
              "text": "能。"
            }
