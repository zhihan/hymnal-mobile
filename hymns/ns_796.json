    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Open my ear this morning."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I want to hear Your voice."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From everything else I’m turning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You only are my choice."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, I long to be filled!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spring up from within me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That others could know Your life-giving flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And no more be thirsty."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, care for the weary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These sheep with no Shepherd."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord I pray You could use me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me a good steward."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, here I am! Fill me freshly!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I long for Your supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I’m filled today, You will have a way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These ones to satisfy."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the reason I’m living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feed the weary ones."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is my true bliss.  I would still do this,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until my Master comes."
            }
          ]
        }
      ],
      "type": "chorus"
    }
