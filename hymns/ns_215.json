          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because You are the God of love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love will never let me go;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everyday it flows."
            }
          ]
        }
