{
  "url": "https://www.hymnal.net/en/hymn/ns/215",
  "title": "I wake up this morning, Lord",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I wake up this morning, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sun shines through my windowsill."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I help but praise Your name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re my Lord and King!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because You...gave Your life up for me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit...You were raised to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now You are...living deep in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As my hope of glory."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day Your mercies they are new,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To me refreshing as the dew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are my bountiful supply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every morning You’re nigh!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
