            {
              "chord": "Bm",
              "text": "自 己"
            },
            {
              "chord": "C♯",
              "text": "覺"
            },
            {
              "chord": "F♯m",
              "text": "得、"
            },
            {
              "chord": "C♯",
              "text": "自"
            },
            {
              "chord": "F♯m",
              "text": "己"
            },
            {
              "chord": "C♯7",
              "text": "記"
            },
            {
              "chord": "F♯m",
              "text": "牢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 想"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "是 活"
            },
            {
              "chord": "A",
              "text": "在 神"
            },
            {
              "chord": "D",
              "text": "前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "但 我"
            },
            {
              "chord": "",
              "text": "暗"
            },
            {
              "chord": "D",
              "text": "許 自"
            },
            {
              "chord": "Em",
              "text": "己"
            },
            {
              "chord": "A7",
              "text": "敬"
            },
            {
              "chord": "D",
              "text": "虔！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的一生充满试炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大至不是常人可忍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人虽不知我的苦艰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我却知道自己坚韧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我想我是丢弃自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我不忘自己经历！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我知我是满受恩惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已至地上无人似我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我身上，在我心内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我能寻出神的工作！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的工作在我身上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我全知道如何欣赏！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我知我的所有登造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我知我的一切善义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知不觉我觉自豪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "中心从神移到自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的手中隔夜吗哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已变臭坏，已被糟蹋。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当有朋友向我慰问，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我苦情表示同情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的骄傲不再隐闷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的忍耐立即空罄；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就失败如同常人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "咒诅生日显出根本。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神阿，我是风闻有你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讲你论你，我是都能；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我的败坏自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从未因你有何变更；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我用你赐固我骄傲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我因你恩加我自高。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但我现今亲眼见你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的圣洁显我污秽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的亮光使我倾圮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的荣耀使我痛悔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我痛悔我怎能以"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对我自己如此着迷？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等惭愧，何等惭愧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你恩典装饰自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高抬自己用你作为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无一动机不是可鄙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的失败不可收拾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的得胜更为羞耻。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等羞耻我能骄傲！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等瞎眼我能愚昧！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "污秽竟会以为洁好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉体竟会以为佳美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是何等无知自义！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我偷多少荣耀归己！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你早知我何等败坏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我竟然一无所知，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然以为自己可赖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂知乃是十分可耻；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，可否求你救我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今天为我开此捆锁。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我心是在希望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能有尘土给我躺卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能有炉灰撒我身上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我懊悔我的堕落；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是羞耻，羞耻无尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我有如此败坏的心。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的言语何等不准，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的生命何等肤浅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的存心无不浊溷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的一切无不可厌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今恨恶我的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我的希望在你。"
            }
          ]
        }
      ]
    }
  ],
