{
  "url": "https://www.hymnal.net/cn/hymn/ch/89",
  "title": "主，你的爱竟然不辞",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "C",
              "text": "愛 竟"
            },
            {
              "chord": "D7",
              "text": "然 不"
            },
            {
              "chord": "G",
              "text": "辭"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 我 忍"
            },
            {
              "chord": "A7",
              "text": "辱 受"
            },
            {
              "chord": "D7",
              "text": "死！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好"
            },
            {
              "chord": "G",
              "text": "叫 我"
            },
            {
              "chord": "",
              "text": "們 勝"
            },
            {
              "chord": "Am",
              "text": "過 罪"
            },
            {
              "chord": "D7",
              "text": "世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "並"
            },
            {
              "chord": "Em",
              "text": "那 壯"
            },
            {
              "chord": "G",
              "text": "士"
            },
            {
              "chord": "D7",
              "text": "權"
            },
            {
              "chord": "G",
              "text": "勢。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，你的担何等的重！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等难于背负！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人的罪恶、鬼的讥讽、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加上神的忿怒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "围困你的狂怒风波，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今已永远平静；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因之我们得着欢乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你得超绝的名。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不久你前被提，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要唱新歌赞你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但在这里－你死的地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要先唱起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
  "metadata": {
    "category": "赞美主",
