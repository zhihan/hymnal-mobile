{
  "url": "https://www.hymnal.net/cn/hymn/ch/77",
  "title": "你是至高荣耀的神",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "你 是"
            },
            {
              "chord": "",
              "text": "至 高、 荣"
            },
            {
              "chord": "C",
              "text": "耀 的"
            },
            {
              "chord": "G",
              "text": "神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "竟 肯"
            },
            {
              "chord": "",
              "text": "降 卑 成"
            },
            {
              "chord": "D7",
              "text": "为 肉"
            },
            {
              "chord": "G",
              "text": "身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作 了 一 个 式 微 的"
            },
            {
              "chord": "C",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主"
            },
            {
              "chord": "G",
              "text": "阿， 我"
            },
            {
              "chord": "D7",
              "text": "记 念"
            },
            {
              "chord": "G",
              "text": "你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你将一切神性荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全用肉身幔子遮罩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显于外者不过枯槁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我记念你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃像根出于干地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多受痛苦，常经忧悒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被人藐视，受人厌弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我记念你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的心里谦卑、温柔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任何遭遇都肯接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神、对人从无怨尤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我记念你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的为人甜美、柔细、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各方均平、不偏不倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神眼中犹如素祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我记念你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的旨意你所顾念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从未接受撒但欺骗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人像你忠诚、完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我记念你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着顺服神的旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你竟甘愿走到死地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且在十架舍了自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我记念你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神因此将你升高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你得着尊贵、荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地一切无不拜朝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我敬拜你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
