    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“I will be God to them” declares the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, our inheritance, described in the Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And they will be to Me a people,” possessed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As God’s inheritance, His riches, expressed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the title deed of all God is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is a testament with all its bequests;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the New Testament is ours to claim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we, in spirit, call upon His name."
            }
          ]
        }
      ]
    },
    {
      "lines": [
