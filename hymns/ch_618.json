      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩赐虽有不同，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵是一位；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "职事虽有多种，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主也是一位。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁也不能无谁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不可轻或重；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各有各的地位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各有各功用。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙恩有多有少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩赐分大小；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看得合乎中道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谦卑不自高。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
