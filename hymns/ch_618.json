            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各显各功用；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "个个都不松弛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "个个都尽忠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "互相供应联系，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此多包容；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫无不谐嫌隙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事主为重。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是元首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会是身体；"
            }
          ]
        },
        {
          "segments": [
