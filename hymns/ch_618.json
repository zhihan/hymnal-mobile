            {
              "chord": "Bm",
              "text": "互 相"
            },
            {
              "chord": "A",
              "text": "作 肢"
            },
            {
              "chord": "D",
              "text": "体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成 为"
            },
            {
              "chord": "A",
              "text": "一 个"
            },
            {
              "chord": "D",
              "text": "身"
            },
