    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I ask no dream, no prophet ecstasies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No sudden rending of the veil of clay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No angel visitant, no opening skies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But take the dimness of my soul away."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hast Thou not bid us love Thee, God and King?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All, all Thine own—soul, heart and strength and mind."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I see Thy cross—there teach my heart to cling."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let me seek Thee, and, oh, let me find."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach me to feel that Thou art always nigh;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach me the struggles of the soul to bear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To check the rising doubt, the rebel sigh;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach me the patience of unanswered prayer."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach me to love Thee with a virgin love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One holy passion filling all my frame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus all the riches of Thyself to prove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart an altar, and Thy love the flame."
            }
          ]
        }
