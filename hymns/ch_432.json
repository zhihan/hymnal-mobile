    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "四面受敌，不被困住；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遭受逼迫，不被轻忽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心里作难，不至失望；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被人打倒，不至死亡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣的死带在身上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣的生就得显彰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死在我身发动运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生在我身就得显明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神既叫主从死复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也必叫我同祂活着。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "外面的人虽然毁坏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的人却新起来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
