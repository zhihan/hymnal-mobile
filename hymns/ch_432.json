    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "至暂至轻苦楚忍受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "极大无比荣耀成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "眼所能见并不顾念，"
            }
          ]
        },
        {
