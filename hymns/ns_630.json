    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy city, all God’s people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sanctified in nature true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saturated with Thine essence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Thy one eternal view."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yield us weighty, constituted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully mingled, Lord, with Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou gain Thy full expression"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy glory fully see."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re God’s tabernacle, dwelling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here is Thine eternal rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re Thy house, Thy splendid temple,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined in spirit, fully blessed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, our bodies we present now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all saints together grow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blended, built, coordinated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’d Thy building truly know."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now betrothed to Thee, dear Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring us to maturity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beautify, reconstitute us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we match Thee perfectly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May our love grow deeper, fuller;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foretaste of our married life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How we long to finally meet Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, the Lamb, and we, the wife!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With that City as our mother,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve been born of God by grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this grace we stand, receiving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy purpose we embrace:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many more sons God desires;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We too bring them forth in love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with God, we’re now components"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Jerusalem above."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Consummated Triune God with"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeemed man is joined as one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Marvelous eternal couple"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To declare all Thou hast done."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, obtain Thy deepest longing—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Corporate man build up in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine economy accomplish;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem complete."
            }
          ]
        }
      ]
    }
