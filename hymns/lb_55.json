      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Many plotted to kill You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Judas he betrayed You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Disciples, they forsook You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "False witnesses were hired."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then Peter, he denied You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Three times in one night."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An illegal trial condemned You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How we afflicted You!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "They smote You with their palms,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And spit into Your precious face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Buffeting and mocking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They led You away!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pilate and Herod"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sent You back and forth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the soldiers, they scourged You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And made a crown of thorns."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With a reed, they beat Your head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pressing the thorns much deeper."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stripping You, they nailed You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Up on a cross of wood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In front of You, they gambled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your clothes and seamless coat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the people passed, despising You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then God forsook You too!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The two thieves on either side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As they hung, reviled You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though You were dead, a soldier"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still would pierce Your side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blood and water poured out,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out from Your broken heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That same blood and water saved me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, how I love You!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When I see the price You paid,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You chose to pay my every debt!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willingly, You bore such shame"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And tasted death for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How could I ever love the world"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That crucified You, dear One?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am not my own, bought with a price."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give myself to You!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
