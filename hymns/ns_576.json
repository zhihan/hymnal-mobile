    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, throughout these years"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have been working to gain me for"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your church, Your expression, Your counterpart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And at times I was stubborn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I refused to turn to You but"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have drawn me so we run after You."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
