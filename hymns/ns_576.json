          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of Your faithfulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have pursued, You have caused me to"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Run after You, not just me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But those around me too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have drawn me, we pursue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To build up Your church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your counterpart, Your heart’s delight."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw me, we will run after Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us see if the vine has budded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If the pomegranates are in bloom;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There I will give You my love."
            }
