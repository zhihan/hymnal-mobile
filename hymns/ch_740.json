        {
          "segments": [
            {
              "chord": "C",
              "text": "主 耶"
            },
            {
              "chord": "",
              "text": "稣， 我 们"
            },
            {
              "chord": "G",
              "text": "聚 集"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "G7",
              "text": "你 墓"
            },
            {
              "chord": "",
              "text": "的 四"
            },
            {
              "chord": "C",
              "text": "围，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "口 中 歌 唱 心"
            },
            {
              "chord": "G",
              "text": "欢"
            },
            {
              "chord": "C",
              "text": "喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见"
            },
            {
              "chord": "G",
              "text": "证 你"
            },
            {
              "chord": "G7",
              "text": "的 作"
            },
            {
              "chord": "C",
              "text": "为。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "们 用"
            },
            {
              "chord": "G7",
              "text": "信 来"
            },
            {
              "chord": "C",
              "text": "跟 随，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "追"
            },
            {
              "chord": "F",
              "text": "踪 你"
            },
            {
              "chord": "",
              "text": "的 道"
            },
            {
              "chord": "G",
              "text": "路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "C",
              "text": "这 庄"
            },
            {
              "chord": "F",
              "text": "严、 奥"
            },
            {
              "chord": "C",
              "text": "妙 水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进"
            },
            {
              "chord": "G",
              "text": "入 你"
            },
            {
              "chord": "G7",
              "text": "的 工"
            },
            {
              "chord": "C",
              "text": "夫。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我们记念"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你魂中的苦难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你向我施恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "曾被波浪冲漫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我你浸死水中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我你曾流血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我你曾离天庭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我你曾命绝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主，你今已复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗已成往事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今你已登宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活着，永不再死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪、死、阴府你毁尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也同你得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你是我的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是坐享其成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今受浸归你死！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承认与你同尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也与你同复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你荣耀有分。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但、世界和罪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今都不能摸我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今同你作旅客，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同你为神生活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
