      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O mystery of mysteries!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of life and death the tree!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Center of two eternities,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which look with rapt, adoring eyes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Onward, and back to Thee’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O cross of Christ, where all His pain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And death is our eternal gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O how our inmost hearts do move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While gazing on that cross!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The death of the incarnate Love!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What shame, what grief, what joy we prove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He should die for us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts were broken by that cry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Eli, lama sabachthani!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Worthy of death, O Lord, we were;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That vengeance was our due;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In grace Thou, spotless Lamb, didst bear"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself our sins, and guilt, and fear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Justice our Surety slew."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee, our Surety, we have died;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee, we there were crucified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Quickened with Thee with life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Raised with Thee from the dead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine Own, now human and divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall with Thee in Thy glories shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church’s living Head!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, who were worthy but to die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now with Thee, “Abba Father,” cry."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
