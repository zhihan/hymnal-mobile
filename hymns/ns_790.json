    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s a feast spread in the Bible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His word is man’s true food."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I long to eat more, for I,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have tasted the Lord is good."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So much wealth is in the Bible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mine its words for precious ore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In it I find all God’s riches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They become my treasure store!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Words of love are in the Bible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unveiling the Author’s heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These words draw and woo His seekers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making them His counterpart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, most precious in the Bible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is not wisdom, truth and grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But behind its words is Jesus!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I behold Him face to face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Face to face! Face to face!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While I read my Bible."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is near, He is here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I read my Bible."
            }
          ]
        }
