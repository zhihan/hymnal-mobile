            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou dost manage all affairs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us in God’s delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both in the heavens and in us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With power in Thy right."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou intercedest all the time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Spirit, with Thy grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In heav’n to plead, in us to groan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Entreating in our place."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou helpest as the living One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And attest by God’s plan"
            }
          ]
        },
        {
          "segments": [
