  "title": "我们享受基督丰富",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "享 受 基"
            },
            {
              "chord": "G",
              "text": "督 豐"
            },
            {
              "chord": "C",
              "text": "富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就 得 成 為 祂"
            },
            {
              "chord": "F",
              "text": "的 豐"
            },
            {
              "chord": "G",
              "text": "滿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分 享 一 切 祂"
            },
            {
              "chord": "D7",
              "text": "之 所"
            },
            {
              "chord": "G7",
              "text": "是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "C",
              "text": "能 使"
            },
            {
              "chord": "F",
              "text": "祂 得"
            },
            {
              "chord": "G",
              "text": "著"
            },
            {
              "chord": "G7",
              "text": "彰"
            },
            {
              "chord": "C",
              "text": "顯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督丰富是祂所是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来作我们一切享受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督丰满乃是召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因享基督而得成就。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "迦南美地丰富出产，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是豫表基督丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借这出产圣殿得成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "象征召会出于基督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "夏娃乃是亚当丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫表召会之于基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "夏娃原是出于亚当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督也是召会出处。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "丰富是我里面基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰满是我外面召会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满基督，作祂表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得与基督同样宝贵。"
            }
          ]
        }
