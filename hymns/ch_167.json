              "chord": "D",
              "text": "恩 主，"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "是 生"
            },
            {
              "chord": "D",
              "text": "命 源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深"
            },
            {
              "chord": "G",
              "text": "而 且"
            },
            {
              "chord": "",
              "text": "甜 之"
            },
            {
              "chord": "A",
              "text": "泉："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你 的"
            },
            {
              "chord": "",
              "text": "活 水 我"
            },
            {
              "chord": "D",
              "text": "已"
            },
            {
              "chord": "G",
              "text": "尝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永"
            },
            {
              "chord": "D",
              "text": "不 再"
            },
            {
              "chord": "A7",
              "text": "渴 再"
            },
            {
              "chord": "D",
              "text": "干。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "的 怜"
            },
            {
              "chord": "",
              "text": "悯 时"
            },
            {
              "chord": "D",
              "text": "扩 展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰"
            },
            {
              "chord": "G",
              "text": "满 如"
            },
            {
              "chord": "",
              "text": "同 海"
            },
            {
              "chord": "D",
              "text": "洋；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 恩"
            },
            {
              "chord": "G",
              "text": "典 彀"
            },
            {
              "chord": "D",
              "text": "我"
            },
            {
              "chord": "A",
              "text": "用，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "D",
              "text": "你 智"
            },
            {
              "chord": "A7",
              "text": "慧 所"
            },
            {
              "chord": "D",
              "text": "量。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我乃属我的良人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的良人属我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将污秽的罪人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进你宴筵所。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的功绩我所倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你外别无可投；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隐藏在你面光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你的保守。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "新妇所爱非妆饰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是良人自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我所注视非荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是你的美丽："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非你所赐的冠冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃你被钉之手；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，你是我荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的永远倚投。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
