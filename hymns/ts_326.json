    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，天天来扶持，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们能不断向前行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，时刻来供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们能脱离幻梦境。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何奇妙，是你的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我们行走的能力。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，使你将自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "化成为灵，住在我灵里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，在我心运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我才能够渴慕来经营。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，作工在我身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "琢磨不断好使我成形；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，量给我处境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使我能破碎流生命。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何奇妙，是你的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我心里多面的作为；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何我能安家在召会？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无非因你爱里的花费！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何我能享受在家里？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无非因你爱手的实际！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，使我能变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着瓦器彰显你荣华；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你的爱，赐给我盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立刻被提变成你形像。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何奇妙，是你的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我改变，催促你归回。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我实在不知、也不会"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "细细述说你爱的宝贵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你浇我，浸透你爱里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我馀生失去在你里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
