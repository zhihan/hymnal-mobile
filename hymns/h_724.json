              "chord": "G",
              "text": "A little"
            },
            {
              "chord": "D7",
              "text": "bird I"
            },
            {
              "chord": "G",
              "text": "am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shut"
            },
            {
              "chord": "C",
              "text": "from the"
            },
            {
              "chord": "",
              "text": "fields of"
            },
            {
              "chord": "D7",
              "text": "air,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "G",
              "text": "in my"
            },
            {
              "chord": "D7",
              "text": "cage I"
            },
            {
              "chord": "G",
              "text": "sit and"
            },
            {
              "chord": "",
              "text": "sing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him who"
            },
            {
              "chord": "A7",
              "text": "placed me"
            },
            {
              "chord": "D",
              "text": "there;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "Well"
            },
            {
              "chord": "G",
              "text": "pleased a"
            },
            {
              "chord": "",
              "text": "prisoner to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because,"
            },
            {
              "chord": "D",
              "text": "my"
            },
            {
              "chord": "C",
              "text": "God, it"
            },
            {
              "chord": "D",
              "text": "pleas"
            },
            {
              "chord": "D7",
              "text": "eth"
            },
            {
              "chord": "G",
              "text": "Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nought have I else to do,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I sing the whole day long;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He whom most I love to please"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doth listen to my song;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He caught and bound my wandering wing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But still He bends to hear me sing."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast an ear to hear"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart to love and bless;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And though my notes were e'er so rude,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst not hear the less;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because Thou knowest as they fall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That love, sweet love, inspires them all."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My cage confines me round;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abroad I cannot fly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But though my wing is closely bound,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart's at liberty;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For prison walls cannot control"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The flight, the freedom of the soul."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O it is good to soar"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These bolts and bars above!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him whose purpose I adore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose providence I love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy mighty will to find"
            }
          ]
        },
        {
          "segments": [
            {
