{
  "url": "https://www.hymnal.net/cn/hymn/ch/439",
  "title": "都因着你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "今 日"
            },
            {
              "chord": "",
              "text": "我 心 因 欢 乐 而 歌 唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 主， 因"
            },
            {
              "chord": "Am",
              "text": "你 是"
            },
            {
              "chord": "D7",
              "text": "我 生"
            },
            {
              "chord": "",
              "text": "命、 安"
            },
            {
              "chord": "G",
              "text": "康；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲 爱 的 主， 前"
            },
            {
              "chord": "B7",
              "text": "途 我"
            },
            {
              "chord": "",
              "text": "全 藉"
            },
            {
              "chord": "Em",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 也 知"
            },
            {
              "chord": "D",
              "text": "道 父"
            },
            {
              "chord": "A7",
              "text": "神 是"
            },
            {
              "chord": "",
              "text": "为 我"
            },
            {
              "chord": "D7",
              "text": "的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "都 因 著"
            },
            {
              "chord": "G7",
              "text": "你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都 因 著"
            },
            {
              "chord": "Am",
              "text": "你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都 因 著"
            },
            {
              "chord": "G",
              "text": "各 各"
            },
            {
              "chord": "",
              "text": "他！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "都 因"
            },
            {
              "chord": "",
              "text": "著"
            },
            {
              "chord": "G",
              "text": "你！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "前有一日，我因惧怕永死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就用行为将我自己装饰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盼望能够避免神的刑罚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我今知你是惟一救法。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将来罪人虽然都要痛哭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你召会却要被提得福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为借你所洒幔里宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她能胜过阴府所有猖獗。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的羔羊为我担当罪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得救，今后永远生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你为我喝公义忿怒的杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "审判已过，现今再无死味。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我在青草地场躺卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "平安的神将祂最好给我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我现今倚在你的胸怀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你交通，并尝你的大爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你保守我的生命佳美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我虽然遇见讥嘲、谤毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也能因信时常仰望父神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学习交托，受苦仍能欢欣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主教我拒绝人世名声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "面如坚石，经过火热水深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿意与主同受羞辱、挫折，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为主的名作一个殉道者！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我被提，在人子前站立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "钉十架者要成我的诗题；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你从天来经历人生苦楚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又在加略舍去生命血肉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "都因着我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都因着我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都因着我一人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都因着我！"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
  "metadata": {
    "category": "经历基督",
    "time": "4/4",
    "hymn_code": "1765545635",
