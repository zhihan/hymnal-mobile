{
  "url": "https://www.hymnal.net/cn/hymn/ch/269",
  "title": "我如困鹿切慕溪水",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 如"
            },
            {
              "chord": "",
              "text": "困 鹿 切"
            },
            {
              "chord": "D",
              "text": "慕 溪"
            },
            {
              "chord": "G",
              "text": "水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里 面 干 渴 难"
            },
            {
              "chord": "D",
              "text": "言；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "哦"
            },
            {
              "chord": "G",
              "text": "神， 我"
            },
            {
              "chord": "",
              "text": "心 惟"
            },
            {
              "chord": "C",
              "text": "你 是"
            },
            {
              "chord": "",
              "text": "追，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并"
            },
            {
              "chord": "D",
              "text": "你 复"
            },
            {
              "chord": "",
              "text": "苏"
            },
            {
              "chord": "D7",
              "text": "恩"
            },
            {
              "chord": "G",
              "text": "典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "活的神阿，你是我神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心饥渴要你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深愿全人与你相亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽享你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的生命、力量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是我的居所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在基督给我饱尝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂给我得着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的笑脸是我拯救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今向你仰望；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的同在是我所求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你多多恩赏。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我如困鹿切慕溪水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你赏我所欲；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦神，除你何能施惠？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟你是我所需。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
