{
  "url": "https://www.hymnal.net/en/hymn/h/838",
  "title": "Thy blueprint, Lord, I treasure dear",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Thy blueprint,"
            },
            {
              "chord": "",
              "text": "Lord, I"
            },
            {
              "chord": "A",
              "text": "treasure"
            },
            {
              "chord": "D",
              "text": "dear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It"
            },
            {
              "chord": "G",
              "text": "shows Thy"
            },
            {
              "chord": "D",
              "text": "tabernacle"
            },
            {
              "chord": "A",
              "text": "real,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It"
            },
            {
              "chord": "D",
              "text": "tells how"
            },
            {
              "chord": "",
              "text": "Thou wouldst"
            },
            {
              "chord": "A",
              "text": "have it"
            },
            {
              "chord": "D",
              "text": "built,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How"
            },
            {
              "chord": "G",
              "text": "Thou Thy"
            },
            {
              "chord": "D",
              "text": "glory"
            },
            {
              "chord": "A",
              "text": "wouldst"
            },
            {
              "chord": "A7",
              "text": "re"
            },
            {
              "chord": "D",
              "text": "veal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ark’s the center of the tent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The tent is but its resting-place:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In it the ten commandments are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the tent it ever stays."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ark the God-man, Christ, displays—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God mixed with man, as gold, wood meet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The law is God’s expression full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which dwells in Christ the Son complete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus Christ’s the center of the Church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which is to Him a resting-place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ the Father ever dwells,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the Church, Christ’s dwelling-place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The tent’s the increase of the ark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both are of wood with gold o’erlaid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church the increase is of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God blent with man here too displayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The boards when joined support the tent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On silver sockets standing sure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gold overlaid, with golden rings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And interlocking bars, secure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church is thus the gathered saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Christ’s redemption standing sure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life divine, by Spirit bound,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together built and framed secure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The tent’s four-layered cover shows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christ of God in every phase;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s glory thus is signified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Covering His holy dwelling-place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Covered by such a glorious Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All saints together knit may be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying all He is for them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him they’re builded gloriously."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law is placed within the ark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ark within the tent doth rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So God in Christ within the Church"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His wondrous glory manifests."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
