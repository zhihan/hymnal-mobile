    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blood, the emblem of redemption,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cleansing all the sins away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ointment, symbol of the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing God to man for aye."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blood doth speak of what God worketh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ointment, what He is for us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His work and by His person"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself is blent with us."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By the blood of Christ’s redemption"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are cleansed from all alloy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By th’ anointing of the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself we may enjoy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By the cleansing and anointing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We with God are kept in one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the blood and by the ointment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, our portion full, is won."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We in faith must claim the cleansing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we need the precious blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever to obey th’ anointing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus to live and walk with God."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God as light we’ll then be knowing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God experience as love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in God as life e’er growing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as power we will prove."
            }
          ]
        }
      ]
    }
