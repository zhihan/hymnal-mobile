    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love Thee with the first love:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast proved Thy love for me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I was dead in sins, offenses,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou hung upon the tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore my sins in Thine own body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I’d live to righteousness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made sin for me, that I might be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made in Thee God’s righteousness!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love Thee with the first love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou didst not save Thyself."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en to death I’d love Thee best, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hating my soul-life, myself."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou laidst down Thy human life that"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I may have Thy life divine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy side piercèd and Thy blood shed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To graft me to Thee, the vine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love Thee with the first love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy love constraineth me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To myself I’d live no longer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I’d live and die to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst give Thyself up for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I now let Thee live for me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis no longer I that liveth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thou, Christ, who lives in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love Thee with the first love:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou art preeminent;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Firstborn of all creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Firstborn from the dead."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou alone must have the first place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all things, O dearest King;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my heart I now enthrone Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reign in me in everything."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love Thee with the first love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the first works I return."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I repent of fleshly labors;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In, by, for myself they were."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Motivated by the first love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lab’ring to adorn Thy bride:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purest gold, pearl, stones most precious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy heart be satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I love Thee with the first love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my fair Bridegroom Thou art."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Thy glorious face I’m gazing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the eyes of unveiled heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! to see Thee as Thou art, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining forth in majesty!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeing Thee, I shall be like Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in life and love we’ll be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
