    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Find the word and eat it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Letting it become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both our joy and gladness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Present and to come."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God with life supplies us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nourishing and sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feed others with His"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life supply complete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All that God has spoken"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Treasure in your heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go and speak with blessings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God to man impart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let God’s word, devoured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill your heart and soul;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pour out from the storehouse"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Found within the scroll."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Every word of Scripture"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is a worthy prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Matchless in expression,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gateway to God’s care."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill each inward part with"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s indwelling word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it touch your conscience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship assured."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let God’s light shine deeply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inward parts to search."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, with revelation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to build the church."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in Christ is speaking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His awesome move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As four living creatures,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We His speaking prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eat the scroll of Scripture!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Utter what God speaks!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prophesy in spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strong in word, yet meek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithfully discharging"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life to all who hear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In divine dispensing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled as God draws near."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take the scroll now opened"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the hand of Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with glad reception"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eat the words of life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every word proceeds out"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the mouth of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oracles of utterance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ministering God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God dispenses riches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us in His word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feeding us for building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In God’s life secured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By this rich dispensing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God supplied within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We become God’s building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
