    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, to be Your testimony"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We a costly price must pay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So, O Lord, for this You’ve shown us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must flee this evil age."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Midst this crooked generation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’ve called some for Your own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To belong to You completely—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your expression fully shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eastern! Western! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both are nullified in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are for Your testimony"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the heavens, glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord! Amen! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From our innermost we say."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, to be Your testimony,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will take the mingled way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we praise You for that woman,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining Bride of Christ to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From her, You will take Your man-child"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To defeat Your enemy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we’ll be those overcomers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To protest these evil days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those who’ve left the world, religion—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining in this crooked age."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, as You express the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So the church expresses You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since we’ve seen the local churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing else could ever do."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we praise You for this vision."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We could never be the same."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah for the churches!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the glory to Your Name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
