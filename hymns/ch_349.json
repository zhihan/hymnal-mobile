    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "众人都慕得主荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羞辱少人要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众人都爱同主掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "损失有谁愿？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "几乎无人因主缘故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看万事如土！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "多人都贪享主甘旨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "少有愿禁食！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多人都喜登主宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "少有愿飘泊！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同祂唱诗虽然有人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "儆醒却不能。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "众人都想同主高贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "卑贱却都畏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当主凡事为他豫备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他就大赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当主稍微求他一点，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就立发怨言。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但那诚实爱主的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祸福都不问，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是他们宝贵心血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也愿为主舍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主给我这样心志，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赤忠忘生死。"
            }
          ]
        }
      ]
