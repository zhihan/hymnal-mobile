      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那日虽有无比荣耀的冠冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但无十架可以顺从；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂为我们所受一切的磨碾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今日才能与祂交通。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入安息，就再寻不到疲倦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再无机会为祂受苦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再也不能为祂经过何试炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再为祂舍弃何幸福。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再为祂舍弃何幸福。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哎阿，为祂，机会已是何等少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有机会快要过去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "机会无多，为祂，蒙羞和受嘲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为祂，再来分心、分虑。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久就无误会、怒骂与凌辱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就无孤单、寂寞、离别；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我当宝贝这些不久的祝福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我借这些与你联结。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我借这些与你联结。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我羡慕早日看见你脸面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那是实在好得无比；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是，我也不愿免去你试炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失去如此交通甜蜜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你怜悯，使我充满你大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不顾一切为你生活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免你仆人今天急切望将来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来又悔今天错过。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来又悔今天错过。"
            }
          ]
        }
      ],
