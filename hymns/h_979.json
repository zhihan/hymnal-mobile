{
  "url": "https://www.hymnal.net/cn/hymn/h/979",
  "title": "How glorious, how bright it shines",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "How glori"
            },
            {
              "chord": "Bm",
              "text": "ous, how"
            },
            {
              "chord": "A",
              "text": "bright it"
            },
            {
              "chord": "D",
              "text": "shines,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The holy,"
            },
            {
              "chord": "Bm",
              "text": "new Je"
            },
            {
              "chord": "A7",
              "text": "ru"
            },
            {
              "chord": "D",
              "text": "sa"
            },
            {
              "chord": "A",
              "text": "lem;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is God's"
            },
            {
              "chord": "Em",
              "text": "dwelling"
            },
            {
              "chord": "D",
              "text": "place with"
            },
            {
              "chord": "A",
              "text": "man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "The spotless"
            },
            {
              "chord": "D",
              "text": "bride of"
            },
            {
              "chord": "A",
              "text": "Christ,"
            },
            {
              "chord": "A7",
              "text": "the"
            },
            {
              "chord": "D",
              "text": "Lamb."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints of the Old and of the New,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heirs of the promise God bestowed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Components of the city are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together built for God's abode."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfectly square the city lies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All sides are equal—length, width, height;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No measurement more long or short,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No part oblique, it stands upright."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The city with its street pure gold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As clear as glass transparent is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Showing that God's transcendent life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its quality and nature is."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Twelve city gates are each one pearl;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus man is through redemption shown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reborn and as a pearl transformed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Entering to a realm God's own."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The twelve foundations of its wall"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are with twelve precious stones adorned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through fire and pressure recomposed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with eternal value formed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The wall of jasper, crystal clear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's glory by it fully shown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glorious light through it does shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He appears as jasper stone."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The wall a separation makes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Excluding all that is unclean;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gold, pearls, and precious stones alone"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The holy city has within."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God and the Lamb the Temple are!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall behold His glorious face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His presence never will depart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We'll worship Him thru endless days."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The city needs no sun nor moon"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God's own glory is its light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lamb's the lamp the city bears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all directions blazing bright."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Out from the throne of God and the Lamb"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flows midst the street a living stream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And on its banks, on either side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The tree of life is thriving seen."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This signifies the life of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just for food or water flows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But carries God's authority"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As it throughout the city goes."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The street of purest gold therein"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's nature as the way doth show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A river in it flows for drink"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fruits of life abundant grow."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The number twelve means government,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfection which eternal is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God blent with man it also tells—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Three multiplied by four shows this."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Darkness and death shall be no more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sorrow and pain shall pass away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Old will be gone and all be new,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God will abide with man for aye."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The city has God's image full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It rules for Him, the sovereign King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfilling His eternal plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Complete content to Him to bring."
            }
          ]
        }
      ]
    }
  ],
