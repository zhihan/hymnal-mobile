{
  "url": "https://www.hymnal.net/cn/hymn/ch/749",
  "title": "看何荣耀看何光彩",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "看， 何"
            },
            {
              "chord": "",
              "text": "荣 耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看， 何"
            },
            {
              "chord": "A",
              "text": "光 彩！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "诸 天"
            },
            {
              "chord": "",
              "text": "国 度"
            },
            {
              "chord": "E",
              "text": "今"
            },
            {
              "chord": "E7",
              "text": "实"
            },
            {
              "chord": "A",
              "text": "现！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "荣 耀"
            },
            {
              "chord": "",
              "text": "之 王， 神 的"
            },
            {
              "chord": "A",
              "text": "基 督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "为 神"
            },
            {
              "chord": "",
              "text": "所 立"
            },
            {
              "chord": "A",
              "text": "来"
            },
            {
              "chord": "A7",
              "text": "掌"
            },
            {
              "chord": "D",
              "text": "权。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "曾 在 肉 身"
            },
            {
              "chord": "A",
              "text": "卑"
            },
            {
              "chord": "A7",
              "text": "微"
            },
            {
              "chord": "D",
              "text": "来 过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被 人 藐 视"
            },
            {
              "chord": "E7",
              "text": "并 厌"
            },
            {
              "chord": "A",
              "text": "恶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "今 带"
            },
            {
              "chord": "D",
              "text": "荣 耀"
            },
            {
              "chord": "",
              "text": "威 严"
            },
            {
              "chord": "A",
              "text": "再 来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "成 全"
            },
            {
              "chord": "",
              "text": "国 度"
            },
            {
              "chord": "A",
              "text": "的"
            },
            {
              "chord": "A7",
              "text": "意"
            },
            {
              "chord": "D",
              "text": "图。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "去从祂神，亘古存者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "领得权柄和国度；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今带着国度回来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀显之于众目。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这‘非人手所凿石头’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已将列国砸粉碎；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变成‘大山’充满天下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出国度的光辉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，地和其上列国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都归基督为基业；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂至高统治之下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满了平安与和谐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "列国之间再无争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再无残杀的战场；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的知识充满遍地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像大水满海洋。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有得胜的基督徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣中与主同管治；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以色列的得救遗民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也要作神的祭司。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这管治教导之下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "列国要作神百姓；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有万物都要得到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀无比的复兴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但被捆丢于深坑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地脱离他霸权；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由主基督为首统治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地蒙福真空前。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有全都降服基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "服祂统治与管理；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作元首，万有中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全祂神的旨意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
