          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis from such a Jesus came"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of Jesus to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To make His reality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Experience unto us."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of Jesus has"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All elements human, divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The living of man in Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And glory of God combine."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The suff’ring of human life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Effectiveness of His death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His rising and reigning too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are all in the Spirit’s breath."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With all these components true"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Spirit in us doth move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by His anointing full"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of Christ we prove."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This Spirit of Jesus doth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Encompass both great and small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inclusively He doth work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us, making God our all."
            }
          ]
        }
      ]
    }
