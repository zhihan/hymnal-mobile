              "text": "不断流自神宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "消除人间一切"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "疲倦与干渴。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，在这园中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督流入我里头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不断滋润、浇灌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我成熟。"
            }
          ]
        }
