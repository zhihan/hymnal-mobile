    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我真欢喜！在神的园里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这园实在可爱又美丽！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天饱尝生命美果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "畅饮生命的乐河；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世上没有比这"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更好的生活！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这‘召会生活’园子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有棵生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结满生命美果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为作人食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放下成见，不搞心思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要简单吃这树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时刻刻享受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甜美的基督。"
            }
          ]
        }
      ],
