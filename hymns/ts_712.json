          "segments": [
            {
              "chord": "",
              "text": "不 斷"
            },
            {
              "chord": "C",
              "text": "的 供"
            },
            {
              "chord": "",
              "text": "應 我 們，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 是"
            },
            {
              "chord": "D",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "新 鮮、"
            },
            {
              "chord": "D7",
              "text": "便 利、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又 親"
            },
            {
              "chord": "G",
              "text": "近！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我 真 歡 喜！"
            },
            {
              "chord": "C",
              "text": "在 神"
            },
            {
              "chord": "",
              "text": "的 園 裡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "這 園"
            },
            {
              "chord": "",
              "text": "實 在"
            },
            {
              "chord": "D7",
              "text": "可 愛"
            },
            {
              "chord": "",
              "text": "又 美"
            },
            {
              "chord": "G",
              "text": "麗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天 天 飽 嘗 生 命"
            },
            {
              "chord": "G7",
              "text": "美 果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "暢 飲"
            },
            {
              "chord": "C",
              "text": "生 命"
            },
            {
              "chord": "",
              "text": "的 樂 河；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世 上"
            },
            {
              "chord": "D",
              "text": "沒 有"
            },
            {
              "chord": "",
              "text": "比 這"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "更 好"
            },
            {
              "chord": "",
              "text": "的 生"
            },
            {
              "chord": "G",
              "text": "活！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会不是学校、工厂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会不是礼拜堂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是生命园子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让基督成长；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主把我们栽于其中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时浇灌又培养，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是神亲手"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经营的农场！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我真欢喜！在神的园里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这园实在可爱又美丽！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天饱尝生命美果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "畅饮生命的乐河；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世上没有比这"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更好的生活！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这‘召会生活’园子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有棵生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结满生命美果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为作人食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放下成见，不搞心思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要简单吃这树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时刻刻享受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甜美的基督。"
            }
          ]
        }
      ],
