        {
          "segments": [
            {
              "chord": "G",
              "text": "召 會"
            },
            {
              "chord": "",
              "text": "生 活， 輝 煌 之 至！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 是"
            },
            {
              "chord": "C",
              "text": "神 美"
            },
            {
              "chord": "",
              "text": "麗 園 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 此"
            },
            {
              "chord": "D",
              "text": "經 歷"
            },
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "D7",
              "text": "成 長，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讚 美"
            },
            {
              "chord": "G",
              "text": "主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 在 基 督 裡 的 豐 富，"
