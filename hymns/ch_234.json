    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不能死者，竟然受死！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是奥秘，谁能尽知？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣之爱，高深长阔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最高天使也难测度！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有天使不必臆猜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是怜悯，当得敬拜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有天使不必臆猜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是怜悯，当得敬拜！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "离开天上父的宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "降世为人，恩何广阔；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚己、舍身，流血、赎罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为救亚当无望族类；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是怜悯，无量、白给，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然临及我这罪魁！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是怜悯，无量、白给，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然临及我这罪魁！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天性黑暗，邪恶满心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵久为罪恶监禁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你眼垂顾，带来恩光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我立苏醒，囚牢明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "锁链尽脱，全人释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来随主，心中欢畅。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "锁链尽脱，全人释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来随主，心中欢畅。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不再定罪，尚何惧忧？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主和一切尽归我有！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活在元首基督里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣之义将我遮掩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坦然来到施恩座前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有主基督作我冠冕。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坦然来到施恩座前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有主基督作我冠冕。"
            }
          ]
        }
