              "text": "mys"
            },
            {
              "chord": "G",
              "text": "terious,"
            },
            {
              "chord": "A",
              "text": "life is"
            },
            {
              "chord": "A7",
              "text": "God Him"
            },
            {
              "chord": "D",
              "text": "self,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose whole in"
            },
            {
              "chord": "G",
              "text": "tention"
            },
            {
              "chord": "",
              "text": "focuses on"
            },
            {
              "chord": "A",
              "text": "man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "God made"
            },
            {
              "chord": "",
              "text": "him to take in the"
            },
            {
              "chord": "E7",
              "text": "tree of"
            },
            {
              "chord": "A",
              "text": "life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "To have"
            },
            {
              "chord": "",
              "text": "a"
            },
            {
              "chord": "G",
              "text": "man of"
            },
            {
              "chord": "",
              "text": "life for"
            },
            {
              "chord": "A",
              "text": "His"
            },
            {
              "chord": "A7",
              "text": "own"
            },
            {
              "chord": "D",
              "text": "plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But man was tempted and seduced to sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By taking knowledge from the other source."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This man then fell as knowledge entered in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And dominated him with all its force."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This knowledge has developed in the man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the human culture on the earth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So man, created to fulfill God’s plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Became a failure full of Satan’s dearth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then God came in the Person of the Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lived He on earth, Christ Jesus was His name—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A living model so that everyone"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could live by life, God’s fullness to obtain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This God-man, Christ, went to the cross and died,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By death He ended knowledge, the old man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Things negative forever crucified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death He subdued, a new life He began!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From death He resurrected and became"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The living Spirit to give life to us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we believe and call upon His name;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This living Spirit comes to dwell in us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By this the very Triune God is now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The living Spirit mingling deep within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit joins in oneness; this is how"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are one spirit evermore with Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this Spirit that we walk and act,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have our being, think, and see all things;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re now within this Spirit! What a fact!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This Spirit to us all God’s fullness brings!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So now we have to set our mind on Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day, each hour, our mind on Him must be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That by this Spirit we’d be saved within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By life and reign in life eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this Spirit that we shall be freed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Sin whose law inside us death would bring."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our mortal bodies will have life indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus sanctified we’ll be in everything."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This Spirit shall transform our natural life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save us from self, build us in one new man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we’re conformed to be like Jesus Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus finishing our God’s eternal plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life is our God and life is Christ our Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life is the Spirit. Life’s the only way—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we’re transfigured and redeemed to God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re waiting, looking forward to that day!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    }
  ],
