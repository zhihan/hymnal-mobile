{
  "url": "https://www.hymnal.net/cn/hymn/ch/723",
  "title": "需要耶稣",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "耶"
            },
            {
              "chord": "A",
              "text": "穌"
            },
            {
              "chord": "D",
              "text": "恩 主"
            },
            {
              "chord": "",
              "text": "是 人 惟 一 需 要："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "G",
              "text": "是 神"
            },
            {
              "chord": "D",
              "text": "成 肉"
            },
            {
              "chord": "",
              "text": "身 生 於 馬"
            },
            {
              "chord": "A",
              "text": "槽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "在"
            },
            {
              "chord": "A",
              "text": "世"
            },
            {
              "chord": "D",
              "text": "為 人"
            },
            {
              "chord": "",
              "text": "歷 盡 萬 般 苦"
            },
            {
              "chord": "G",
              "text": "惱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "末 了 被 釘 木"
            },
            {
              "chord": "D",
              "text": "架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 救 你"
            },
            {
              "chord": "A",
              "text": "將"
            },
            {
              "chord": "A7",
              "text": "命"
            },
            {
              "chord": "D",
              "text": "傾 倒。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "需 要 耶 穌！"
            },
            {
              "chord": "G",
              "text": "需 要"
            },
            {
              "chord": "",
              "text": "耶 穌！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "人 人"
            },
            {
              "chord": "",
              "text": "都 需 要 耶"
            },
            {
              "chord": "A7",
              "text": "穌！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "要 脫"
            },
            {
              "chord": "",
              "text": "罪 擔 需 要 主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 得 平 安 需 要"
            },
            {
              "chord": "D7",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "要 免"
            },
            {
              "chord": "",
              "text": "沉 淪"
            },
            {
              "chord": "D",
              "text": "得 永"
            },
            {
              "chord": "",
              "text": "生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "需"
            },
            {
              "chord": "A7",
              "text": "要"
            },
            {
              "chord": "D",
              "text": "耶 穌！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "升天永作中保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "差遣圣灵下来将你寻找；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若来信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂尊名求告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必赐你恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你一切需要。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你心虽暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能彻底光照；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你罪虽多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必全都宽饶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂血能将你的污秽除掉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂灵必赐生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来将你软弱尽消。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的人生常感有所缺少；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有一需要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你尚莫名其妙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这需要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟从耶稣得到："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能满足你心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除去你虚空无聊。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "需要耶稣！需要耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人人都需要耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要免虚空需要主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得满足需要主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要使人生有意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你需要耶稣！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人在世上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽是劳苦烦恼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遭遇困苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是无求无告；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世事虚谎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还有甚么可靠？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这些都是说出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣是人的需要！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世人不分智愚、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "男女、老少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都已犯罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亏缺神的荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除信耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "别无得救之道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为惟有耶稣"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能满足神、人需要。"
            }
          ]
        }
      ]
    }
  ],
