    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No man or angel ever knew"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This secret hidden deep in You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You desired to be one with man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the world began."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though sin came in to ruin me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Satan’s scheme and subtlety"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing could break Your love for me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gain me totally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This divine romance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is My heart’s deep plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I became a lowly man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To court My country girl."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing could deter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing can alter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My eternal love for her;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll gain My country girl."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As King of kings You became a man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You died for me—I’ve been redeemed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection made us queen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To marry You, my King."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From death You ’rose and entered me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I now possess Your divinity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life and nature we’re the same:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both human and divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your love I’m drawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To You I belong;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am not my own, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m Yours alone."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your love I’m drawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your name I’m charmed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Your Person captured me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I’ve been kissed by Thee."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, in this close sweet fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, be with me so intimate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So personal and affectionate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A sweet relationship."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, daily change my inward being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, all my heart possessing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all my being—transforming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be Your bride and queen."
            }
          ]
        }
      ],
