        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that I long for is You, Lord, who love me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of You most lovely, my heart would fain lay hold!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Please, Lord, come quickly, grant this aspiration—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That evermore in Your presence I might be;"
