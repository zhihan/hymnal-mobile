              "text": "I'd see and hear You for all eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "She's light and love and songs of praises,"
