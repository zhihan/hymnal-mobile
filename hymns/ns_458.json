    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then one day I heard the gospel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I believed and called on Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou as life came in to fill me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making life so full of meaning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Son revealed in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Son revealed in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All-inclusive was the transfer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Baptized—four-fold—into Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into Thy death, Body, and Person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus to live and walk in newness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in life and living with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in life and living with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Captivated by Thy beauty,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I left all to follow Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my hopes and dreams forsaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Counting all as loss and refuse;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Losing sight of all but Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Losing sight of all but Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Strengthening me with Thy power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Thy Spirit inwardly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my spirit Thou art spreading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my soul Thou art transforming;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art making home in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art making home in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d grow up in Thee in all things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till I am the same as Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till through me, Thou, once more living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my human virtues filling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Art thus fully formed in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Art thus fully formed in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Using all things, persons, and matters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art disciplining me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till by outer man consuming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my inner-man renewing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis no longer I but Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis no longer I but Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not alone but with Thy members"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art sweetly placing me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fitting me into Thy building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blending out all self distinctions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy church would builded be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy church would builded be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Till that day I stand before Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Render my account to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant me grace that I’d live daily"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with Thee in Thine appearing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, my glorious hope, to be,"
            }
          ]
        },
        {
          "segments": [
