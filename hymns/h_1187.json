    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A better covenant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And better promises;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A better law of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sacrifice this is."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption’s work, done long ago,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A better blood has made it so."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Hebrews eight we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The way to make us whole;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life planted deep within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which spreads into the soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of life, imparted, still"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inscribed in mind, emotion, will."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of letters leave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of life pursue;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The one is old and dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The other fresh and new."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dead teachings cannot help the seed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of life is what we need."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of life in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In function now we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Works not by will and thought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But automatically."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It saturates, conforms to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The standard model spreads within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our sins are all forgiv’n,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life imparted too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is our God today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we’re His people true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We know Him in an inward way:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These blessings four have come to stay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re being sonized now;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life within will do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The deep transforming work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of making us anew."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In ages past, the work was done—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now prayer is over—praise the Son!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
