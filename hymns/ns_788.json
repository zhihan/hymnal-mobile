{
  "url": "https://www.hymnal.net/en/hymn/ns/788",
  "title": "You Are the Way",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There may be days when I’m lost and afraid,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I can’t seem to find my own way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Weakened with doubts, looking for a way out."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help me turn to the spirit, call on Your name, and say,"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(You are in me just waiting for me to say)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(You are Love, You are Light, You are the Way.)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just keep me, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m Yours evermore."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are light in the darkest of night."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your Word I have light for the way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re faithful and true. Give me eyes to see You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To see you in spirit, trust in Your name, and say,"
            }
          ]
        }
      ],
