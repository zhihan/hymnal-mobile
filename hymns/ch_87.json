{
  "url": "https://www.hymnal.net/cn/hymn/ch/87",
  "title": "赞美救主赞美救主",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 我"
            },
            {
              "chord": "",
              "text": "寶 貴 你 的"
            },
            {
              "chord": "Em",
              "text": "行 徑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "如 何"
            },
            {
              "chord": "",
              "text": "在 此 受 苦"
            },
            {
              "chord": "D",
              "text": "害；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那 些 最 終 悲 痛"
            },
            {
              "chord": "G",
              "text": "情 形，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "使 我"
            },
            {
              "chord": "",
              "text": "更 覺"
            },
            {
              "chord": "A",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "可"
            },
            {
              "chord": "D",
              "text": "愛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "讚 美 救 主， 讚 美 救 主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讚 美 主 為 罪 人"
            },
            {
              "chord": "A",
              "text": "死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "榮 耀"
            },
            {
              "chord": "",
              "text": "救 主， 榮 耀 救 主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "榮 耀、 榮 耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 為"
            },
            {
              "chord": "A",
              "text": "死 人"
            },
            {
              "chord": "D",
              "text": "活。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你当时艰难何大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大到无人会究推；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无道摧残、无理糟蹋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "痛苦有谁能微窥！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美救主，赞美救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主为罪人死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀救主，荣耀救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀、荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主为死人活。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "可爱的主，当你救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一人能跟随；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为许多定罪囚奴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需要你独受鞭锤。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美救主，赞美救主，"
            }
          ]
