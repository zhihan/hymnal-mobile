              "text": "荣耀、荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主为死人活。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时你量罪的距离－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忿怒、咒诅和悲哀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为人所卖，为神所弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们才识你可爱。"
            }
          ]
        }
      ],
