{
  "url": "https://www.hymnal.net/en/hymn/ns/460",
  "title": "Thou, Triune God, eternally",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Thou, Triune"
            },
            {
              "chord": "",
              "text": "God, eternal"
            },
            {
              "chord": "A",
              "text": "ly"
            }
          ]
        },
        {
