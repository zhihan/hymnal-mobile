            },
            {
              "chord": "E",
              "text": "three, insep'ra"
            },
            {
              "chord": "E7",
              "text": "bly"
            },
            {
              "chord": "A",
              "text": "one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A"
            },
            {
              "chord": "G",
              "text": "realm divine"
            },
            {
              "chord": "",
              "text": "and mystical,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Art"
            },
            {
              "chord": "D",
              "text": "formed as"
            },
            {
              "chord": "",
              "text": "an in"
            },
            {
              "chord": "A",
              "text": "cor"
            },
            {
              "chord": "A7",
              "text": "p'ra"
            },
            {
              "chord": "D",
              "text": "tion."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thine indwelling mutually"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou doth exist essentially;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy will to bring humanity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into this sphere economically."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through incarnation in the Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This realm was first seen in the flesh;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within Christ’s body physical"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Godhead’s fullness manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His human life did manifest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Coordination beauteous:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One acted, Three did operate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In harmony so marvelous."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through death and resurrection was"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This life divine in full released"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To form Thy Body mystical,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This realm divine to thus increase."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This habitation’s Thine abode,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Body mystical, divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enlargement of our Father’s house,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit’s child, Son’s spreading vine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy final form the Spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The realization of the Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee we’re blent, divine-human"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incorporation to become."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit into ours has come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One mingled spirit formed, become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Body, Father, Spirit, Son—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An entity that’s Four yet One."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thine own glory, life, and word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we are all thus one in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such oneness doth reflect Thine own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The oneness seen among the Three."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s love, Christ’s grace, the fellowship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Holy Spirit, reaching man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As living water, issue from"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The throne of God and of the Lamb."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This fellowship of life divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Father and His Son have shared;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re called into this fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which the apostles have declared."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit with our spirit is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The factor for us to be one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The key to live the Christian life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And secret of our salvation."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ministry of Christ in full"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within this realm is carried out,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s complete salvation too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within this sphere is brought about."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In all their living and their work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This mingled life th’ apostles sought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God to manifest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In character and service wrought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In all our living and our work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So we must also do the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In daily life, we would make this"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our top priority and aim."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As therefore we have thus received,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So in all things we walk in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine all-inclusiveness to grasp,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We call and pray unceasingly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "16"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We live in Thee and Thou with us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In two-way traffic mutually:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we live, exist, and move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide uninterruptedly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "17"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name which Thou hast given us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Denotes Thy Person as our sphere,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sum total of Thy Being, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into which we’ve been gathered here."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "18"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art in us Thy kingdom too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With joy and peace and righteousness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal life’s totality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church life, sphere in which we’re blessed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "19"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem will be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This realm’s domain perpetually;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou in the Father, we in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou in us eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "20"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O, may we see, experience"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The realm of Thine economy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all the details of our life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To practice living one with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "21"
    }
  ],
