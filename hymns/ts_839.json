{
  "url": "https://www.hymnal.net/cn/hymn/ts/839",
  "title": "云彩",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的生命不再挥霍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自从我看见云彩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "越过一片死寂荒漠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远远的显现出来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它像光明火柱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照亮黑暗道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "燃起人生新希望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "定住我的脚步。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的人生变得充实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正当我迎向云彩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙万物真理柱石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千百年历久不衰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它是神所经营，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活神显于肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我无比信心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我无比温馨。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的生活何等豪迈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我已拥有云彩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄姊妹坚强的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "围绕我不至摇摆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真理照亮我的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典无穷无尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从此我心有所归，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再叹息徘徊。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我与你们已经融合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也化为这朵云彩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天空多么灿烂明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不怕那弯曲世代；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我大步向前去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将这见证高举，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿它光采更壮丽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永世不渝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "（尾声）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，噢！主，噢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我放下各样重担，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生活在光明的云彩。"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
  "metadata": {
    "category": "事奉与福音",
    "time": "3/4",
    "hymn_code": "336717636712123",
    "midi_tune_url": "https://www.hymnal.net/Hymns/ChineseTS/midi/tunes/ts0839_tune.midi",
