    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word is like a starry host:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A thousand rays of light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are seen to guide the traveler,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make his pathway bright."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word is like an armory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where soldiers may repair,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And find, for life’s long battle day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All needful weapons there."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O may I love Thy precious Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May I explore the mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May I its glorious riches take,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May light upon me shine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O may I find my armor there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word my trusty sword;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll learn to fight with every foe"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The battle of the Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Word of the ever living God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will of His glorious Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without Thee how could earth be trod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or God and Christ be won?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grant us all aright to learn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wisdom it imparts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to its heav’nly teaching turn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With simple, child-like hearts."
            }
          ]
        }
      ]
