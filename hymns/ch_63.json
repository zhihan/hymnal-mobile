{
  "url": "https://www.hymnal.net/cn/hymn/ch/63",
  "title": "耶稣你名何等芬芳",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "耶 稣！"
            },
            {
              "chord": "",
              "text": "你 名 何"
            },
            {
              "chord": "E",
              "text": "等 芬"
            },
            {
              "chord": "A",
              "text": "芳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "E",
              "text": "蒙 恩"
            },
            {
              "chord": "B7",
              "text": "人 身"
            },
            {
              "chord": "E",
              "text": "上！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "A",
              "text": "救 罪"
            },
            {
              "chord": "",
              "text": "人， 心"
            },
            {
              "chord": "D",
              "text": "里 所"
            },
            {
              "chord": "E",
              "text": "念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无"
            },
            {
              "chord": "A",
              "text": "一 像"
            },
            {
              "chord": "E",
              "text": "你"
            },
            {
              "chord": "E7",
              "text": "这"
            },
            {
              "chord": "A",
              "text": "甜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神来为人，所表恩义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你名包含无遗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上生命、世间生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在你身显著！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘耶稣’这名表明大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何忍受祸害，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这名说出我们零丁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上如何同情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣无罪，为我成罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我蒙恩受惠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你舍你身，来得我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今后你重我轻。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "题起你名，我心即伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬拜救主我主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱救我，我今归你－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这超万人的你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
