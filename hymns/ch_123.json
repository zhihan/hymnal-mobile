    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "受膏的王、一切的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入荣耀得万福！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前曾被人讥笑、厌弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你欲救人，人绝你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我敬爱你、称颂你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今得尊荣至无极。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾死过，生命的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祝福人者竟受诅！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是父神所爱所重，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟受苦难学顺从；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我仰望你、记念你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我亲历忧患地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不久华冠将加你首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久铁杖操你手！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的基督，我们现今"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候你从天降临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我敬爱你、顺服你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远认你为基督。"
            }
          ]
        }
