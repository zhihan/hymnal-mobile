    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "施恩宝座虽然在天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂天梯通到我灵里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以我不在魂里游荡，"
            }
          ]
        },
        {
