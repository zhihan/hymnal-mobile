              "chord": "",
              "text": "按着麦基洗德的等次；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今为着神利益争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就代求供我能力。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等我得胜杀败众仇敌，"
            }
          ]
        },
        {
          "segments": [
