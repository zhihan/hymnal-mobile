{
  "url": "https://www.hymnal.net/en/hymn/ns/23",
  "title": "Lovers of Christ",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lovers of Christ in His ascension—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoy the riches of His life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She becomes His private garden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With its fountain, fruit, and spice."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is hers and she is Christ’s dear love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "She is as beautiful as Tirzah"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As lovely as Jerusalem."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through her living in Christ’s ascension"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her dear heart is now His home."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She’s become the sanctuary of God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who is this woman I am seeing?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining forth as the moon and sun."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She is absolutely heavenly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the old creation free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Overcoming all to live within the veil."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "An army terrible with banners"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s lovers overcome to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those attracted by His beauty,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully trusting in His power."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her romance is now the dances of two camps."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Shulammite, His duplication,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His counterpart has now become."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She’s the same in life and nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His expression to the full;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consummated as the New Jerusalem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
