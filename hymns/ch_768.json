{
  "url": "https://www.hymnal.net/cn/hymn/ch/768",
  "title": "阿神中心的观念",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "阿， 神"
            },
            {
              "chord": "",
              "text": "中 心 的 觀 念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "乃 是"
            },
            {
              "chord": "",
              "text": "與 人"
            },
            {
              "chord": "A7",
              "text": "相 結"
            },
            {
              "chord": "D",
              "text": "聯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 來 作 人 的 一 切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 祂"
            },
            {
              "chord": "A",
              "text": "計 畫"
            },
            {
              "chord": "",
              "text": "得 成"
            },
            {
              "chord": "D",
              "text": "全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人是被造的瓦器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有灵、有魂也有体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人可取神作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此与神成为一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着生命的流通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人变宝石为神用；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "适合为神造居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让神彰显祂光荣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是圣城神所建，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是居所神所羡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是新耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完满成全神心愿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是众圣的建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神、人的相调；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原是父神所筹画，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神、人的需要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神和羔羊的宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这荣耀的居所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从这掌权的中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出圣灵生命河。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长在河的两岸处；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结出神圣生命果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应众圣作食物。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神在基督里作光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "透过全城来照亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡之夜全驱尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣之光照辉煌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神在人里，人在神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "互为居所来藏身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人的内容乃是神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的表现乃是人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
