      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In bondman’s form, with lowliness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou walkedst on this earth of woe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The human living Thou didst have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all its suff’rings undergo."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Born in a manger as a babe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wast a child among the poor;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou as a carpenter didst work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And e’en an outlaw’s death endure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then Thou wast raised up from the dead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still with the human nature true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as a man in form divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou didst ascend to heaven too."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now over all, and on the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, still a man, art glorified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A man with God in light divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With whom our God is satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In glory Thou wilt come again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still as a man appearing then;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As King of kings, with pow’r divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With human nature seen by men."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, as the center of all things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the new heav’n and earth shalt be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever as the One divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Existing in humanity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
