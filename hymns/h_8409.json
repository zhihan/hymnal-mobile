            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is an everlasting love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In ever rich supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And so we dwell together,"
            }
          ]
        },
        {
