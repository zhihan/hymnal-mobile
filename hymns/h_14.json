    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Unresting, unhasting, and silent as light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor wanting, nor wasting, Thou rulest in might;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy justice like mountains high soaring above"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy clouds which are fountains of goodness and love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To all life Thou givest, to both great and small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all life Thou livest, the true life of all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We blossom and flourish as leaves on the tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And wither and perish, but nought changeth Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Great Father of Glory, pure Father of Light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine angels adore Thee, all veiling their sight;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All laud we would render, O help us to see:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis only the splendor of light hideth Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Immortal, invisible, God only wise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In light inaccessible hid from our eyes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Most blessed, most glorious, the Ancient of Days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Almighty, victorious, Thy great name we praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
