              "text": "从衷返照祂荣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告要将主发表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让祂借我来求诉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在我里的基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告天上的基督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告要将主发表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学习不凭自己求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全向着主祷告，"
            }
          ]
        },
        {
          "segments": [
