        {
          "segments": [
            {
              "chord": "",
              "text": "祷告要将主发表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须说出祂所要，"
            }
          ]
        },
        {
          "segments": [
            {
