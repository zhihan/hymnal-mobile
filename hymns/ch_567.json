            },
            {
              "chord": "A7",
              "text": "我 自"
            },
            {
              "chord": "D",
              "text": "己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "讓 主"
            },
            {
              "chord": "E7",
