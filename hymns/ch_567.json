    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告要将主发表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总要将祂来瞻仰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同镜子在观看，"
            }
          ]
        },
        {
          "segments": [
            {
