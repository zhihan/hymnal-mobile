    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There is, like Anak’s sons of old,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A race of giants still:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self-glorying, self-confidence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self-seeking and self-will."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still must these haughty Anakims"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Caleb’s sword be slain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ere Hebron’s heights of heav’nly love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our conqu’ring feet can gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, save me from self-will, dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which claims Thy sacred throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! let my will be lost in Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And let Thy will be done."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, keep me from self-confidence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And self-sufficiency;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me exchange my strength for Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lean alone on Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, save me from self-seeking, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me not be my own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A living sacrifice I come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, keep me Thine alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From proud vain glory save me, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From pride of praise and fame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Christ be all the honor given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory to His name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Savior. slay the self in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy consuming breath;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Show me Thy heart, Thy wounds, Thy shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That self be put to death."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Shekinah flame came down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en Moses could not stay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So let Thy glory fill me now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And self forever slay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
