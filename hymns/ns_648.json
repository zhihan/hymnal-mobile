    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We, like Peter, all have stumbled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such defeats make our strength crumble,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our once proud hearts become humble,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are so low,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In these moments the Lord comes in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeking our love and affection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we listen, we can hear Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saying to us..."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In these days the Lord is hindered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because of a lack of shepherds"
            }
          ]
