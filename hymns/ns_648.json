              "text": "Who dispense the milk of the Word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the lost sheep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He needs man’s cooperation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To let Him shepherd from within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will you be one who is open"
            }
          ]
        },
        {
          "segments": [
