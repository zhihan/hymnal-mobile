    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A long, long road I traveled night and day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sought to find within myself some way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Aught I could do, or feel to bring me near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self effort failed, and I was filled with fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then I found Christ was the only way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I must come to Him and in Him stay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O wondrous place! O home divinely fair!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I, God’s little one, safe hidden there."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, as I dwell in Thee and Thou in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So make me dead to everything but Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That as I rest within my home most fair,"
            }
          ]
        },
        {
