    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In elevation how beauteous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The joy of all the earth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In elevation how beauteous"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Zion, that city of worth!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O there is a river in Zion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That flows so deep and so broad."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O how the streams of that river"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make glad the city of God!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise waiteth for Thee, Lord, in Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise waiteth, O God, for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise waiteth for Thee, Lord, in Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Zion is filled with Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How great the Lord is in Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How greatly to be praised,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How great He is in that city"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which over the earth is raised."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O bless the Lord out of Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O let His praises swell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O bless the Lord out of Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ye who in Jerusalem dwell."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord bless thee out of Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord bless thee o'er and o'er!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord bless thee out of Zion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life for evermore!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold how good and how pleasant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all the brethren to be!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold how good and how pleasant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To dwell in unity!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O tell it to all generations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O tell it to all who will come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O tell it to all generations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit and Bride say, \"Come!\""
            }
          ]
        }
      ]
    }
