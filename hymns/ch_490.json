        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "怕 改"
            },
            {
              "chord": "",
              "text": "变 一"
            },
            {
              "chord": "A",
              "text": "点；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "如 此"
            },
            {
              "chord": "",
              "text": "把 握 不"
            },
            {
              "chord": "D",
              "text": "落"
            },
            {
              "chord": "G",
              "text": "空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "D",
              "text": "此 没"
            },
            {
              "chord": "A7",
              "text": "有 改"
            },
            {
              "chord": "D",
