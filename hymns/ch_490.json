      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "穷困难迫我回头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任主领我何方；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不至有何不够，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的牧人在旁。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的慧心常清醒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的明眼不眛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知祂行的路径，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要始终跟随。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "青草地场尚在前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我从所未见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再过就是清朗天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今虽稠云绵绵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的希望真久长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的途径光明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主掌握我宝藏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要和我同行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "或许明朝天未晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵不及等待，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就脱肉体全不要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，就与你同在。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安息！睡眠！何宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你保护照顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或许你忽荣耀归，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召我座前相晤！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时看见你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被众选民拥挤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是荣耀又美丽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是歌唱无已。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙应许的日期，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们能够同你"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远享受神安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远喜乐满意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
