              "text": "风 四"
            },
            {
              "chord": "D",
              "text": "面 起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "G",
              "text": "许 无"
            },
            {
              "chord": "",
              "text": "多 希"
            },
            {
