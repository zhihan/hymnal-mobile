    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In your daily duty, standing up for right,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are you sometimes weary—heart not always light?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doubt your Savior never,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This your motto ever:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can all things, all things do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ, which strengtheneth me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If your way be weary He will help you through—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help you in your troubles and your pleasures too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Say, when Satan's by you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Say, when all things try you:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can all things, all things do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ, which strengtheneth me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In a world of trouble, tempted oft to stray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You need never stumble, Satan cannot stay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will but tempt you vainly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If you tell him plainly:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can all things, all things do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ, which strengtheneth me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus' power is boundless, boundless as the sea;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is always able, able to keep me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Power bring from my weakness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory from my meekness:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can all things, all things do"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ, which strengtheneth me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
