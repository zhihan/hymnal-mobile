      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en as Eve is part of Adam"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Taken out of him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So the Church is Christ’s own increase"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Himself within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As from out the buried kernel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many grains are formed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the grains together blended"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To a loaf are formed;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So the Church, of many Christians,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ doth multiply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him expressing as one Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God to glorify."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the branches of the grapevine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are its outward spread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With it one, abiding, bearing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clusters in its stead;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So the Church’s many members"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s enlargement are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with Him in life and living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spreading Him afar."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulness, increase, duplication,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His expression full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growth and spread, continuation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surplus plentiful,"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Church to Christ, and thereby"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in Christ may be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorified thru His redeemed ones"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the Church and Christ together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s great mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the mingling of the Godhead"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With humanity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
