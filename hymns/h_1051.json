          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To loyal hearts and free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That every promise is fulfilled,"
            }
          ]
        },
        {
          "segments": [
