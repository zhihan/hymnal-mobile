    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though coming weak and vile,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost my strength assure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost my vileness fully cleanse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till spotless all, and pure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I am coming, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Coming now to Thee:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash me, cleanse me in the blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That flowed on Calvary."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Jesus who confirms"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blessed work within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By adding grace to welcomed grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where reigned the power of sin."
            }
          ]
        }
      ],
