    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As I read, I pray, as I pray, I read,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingling both as one spontaneously."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You respond within with words so sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I repeat these words to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m a newborn babe—it’s the milk I need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the knowledge of the dead teaching."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I eat Your word, it becomes to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart’s joy and rejoicing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweeter than honey, precious more than gold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It will not be void, but as the rain and snow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It will do Your will—bear the life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearing fruit a hundred-fold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When my heart is like a rock so cold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s Your word so strong that hammers stone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the grain of life may come to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And supply me inwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s my food, my drink, and my life supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love to eat it every day and night."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I just turn and open up to Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the rivers flow right in."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
