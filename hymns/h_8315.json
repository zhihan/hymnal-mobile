{
  "url": "https://www.hymnal.net/cn/hymn/h/8315",
  "title": "Unclean Lips, Impure Heart",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My lips are foul, my heart impure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm a vile failure, utterly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my past hopes no more endure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, hast Thou yet some grace for me?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In holiness, self's active yet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When humble, I on self rely;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en the remorseful tears I shed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These, too, Thy cleansing blood require."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In best intentions, self remains;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In highest sacrifice, self's aims;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart is my own enemy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, may my hope yet in Thee stay?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In serving God, opinions lurk;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In loving man, self-interest hides."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I dare not stop, nor can I work;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everywhere, in all, self abides."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The old creation's hard to shed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I but move, there self is mired."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, that Thy glory Thou wouldst send,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart to flood and bless entire."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Naught dare I ask, nor aught avow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Naught can I do but gaze on Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Might Thou Thy precious Word bestow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory divine reveal to me?"
            }
          ]
        }
      ]
    }
  ],
