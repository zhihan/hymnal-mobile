  "title": "神是人所不能见者",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 是"
            },
            {
              "chord": "",
              "text": "人 所 不"
            },
            {
              "chord": "A",
              "text": "能"
            },
            {
              "chord": "A7",
              "text": "見"
            },
            {
              "chord": "D",
              "text": "者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "從 未 有 人 見"
            },
            {
              "chord": "E",
              "text": "過"
            },
            {
              "chord": "E7",
              "text": "祂"
            },
            {
              "chord": "A",
              "text": "形；"
            }
