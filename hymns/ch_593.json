              "text": "召会具有基督形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是祂扩增，是祂普及；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂之所是全在召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会乃是祂的身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神乃在子神里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子神且已成为那灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今这位三一神灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是与召会合一同性。"
            }
          ]
        }
