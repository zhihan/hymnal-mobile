        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "但 有"
            },
            {
              "chord": "",
              "text": "基"
            },
            {
              "chord": "A",
              "text": "督 作"
            },
            {
              "chord": "D",
              "text": "祂 奧"
            },
            {
              "chord": "A",
              "text": "祕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "將 祂"
            },
            {
              "chord": "",
              "text": "向 人 全"
            },
            {
              "chord": "A",
              "text": "然"
            },
            {
              "chord": "A7",
              "text": "表"
            },
            {
              "chord": "D",
              "text": "明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是神的活话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神惟一真实说明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是神的具体化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂得见神的本性。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是神本体真像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神荣耀所发光辉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的丰满住祂里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神之所是由祂发挥。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督现今也是隐瞒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上今日无人能见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但有召会作祂奥秘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到处将祂显于人前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会是祂丰满表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是召会内容生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会是祂真实复本，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂借召会向人显明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
