    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once darkness, we did walk in hate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Far from Your holy flame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Light quelled sin’s gloom; our needs You sate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Born of Your radiant name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not merely children of the day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But light itself—we rise!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Awake, o sleeper, from the dead:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Light shines! Light makes us Christ!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "True Life in us, unconquerable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each blow Christ can endure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No storm, no hell, no tempter’s pull"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can shake Life’s power pure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our mortal life, Light’s tests expose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its frailty laid so bare!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our strength dissolves, but Christ bestows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life beyond death’s snare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As light reveals, Your life supplies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A pathway sure and bright."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From depths of love, we realize"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our growth is borne by light."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In light, no veil now hides Your face—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our sight, restored and clear!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through You, we walk, transformed in grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your glory drawing near!"
            }
          ]
        }
      ],
