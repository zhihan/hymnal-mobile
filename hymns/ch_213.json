  "title": "主阿愿你属天之风",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "願 你 屬"
            },
            {
              "chord": "G",
              "text": "天 之"
            },
            {
              "chord": "D",
              "text": "風，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "現"
            },
            {
              "chord": "A",
              "text": "在 吹"
            },
            {
              "chord": "A7",
              "text": "到 我"
            },
            {
              "chord": "D",
              "text": "身！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用 那 感 人、 復"
            },
            {
              "chord": "G",
              "text": "興 大"
            },
            {
              "chord": "D",
              "text": "能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吹"
            },
            {
              "chord": "A",
              "text": "動 我"
            },
            {
              "chord": "A7",
              "text": "的 心"
            },
            {
              "chord": "D",
              "text": "魂。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "大 能 主"
            },
            {
              "chord": "D7",
              "text": "阿， 求"
            },
            {
              "chord": "G",
              "text": "你 降"
            },
            {
              "chord": "",
              "text": "臨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用"
            },
            {
              "chord": "D",
              "text": "你 聖"
            },
            {
              "chord": "A7",
              "text": "靈 來"
            },
            {
              "chord": "D",
              "text": "吹！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用 你 大"
            },
            {
              "chord": "D7",
              "text": "能 將"
            },
            {
              "chord": "G",
              "text": "我 吹"
            },
            {
              "chord": "",
              "text": "過，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "帶"
            },
            {
              "chord": "D",
              "text": "來 湧"
            },
            {
              "chord": "A7",
              "text": "流 活"
            },
            {
              "chord": "D",
              "text": "水！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "用你能力之灵来吹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吹去所有障碍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你生命之灵来呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呼进你的大爱。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "大能主阿，求你降临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你圣灵来吹！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你大能将我吹过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来涌流活水！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵具有七倍丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为使我享你分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你叫我有分这灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历三一之神。"
            }
          ]
        }
      ]
    },
