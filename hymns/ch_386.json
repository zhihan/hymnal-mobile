    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督就是我的世界："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "百般试炼之助，"
            }
          ]
        },
        {
          "segments": [
