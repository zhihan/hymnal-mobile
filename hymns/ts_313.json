{
  "url": "https://www.hymnal.net/cn/hymn/ts/313",
  "title": "愿我爱全归你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "前我曾多次呼求主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是从未这样实际的摸着我主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知为何故忽见祂丰采，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦我的主耶稣，我爱你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世上的事物我已不再属，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着这位可爱的生命救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让万事逝去，只要我能够"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天在召会中来爱你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣！奇妙的耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我何等的救主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，愿我爱全归你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天欢喜快乐地"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你实际！"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
