    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"主请进入你的园子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良人请来随意尝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "佳美果子上等香品，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘美丰盈供你享。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"我的妹子，我的新妇，"
