            },
            {
              "chord": "",
              "text": "从 我"
            },
            {
              "chord": "A7",
              "text": "里 流"
            },
            {
              "chord": "",
              "text": "出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 为"
            },
            {
