        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿"
            },
            {
              "chord": "F",
              "text": "们！ 阿"
            },
            {
              "chord": "",
              "text": "们！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "一 呼"
            },
            {
              "chord": "",
              "text": "一 吸 我 就 活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿"
            },
            {
              "chord": "F",
              "text": "们！ 阿"
            },
            {
              "chord": "",
              "text": "们！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，"
            },
            {
              "chord": "Dm",
              "text": "祂 呼"
            },
            {
              "chord": "",
              "text": "出 而"
            },
            {
