      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "约翰第三章"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是指外面空气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "风在外面吹呀吹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随意而吹。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不知它来自何方，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不知它吹往何处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡从圣灵生的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也都是如此。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "约翰二十章"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是指里面空气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣所呼出的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要我们接受这气─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不必思虑，只要呼吸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们经历生命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是借着这气。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无论在那里都有"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "空气，空气！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它包围笼罩我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随时、随地！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "白白赐给，丰富便利，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们生活丰盛无比；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以弟兄姊妹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同来吸这气。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "只要来呼喊祂名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主！哦主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就成我们气息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主！哦主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从最深处吸入祂名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我们充满生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这位耶稣是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等生命供应！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
