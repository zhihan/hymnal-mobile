    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借这人位成形在我里，我成祂身上的一肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有行动都不再单独，全在配搭里。"
