{
  "url": "https://www.hymnal.net/cn/hymn/ch/16",
  "title": "我们赞美你的公义",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "赞 美 你"
            },
            {
              "chord": "E",
              "text": "的 公"
            },
            {
              "chord": "",
              "text": "义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "的 正"
            },
            {
              "chord": "D",
              "text": "义 我"
            },
            {
              "chord": "",
              "text": "们 称"
            },
            {
              "chord": "E",
              "text": "奇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "永 远"
            },
            {
              "chord": "",
              "text": "见"
            },
            {
              "chord": "E",
              "text": "证"
            },
            {
              "chord": "E7",
              "text": "不"
            },
            {
              "chord": "A",
              "text": "已。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 审 判 全"
            },
            {
              "chord": "E",
              "text": "地 的"
            },
            {
              "chord": "",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "A",
              "text": "你 不"
            },
            {
              "chord": "D",
              "text": "义 谁"
            },
            {
              "chord": "",
              "text": "能 寻"
            },
            {
              "chord": "E",
              "text": "出？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "你 是"
            },
            {
              "chord": "",
              "text": "全"
            },
            {
              "chord": "E",
              "text": "然"
            },
            {
              "chord": "E7",
              "text": "公"
            },
            {
              "chord": "A",
              "text": "义！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "公义是你宝座根基，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和平借此得以建立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像你信实坚定！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你这无比公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督恩典作王管理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得享和平。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的公义使你儿子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去到十架为我受死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎借此成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当这救赎人肯信倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的公义立刻称义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人得蒙拯救。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着显明你的公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾宽容前一时期"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众人所有过犯；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并为显明你的公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也赦免这一时期"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪人所有罪愆。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一日你要审判万民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你公义显得完尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着我主基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要靠你义站立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能将我们摇移，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典因义显著。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将来国度充满公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和平得在其上建立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万物和谐、同居；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在那永世新天新地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更要充满你的公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照着你所应许。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "敬拜父",
