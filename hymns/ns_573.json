    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Drawn nigh, we come in Your Son, full of cheer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing between us but fellowship dear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Coordinated, before You we stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hidden in Christ, under grace o’er us spanned."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Are we not shielded and joined in Your Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Four living creatures whose wings meet as one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wings straight, and covering, wings paired on each side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pointing to Christ, worthy, pure, dignified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Covered, connected, beneath such expanse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ we speak, this Your oracle grants."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaven is open! Our skies are so clear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stretched forth like crystal, both awesome and sheer."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Wings of an eagle, in us multiplied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sound like great waters, like thunderous tide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our voice like Yours roars in tumult and din,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your throne above us, You ruling within!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All hail the Father Who sits on the throne!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All hail His Son on His right hand alone!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All hail the Spirit that moves with the wheel!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fervently praise the Almighty with zeal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
