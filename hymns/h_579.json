          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vaster, broader than the sea:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how marvelous Thy goodness,"
            }
          ]
        },
        {
          "segments": [
