              "text": "Know what wealth of grace is Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Know Thy certainty of promise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And have made it mine."
            }
          ]
        }
      ],
