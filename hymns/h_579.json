    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Simply trusting Thee, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I behold Thee as Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy love, so pure, so changeless,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satisfies my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satisfies its deepest longings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meets, supplies its every need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Compasseth me round with blessings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine is love indeed."
            }
          ]
        }
      ],
