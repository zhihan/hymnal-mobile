    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今赐福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并要永远赐福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今救我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并要永远救我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要扶我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此无倚中途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要领我危关"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "平安度过。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我主、我神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的对你认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我心满平安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "口满歌唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的生命、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐、杖子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倚身于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我软弱变强。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我是缺乏、饥渴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我这心怀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "焦慕这里所难寻的甘甜："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恋人逐渐离开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们离开"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "留下空隙"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着更为可恋。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "更多的你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你时刻启迪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更多你的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主、我神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更多的你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在于恩典、能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更多你的怜悯"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐给我身。"
            }
          ]
        }
      ],
