    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我在这里，世人瞠目惊喟："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"竟如此枉费？\"但我无悔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因知道所信是谁！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在这里！得上好机会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将宝贵玉瓶打碎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证祂的甘美。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我在这里，撒但已在抖颤："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真相终揭穿─大巴比伦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要被神烈火审判。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在这里！永不向后看！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上到楼房来奉献，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "福音地极传遍！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我在这里，我看见祂微笑："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的一声\"好\"，价值何高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜一切人的荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在这里！归回为建造；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑夜已深将破晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿祂来得早！"
            }
          ]
        }
      ],
