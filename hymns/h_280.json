    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Lord, how dry my heart is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It yearns and pants for Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The filling of Thy Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is now my fervent plea."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the smitten Rock, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would entirely hide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pour thru Thy living water,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till I am satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, from myself deliver,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all its misery;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d henceforth be forever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Completely filled with Thee."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How cold my heart has been, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How slow obeying Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So fill me with Thy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll ne’er rebellious be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I lie upon Thy altar"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And dare not move away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may Thy flame descending"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consume my all, I pray."
            }
          ]
        }
