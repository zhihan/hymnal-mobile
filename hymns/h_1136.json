    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not the outward action—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pure behavior, conduct good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Proper poise and perfect manners,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doing what we think we should;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But it’s Christ, a living Person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingled thus with us within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spreading into all our being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So that we might live by Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Lord, let our every action,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything we do and say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come from Thee alone, experienced"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In a real and inner way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We reject the empty teachings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leave the methods and the strife."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let our only way of living"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be the overflow of life!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Following the inner feeling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living in the overflow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Moving in the rich anointing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by what we think or know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing through intent or motive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or with purpose duly done,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But just following this feeling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living by the living One!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we’re sanctified completely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saturated thoroughly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the old religious concept:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Separated doctrinally."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But ’tis Christ Himself within us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Added to our every part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All supplying, satisfying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making home in all our heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
