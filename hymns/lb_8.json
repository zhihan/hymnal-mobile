    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! Vast Unmeasured Portion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! Bountiful Supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In light the saints enjoy Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou dost reign thereby."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the Father’s bosom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beloved Son Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sweetness of the Godhead"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us Thou dost impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Most Excellent of mankind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Creation’s firstborn One!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God saw Thee and foreknew Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The first created One."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, twice to Thee ’tis given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yea, born and born again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A man in resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The firstborn from the dead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The universal Fullness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So pleased resides in Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within Thee dwells the Godhead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou, Lord, dwell in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Preeminent, transcendent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unique in all Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’erflowing all the heavens,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou now dost fill my heart!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the hope of glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The center and the focus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God’s economy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secret of the ages,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Veiled from eternity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The hidden dispensation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God in me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
