{
  "url": "https://www.hymnal.net/cn/hymn/ch/125",
  "title": "主你是神受膏者",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "G7",
              "text": "神 受"
            },
            {
              "chord": "C",
              "text": "膏 者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 萬"
            },
            {
              "chord": "F",
              "text": "王 之"
            },
            {
              "chord": "G",
              "text": "王！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "C",
              "text": "此 俯"
            },
            {
              "chord": "G7",
              "text": "伏 並"
            },
            {
              "chord": "C",
              "text": "敬"
            },
            {
              "chord": "F",
              "text": "拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向"
            },
            {
              "chord": "C",
              "text": "你 高"
            },
            {
              "chord": "G7",
              "text": "聲 頌"
            },
            {
              "chord": "C",
              "text": "揚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 國"
            },
            {
              "chord": "F",
              "text": "度 無"
            },
            {
              "chord": "C",
              "text": "窮 盡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 寶"
            },
            {
              "chord": "F",
              "text": "座 堅"
            },
            {
              "chord": "G",
              "text": "定！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "的 治"
            },
            {
              "chord": "G7",
              "text": "理 公"
            },
            {
              "chord": "C",
              "text": "而"
            },
            {
              "chord": "F",
              "text": "仁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "榮"
            },
            {
              "chord": "C",
              "text": "耀 無"
            },
            {
              "chord": "G7",
              "text": "可 抗"
            },
            {
              "chord": "C",
              "text": "衡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在那锡安圣山上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已将你立定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并将列国赐给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你基业永恒。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已将祂的权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全委托于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要你列国全管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永世无已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "日期尚未满足时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗尚在掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍有千万的群众，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你忠贞颂赞！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大洋这岸到那岸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你民向你歌唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬拜、爱戴、事奉你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作彼救主－君王！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "等到豫定的日子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要荣中降临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地和其上的列国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要向你归顺。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满了光辉和威严，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要被尊为王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各族、各民和各国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要将你颂扬！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
  "metadata": {
    "category": "赞美主",
