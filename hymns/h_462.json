    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Privations, sorrows, bitter scorn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life of toil, the mean abode,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The faithless kiss, the crown of thorn—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are these the consecrated road?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, should my path through suff’ring lie,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forbid it I should e’er repine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still let me turn to Calvary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor heed my griefs, rememb’ring Thine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O let me think how Thou didst leave"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Untasted every pure delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To fast, to faint, to watch, to grieve,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The toilsome day, the homeless night:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To faint, to grieve, to die for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou camest, not Thyself to please;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, dear as earthly comforts be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall I not love Thee more than these?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
