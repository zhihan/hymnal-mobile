{
  "url": "https://www.hymnal.net/cn/hymn/ch/385",
  "title": "主阿你是吗哪",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "你 是 嗎"
            },
            {
              "chord": "Dm",
              "text": "哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "G",
              "text": "經 從"
            },
            {
              "chord": "G7",
              "text": "天 降"
            },
            {
              "chord": "C",
              "text": "下；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "來 作 我"
            },
            {
              "chord": "C7",
              "text": "的 食"
            },
            {
              "chord": "F",
              "text": "物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "使"
            },
            {
              "chord": "C",
              "text": "我 得"
            },
            {
              "chord": "G7",
              "text": "著 飽"
            },
            {
              "chord": "C",
              "text": "足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是磐石裂破，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出活水为我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随时我都可喝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我免去干渴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现在我来就你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我又渴又饥；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你自己餧我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我活水解渴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿吃你、喝你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吸取你的自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饱尝你的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "畅饮你的圣灵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "若非如此吸取，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就难免去空虚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此吃你、喝你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能生活有力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
