    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Philadelphia,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine are works that please the Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strength thou hast, though just a little"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And hast kept His living Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou His holy name denied not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But confessed it here below—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, a door is set before thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through which none but thee can go."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, beloved Philadelphia,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dost His Word of patience keep."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the hour of trial He'll save thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which o'er all the world shall sweep."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Troublers too shall know He loves thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They to thee must then bow down."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Hold thou fast, for I come quickly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That no man may take thy crown.\""
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, overcomers,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"In the temple of My God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will build them in as pillars,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nevermore to go abroad.\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's own name is written on them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the new name of the Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the triune God they're blended;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They're the city of our God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, out of heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Comes the New Jerusalem:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gates of pearl and walls of jasper,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingled with each precious gem."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Philadelphia, Philadelphia,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has become His Bride so dear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the Spirit in the churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks to all who have an ear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
