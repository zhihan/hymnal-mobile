{
  "url": "https://www.hymnal.net/en/hymn/ns/290",
  "title": "The song to my Beloved",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Your beauty and love have drawn me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To pursue after You speedily."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your chambers I am brought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And nourished here by Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Belov’d, I belong to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O my Love, You’re so beautiful."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re the same in life and in nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In love ever insep’rable."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your nature is mine sanctified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my beauty’s from Your life divine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m renewed, submissive, sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee, with hind’s feet leap."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As a dove, You alone do I see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a lily, I’m trusting in Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m transformed and built by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your rest and joy to be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the fields let me follow You, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my days work, in loving accord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be matured, Your Queen, Your Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then raptured, glorified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O set me a seal on Thy heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love strong as death doth abound."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King, Belov’d, for You I am longing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come quickly upon Spice’s Mount!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
  "metadata": {
