{
  "url": "https://www.hymnal.net/cn/hymn/ch/603",
  "title": "神，我赞美你的计画",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神， 我"
            },
            {
              "chord": "",
              "text": "讚 美 你"
            },
            {
              "chord": "A",
              "text": "的"
            },
            {
              "chord": "A7",
              "text": "計"
            },
            {
              "chord": "D",
              "text": "畫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 使 我 們 成 為 你"
            },
            {
              "chord": "A",
              "text": "家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "給 你"
            },
            {
              "chord": "",
              "text": "安 居， 由"
            },
            {
              "chord": "A",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "充"
            },
            {
              "chord": "D",
              "text": "滿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 在 子 裡 好"
            },
            {
              "chord": "A",
              "text": "得"
            },
            {
              "chord": "A7",
              "text": "彰"
            },
            {
              "chord": "D",
              "text": "顯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们虽是你所创造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你形像，作你代表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过仅是土造陋器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面有灵，外面是体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有接受你作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能有你精金性情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你与我们调和为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与你成为一体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你生命流通、滋润，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸透我的全心、全魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就变成珍珠、宝石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你荣形一样一式。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是，恩主，我们深知，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这些并非为供赏识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是全为建造、配搭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的荣耀之家。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我在此献上自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你接在建造手里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我折服，将我联络，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "造成你能安居之所。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天然生命、孤僻性格，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你全都为我攻破，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再单独，不再自善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与众圣徒调成一团。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此才能作你配偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你爱所是所有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "共同生活，互相安居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你心，得你称许。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "召会",
    "time": "2/2",
