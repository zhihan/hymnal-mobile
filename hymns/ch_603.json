    "midi_tune_url": "https://www.hymnal.net/Hymns/Chinese/midi/tunes/c0603_tune.midi",
    "current_key": "F Major",
    "original_key": "D Major",
    "capo": 3,
    "related": [
      {
        "url": "https://www.hymnal.net/en/hymn/h/837",
