            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re walking in her midst;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She is Your heart’s interest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To You, Lord, nothing else exists."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No, nothing can deter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No person can alter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love, dear Lord, You have for her."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This mystery, Oh how great!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, saints it’s not too late!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All else is vanity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take this reality."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your eyes, a flame of fire."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To one, Lord, You aspire:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s her, Lord, You completely desire."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The breastplate on Your chest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Golden girdle on Your breast."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Bride: on her Your heart is set!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, stand together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with another."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ and the churches are"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The end of our search."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The speaking of Your voice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trumpets Your single choice:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Son of Man, Your gold lampstand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, keep me in Your hand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the seven golden lampstands,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining You for Your eternal plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We at Your feet do fall."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have mercy on us all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your face, the shining sun,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Touch me, Oh Living One!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re never satisfied"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until You have Your Bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts with Yours must coincide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transfuse me with Your sense."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your call is so immense."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Responding to Your love intense!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, open wide to Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t let this vision dim."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, take our being!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wreck us from everything!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I hate to lukewarm be!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, burn me thoroughly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My first, My best, I come to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The seven Spirits burn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Intensified to turn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart for You to be so firm."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant me a hot pursuit!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All else in me uproot!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, do burn each part!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant me a fresh new start."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, be my first and best."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All else I would detest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My all in You, Lord, I invest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I now pour out on Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You have conquered me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are my choice eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re in the final stage,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The age of every age."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, in me advance!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thank You for this last chance."
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
