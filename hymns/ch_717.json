      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣为赐丰富恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经流出宝血；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若投此朱红泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得洁如白雪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，主是道路、真理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引人进入安息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立即相信，勿再迟疑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得永生福气。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来阿！加入这个圣队，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同向荣耀直往；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美丽天城无忧无泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不息之乐永享。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "被罪压害人人要来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主在此等待；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要救你，安你心怀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要你肯信祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "只要信祂！只要信祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在要信祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要救你！祂要救你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在要救你！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣替你钉死十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流血作你赎价；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎已成不用代价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要你肯信祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣对你满有慈爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩门为你大开；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "机会一过未必再来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请你快来信祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "快来信祂！快来信祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在快信祂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能救你！祂能救你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在能救你！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不久离世，结局怎样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得救或是灭亡？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永生何乐！永死难当！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请你快来信祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
