      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘基督已为罪人死了，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我读话语，我信功效，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因在我心我有需要："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来作我的救主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是否没有别的法子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给神去作？我是不知；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我只能连唱美诗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂救我借救主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂竟离开荣耀天畔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟来地上为人受难；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你说奇怪，我无同感，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我已经识救主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿祂能在我心里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全看见劳苦功绩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂对祂工作满意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同我对我救主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让我无论生存、死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得力、得慰从这宝矿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今活着永远为王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却曾死过为救主。"
            }
          ]
        }
      ],
