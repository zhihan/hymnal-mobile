              "text": "祷告与主同劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到大轮已转动；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主一同来祷告，"
            }
          ]
        },
        {
          "segments": [
