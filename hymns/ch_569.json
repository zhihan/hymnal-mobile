      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告与主同劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让主发起并推行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有计画和工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是主借我完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
