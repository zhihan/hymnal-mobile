{
  "url": "https://www.hymnal.net/cn/hymn/ch/569",
  "title": "祷告与主同劳苦",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "禱 告"
            },
            {
              "chord": "",
              "text": "與 主"
            },
            {
              "chord": "C",
              "text": "同 勞"
            },
            {
              "chord": "G",
              "text": "苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "禱 告"
            },
            {
              "chord": "C",
              "text": "為 主"
            },
            {
              "chord": "",
              "text": "將 路"
            },
            {
              "chord": "D",
              "text": "鋪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "禱 告"
            },
            {
              "chord": "G",
              "text": "把 主"
            },
            {
              "chord": "D",
              "text": "來 推"
            },
            {
              "chord": "G",
              "text": "動，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也 被"
            },
            {
              "chord": "C",
              "text": "推 動"
            },
            {
              "chord": "D",
              "text": "走 主"
            },
            {
              "chord": "G",
              "text": "路。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告与主同劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照主心意和目的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主完全的联合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到祝福能满溢。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告与主同劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己雄心要抛弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "己意也要全拒绝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟独顾到主旨意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告与主同劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让主发起并推行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有计画和工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是主借我完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告与主同劳苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到大轮已转动；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主一同来祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到召会能跟从。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "祷告",
