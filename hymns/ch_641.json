{
  "url": "https://www.hymnal.net/cn/hymn/ch/641",
  "title": "今日战争凶猛",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "今 日"
            },
            {
              "chord": "",
              "text": "战 争 凶 猛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇 敌 更"
            },
            {
              "chord": "A",
              "text": "强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "战 场"
            },
            {
              "chord": "",
              "text": "呼 喊 之 声"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比"
            },
            {
              "chord": "E",
              "text": "前"
            },
            {
              "chord": "E7",
              "text": "响"
            },
            {
              "chord": "A",
              "text": "亮！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "阴 府"
            },
            {
              "chord": "",
              "text": "反"
            },
            {
              "chord": "D",
              "text": "抗 之"
            },
            {
              "chord": "",
              "text": "声"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比"
            },
            {
              "chord": "E7",
              "text": "前 厉"
            },
            {
              "chord": "A",
              "text": "害！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "却 有"
            },
            {
              "chord": "",
              "text": "半"
            },
            {
              "chord": "Em",
              "text": "夜 呼"
            },
            {
              "chord": "",
              "text": "声："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "『我"
            },
            {
              "chord": "A",
              "text": "必"
            },
            {
              "chord": "A7",
              "text": "快"
            },
            {
              "chord": "D",
              "text": "来！』"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日试炼更苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交战益烈；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阴府一齐鼓舞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "集队来劫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在此处守等，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更难得胜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却听喜乐之声："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘耶稣已近！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "更难证实主话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此末世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为撒但攻打，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竭其权势；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我需更大灵力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才会败敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主来不再叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等乐呢！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁愿一直前进，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借主大能？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁要坚定相信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以至得胜？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁要靠主壮心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以至奏凯？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此之人乐听："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘我必快来！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁选神的最好－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架窄路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "历尽百般苦恼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不回顾？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁敢奋勇直前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍苦、受惊？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因在此时可见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘耶稣已近！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现今黑暗深厚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们当前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至被提时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光明才现！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在彼我们见主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌已败，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜者同欢呼："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘耶稣已来！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
