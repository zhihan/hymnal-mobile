    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As I go on, there’s a test:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will I all things, dear Lord, detest?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will I to “precious” things adhere,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet lose Your presence, Lord, so dear?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I’m by pride, ambition, lost,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, Lord, expose me at all cost."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I choose to stay, remain in life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save me from death, turn me to life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chase all the shades of night away;"
            }
          ]
        },
        {
          "segments": [
