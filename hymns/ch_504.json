              "text": "不必苦求不辍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我当安息，不当奔波，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因主的话算得数。"
            }
          ]
        }
