    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Baptized in the Holy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Spirit we're immersed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the church is born of Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All religion is dispersed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Spirit, in the Spirit—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers, this is all we need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the church must be in Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not in teaching, form, or creed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The communion of the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the fellowship we share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the brothers, all the sisters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only for the Spirit care."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the Spirit in the churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks to those who have an ear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seven Spirits for the churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are our blessed portion here."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Come and drink the living water,\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Say the Spirit and the Bride—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Church and Spirit speak together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Utterly identified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just according to the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must be our reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just the Spirit in the churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Lord's recovery."
            }
          ]
