              "chord": "",
              "text": "That we may share Thee thus."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The portion is the cup divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Composed of Jesus’ blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This cup of blessing we receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And gain what is of God."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We eat of Thee, the Bread of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By sharing here this bread;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we remember Thee in love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Thyself are fed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We all enjoy the blessings gained"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By drinking of this cup;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we remember Thee with joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we are taken up."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By feasting on this bread and cup"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy death we now declare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And testify Thou art our life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all we daily share."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re waiting for that glorious hour,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When in the fullest way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll feed on Thee and feast with Thee"
            }
          ]
        },
