    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀召会为神所有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纯洁无瑕何神圣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭神生命活神性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "窄门狭路灵中行。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照神旨意生活事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "伟大成就非我望；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭着祷告、那灵与话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同工同前往。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何其怜悯，我们得以"
            }
          ]
