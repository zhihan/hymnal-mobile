        {
          "segments": [
            {
              "chord": "",
              "text": "一生作你独特子民；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你恢复我们全倾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "紧紧跟随不稍偏离。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终极异象管制规律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "枉费一切为你身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同奔赛程神旨得成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀新妇迎你再临！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "独一之神独一心意，"
            }
          ]
        },
