              "chord": "",
              "text": "必知主心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一脱离自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纯洁又安息。"
            }
          ]
        }
