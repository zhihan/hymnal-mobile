    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要思想耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天都如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要自甘卑微，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再有大志；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那无穷生命"
            }
          ]
        },
        {
          "segments": [
