              "chord": "",
              "text": "也要多认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠复活大能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历主的死。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要思想耶稣，"
            }
          ]
        },
        {
          "segments": [
