      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要思想耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你在向前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要一直向上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瞻仰祂荣面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必荣上加荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变成祂形状，"
            }
          ]
        },
        {
