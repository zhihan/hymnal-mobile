  "raw_sections": [
    "用 功朝 見主面，",
    "多和 主對講，",
    "常 住在 祂裡面，",
    "以祂 話為糧。",
    "等 候在 祂面 前，",
    "柔 順且 降服，",
    "每件 事上不忘",
    "尋求 祂祝福。",
    "用功朝见主面，",
    "事务虽忙碌；",
    "多花时间单独",
    "和主在密处。",
    "借着仰望耶稣，",
    "你变祂形像；",
    "在你行为之上，",
    "人见祂模样。",
    "用功朝见主面，",
    "让祂作领导；",
    "任何事情发生，",
    "不在祂前跑；",
    "无论是乐是苦，",
    "始终跟随主，",
    "始终相信祂话，",
    "常仰望耶稣。",
    "用功朝见主面，",
    "内心须宁静；",
    "让祂前来管理",
    "意念和性情。",
    "祂灵把你带到",
    "爱的发源所，",
    "如此你才配作",
    "属天的工作。"
  ]
}