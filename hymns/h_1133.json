    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O show me that Christ is the hope of Thy call—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O glorious hope, Christ will fill all in all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reveal Him—the riches of glory in us—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As God’s own inheritance. How glorious!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God of our Lord Jesus, let me perceive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th’ exceeding great pow’r unto us who believe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The power that raised Christ, Thy Son, from the dead"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And made Him o’er all, to His Body, the Head."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, Thou hast wrought all this pow’r into Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who now lives in me as my Person, my life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O grant revelation, dear Father, to see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This transcending pow’r is a Person in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Christ is the hope, He’s the glory and power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So Christ I must take as my Person each hour."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then in me such power will be exercised,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My hope and God’s glory will be realized."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
