              "text": "Thou hearts alone wouldst move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou only hearts dost love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would love Thee as Thou lov’st me,"
            }
          ]
        },
