              "text": "O Jesus most desired."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What off’ring can I make,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, to love like Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou, the Word, didst stoop to take"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A human form like mine?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Give Me thy heart, My son”:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou my heart hast won;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would love Thee as Thou lov’st me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus most desired."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heart is opened wide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its offered love most free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That heart to heart I may abide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And hide myself in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ah, how Thy love doth burn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till I that love return!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would love Thee as Thou lov’st me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus most desired."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here finds my heart its rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Repose that knows no shock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The strength of love that keeps it blest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee, the riven Rock."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart, as girt around,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her citadel hath found;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would love Thee as Thou lov’st me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus most desired."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
