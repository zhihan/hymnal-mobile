    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis not enough to save our souls,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To shun th’ eternal fires;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thought of God will rouse the heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To more sublime desires."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God only is the creature’s home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though rough and straight the road;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet nothing less can satisfy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love that longs for God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, utter but the Name of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Down in your heart of hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And see how from the world at once"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All tempting light departs."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A trusting heart, a yearning eye,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can win their way above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If mountains can be moved by faith,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is there less power in love?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How little of that road, my soul!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How little hast thou gone!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take heart, and let the thought of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Allure thee further on."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The freedom from all willful sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian’s daily task;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! these are graces far below"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What longing love would ask!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The perfect way is hard to flesh;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not hard to love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If thou wert sick for want of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How swiftly wouldst thou move!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then keep thy conscience sensitive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No inward token miss:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And go where grace entices thee—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfection lies in this."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
