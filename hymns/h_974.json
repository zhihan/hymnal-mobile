    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He looked for a city, his God should prepare;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No mansion on earth, could he covet or share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For had not God told him, that royal abode"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Awaited His pilgrims on ending the road."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "City! O city fair!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s dwelling with man to eternity is there."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He looked for a city; if sometimes he sighed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be trudging the road, all earth’s glory denied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thought of that city changed sighing to song,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the road might be rough, but it could not be long."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "City! O city fair!"
