{
  "url": "https://www.hymnal.net/cn/hymn/ch/160",
  "title": "哦主你是神的见证",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 是 神"
            },
            {
              "chord": "G",
              "text": "的 見"
            },
            {
              "chord": "",
              "text": "證，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遠"
            },
            {
              "chord": "D",
              "text": "非 律"
            },
            {
              "chord": "A7",
              "text": "法 能"
            },
            {
              "chord": "D",
              "text": "比；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "律 法 不 過 是"
            },
            {
              "chord": "G",
              "text": "你 小"
            },
            {
              "chord": "",
              "text": "影，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "是 律"
            },
            {
              "chord": "A7",
              "text": "法 實"
            },
            {
              "chord": "D",
              "text": "際。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "律"
            },
            {
              "chord": "A",
              "text": "法 僅"
            },
            {
              "chord": "A7",
              "text": "是 神"
            },
            {
              "chord": "D",
              "text": "的 說"
            },
            {
              "chord": "",
              "text": "明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "描"
            },
            {
              "chord": "E7",
              "text": "述 神"
            },
            {
              "chord": "",
              "text": "是 如"
            },
            {
              "chord": "A7",
              "text": "何；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而"
            },
            {
              "chord": "D",
              "text": "你 乃"
            },
            {
              "chord": "",
              "text": "是 神"
            },
            {
              "chord": "G",
              "text": "的 實"
            },
            {
              "chord": "",
              "text": "際，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "D",
              "text": "在 你"
            },
            {
              "chord": "A7",
              "text": "裡 住"
            },
            {
              "chord": "D",
              "text": "著。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "约柜也是你的豫表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其中仅有律法；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你里面有神自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着一切安家。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "约柜乃用坚实木料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上面包金而造；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫表你有正确人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并有神性相调。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是那真实帐幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有神住你里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你成肉身，与人同住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有真理、恩典。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你人见神的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的活话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你凭光、爱所有言行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神活的图画。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣殿也是你的豫表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的真殿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神带一切居住于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你得着彰显。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但虽尽其力拆毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你置于死地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你却在复活里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更大之殿建起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城象征你的丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你新妇小影；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是你的丰满扩充，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出于你的丰盛。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在你里作城的光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是城中明灯；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带神经她照亮众人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神荣耀显明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，帐幕、约柜、律法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以及圣殿、圣城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都是你宝贵自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说出你的丰盛。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "中心是你，圆周是你、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切全都是你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人全都在你一身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心宝爱、称奇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "赞美主",
