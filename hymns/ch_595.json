{
  "url": "https://www.hymnal.net/cn/hymn/ch/595",
  "title": "教会乃是基督器皿",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "召 會"
            },
            {
              "chord": "",
              "text": "乃 是 基"
            },
            {
              "chord": "A",
              "text": "督 器"
            },
            {
              "chord": "D",
              "text": "皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將 祂 盛 裝， 將"
            },
            {
              "chord": "E",
              "text": "祂"
            },
            {
              "chord": "E7",
              "text": "彰"
            },
            {
              "chord": "A",
              "text": "顯；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "猶 如"
            },
            {
              "chord": "",
              "text": "人 的 血"
            },
            {
              "chord": "D",
              "text": "肉 身"
            },
            {
              "chord": "A",
              "text": "體，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "人"
            },
            {
              "chord": "D",
              "text": "在 其"
            },
            {
              "chord": "",
              "text": "中 得"
            },
            {
              "chord": "A",
              "text": "著"
            },
            {
              "chord": "A7",
              "text": "表"
            },
            {
              "chord": "D",
              "text": "現。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如同圣殿之于约柜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是其容器、安息之所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会乃是基督住处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内容基督在她住着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是神的奥秘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神解说，将神表现；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会也是基督奥秘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂言明，将祂彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督召会所有肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原都属于泥土之类；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以需要重生变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变为透明，成为宝贵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着变化同被建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来作基督透明器皿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盛装基督所有丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将祂一切显于人群。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神合作同工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完成所有变化工作；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会得成团体器皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同圣城作神居所。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此召会何其宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各方都是透明、透亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "盛装基督和神丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照出基督和神荣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神作亮光，主作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵作活的生命水流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神由她彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显于万有直到永久！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
