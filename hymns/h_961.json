    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saint after saint on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has lived, and loved, and died;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as they left us one by one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We laid them side by side;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We laid them down to sleep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But not in hope forlorn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We laid them but to ripen there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till the last glorious morn."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The serpent’s brood increase,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The powers of hell grow bold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The conflict thickens, faith is low,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love is waxing cold."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How long, O Lord our God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy, and true, and good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wilt Thou not judge Thy suffering Church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her sighs, and tears, and blood?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We long to hear Thy voice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To see Thee face to face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To share Thy crown and glory then,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As now we share Thy grace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should not the loving bride"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her absent bridegroom mourn?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should she not wear the signs of grief"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until her Lord return?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The whole creation groans,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And waits to hear that voice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That shall her beauteousness restore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make her wastes rejoice."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, Lord, and wipe away"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The curse, the sin, the stain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make this blighted world of ours"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own fair world again."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
