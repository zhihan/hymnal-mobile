            },
            {
              "chord": "D7",
              "text": "pierced"
            },
            {
              "chord": "G",
              "text": "hands;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Points to the wounded feet and"
            },
            {
              "chord": "C",
              "text": "side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
