      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What food luxurious loads the board"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When, at His table, sits the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wine how rich, the bread how sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus deigns the guests to meet!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If now, with eyes defiled and dim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We see the signs, but see not Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may His love the scales displace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bid us see Him face to face!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou glorious Bridegroom of our hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy present smile Thy grace imparts!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, lift the veil, if veil there be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let every saint Thy glory see!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
