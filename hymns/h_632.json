    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Gazing thus our sin we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Learn Thy love while gazing thus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sin which laid the Cross on Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love which bore the Cross for us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we learn to serve and give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And rejoicing, self deny;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we gather love to live;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we gather faith to die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Symbols of our liberty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our service here unite;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Captives, by Thy Cross set free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soldiers of Thy Cross, we fight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Pressing onwards as we can,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still to this our hearts must tend;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where our earliest hopes began,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There our last aspirings end."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Till amid the hosts of light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We in Thee redeemed, complete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Thy Cross made pure and white,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cast our crowns before Thy feet."
            }
          ]
        }
      ],
