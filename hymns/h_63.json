      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O loving wisdom of our God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When all was sin and shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He, the last Adam, to the fight"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to the rescue came."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O wisest love! that flesh and blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which did in Adam fail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should strive afresh against the foe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should strive and should prevail."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And that a higher gift than grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should flesh and blood refine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s presence, and His very self"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And essence all-divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O generous love! that He, who smote"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In man for man the foe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The double agony in man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For man should undergo."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the garden secretly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And on the cross on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should teach His brethren, and inspire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To suffer and to die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise to the Holiest in the height,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the depth be praise:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all His words most wonderful;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Most sure in all His ways."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
