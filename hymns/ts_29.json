          "chord": "",
          "text": "此心坚定不移；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"狮子羔羊\"揭奥秘，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们赞美不已！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "长老、活物齐俯伏，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "座前敬拜歌唱；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "赞美昼夜不歇息，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "都归\"狮子羔羊\""
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们和声同响应，"
        }
      ]
    },
