      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise Him! praise Him! Jesus, our blessed Redeemer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our sins He suffered and bled and died;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He, our Rock, our Hope of eternal salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hail Him! hail Him! Jesus, the Crucified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving Savior, meekly enduring sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crowned with thorns that cruelly pierced His brow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once for us rejected, despised, and forsaken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prince of Glory, ever triumphant now."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise Him! praise Him! Jesus, our blessed Redeemer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heavenly portals, loud with hosannahs ring!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Savior, reigneth for ever and ever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crown Him! crown Him! Prophet and Priest and King!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death is vanquished! Tell it with joy, ye faithful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where is now thy victory, boasting grave?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus lives! No longer thy portals are cheerless;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus lives, the mighty and strong to save."
            }
          ]
        }
