{
  "url": "https://www.hymnal.net/cn/hymn/ch/156",
  "title": "恩主你是公义太阳",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "恩 主，"
            },
            {
              "chord": "",
              "text": "你 是 公"
            },
            {
              "chord": "G",
              "text": "义 太"
            },
            {
              "chord": "D",
              "text": "阳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "富 有 医 治 光"
            },
            {
              "chord": "A7",
              "text": "线；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "的 荣"
            },
            {
              "chord": "",
              "text": "耀 面"
            },
            {
              "chord": "G",
              "text": "光 照"
            },
            {
              "chord": "D",
              "text": "临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带"
            },
            {
              "chord": "G",
              "text": "来 生"
            },
            {
              "chord": "A",
              "text": "命、"
            },
            {
              "chord": "A7",
              "text": "平"
            },
            {
              "chord": "D",
              "text": "安。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "慈爱神的怜悯心肠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫你临到我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要照亮坐在黑暗"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死荫之中的人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对我你像无云清晨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又如日出晨光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们乃像地上嫩草，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你光线生长。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩光带着可爱光线，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "扩增犹如天曙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面越照越明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至中天日午。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "清明光线照透苦难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如雨后晴光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着你的怜悯、慈爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不停止照亮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是明亮晨星，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我儆醒赏赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照亮那些爱你之人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正当黑暗深时。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我爱慕你光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我眼光清明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "儆醒、祷告、等候你来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如等候晨星。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
