        {
          "segments": [
            {
              "chord": "D",
              "text": "我 主"
            },
            {
              "chord": "A",
              "text": "耶"
            },
            {
              "chord": "D",
              "text": "穌，"
            },
            {
              "chord": "A",
              "text": "惟 你"
            },
            {
              "chord": "Bm",
              "text": "是 配，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "來"
            },
            {
              "chord": "B",
              "text": "得"
            },
            {
              "chord": "Em",
              "text": "永"
            },
            {
              "chord": "A",
              "text": "遠"
            },
            {
              "chord": "D",
              "text": "的 讚"
            },
            {
              "chord": "A",
              "text": "美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "因 你"
            },
            {
              "chord": "A",
              "text": "愛 心、"
            },
            {
              "chord": "D",
              "text": "恩"
            },
            {
              "chord": "G",
              "text": "典、"
            },
            {
              "chord": "D",
              "text": "慈"
            },
            {
              "chord": "A",
              "text": "良，"
            }
          ]
