      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们满心感激不尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前来称颂你尊名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一生一世满被恩惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到处述说你宝贵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所拜的主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是何等的宽恕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的爱心像你能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永无限量永无已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣，你是首先、末后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要领我到尽头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因着已往我赞美你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着将来我靠你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞祂！赞祂！赞我恩人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣徒们哪，当高声！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞祂！赞祂！直到天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞得完全赞得长。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
