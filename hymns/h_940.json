    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While we pray for pard’ning grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the dear Redeemer’s name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Show Thy reconciled face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take away our sin and shame:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From our worldly cares set free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we rest this day in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we come Thy name to praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us feel Thy presence near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thy glory meet our eyes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While we in Thy house appear:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here afford us, Lord, a taste"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of our everlasting feast."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thy gospel’s joyful sound"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conquer sinners, comfort saints;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make the fruits of grace abound,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring relief for all complaints:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus may all our Lord’s Days prove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we meet the Lord above."
            }
          ]
        }
      ],
