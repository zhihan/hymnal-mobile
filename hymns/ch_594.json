      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "夏娃乃是亚当一部，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出自于亚当；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会也是基督扩增，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出于祂肋旁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一粒麦子落地死了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结出许多粒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "许多子粒磨粉相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就成为一体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照样基督死而复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也得了繁生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "许多信徒成为一身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来将祂表明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄树的许多枝子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是树开展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与树合一，住树里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结果显丰满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照样，基督许多肢体"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是祂扩大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂成一，活在祂里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂得发达。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "繁殖、扩增、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "开展、普及、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长大与表现、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复本、再世、继续、富馀、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "扩大与丰满："
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是召会之于基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神得荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂所救赎的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远来显照。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是基督与祂召会－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的大奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是神性与我人性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "相调成为一。"
            }
          ]
        }
      ],
