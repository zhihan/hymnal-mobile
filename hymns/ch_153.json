{
  "url": "https://www.hymnal.net/cn/hymn/ch/153",
  "title": "主你是我照护侍从",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "是 我 照"
            },
            {
              "chord": "E",
              "text": "护 侍"
            },
            {
              "chord": "A",
              "text": "从，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "E",
              "text": "是 我"
            },
            {
              "chord": "B7",
              "text": "保 惠"
            },
            {
              "chord": "E",
              "text": "师；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "又 是"
            },
            {
              "chord": "",
              "text": "我 诚"
            },
            {
              "chord": "D",
              "text": "信 中"
            },
            {
              "chord": "E",
              "text": "保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "A",
              "text": "前 为"
            },
            {
              "chord": "E",
              "text": "我"
            },
            {
              "chord": "E7",
              "text": "办"
            },
            {
              "chord": "A",
              "text": "事。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的辩护顾问，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是我辩护者；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我凡事的代祷者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是我帮助者。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你照着神所喜悦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我办理一切；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在天上，又在我里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事为我解决。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃是那内住之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常为我代祷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上辩护，我里叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代我向神求告。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "永远活着，照神旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "施恩、帮助惟殷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着复活生命大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加强里面的人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那赐生命之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常顾我软弱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵中，用你大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我凭你活着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借你爱怜，以你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远服事、眷念；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好使你作我们一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们作你丰满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
