            {
              "chord": "D",
              "text": "有 一"
            },
            {
              "chord": "",
              "text": "人， 有 一 人， 宝 座 上 坐"
            },
            {
              "chord": "Em",
              "text": "著；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有 一 人，"
            },
            {
              "chord": "Em7",
              "text": "作 先"
            },
            {
              "chord": "",
              "text": "锋，"
            },
            {
              "chord": "A7",
              "text": "道 路"
            },
            {
              "chord": "",
              "text": "已 开"
            },
            {
              "chord": "D",
              "text": "拓；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这 人 子 是 耶 稣， 我 们 乐 追"
            },
            {
              "chord": "G",
              "text": "随；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "祂 已"
            },
            {
              "chord": "",
              "text": "得 胜，"
            },
            {
              "chord": "D",
              "text": "我 们"
            },
            {
              "chord": "G",
              "text": "与 祂"
            },
            {
              "chord": "D",
              "text": "同"
            },
            {
              "chord": "A7",
              "text": "登"
            },
            {
              "chord": "D",
              "text": "位。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "向上去，向上去，与祂同登极；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向上去，经罪世，胜黑暗忧悒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但虽将人掳，我们得释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且必同主高升，宝座上为王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同蒙召，同蒙召，命定作君王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同蒙召，成后嗣，世界甘埋葬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我们岂够格，配得这命定？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主搜寻、焚烧，将我全炼净。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来搜寻，来搜寻，焚烧我内心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来搜寻，来焚烧，渣滓都除尽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毋畏惧，毋退缩，当清楚看见："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此搜寻、焚烧乃是主恩眷。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一道虹，一道虹，显人子周围；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一道虹，在宣告，信实永不颓："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神审判厉如火，我本当遭祸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟蒙赦宥，前来赞祂恩深阔。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
