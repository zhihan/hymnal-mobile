{
  "url": "https://www.hymnal.net/en/hymn/h/78",
  "title": "Gracious Lord, Thy name I AM is",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D7",
              "text": "Gracious"
            },
            {
              "chord": "G",
              "text": "Lord, Thy"
            },
            {
              "chord": "",
              "text": "name \"I"
            },
            {
              "chord": "D",
              "text": "AM\" is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious"
            },
            {
              "chord": "G",
              "text": "name, how"
            },
            {
              "chord": "C",
              "text": "rich and"
            },
            {
              "chord": "D",
              "text": "full 'tis,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All- in"
            },
            {
              "chord": "G",
              "text": "clusive,"
            },
            {
              "chord": "",
              "text": "faithful"
            },
            {
              "chord": "C",
              "text": "too 'tis—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "All we"
            },
            {
              "chord": "G",
              "text": "need,"
            },
            {
              "chord": "D7",
              "text": "Thou"
            },
            {
              "chord": "G",
              "text": "art!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the Son, the Father in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit now indwell me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the riches of Thyself we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May experience."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the Temple for God’s dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the Father’s life e’er telling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We in Thee with joy excelling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face to face see Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the Lamb and Thou the Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the bride Thou sufferedst sin’s doom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wounded, crucified in our room;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we find our rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art wisdom and the way, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou our lives dost plan each day, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace to us Thou dost convey, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy path to walk."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Pure and holy, righteous Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with God, well-pleasing His heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou within to us dost impart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Harmony with God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art life and Thou art light, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death hast swallowed, banished night, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast quickened, given sight, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are now set free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art resurrection power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the conqu’ror in hell’s hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost us with might empower"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Over all to reign."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Living water, food supply, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Thyself art, and didst die, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our want to satisfy, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we feast on Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the Shepherd and Physician,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast healed our sick condition;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Comfort, guide, protect—Thy mission;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost care for us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Priest and King Thou art fore’er, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into God we’re brought, and there, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine authority we share, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What an honored place!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou our Hope and our Redemption,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt change our old creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make of Thee a duplication,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus Thyself express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou our Joy, our Peace, our Glory;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Truth, and Grace, the Rock, the Life-tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Building, Mountain, Sun, and Shield—we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er can tell it all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What Thou art—eternal, boundless,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full and perfect, rich, exhaustless—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meets our need to utter fullness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from us o’erflows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    }
  ],
