    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I once was an out-cast stranger on earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A sinner by choice, and an alien by birth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But I’ve been adopted, my name’s written down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An heir of salvation, the kingdom and crown."
            }
          ]
        }
