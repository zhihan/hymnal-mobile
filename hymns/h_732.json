    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Father’s own Son, the Savior of men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once wandered on earth as the poorest of them."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now He is pleading our pardon on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be His when He comes by and by."
            }
          ]
        }
