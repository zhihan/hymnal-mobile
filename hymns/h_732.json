    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though poor on this earth, oh, why should I care?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since glorious things for me God doth prepare;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though trials abound, yet, still I may sing:"
