    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日去世复有何恐？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为恩主已救我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但一想到双手空空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愁云立即覆我额！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我岂可以空手见主？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂可双手空空去？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未领一人来归基督！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂可双手空空去？"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前犯罪所废岁月，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "假若现在能赎回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我必完全奉献无缺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乐行主旨不再违。"
            }
          ]
        }
