{
  "url": "https://www.hymnal.net/cn/hymn/ts/310",
  "title": "单单爱你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "快 乐 日，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当"
            },
            {
              "chord": "D7",
              "text": "我 已"
            },
            {
              "chord": "",
              "text": "经 别"
            },
            {
              "chord": "G",
              "text": "无 他"
            },
            {
              "chord": "",
              "text": "途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当 主 夺 取 我"
            },
            {
              "chord": "D",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从 无 边 黑 暗"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进"
            },
            {
              "chord": "A",
              "text": "入 祂"
            },
            {
              "chord": "A7",
              "text": "光 明"
            },
            {
              "chord": "",
              "text": "的 国"
            },
            {
              "chord": "D",
              "text": "度。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我新生开始，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这新生命是神爱子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不再为幻梦"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而如醉如痴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因活泉涌流我深处！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我转向祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就供应祂的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂生命成为"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我人生的实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，阿利路亚在我里！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我单单爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其他的爱求你烧去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从现今到永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我一切的一切。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
