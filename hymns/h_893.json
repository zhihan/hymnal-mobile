    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Trials more bitter grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fighting doth enlarge;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hell's forces rally all their pow'rs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And gather for the charge."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet while we wait and watch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And feel the war severe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We hear the joyful song ring out,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the Lord, is near!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis harder at the end"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The word to testify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Satan fights with all his pow'r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our witness to defy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Much greater strength we need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The foe to overcome;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How happy when the Lord we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all our sighing's done!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who then will forward go"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strong in His mighty power?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who then will firmly trust the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the vict'ry hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till with the conqu'rors blest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The triumph song's begun?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man will then rejoice to hear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold, I quickly come!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who then will choose God's best,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And take the narrow track,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though passing thru the wildest storms,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet never turning back?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who now will dare press on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enduring pain and fear?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All such will then rejoice to see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the Lord, is near!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though deep the darkness be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We still would onward go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we the day of rapture greet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And glory 'round shall glow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis there we'll see the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Satan overcome;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The overcomers will rejoice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the Lord, has come!"
            }
          ]
        }
