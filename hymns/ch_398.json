    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在天上坐在"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父神的右边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我作大祭司"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将血献神前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在天作我中保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "担负我重担，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭祂爱心、忠诚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "办理我案件。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是生命之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在我灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此作我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有且带同；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我内心力量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩惠时供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我里面侍从，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "维持以大能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在天上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我作一得荣人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我开路先锋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "幔内显荣身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在那属天境地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以祂的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将人带到神里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人、神得成一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在我里使我"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有分神丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃那灵将神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带到我里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着启示，使神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之中，神、人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "相调成为一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "升天客观救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今住高天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久祂要归回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众目得观赏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内住主观基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今活我灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久祂要显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "改变我贱体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "日子不久要到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地要结联，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在新圣城撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人再无间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在那荣耀时日，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "客观与主观"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我相调为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全又永远。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
