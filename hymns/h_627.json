    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I “glory in the Cross” most loving Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because I know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the power to save and satisfy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where’er I go."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The daily Cross becomes the deepest joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For just beyond"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Cross, I clearly see how Cross and Crown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do correspond."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, gracious Lord, how sweet to take from Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The daily Cross!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And know that I can never separate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its gain and loss."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The daily Cross is daily loss to all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That keeps from Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The daily Cross is daily gain of all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art for me."
            }
          ]
        }
