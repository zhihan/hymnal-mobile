          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就有信徒在流浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何必到处寻找失迷羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当劝勉、挽回、安慰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "体贴主心肠，"
