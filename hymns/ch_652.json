    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘你们的光当照人前，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是主命令，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们应当遵从莫掩藏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一个罪人弃暗就光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也需人引领，"
            }
          ]
        },
        {
          "segments": [
            {
