{
  "url": "https://www.hymnal.net/cn/hymn/ch/529",
  "title": "当日神在伊甸园中",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "当 日"
            },
            {
              "chord": "",
              "text": "神 在 伊"
            },
            {
              "chord": "G",
              "text": "甸 园"
            },
            {
              "chord": "D",
              "text": "中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将 人 置"
            },
            {
              "chord": "A",
              "text": "于 二"
            },
            {
              "chord": "A7",
              "text": "树 之"
            },
            {
              "chord": "D",
              "text": "前："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 生 命 树 指"
            },
            {
              "chord": "A",
              "text": "明 自"
            },
            {
              "chord": "D",
              "text": "己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "以 知"
            },
            {
              "chord": "",
              "text": "识"
            },
            {
              "chord": "D",
              "text": "树 表"
            },
            {
              "chord": "A",
              "text": "明"
            },
            {
              "chord": "A7",
              "text": "撒"
            },
            {
              "chord": "D",
              "text": "但。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命树乃神的中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照神永远计画所定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是要在基督里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给人接受，作人生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "知识树是神的警告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "题示神外另有源头："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恶者撒但，死亡渊薮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人若接触，死亡必受。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之树人肯接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人必得着神作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且必变成珍贵宝石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的心愿借此完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "知识一树人若接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但必得进人里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为罪恶，带进死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神计画难得成全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是表明只有神是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们生命惟一源头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着神外一切事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是摸着死亡之由。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "知识不过带来死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽管外观是善非恶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神之外任何事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是撒但施计之所。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不只恶与基督相对，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是善也与祂相抵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡属知识不拘善恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都与生命相反不一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，教我们惟独摸你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫我们被你充满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你外事物概不接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对恶如此，对善亦然。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
  "metadata": {
    "category": "里面生命的各方面",
