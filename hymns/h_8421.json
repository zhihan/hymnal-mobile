    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I could not do without Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For oh! the way is long,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I am often weary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sigh replaces song."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How could I do without Thee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I do not know the way!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou knowest, and Thou leadest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And wilt not let me stray."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I could not do without Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus, Saviour dear!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en when my eyes are holden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know that Thou art near."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How dreary and how lonely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This changeful life would be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without the sweet communion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secret rest with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I could not do without Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No other friend could read"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The spirit’s strange deep longing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Interpreting its need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No human heart could enter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each dim recess of mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And soothe and hush and calm it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O blessèd  Lord, but Thine!"
            }
          ]
        }
      ],
