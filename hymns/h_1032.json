    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, ye needy, come and welcome;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's free bounty glorify;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True belief and true repentance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every grace that brings us nigh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without money, without money,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come to Jesus Christ and buy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let not conscience make you linger,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor of fitness fondly dream;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the fitness He requireth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to feel your need of Him:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This He gives you, this He gives you,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis the Spirit's rising beam."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, ye weary, heavy laden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lost and ruined by the fall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If you tarry till you're better,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You will never come at all:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the righteous, not the righteous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinners Jesus came to call."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Agonizing in the garden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Redeemer prostrate lies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the bloody tree behold Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hear Him cry, before He dies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"It is finished!\" \"It is finished!\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinner, will not this suffice?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo! th' incarnate God, ascended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pleads the merit of His blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Venture on Him, venture wholly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let no other trust intrude:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None but Jesus, none but Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can do helpless sinners good."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
