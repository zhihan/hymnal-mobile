  "title": "主当我们借着这水",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 当"
            },
            {
              "chord": "",
              "text": "我 们"
            },
            {
              "chord": "A",
              "text": "藉"
            },
            {
              "chord": "D",
              "text": "著 这"
            },
            {
              "chord": "",
              "text": "水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承 认 同 死 事"
            },
            {
              "chord": "A",
              "text": "实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "求"
            },
            {
              "chord": "D",
              "text": "你 在"
            },
            {
              "chord": "",
              "text": "此"
            },
            {
              "chord": "G",
              "text": "怜"
            },
            {
              "chord": "D",
              "text": "悯 施"
            },
            {
              "chord": "",
              "text": "惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启"
            },
            {
              "chord": "A",
              "text": "示 它"
            },
            {
              "chord": "A7",
              "text": "的 价"
            },
            {
              "chord": "D",
              "text": "值。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这水归入你死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你一同埋葬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们永远离罪若失，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离罪的捆绑。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这水归入你死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你一同埋葬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就此与世长辞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离今世君王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此与你一同复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离死亡权势；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你结出成圣美果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活出新生样式。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此受浸归于你名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再属于自己；"
            }
          ]
        },
