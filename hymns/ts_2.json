            },
            {
              "chord": "A",
              "text": "抵"
            },
            {
              "chord": "A7",
              "text": "挡"
            },
            {
              "chord": "D",
              "text": "主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "『我 们 挣 开"
            },
            {
              "chord": "A",
              "text": "一 切"
            },
            {
              "chord": "A7",
              "text": "捆 绑，"
            },
            {
              "chord": "D",
