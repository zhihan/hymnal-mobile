            },
            {
              "chord": "",
              "text": "谋 算 虚 妄"
            },
            {
              "chord": "A7",
              "text": "事；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "君 王"
            },
            {
              "chord": "D7",
              "text": "臣 宰"
            },
            {
              "chord": "G",
              "text": "起 来"
            },
            {
