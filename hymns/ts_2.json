{
  "url": "https://www.hymnal.net/cn/hymn/ts/2",
  "title": "当以嘴亲子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "看 哪，"
            },
            {
              "chord": "D7",
              "text": "地 上"
            },
            {
              "chord": "G",
              "text": "萬 民"
            },
            {
              "chord": "",
              "text": "聚 集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "一 同"
            },
            {
              "chord": "",
              "text": "謀 算 虛 妄"
            },
            {
              "chord": "A7",
              "text": "事；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "君 王"
            },
            {
              "chord": "D7",
              "text": "臣 宰"
            },
            {
              "chord": "G",
              "text": "起 來"
            },
            {
              "chord": "",
              "text": "商 議，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "同 聲"
            },
            {
              "chord": "",
              "text": "一 氣"
            },
            {
              "chord": "A",
              "text": "抵"
            },
            {
              "chord": "A7",
              "text": "擋"
            },
            {
              "chord": "D",
              "text": "主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "『我 們 掙 開"
            },
            {
              "chord": "A",
              "text": "一 切"
            },
            {
              "chord": "A7",
              "text": "捆 綁，"
            },
            {
              "chord": "D",
              "text": "脫"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去 他 們"
            },
            {
              "chord": "G",
              "text": "的 繩"
            },
            {
              "chord": "A7",
              "text": "索，』"
            },
            {
              "chord": "D",
              "text": "世 上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "君 王"
            },
            {
              "chord": "G",
              "text": "如 此"
            },
            {
              "chord": "",
              "text": "設 謀，"
            },
            {
              "chord": "D",
              "text": "抵 擋"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 並"
            },
            {
              "chord": "A",
              "text": "受"
            },
            {
              "chord": "A7",
              "text": "膏"
            },
            {
              "chord": "D",
              "text": "者。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那坐天上的必发笑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主必定嗤笑他们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时祂在怒中责备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "烈怒中惊吓他们。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂的锡安圣山上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已膏祂的君王─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神自己的宣告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "警戒地上的诸王。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现今基督，神所膏者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传扬主神的旨意："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘你是我子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（在复活里），"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在今日生了你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我将列国都赐给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你承受为基业，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你显王权，手拿铁杖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将他们打破摔裂。’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们君王应当省悟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "审判官该受管教；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当存畏惧事奉我主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又存战兢而欢跃。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当以嘴亲子，消祂怒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得你道中灭亡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘投靠祂的是有福的，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们同来欢唱！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，赞美神，我们看见"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你独一受膏之子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从虚妄中我们悔改，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在爱里亲你爱子。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘投靠祂的是有福的’─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非那‘遵守律法的；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要信靠那复活者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必蒙福永无已。"
            }
          ]
        }
      ]
    }
  ],
