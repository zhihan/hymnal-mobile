      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那坐天上的必发笑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主必定嗤笑他们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时祂在怒中责备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "烈怒中惊吓他们。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂的锡安圣山上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已膏祂的君王─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神自己的宣告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "警戒地上的诸王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现今基督，神所膏者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传扬主神的旨意："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘你是我子"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（在复活里），"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在今日生了你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我将列国都赐给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你承受为基业，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你显王权，手拿铁杖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将他们打破摔裂。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们君王应当省悟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "审判官该受管教；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当存畏惧事奉我主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又存战兢而欢跃。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当以嘴亲子，消祂怒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得你道中灭亡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘投靠祂的是有福的，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们同来欢唱！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，赞美神，我们看见"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你独一受膏之子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从虚妄中我们悔改，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在爱里亲你爱子。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘投靠祂的是有福的’─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非那‘遵守律法的；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要信靠那复活者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必蒙福永无已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
