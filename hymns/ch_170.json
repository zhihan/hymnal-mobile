{
  "url": "https://www.hymnal.net/cn/hymn/ch/170",
  "title": "恩主我心对你所爱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "恩 主，"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "心 对"
            },
            {
              "chord": "",
              "text": "你 所"
            },
            {
              "chord": "D",
              "text": "爱、"
            },
            {
              "chord": "A7",
              "text": "所"
            },
            {
              "chord": "D",
              "text": "宝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "G",
              "text": "此， 我"
            },
            {
              "chord": "D",
              "text": "口 都"
            },
            {
              "chord": "A",
              "text": "要 欢"
            },
            {
              "chord": "E7",
              "text": "乐 发"
            },
            {
              "chord": "A",
              "text": "表；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "这 复"
            },
            {
              "chord": "Bm",
              "text": "活， 作"
            },
            {
              "chord": "G",
              "text": "我 福"
            },
            {
              "chord": "B",
              "text": "分 的"
            },
            {
              "chord": "Em",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "现"
            },
            {
              "chord": "A7",
              "text": "今 我"
            },
            {
              "chord": "D",
              "text": "要"
            },
            {
              "chord": "Bm",
              "text": "向"
            },
            {
              "chord": "G",
              "text": "你 献"
            },
            {
              "chord": "A7",
              "text": "上 称"
            },
            {
              "chord": "D",
              "text": "祝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此，你给我们再次尝到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的同在何其可爱、可宝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你荫下我们欢乐、安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的美果我们饱尝不已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾孤单，直至落到死地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像粒麦子结出许多子粒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着复活生出许多弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你一切我们都能与共。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你今作了我们一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面我们一无所缺；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已满足我们所有需要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心感铭，我口永要称道。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
