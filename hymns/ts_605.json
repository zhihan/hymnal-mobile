        {
          "chord": "",
          "text": "为建造！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "凡事长进联元首，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "百节相助功用调，"
