      "segments": [
        {
          "chord": "",
          "text": "为建造！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "相互宽容过得去，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "存心忍耐吃得消，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "竭力保守那灵一─"
        }
      ]
