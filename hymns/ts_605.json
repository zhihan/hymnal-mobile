    {
      "segments": [
        {
          "chord": "",
          "text": "为建造！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为建造！为建造！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "放下成见与爱好，"
