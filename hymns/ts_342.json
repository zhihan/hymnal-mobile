              "text": "与你同工等候被提。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "起来与你同往田间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "清晨流连葡萄园；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "风茄见证你我相联，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我结果佳美新鲜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你旨意，爱你所爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫备新妇趁现在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "殷勤劳苦，盼望等待，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良人哪，愿你快来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
