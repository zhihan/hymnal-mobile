    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "蓦然醒悟，失去你面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体里将你寻见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱作你华轿坐垫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我成你喜乐冠冕。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你召我上真理山岭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同你活在升天境；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心答应，我目送情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘心作你园、泉、井。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，在你与我爱的交通里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你天天吸引，呼召我脱自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我凡事与你是一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同工等候被提。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "听见柔声，要我开门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上前，你竟已转身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我述说可爱良人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真实同在又满魂。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你佳偶，全因你恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且带盼望如清晨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "书拉密女与所罗门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人调和永不分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，在你与我爱的交通里，"
            }
