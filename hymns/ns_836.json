    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s vessels kind would not forget"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This poor soul, most decried."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A God so real, through them I met;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I could no more deny."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Alone, distressed, from peace apart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I for God’s solace yearned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their tender love warmed up my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until it Godward turned."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O precious faith! O sweetest love!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O joy beyond compare!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life’s every turn God’s mercy proved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unfailing, secret care."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet God would know my dreams remained;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I craved what earthlings craved."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By mercy I God’s vision gained;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His goal my path re-paved."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en if I take the wings of dawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At ocean’s limits dwell*,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God faithful, wise, will lead me on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His searchings keep me well."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart o’erflows with songs of praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s mercy is my crown."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love a wretched soul embraced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transforms to glory-bound."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Go forth! Our Shepherd yearns that more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lost prodigals we’d find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into each wounded heart outpour"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh, timely oil and wine!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Search out the weak, the wayward, lost;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In meekness bring them home!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Warm, tender love they need the most"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s acceptance shown."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is pleased to build His home"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every contrite heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The feeble in His hand become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His warring counterpart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ will all Satan’s work efface"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through wisdom full and grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church will e’er His foe disgrace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To universal praise!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
