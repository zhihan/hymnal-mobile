            },
            {
              "chord": "C",
              "text": "self God's"
            },
            {
              "chord": "A7",
              "text": "Kingdom"
            },
            {
              "chord": "D7",
              "text": "grow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "G",
              "text": "thus ful"
            },
            {
              "chord": "C",
              "text": "fill th'e"
            },
            {
              "chord": "D7",
              "text": "ternal"
            },
            {
              "chord": "G",
              "text": "plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He was the only grain of wheat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whence many grains have been produced"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be the Kingdom’s children meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru whom God’s reign is introduced."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Satan, enemy of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sowed many tares among the wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom’s children to confuse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And awful damage to create."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this subtle work of his,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The mixing of the tares with wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom in appearance is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abnormal and grotesquely great."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Kingdom should as mustard be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A little herb, yet good for food,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But it has changed into a “tree,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A system of great magnitude."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Instead of being good for food,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A lodge of “birds” it has become:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis now a place where evil men"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And evil spirits make their home."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A great religion of the world"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its outward form to us reveals."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Including pagan, evil things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As leaven mingled with the meal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A system of the world as such,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It thus has changed in outward form;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By evil things which it imbibes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Corruption inwardly doth swarm."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But something hidden God doth seek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As “pearl” and “treasure in the field”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As such the Lord would us transform"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That pearl and treasure be revealed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis hidden from vast Christendom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from the Kingdom’s great facade,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in its full reality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis transformed like to Christ and God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, separate us from the “tares,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And save us from the monstrous “tree”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all the “leaven” purge us now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may purely be of Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thou in life transform our souls"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we as precious stones may be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meet for Thy house to build and in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Kingdom’s full reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    }
  ],
