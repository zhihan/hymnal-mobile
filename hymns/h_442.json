    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully surrendered—life, time, and all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thou hast given me held at Thy call."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak but the word to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly I’ll follow Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now and eternally"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Obey my Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully surrendered—silver and gold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His, who hath given me riches untold."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All, all belong to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou didst purchase me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine evermore to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, my Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully surrendered—Lord, I am Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully surrendered, Savior divine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live Thou Thy life in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All fullness dwells in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not I, but Christ in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ all in all."
            }
          ]
        }
      ],
