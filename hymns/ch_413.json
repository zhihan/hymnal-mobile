{
  "url": "https://www.hymnal.net/cn/hymn/ch/413",
  "title": "宝贝的救主",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "無 別"
            },
            {
              "chord": "",
              "text": "聲 音 破 此 靜"
            },
            {
              "chord": "G7",
              "text": "寂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "無 別"
            },
            {
              "chord": "C",
              "text": "蹤 跡"
            },
            {
              "chord": "",
              "text": "侵 擾 此"
            },
            {
              "chord": "G",
              "text": "光 景，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 有"
            },
            {
              "chord": "D",
              "text": "祂 美"
            },
            {
              "chord": "",
              "text": "麗、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寶 貝"
            },
            {
              "chord": "G",
              "text": "的 自"
            },
            {
              "chord": "",
              "text": "己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和"
            },
            {
              "chord": "A",
              "text": "祂 可"
            },
            {
              "chord": "A7",
              "text": "愛 的"
            },
            {
              "chord": "D",
              "text": "柔"
            },
            {
              "chord": "D7",
              "text": "聲。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "寶 貝"
            },
            {
              "chord": "G",
              "text": "的 救"
            },
            {
              "chord": "",
              "text": "主、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "親 愛"
            },
            {
              "chord": "D",
              "text": "的 耶"
            },
            {
              "chord": "",
              "text": "穌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可 否 求 你"
            },
            {
              "chord": "D7",
              "text": "向 我"
            },
            {
              "chord": "",
              "text": "說"
            },
            {
              "chord": "G",
              "text": "出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 曾 為 何"
            },
            {
              "chord": "B7",
              "text": "故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 究"
            },
            {
              "chord": "Em",
              "text": "是 何"
            },
            {
              "chord": "C",
              "text": "如，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "G",
              "text": "這 安"
            },
            {
              "chord": "",
              "text": "靜"
            },
            {
              "chord": "D7",
              "text": "屬 天"
            },
            {
              "chord": "G",
              "text": "處？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "安静之中有祂莅止，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂向我密语，深入我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带我进内室，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我表意思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说祂是我的爱人。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贝的救主、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱的耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可否求你向我说出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾为何故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你究是何如，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这安静属天处？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此就是属天圣境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不许有声音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切安静；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我喜乐来近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我渴求来饮"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你肯表露的爱情。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贝的救主、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱的耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可否求你向我说出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾为何故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你究是何如，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这安静属天处？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这俯伏安静之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我不敢稍动弹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恐有音失踪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恐有语落空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我失你爱的片段。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贝的救主、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱的耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可否求你向我说出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾为何故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你究是何如，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这安静属天处？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我魂，当息！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心，当足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已达到最高快乐间："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安卧你救主亲爱的胸府，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "注视祂的可爱面。"
            }
          ]
        }
      ]
    },
