{
  "url": "https://www.hymnal.net/cn/hymn/ch/10",
  "title": "哦神你是何超越",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 神，"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "是 何"
            },
            {
              "chord": "D",
              "text": "超 越，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 何 等 聖"
            },
            {
              "chord": "A",
              "text": "別！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "無"
            },
            {
              "chord": "D",
              "text": "何 能"
            },
            {
              "chord": "G",
              "text": "與 你"
            },
            {
              "chord": "D",
              "text": "並 列，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的 一"
            },
            {
              "chord": "E7",
              "text": "切 超"
            },
            {
              "chord": "A",
              "text": "絕！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "是 宇"
            },
            {
              "chord": "",
              "text": "宙 的"
            },
            {
              "chord": "G",
              "text": "至"
            },
            {
              "chord": "D",
              "text": "聖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 聖 中 之"
            },
            {
              "chord": "A",
              "text": "聖！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "的 永"
            },
            {
              "chord": "G",
              "text": "能 和"
            },
            {
              "chord": "D",
              "text": "神 性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遠"
            },
            {
              "chord": "A",
              "text": "超 萬"
            },
            {
              "chord": "A7",
              "text": "有、 眾"
            },
            {
              "chord": "D",
              "text": "生！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是圣而有分别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅无罪圣洁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅丝毫无残缺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且与完全有别。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能与你比拟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能与你攀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论以何代替你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是对你亵慢！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在优者之外优，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你与优者有别；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在秀者之外秀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "秀者与你难列。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你与善者也有别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你善乃是超绝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美者与你也难列，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你美也是超越。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣别乃是你特性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已赐给我们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那分别的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已经有分。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与你同超越，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因已与你同性；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们追随你圣别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得分别为圣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美你超越，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美你的圣别！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何能与你并列，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的一切超绝！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美你特性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经赐给我们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那分别的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已经有分。"
            }
          ]
        }
      ],
