    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But there’s a Person in my spirit now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Born as a babe so small, so weak, so low;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who by the Word’s pure milk will grow to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The overcoming inner man in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gain my heart."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ as my Person must possess my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be preeminent in every part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The former owner died but haunts it still."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, move in; my mind, emotion, will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now welcome Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit mingled, we are one, O Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The human and divine in one accord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou must have a proper faculty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thy glorious personality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May be expressed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So, Lord, I give my heart to Thee today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That it may be Thy home in every way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A place for Thee to come and settle down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thy grand recovery work to crown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In one new man."
            }
          ]
        }
