    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On thee at the creation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The light first had its birth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On thee, for our salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ rose from depths of earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On thee, our Lord, victorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit sent from heaven;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus on thee, most glorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A triple light was given."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Today on weary nations"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The heavenly manna falls!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To holy convocations"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The silver trumpet calls,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where gospel light is glowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With pure and radiant beams,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And living water flowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With soul-refreshing streams."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "New graces ever gaining"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From this of days the best,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We reach the rest remaining"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For people who are blest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Holy Ghost be praises,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Father and to Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church her voice upraises"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee, blest Three in One."
            }
          ]
        }
      ],
