            },
            {
              "chord": "A",
              "text": "Lord, in"
            },
            {
              "chord": "A7",
              "text": "all its"
            },
            {
              "chord": "D",
              "text": "length,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And breadth and"
            },
            {
              "chord": "G",
              "text": "fulness,"
            },
            {
              "chord": "",
              "text": "as my daily"
            },
            {
              "chord": "A",
              "text": "strength;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Into"
            },
            {
              "chord": "",
              "text": "life's future fearless"
            },
            {
              "chord": "E7",
              "text": "I may"
            },
            {
              "chord": "A",
              "text": "gaze,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "For, Savior,"
            },
            {
              "chord": "G",
              "text": "Thou art"
            },
            {
              "chord": "",
              "text": "with me"
            },
            {
              "chord": "A",
              "text": "all"
            },
            {
              "chord": "A7",
              "text": "the"
            },
            {
              "chord": "D",
              "text": "days."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Days may be coming fraught with loss and change,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New scenes surround my life and fancies strange;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I thank Thee that no day can ever break,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, when Thou wilt leave me or forsake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There may be days of darkness and distress,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When sin has power to tempt, and care to press,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in the darkest day I will not fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For, ’mid the shadows, Thou wilt still be near."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Days there may be of joy and deep delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When earth seems fairest, and her skies most bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then draw me closer to Thee, lest I rest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Elsewhere, my Savior, than upon Thy breast."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the other days that make my life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Marked by no special joy or grief or strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Days filled with quiet duties, trivial care,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burdens too small for other hearts to share;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Spend Thou these days with me, all shall be Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So shall the darkest hour with glory shine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then when these earthly years have passed away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me be with Thee in the perfect day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
