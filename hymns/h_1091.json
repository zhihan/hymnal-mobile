    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy blood has now been sprinkled on the throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In full redemption for Thy people’s sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sweetness of the love that Thou hast shown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has ris’n to fill the holiest place within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by the blood once offered in that place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God flows to us in mercy and in grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, Lord, Thou camest not just to atone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thou didst come and bear our sins away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, with a conscience purged, approach the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all our sins were laid on Thee that day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, separated from the Father’s face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Didst pay the awful price for us in grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The way into God’s presence thus is cleared,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For ransomed sinners who have heard Thy call."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, hast taken all that we had feared"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou didst shed Thy blood and give Thine all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our heart in grateful praise to Thee we bind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now our life in Thee alone we find."
            }
          ]
        }
      ]
    }
