      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It passeth telling, that dear love of Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior, Jesus; yet these lips of mine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would fain proclaim to sinners, far and near,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A love which can remove all guilty fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love beget."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It passeth praises, that dear love of Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior, Jesus; yet this heart of mine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would sing that love, so full, so rich, so free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which brings a rebel sinner, such as me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nigh unto God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But though I cannot sing, or tell, or know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fulness of Thy love, while here below,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My empty vessel I may freely bring;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Thou, who art of love the living spring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My vessel fill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I am an empty vessel—not one thought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or look of love to Thee I’ve ever brought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet I may come, and come again to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With this the empty sinner’s only plea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou lovest me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, fill me, Jesus, Savior, with Thy love!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lead, lead me to the living fount above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thither may I, in simple faith draw nigh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And never to another fountain fly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But unto Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, when Thee face to face I see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When on Thy lofty throne I sit with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then of Thy love, in all its breadth and length,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its height and depth, its everlasting strength,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My soul shall sing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
