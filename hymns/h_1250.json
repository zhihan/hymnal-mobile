    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We heard of it while yet far off,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We found it in the way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We then came up into her courts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And here we’ll ever stay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Arise, O Lord, into Thy rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou and Thy ark so strong."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy priests are clothed with righteousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy saints with joy and song."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord has sworn in truth to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will not turn away—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Seed shall sit with Him enthroned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And reign with Him for aye."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord hath found a place to dwell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hath chosen Zion fair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His habitation it will be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is His rest fore’er."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Her food abundant He will bless,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her needy, satisfy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with salvation clothe her priests,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all her want supply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The horn of David’s budding here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A lamp for earth’s dark night."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His enemies are clothed with shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His saints with crowns of light."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And now within these latter days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amidst earth’s dark unrest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s house is being built again"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all His people blessed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Secure within the local church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With saints in one accord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We meet to just release our praise,"
            }
          ]
        },
