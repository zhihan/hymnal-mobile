        {
          "segments": [
            {
              "chord": "",
              "text": "永勿再属你自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你自己全给基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全然属祂无所遗。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂曾舍己为要得你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今来要你全归祂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡祂所有都已给你，"
            }
          ]
        },
        {
