    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，只属于我主基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来何等的安息！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我所有全都不留，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰盛我能倚。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀恩主，将我接收，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我完全属于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "适合享受你作我分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我喜欢成你的。"
            }
          ]
        }
