    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，只属于我主基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来何等的安息！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我所有全都不留，"
            }
          ]
        },
        {
          "segments": [
