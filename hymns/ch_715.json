    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽然使主忧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂仍愿拯救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂忍耐，祂渴望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等你回头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽然拒不受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂仍在等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂等候你悔改，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "相信得救。"
            }
          ]
        }
