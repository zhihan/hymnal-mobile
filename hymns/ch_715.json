            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何不趁今天让主救你？"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主受死，把魔伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并将罪担当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又复活，升天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主作王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡废，生命彰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你可得释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何必再受捆绑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等待沦亡？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
