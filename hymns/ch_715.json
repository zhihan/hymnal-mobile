      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恶者手你安卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被任意加祸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽想，却不能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱他掌握；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他摆布，他弄捉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你受困惑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如鱼鸟被圈捕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "难逃网罗！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主渴望拯救你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主等候救你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何不趁今天让主救你？"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "残岁月，增却减！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人生像云烟！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能知，朝夕间"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不会消散？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死亡后，有审判！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地狱又紧联！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你如何能逃避"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永火烈焰？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
