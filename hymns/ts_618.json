          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一人有心伤，众人都流泪。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此相助相顾，全体同心合意，"
