              "chord": "",
              "text": "哦阿利路亚，事奉在一起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在主爱里，结合在一起，"
