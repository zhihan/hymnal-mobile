          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来到主面前，个个像活石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造为灵宫，祭司的体系。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着耶稣基督，奉献神喜灵祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦阿利路亚，事奉在一起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在主爱里，结合在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用爱心包容，用和平联系；"
