        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奉耶稣大名，靠元首功绩。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随时多方祷告，灭尽仇敌诡计，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦阿利路亚，争战在一起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在荣耀里，与主在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "咒诅成往事，天地俱和煦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命水解渴，生命果充饥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新郎偕新妇，相爱永同居。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人永远合一，光明喜乐无比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦阿利路亚，与主在一起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
