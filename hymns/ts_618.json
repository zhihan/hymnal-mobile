    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在圣灵里，交通在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丢弃了道理，抛掉了虚仪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不拘在形式，不泥于字句，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的新样，活水的洋溢。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再属于宗教，凡事追求实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦阿利路亚，交通在一起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在召会里，事奉在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除尽了恶毒，吃饱了灵食；"
