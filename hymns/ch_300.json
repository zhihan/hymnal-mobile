      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "变成主的形状！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主就是那灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肯让主灵通畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此愿就完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "敞着我脸观瞧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瞧见主荣光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同镜子返照，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照出主形状。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿再无遮蔽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常将主返照；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更愿心能纯一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "返照无搅扰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "观看主的荣光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主面对面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直将主瞻仰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心不再他转。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "变成主的形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是我目标！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将主印在心上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反映主荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "变成主的形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣上又加荣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出主的荣光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无穷又无终！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
