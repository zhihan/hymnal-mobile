              "text": "变 成"
            },
            {
              "chord": "A",
              "text": "主 的"
            },
            {
              "chord": "D",
              "text": "形 状！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这 是"
            },
            {
              "chord": "E7",
              "text": "我 心"
            },
            {
              "chord": "A",
              "text": "愿！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 今"
            },
            {
              "chord": "",
              "text": "深 切"
            },
            {
              "chord": "G",
              "text": "仰 望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "愿 主"
            },
            {
              "chord": "A7",
              "text": "就 成"
            },
            {
              "chord": "D",
              "text": "全！"
            }
