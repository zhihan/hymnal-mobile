{
  "url": "https://www.hymnal.net/cn/hymn/ts/855",
  "title": "祂血永是我保障",
  "lines": [
    {
      "segments": [
        {
          "chord": "D",
          "text": "豈 能"
        },
        {
          "chord": "",
          "text": "不 高 聲 頌 揚？"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "A",
          "text": "豈 能"
        },
        {
          "chord": "",
          "text": "不 徧"
        },
        {
          "chord": "A7",
          "text": "傳 四"
        },
        {
          "chord": "D",
          "text": "方？"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "寶 血 洗 罪 有 功 效，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪 人"
        },
        {
          "chord": "A",
          "text": "速 速"
        },
        {
          "chord": "",
          "text": "來 投"
        },
        {
          "chord": "D",
          "text": "靠！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "远比祭牲血更美，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "带来救恩福全备；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊无瑕、血无疵，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不见朽坏到永世。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "听哪！宝血在发声，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "闻于神前显权能；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在宝座前为我言，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "功效绝佳永不变。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "前我良心有亏欠，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "时有控告无平安；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "所有玷污尽显露，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "叹息、痛苦不止住。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "岂知宝血洗罪污，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神前功效永充足；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪案全销，得近神，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "借血罪人蒙神恩！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "无须祭牲血再洒，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "无须凭\"死行\"脱罚；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "无何能使神喜悦，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "诸天惟听主宝血。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "因祂流血我得赎，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪得全赦，享永福；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "先民不过将罪遮，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我得洁净，唱乐歌。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "进入平安，何稳妥，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "良心无亏，罪污脱；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不再羞愧，无重担，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "与神和好，心安然。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚！深难测！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "宝血价值我寻得！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "故当歌唱，再歌唱，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂血永是我保障！"
        }
      ]
    }
  ],
  "metadata": {
    "category": "事奉与福音",
