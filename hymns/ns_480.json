    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ankle-holder, a supplanter;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My demands to God I bring."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If God keeps me, clothes and feeds me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him I’ll own as God, my King."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chosen ere the earth’s foundation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Israel,” I to blessing cling."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I suffer, squeezed by Laban,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am sheltered ’neath Your wing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ladder joining earth and heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make my heart Your dwelling place."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burden me to build Your house, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this now I consecrate."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pillars stand—“He will Establish,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“In Him’s Strength”—of truth the base."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain me to enlarge Your temple,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Testimony propagate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While I pass through tribulations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Situations heated press."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me see Your hand most sovereign;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oil anointing on me dress."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my days, Your presence filleth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life and nature, God express,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leaning on You, Staff, my Shepherd,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flowing out to others bless."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stone-ify me for Your building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I desire a home for Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me share Your dream of Bethel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Duplicate Your heart in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burn, refine away the nat’ral;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transformed preciousness I’d be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, perfect me as a pillar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Standing solid, weightily."
            }
          ]
        }
      ],
