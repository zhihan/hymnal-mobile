{
  "url": "https://www.hymnal.net/cn/hymn/ch/541",
  "title": "哦主你今乃是那灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 今 乃"
            },
            {
              "chord": "A",
              "text": "是"
            },
            {
              "chord": "A7",
              "text": "那"
            },
            {
              "chord": "D",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住 在 我"
            },
            {
              "chord": "G",
              "text": "们 灵"
            },
            {
              "chord": "A",
              "text": "里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "二 灵"
            },
            {
              "chord": "",
              "text": "现"
            },
            {
              "chord": "D",
              "text": "今 成"
            },
            {
              "chord": "A7",
              "text": "为 一"
            },
            {
              "chord": "D",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "你 我"
            },
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "A",
              "text": "成"
            },
            {
              "chord": "A7",
              "text": "为"
            },
            {
              "chord": "D",
              "text": "一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的灵与我们的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远同证不弛："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们乃是神的儿女，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且是神的后嗣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已成为生命之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来将自己赐赋；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今在我们灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你的丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你今是那生命之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引导、光照、流通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今在我们灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随你生活、行动。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那灵，在我灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常加强、供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵中，借着你灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们敬拜、事奉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那灵，经过我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时以叹息代祷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵里，同着你灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们向你祷告。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿回到我们灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此接触你灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这灵中我们得享"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的神圣供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，这是何等联结，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二灵竟成一灵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵活在我的灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵住于你灵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
