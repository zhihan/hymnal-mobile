          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 你 甘 願 枉 費， 一"
            },
            {
              "chord": "Bm",
              "text": "無 所"
            },
            {
              "chord": "",
              "text": "顧。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "從 我"
            },
            {
              "chord": "",
              "text": "玉"
            },
            {
              "chord": "D",
              "text": "瓶 傾"
            },
            {
              "chord": "",
              "text": "倒 香"
            },
            {
              "chord": "Bm",
              "text": "膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 你"
            },
            {
              "chord": "G",
              "text": "身、 你"
