    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我将贵重膏油取出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏抹我所至爱的主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你脚前我今俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏油芬芳，因着爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "漫溢四处。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱你！爱你主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你甘愿枉费，一无所顾。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我玉瓶倾倒香膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你身、你头、你脚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你─挚爱主，我爱，你耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人说你若凡事知道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必知是谁在摸你脚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，我罪实不可告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不配摸你，还妄想"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献上香膏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我爱。。。爱你，主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱深是因多得赦罪之故。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我玉瓶倾倒香膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你身、你头、你脚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你─挚爱主，我爱，你耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我要用我爱洗你足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你脚前，我己可不顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的价值有谁能述？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的爱情并全人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都当你属。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱你！爱你，主耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱情我全人都为你，主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求悦纳我和我香膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱主，这是我上好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你─挚爱主，我爱，你耶稣！"
            }
          ]
        }
