            },
            {
              "chord": "Bm",
              "text": "我"
            },
            {
              "chord": "Em",
              "text": "愛，"
            },
            {
              "chord": "A7",
              "text": "你 耶"
            },
            {
              "chord": "D",
              "text": "穌！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我將貴重膏油取出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏抹我所至愛的主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你腳前我今俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏油芬芳，因著愛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "漫溢四處。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愛你！愛你主耶穌！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為你甘願枉費，一無所顧。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "從我玉瓶傾倒香膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為你身、你頭、你腳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為你─摯愛主，我愛，你耶穌！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人說你若凡事知道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必知是誰在摸你腳；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，我罪實不可告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不配摸你，還妄想"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "獻上香膏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我愛。。。愛你，主耶穌！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愛深是因多得赦罪之故。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "從我玉瓶傾倒香膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為你身、你頭、你腳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為你─摯愛主，我愛，你耶穌！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我要用我愛洗你足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你腳前，我己可不顧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的價值有誰能述？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的愛情並全人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都當你屬。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愛你！愛你，主耶穌！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愛情我全人都為你，主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求悅納我和我香膏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愛主，這是我上好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為你─摯愛主，我愛，你耶穌！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
