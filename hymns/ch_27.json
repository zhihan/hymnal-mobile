    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神，你儿子为何"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离开天上宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受苦直到命绝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出祂的宝血？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无他，乃是祂的大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无他，乃是祂的大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫祂这样为我受害。"
            }
          ]
        }
