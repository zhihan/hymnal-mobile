              "text": "Only night and tears and endless woe!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What, though I might live without the Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I come to die, how would it be?"
