    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Wrecked outright!” So we lament;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when storms have done their worst,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the soul, surviving all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Eternal arms is nursed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There to find that nought can move"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One, embosomed in such love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Wrecked outright!” No more to own"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en a craft to sail the sea;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still a voyager, yet now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anchored to Infinity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing left to do but fling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Care aside, and simply cling."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Wrecked outright!” ’Twas purest gain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Henceforth other craft can see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the storm may be a boon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That, however rough the sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself doth watchful stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the “wreck” is in His hand."
            }
          ]
        }
      ],
