{
  "url": "https://www.hymnal.net/cn/hymn/ts/814",
  "title": "夸胜",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现在就是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主的得胜里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不需要我们再来"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挣扎与努力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们只要享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵里来支取，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就经历得胜实际。"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为何不齐夸胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "齐夸胜齐夸胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已经与主"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同高升！同高升！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三层天，在灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得胜，多容易！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但在我们脚底！"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在主得胜里面"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们一同有分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这得胜的联结"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是永远不可分。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我岂能再失败、灰心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "软弱无能？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我现在享受得胜！"
            }
          ]
        }
      ],
      "type": "verse"
    }
  ],
  "metadata": {
    "category": "事奉与福音",
    "time": "3/4",
