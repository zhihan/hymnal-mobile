      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I take Him at His word indeed:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Christ died for sinners”—this I read;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in my heart I find a need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Him to be my Savior!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That He should leave His place on high"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And come for sinful man to die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You count it strange? So once did I"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before I knew my Savior!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And, oh, that He fulfilled may see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The travail of His soul in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with His work contented be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I with my dear Savior!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, living, dying, let me bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My strength, my solace from this spring—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He who lives to be my King"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once died to be my Savior!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
