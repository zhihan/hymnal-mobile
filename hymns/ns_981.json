              "text": "race is"
            },
            {
              "chord": "G",
              "text": "set,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "Demanding"
            },
            {
              "chord": "D",
              "text": "that all"
            },
            {
              "chord": "A",
              "text": "weight and"
            },
            {
              "chord": "D",
              "text": "sin"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be"
            },
            {
              "chord": "G",
              "text": "put a"
            },
            {
              "chord": "D7",
              "text": "way, and,"
            },
            {
              "chord": "G",
              "text": "tireless"
            },
            {
              "chord": "",
              "text": "yet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "D",
              "text": "with endurance"
            },
            {
              "chord": "C",
              "text": "run"
            },
            {
              "chord": "D7",
              "text": "to"
            },
            {
              "chord": "G",
              "text": "win!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And yet this race is set in grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The very Christ whom we enjoy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For mortal strength there is no place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must the Spirit’s power employ."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The prize to gain, ahead it lies:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How precious! ’Tis, the very Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Laid hold by Him, we e’er would rise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And run by His supporting might."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our running’s not for selfish pride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor for our boast in crown or throne."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis duty ours, self-choice aside."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We run for Christ and Christ alone!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For this we give our life and all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our might, our strength, our days withal."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him we live—the upward call."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him we die—the gain of all!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And when we fall, we quickly rise!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An all-sufficient grace outpoured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And varied still, with stores untried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exhaustless grace He doth afford."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His partners dear, His brethren true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No time is there for looking back!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One thing remains: to e’er pursue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One who doth our hearts attract."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No more we hope in things of old;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more we dream of vanity!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The peerless Christ is now our goal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our prize for all eternity!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
