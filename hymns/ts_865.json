    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无奈己意，只求称心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羡慕神旨，却仍贪享安逸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光照临及，才识自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "处处搀杂事，事己意充替。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主手管治，破碎甄陶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我衰减，逐日脱自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵分赐，更新变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你扩增，安家我心里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，是你极深怜恤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀经纶引我离地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱里回应，奉献全人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不从己意，惟愿是你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同灵、同魂、思念同一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建神家一齐努力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成神帐幕─圣城撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人永得满足安息。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "筑坛奉献，得着加力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神却呼召：起来，上伯特利！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历神家─召会实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再是\"我，乃基督活我里。\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱困迫，脱离个人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你家，我们才安息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同众肢体，献作活祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为召会，\"枉费\"亦欢喜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
