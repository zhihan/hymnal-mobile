    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "答应呼召，凭七倍灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作得胜者，此心绝不稍移；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "持守主话，靠主圣名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠勇向前，一生不再偏离。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竭力奋鬬，同心配搭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奉差遣，心系于全地。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度福音，遍传地极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怀雄心，只讨主欣喜。"
            }
          ]
        }
