              "text": "Grows the tree, our enjoyment for eternity!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So I’ve no cause to frown as one who’s received this zoe."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know life runs its course and triumphs inevitably."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m required just to stay in the flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I do the drinking then God gives the growth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So there’s joy in my heart, and a spring in my step,"
            }
          ]
        },
        {
