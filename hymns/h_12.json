    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In love Thou in the Son didst flow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Among the human race;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost as Spirit also flow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within us thru Thy grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though we in sin and wickedness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Went far from Thee apace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in the Son Thou didst redeem,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bestowing life and grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though we have often slighted Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit often grieved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou dost still as Spirit come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As life to be received."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou as the Spirit in the Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hast mingled heretofore;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt thru fellowship anoint"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And increase more and more."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The love of God, the grace of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit’s flowing free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enable us God’s wealth to share"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru all eternity."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father, Son, and Spirit—one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So richly care for us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love with one accord we sing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And e’er would praise Thee thus."
            }
          ]
        }
      ]
    }
