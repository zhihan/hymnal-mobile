        {
          "segments": [
            {
              "chord": "",
              "text": "活着就是基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟祂作人位，从我们活出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "事事处处无误。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "行事并为人与福音是一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论何事临及；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在一个灵里，为福音站立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同魂一起努力。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们宣扬福音的奥秘，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主称心如意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督作生命，召会为身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传遍居人之地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
