    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每日的境遇，无论苦或甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都为福音进展；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为福音、死活，使主显人前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生活在地如天。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "笃信无畏惧，灵中常放胆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讲说神的圣言；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在爱里行事，凭大能争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主联结无间。"
            }
          ]
        }
