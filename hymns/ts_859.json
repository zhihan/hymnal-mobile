      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事能放胆，不怕仇敌阻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主灵供应充足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督常显大，无论何事故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生死都不在乎。"
            }
          ]
        },
        {
          "segments": [
            {
