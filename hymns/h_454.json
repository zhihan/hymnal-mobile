    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine am I by all ties,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And chiefly Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For through Thy sacrifice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, art mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thine own cords of love, so sweetly wound"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Around me, closely I to Thee am bound."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee, Thou Bleeding Lamb,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I all things owe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that I have and am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all I know;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that I have is now no longer mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I am not my own: Lord, I am Thine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I, Lord, withhold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life’s brightest hour"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Thee; or gathered gold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or any power?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why should I keep one precious thing from Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou hast given Thine own dear Self for me?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I pray Thee, Savior, keep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Me in Thy love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the world Thou sweep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And me remove"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To that fair realm, where, sin and sorrow o’er,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou and Thine own are one for evermore."
            }
          ]
        }
      ],
