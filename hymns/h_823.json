      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To the throne Christ has ascended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Far above all rule and power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God has made Him Head o’er all things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Church, His Body here."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All in all He ever filleth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His fulness is expressed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the Church, which is His Body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His image manifests."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We, once dead in our offences,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Walking in the worldly course,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lusts of flesh and mind fulfilling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan and his hosts their source,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God with Christ has resurrected,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seated in the heavenlies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, His masterpiece, created"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ Jesus, Him to please."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jews and Gentiles are one body—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God His myst’ry has made known—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On apostles, prophets founded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Christ the cornerstone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We in Him are built together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God’s dwelling manifest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fitly framed by God the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His pleasure and His rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In eternal ages purposed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His wisdom be made known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was the Church, His hidden myst’ry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where the Son could make His home;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the saints may all in spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Apprehend His boundlessness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Know His love which passes knowledge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God’s fulness to possess."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One in body, hope, and Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in faith, one Lord, the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One baptizing, with one Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Church may thus be one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to know in all His fulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto manhood be matured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er by winds of doctrine carried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor by cunning men allured."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Many gifts the Lord has given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His Body He may build,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the saints may be perfected"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And their ministry fulfilled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we must put off the old man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may put on the new;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus, renewed in mind and spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will bear God’s image true."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ in love Himself has given"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Church be sanctified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without blemish, spot, or wrinkle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To become His glorious bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He does nourish her and cherish"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a man his body treats;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He and she become one body—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the myst’ry very great."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Body, house, new man the Church is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bride, and temple, and yet more:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She’s the army too which fighteth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God’s foe to triumph o’er."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She is clothed with all God’s armor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His mighty strength is strong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Standing in the Lord, resisting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all prayers she fighteth on."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
