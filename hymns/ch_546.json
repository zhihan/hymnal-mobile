          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你那灵将我浸透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我全像你模样。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从我灵中向外开展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就变化我全魂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更新里面每一部分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全人都归顺。"
            }
          ]
        }
