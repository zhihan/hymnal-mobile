    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已用祂神圣生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵中重生我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂还须在我魂中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作那变化的工作。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主将我魂的各部，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都变成你形像；"
