  "title": "神的圣灵是神传达",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "聖"
            },
            {
              "chord": "Bm",
              "text": "靈 是"
            },
            {
              "chord": "A",
              "text": "神 傳"
            },
            {
              "chord": "D",
              "text": "達，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 祂， 神"
            },
            {
              "chord": "Bm",
              "text": "得 進"
            },
            {
              "chord": "A7",
              "text": "入"
            },
            {
              "chord": "D",
              "text": "我"
            },
            {
              "chord": "A",
              "text": "裡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 祂， 神"
            },
            {
              "chord": "Em",
              "text": "在 基"
            },
            {
              "chord": "D",
              "text": "督 裡"
            },
            {
              "chord": "A",
              "text": "面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "給 我"
            },
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "D",
              "text": "著， 作"
            },
            {
              "chord": "A",
              "text": "我"
            },
            {
              "chord": "A7",
              "text": "經"
            },
            {
              "chord": "D",
              "text": "歷。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神之为父是作源头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神之为子是为表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神之为灵是为进入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得着神的丰满。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父原住在难近光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子来将祂向人显明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵又将祂向人传达，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人可灵中将祂接领。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父在子里来人中间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子又成灵进人里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父、子、圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今住在我们灵间。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父神乃在子神里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着化身而得彰显；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵神乃是子神实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我得著作我恩典。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿父神对我之爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在子神里成我恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着灵神交通传达，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得享神的丰满。"
            }
          ]
        }
      ]
