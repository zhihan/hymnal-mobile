    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Anointed King, with glory crownèd,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rightful Heir and Lord of all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once rejected, scorned, disownèd,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en by those Thou cam’st to call:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee we honor, Thee adore—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious now and evermore."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord of life! to death once subject;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blesser, yet a curse once made;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy Father’s heart the object,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in depths of anguish laid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee we gaze on, Thee recall—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearing here our sorrows all."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Royal robes shall soon invest Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Royal splendors crown Thy brow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ of God, our souls confess Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King and Sov’reign even now!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee we rev’rence, Thee obey—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Own Thee Lord and Christ alway."
            }
          ]
        }
      ]
