      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we’re God’s temple in three parts;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our inmost part the spirit is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There God and Christ as Spirit dwell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The holiest place of holy ’tis."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here within our inmost part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God in Christ is all to us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here the Holy Spirit makes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord reality to us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here within the spirit-part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We contact Christ and dwell with Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by our spirit we with God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have fellowship and worship Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here that Christ is like the land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where we may dwell, its wealth enjoy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here that we must fight the foe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Christ’s authority employ."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The spirit we must seek to know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Discerning spirit from the soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And live within this holiest place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To worship God and reach His goal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The soul we ever must forsake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Press on, God’s rest to enter in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Christ we may possess in full"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all God’s plan fulfill therein."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
