    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, help us to redeem these golden moments;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our vessels fill with ointment from above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help us amen each trial and tribulation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase in us; make us abound in love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s coming soon—these moments are so precious."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The oil is here—Oh, let us buy the more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amen the trials and welcome tribulations—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom’s ours through these afflictions sore."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, ever turn us from our soulish pleasures"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gaze upon Thy tender, loving face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, keep us running forth to meet the Bridegroom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And patiently attending to the race."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus comes, will we be in His presence?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus comes, will we His face behold?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us not return to sloth and folly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But jealously His loving presence hold."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As His dear Bride, let us go forth to meet Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our lamps well-trimmed, our fires burning bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our vessels filled, our eyes set on His glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be with Him completely satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, satisfied—Christ and His Bride together."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, satisfied—throughout eternity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a rest, what joy, what love, what favor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be His Bride when He comes to His feast!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
