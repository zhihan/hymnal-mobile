      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord Jesus, precious Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I still stubborn be?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thy feet cast all my hard'nings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And return with songs and singings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis my love to be Thy bondslave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis my joy to Thee obey."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord Jesus, precious Jesus,"
