          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy way only will I choose;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though in tears while I'm obeying,"
            }
          ]
        },
        {
          "segments": [
            {
