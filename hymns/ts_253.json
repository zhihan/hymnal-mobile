    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督还是真石榴树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命丰美充足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是橄榄树，新油产出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏抹永不缺如；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流奶与蜜，美善甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供我滋养，加我能力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富，如此完全─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督美地！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这美地不缺食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们一无所缺；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是如此丰饶富庶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们颂赞不绝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上好美地，广大无边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应有尽有，齐备完全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今在我心还要扩展─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无量无限！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这地石头如铁之坚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "山内可以挖铜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "权柄如铁，凭以争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌不能得逞；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再经苦难，渣滓全去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "炼净明亮，如铜显出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有铁有铜，应付所需─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是基督！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为这美地我们颂赞："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你何其包罗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃喝饱足，让你充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰富岂能尽说！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求使我们经营不辍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美地实际增长不已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的喜乐，我的生活─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督美地！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
