{
  "url": "https://www.hymnal.net/cn/hymn/ch/15",
  "title": "若无流血就有赦罪",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "若 無"
            },
            {
              "chord": "",
              "text": "流 血 就"
            },
            {
              "chord": "D",
              "text": "有 赦"
            },
            {
              "chord": "G",
              "text": "罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如 何 對 付 公"
            },
            {
              "chord": "D",
              "text": "義？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "若"
            },
            {
              "chord": "G",
              "text": "已 流"
            },
            {
              "chord": "",
              "text": "血 仍"
            },
            {
              "chord": "C",
              "text": "然 責"
            },
            {
              "chord": "",
              "text": "備，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍"
            },
            {
              "chord": "D",
              "text": "然 不"
            },
            {
              "chord": "",
              "text": "能"
            },
            {
              "chord": "D7",
              "text": "合"
            },
            {
              "chord": "G",
              "text": "理。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神，你今已不能追究，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主已经献祭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着完全自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我罪像东离西。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你义所有每一要求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主都付代价；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今你只能加宽宥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因无审判可加。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "前是爱叫祂来救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你义要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你义，今叫我主"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放所有罪囚。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙、奇妙，在十字架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我遇爱和公义；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱和公义如此交加，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我歌唱不已。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
