{
  "url": "https://www.hymnal.net/cn/hymn/ch/425",
  "title": "我是受造的瓦器",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 是"
            },
            {
              "chord": "",
              "text": "受 造 的 瓦 器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "寶 貝"
            },
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "A7",
              "text": "放 我"
            },
            {
              "chord": "D",
              "text": "裡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 須 作 祂 的 器 皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 作"
            },
            {
              "chord": "A",
              "text": "內 容"
            },
            {
              "chord": "",
              "text": "來 藏"
            },
            {
              "chord": "D",
              "text": "隱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照祂形像我被造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "适合基督来住着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神使器皿的形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与其内容能相像。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今居留在我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂大能来支撑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得与祂成一灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受祂实际的供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天天居衷在感动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时调和相交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有脚步祂保守，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每一部分祂浸透。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让祂由衷得表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂在我被人见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我须透明又透亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂可借我得显彰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "变化乃是我所需，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人破碎无所馀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "泥土得改原形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变成宝贝的模样。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "经历基督",
