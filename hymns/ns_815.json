    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As day after day is unfolding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And hours and moments pass by,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep granting Thy fresh visitation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy countenance, each time I rise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy goodness and Thy glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Infuse me, time after time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy rich supply strengthening me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit to mingle with mine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the true light, O Lord Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee all my steps are so clear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee I’m in fellowship’s sweetness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy sin-cleansing blood brings Thee near."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy presence with Thy promise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A great lamp, leadeth me on!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When my dark heart Thou entered in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy light changed my sighing to song!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal Light, brightness unchanging,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou reachest me, scatt’ring all gloom;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee is the fountain of life, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy light, life in me doth bloom."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy wonders and Thy workings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have touched me by Thy word’s light!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My God who said, “Let there be light!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is living and speaking inside!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From darkness to light, Lord Thou brought me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh mercies descend from above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With saints in Thy kingdom rejoicing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Announcing Thy life and Thy love!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy vict’ry and Thy virtues,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exhibit light to all men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In newness, through Thy City shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bright, glorious Jerusalem!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
