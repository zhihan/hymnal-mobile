    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Every day the Lord Himself is near me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a special mercy for each hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my cares He fain would bear and cheer me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He whose name is Counsellor and Pow’r."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The protection of His child and treasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is a charge that on Himself He laid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“As thy days, thy strength shall be in measure,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This the pledge to me He made."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Help me then, in every tribulation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So to trust Thy promises, O Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I lose not faith’s sweet consolation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Offered me within Thy holy Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help me, Lord, when toil and trouble meeting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’er to take, as from a father’s hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One by one, the days, the moments fleeting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till with Christ the Lord I stand."
            }
          ]
        }
