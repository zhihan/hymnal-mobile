        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus I cast the world behind me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus most beloved shall be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beauteous more than all things beauteous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He alone is joy to me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bright with all eternal radiance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the glory of Thy face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art loving, sweet, and tender,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of pity, full of grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When I hated, Thou didst love me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shedd’st for me Thy precious blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still Thou lovest, lovest ever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall I not love Thee, my God?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep my heart still faithful to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That my earthly life may be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But a shadow to that glory"
            }
          ]
        },
