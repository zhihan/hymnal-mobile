    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Breathe, O breathe Thy loving Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into every troubled breast;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us all in Thee inherit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us find the promised rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take away the love of sinning;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Alpha and Omega be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "End of faith, as its beginning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set our hearts at liberty."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, Almighty, to deliver,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us all Thy life receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thy presence e’er be with us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never more Thy temples leave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee we would be always blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Serve Thee as Thou wouldst approve,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pray, and praise Thee without ceasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory in Thy perfect love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Finish, then, Thy new creation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pure and spotless let us be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us see Thy great salvation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfectly restored in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Changed from glory into glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till with Thee we take our place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we cast our crowns before Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lost in wonder, love and praise."
            }
          ]
        }
      ],
