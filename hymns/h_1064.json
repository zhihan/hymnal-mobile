      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love to tell the story;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More wonderful it seems"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than all the golden fancies"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all my golden dreams,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love to tell the story,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It did so much for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And that is just the reason"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I tell it now to thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
