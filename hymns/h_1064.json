    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love to tell the story;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis pleasant to repeat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What seems each time I tell it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More wonderfully sweet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love to tell the story;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For some have never heard"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The message of salvation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From God’s own holy Word."
            }
          ]
        }
      ]
    },
