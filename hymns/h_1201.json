    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With the cloud we have His presence"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweetly hov’ring over us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So enveloped by His nearness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Lord we put our trust."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the cloud brings with it fire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To consume our selfish lusts;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That as ashes something higher"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May be added into us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then from out the flashing fire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Comes th’ electrum glowing bright."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as gold and man as silver"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now are mingled. What a sight!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This bright metal, O Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Thyself, Lamb-God sublime."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, work Thyself within us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till th’ electrum in us shines."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By our passing through this cycle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living creatures we become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To express the life of Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He with whom we’ve been made one."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We express Him as a human,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a man so good and fine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Balanced, normal, never striving;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully human, yet divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We express Him as a lion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conquering every enemy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As an ox obedient, lowly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithful in His ministry."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We express Him as an eagle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So transcendent, soaring high;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never held by fear or flatter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He above it all does fly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! What a figure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the way God deals with us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the wind, cloud, fire, electrum,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the creatures glorious:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the man, the ox and lion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the eagle—all the four"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will be our complete expression"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we eat Him more and more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
