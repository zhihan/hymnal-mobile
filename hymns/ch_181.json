  "title": "哦主耶稣借着饼杯",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主"
            },
            {
              "chord": "",
              "text": "耶 稣， 藉 著"
            },
            {
              "chord": "A",
              "text": "饼 杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 们"
            },
            {
              "chord": "A",
              "text": "陈 列"
            },
            {
              "chord": "A7",
              "text": "你 的"
            },
            {
              "chord": "D",
              "text": "死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "温 习 你 爱 所 作"
            },
            {
              "chord": "A",
              "text": "所 为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "珍 赏"
            },
            {
              "chord": "A7",
              "text": "你 死"
            },
            {
              "chord": "",
              "text": "的 价"
            },
            {
              "chord": "D",
              "text": "值。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "饼 杯"
            },
            {
              "chord": "A7",
              "text": "分 列，"
            },
            {
              "chord": "D",
              "text": "身 血"
            },
            {
              "chord": "",
              "text": "分 开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "表 明"
            },
            {
              "chord": "A7",
              "text": "你 死"
            },
            {
              "chord": "D",
              "text": "已 成"
            },
            {
              "chord": "",
              "text": "就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 感 戴，"
            },
            {
              "chord": "G",
              "text": "我 灵"
            },
            {
              "chord": "D",
              "text": "敬 拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 口"
            },
            {
              "chord": "D",
              "text": "向 你"
            },
            {
              "chord": "A7",
              "text": "献 歌"
            },
            {
              "chord": "D",
              "text": "讴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你 尝 死 亡 苦"
            },
            {
              "chord": "A",
              "text": "味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 饮"
            },
            {
              "chord": "A7",
              "text": "救 恩"
            },
            {
              "chord": "D",
              "text": "福 杯！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 爱 所 作"
            },
            {
              "chord": "G",
              "text": "所 为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配"
            },
            {
              "chord": "D",
              "text": "得 永"
            },
            {
              "chord": "A7",
              "text": "远 赞"
            },
            {
              "chord": "D",
              "text": "美！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱叫你为我流血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要引我到神前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我与神不再隔绝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随时得见神圣面。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀、圣洁、公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有要求已满足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我能借着你死功绩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坦然与神来接触。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你尝死亡苦味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我饮救恩福杯！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱所作所为，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得永远赞美！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你死已将幔子裂开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我打通至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除去我与神的阻碍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能到施恩座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得神怜恤，蒙神恩惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我应时的帮助，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同饮到生命活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饱尝神性的丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你尝死亡苦味，"
            }
          ]
        },
        {
          "segments": [
            {
