            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得永远赞美！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你既如此将我赎回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就使我能作祭司，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得享神的一切甘美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常在神前供圣职。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此福气、如此恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都由于你受死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿不断如此记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到喝新的日子。"
            }
          ]
        }
      ],
