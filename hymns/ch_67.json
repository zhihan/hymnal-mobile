{
  "url": "https://www.hymnal.net/cn/hymn/ch/67",
  "title": "我们爱唱基督神子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "大 地"
            },
            {
              "chord": "",
              "text": "無 名"
            },
            {
              "chord": "A",
              "text": "甜 至"
            },
            {
              "chord": "A7",
              "text": "如 此！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "名 甜"
            },
            {
              "chord": "G",
              "text": "至 此"
            },
            {
              "chord": "D",
              "text": "高"
            },
            {
              "chord": "A7",
              "text": "天"
            },
            {
              "chord": "D",
              "text": "無！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 離 榮 耀"
            },
            {
              "chord": "A",
              "text": "來 世"
            },
            {
              "chord": "A7",
              "text": "界 時，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 將"
            },
            {
              "chord": "G",
              "text": "這 名"
            },
            {
              "chord": "D",
              "text": "賜"
            },
            {
              "chord": "A7",
              "text": "救"
            },
            {
              "chord": "D",
              "text": "主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 愛 唱： 基 督"
            },
            {
              "chord": "A7",
              "text": "神 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "並 且"
            },
            {
              "chord": "",
              "text": "稱 祂"
            },
            {
              "chord": "Bm",
              "text": "為 耶"
            },
            {
              "chord": "A",
              "text": "穌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "因 為"
            },
            {
              "chord": "",
              "text": "從 來"
            },
            {
              "chord": "A",
              "text": "未 有"
            },
            {
              "chord": "A7",
              "text": "文 字，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "這 寶、"
            },
            {
              "chord": "G",
              "text": "這 甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "如"
            },
            {
              "chord": "A7",
              "text": "『耶"
            },
            {
              "chord": "D",
              "text": "穌。』"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当人将祂挂在木上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们同时挂这名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫天下都能欣赏"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们爱祂的究竟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们爱唱：基督神子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且称祂为耶稣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为从来未有文字，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这宝、这甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如‘耶稣。’"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂上升高坐宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神将这名赏赐祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万膝跪拜、万口唱和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上地下都迎驾！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
