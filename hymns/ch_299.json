            },
            {
              "chord": "G7",
              "text": "樂 全"
            },
            {
              "chord": "C",
              "text": "滅 跡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "有 心"
            },
            {
              "chord": "D7",
              "text": "願 滿"
            },
            {
