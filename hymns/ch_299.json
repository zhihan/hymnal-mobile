            },
            {
              "chord": "G",
              "text": "徒 可"
            },
            {
              "chord": "",
              "text": "食 之"
            },
            {
              "chord": "D",
              "text": "餅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每"
            },
            {
              "chord": "G",
              "text": "日 嗎"
            },
            {
              "chord": "G7",
              "text": "哪 天"
            },
            {
              "chord": "C",
              "text": "所 賜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "適"
            },
            {
              "chord": "D",
              "text": "合 屬"
            },
            {
              "chord": "D7",
              "text": "天 性"
            },
            {
              "chord": "G",
              "text": "情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "長 久 渴 慕 享"
            },
            {
              "chord": "D",
              "text": "受 你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "飽 嘗 你 的 豐"
            },
            {
              "chord": "G",
              "text": "富，"
            }
          ]
        },
        {
          "segments": [
            {
