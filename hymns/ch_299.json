      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "涌流生命的活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流自裂开灵磐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "明晶活泉何甘美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是爱的泉源。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我白白来畅饮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "消除我的干渴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你外，别水不再寻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远将你来喝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "吃你、喝你、享受你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们敬拜感戴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你话并你灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饱尝你的大爱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我从你得𫗪养，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭你活在地上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有长成的身量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫你得着显彰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
