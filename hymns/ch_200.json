{
  "url": "https://www.hymnal.net/cn/hymn/ch/200",
  "title": "现今神的圣别之灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "现 今"
            },
            {
              "chord": "",
              "text": "神 的 圣"
            },
            {
              "chord": "A",
              "text": "别 之"
            },
            {
              "chord": "",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃"
            },
            {
              "chord": "D",
              "text": "是 神"
            },
            {
              "chord": "G",
              "text": "的 生"
            },
            {
              "chord": "A",
              "text": "命 之"
            },
            {
              "chord": "",
              "text": "灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将"
            },
            {
              "chord": "D",
              "text": "我 点"
            },
            {
              "chord": "",
              "text": "活， 赐"
            },
            {
              "chord": "A",
              "text": "我 生"
            },
            {
              "chord": "D",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 适 合 神"
            },
            {
              "chord": "A7",
              "text": "所 命"
            },
            {
              "chord": "D",
              "text": "定。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作活水，解我干渴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远供我生命水流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应基督作我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心愿望祂全成就。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照亮我以生命之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我全人驱尽黑暗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应基督作我亮光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我黑夜变成中天。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强我以生命大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加力给我里面的人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应基督作我能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神计画运行施恩。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着神圣生命的律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放我脱罪恶的律；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着神的圣别性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面将我规律。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作神的生命之灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰盛果子借我结出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出神的各种美德，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着生命供人基督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之灵供应生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用神生命将我变化；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更新我的里面部分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使与基督相像无差。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主用你生命的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我各部全都充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全人尽都浸透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你生命在我彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "圣灵的丰满",
