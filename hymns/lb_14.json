              "text": "As I gaze on You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m filled with You, my Love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only You alone will do."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can’t make it without You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep me close to You,"
            }
          ]
        },
        {
          "segments": [
