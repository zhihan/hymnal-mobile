    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me touch You as before,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Craving for You more and more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the very best!"
            }
          ]
        },
        {
          "segments": [
