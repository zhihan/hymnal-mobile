      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing and no one can satisfy me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "but You anymore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, my first Love, oh set me on fire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For You, my only desire."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just infuse me with Your eyes."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! This union satisfies!"
            }
          ]
