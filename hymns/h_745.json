{
  "url": "https://www.hymnal.net/en/hymn/h/745",
  "title": "O Lord, Thou art the Spirit now (mingling)",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "O Lord,"
            },
            {
              "chord": "",
              "text": "Thou art the"
            },
            {
              "chord": "A",
              "text": "Spir"
            },
            {
              "chord": "A7",
              "text": "it"
            },
            {
              "chord": "D",
              "text": "now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who in our"
            },
            {
              "chord": "G",
              "text": "spirit"
            },
            {
              "chord": "A",
              "text": "lives;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "One spirit"
            },
            {
              "chord": "D",
              "text": "have the"
            },
            {
              "chord": "A7",
              "text": "two be"
            },
            {
              "chord": "D",
              "text": "come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Which oneness"
            },
            {
              "chord": "A",
              "text": "to"
            },
            {
              "chord": "A7",
              "text": "us"
            },
            {
              "chord": "D",
              "text": "gives."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit with our spirit, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The witness ever bears"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we the Father’s children are"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And of God’s glory heirs."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis in our spirit Thee we touch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy riches to enjoy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as the Spirit Thou dost give"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself without alloy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis in our spirit we may walk"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And follow Thee alway,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While, as the Spirit, Thou dost lead"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And light impart each day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit, by Thy Spirit, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We live and worship Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, in our spirit, thru Thine own"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strengtheneth constantly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit, with Thy Spirit, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We offer prayer to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While, as the Spirit, Thou in us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Groanest unutterably."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We to our spirit would return"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And there would contact Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis in the spirit we may share"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our heritage divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What oneness, O my Lord, is this—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Two spirits intertwine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit in our spirit lives,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ours abides in Thine!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
