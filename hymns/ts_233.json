  "raw_sections": [
    "呼 喊『哦， 主 耶 稣！』 这 使",
    "我 们 灵 刚强！在 灵",
    "里 摸 著 主，忧 郁",
    "就 变 成 颂扬！ 切勿",
    "听 从 撒 但， 切勿",
    "受 他 的 打 岔， 只要",
    "回 到 灵 里 行动， 毫不",
    "惧 怕！呼 喊",
    "『哦， 主耶 稣，』就 必终 日",
    "将 祂享！"
  ]
