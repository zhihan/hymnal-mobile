            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "終 必 被 置 死"
            },
            {
              "chord": "A",
              "text": "地！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "因 為"
            },
            {
              "chord": "",
              "text": "十 架 用 意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就 是 使 人 絕"
            },
            {
              "chord": "G",
              "text": "氣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "所 以"
            },
            {
              "chord": "",
              "text": "十"
            },
            {
              "chord": "D",
