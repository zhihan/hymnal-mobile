      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神的救法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将人十架治杀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像是残酷刑罚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实是荣耀救拔；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非让十架剪除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能经历基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架将我结束，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督才能活出。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "十架最终目的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是成功神意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神意最大仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是人的自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "治死魂的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己才能除净；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除去己的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神意才得通行。"
            }
          ]
        }
