    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak, O blessed Master,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this quiet hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me see Thy face, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feel Thy touch of power."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For the words Thou speakest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They are life indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living bread from heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now my spirit feed!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All to Thee is yielded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am not my own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blissful, glad surrender,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am Thine alone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak, Thy servant heareth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be not silent, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Waits my soul upon Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the quickening word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill me with the knowledge"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy glorious will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thine own good pleasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy child fulfill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Like a watered garden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of fragrance rare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lingering in Thy presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let my life appear."
            }
          ]
        }
      ],
