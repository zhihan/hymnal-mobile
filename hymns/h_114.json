    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Paschal Lamb, by God appointed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our sins on Thee were laid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By our Father’s love anointed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou redemption’s price hast paid."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All who trust Thee are forgiven"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the virtue of Thy blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Opened are the things of heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace shines forth to man from God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, hail! enthroned in glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where for us Thou dost abide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, by faith, do now adore Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seated at Thy Father’s side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There, for us Thou now art pleading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There Thou dost our sorrows share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever for us interceding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till in glory we appear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Worship, honor, praise, and blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art worthy to receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loudest praises, without ceasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meet it is for us to give."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In that day Thy saints will meet Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Welcome Thee with grateful song;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joyful hearts will ever greet Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Source of joy to all the throng!"
            }
          ]
        }
