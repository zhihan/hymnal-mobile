    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Christ will get His kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Notwithstanding Satan’s plans;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s obtaining something real by"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growing in the hearts of man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing like religion teaches:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“You must wait until you die”—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the kingdom Christ is building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is on earth before our eyes."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His Son, Jesus, is our Savior."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once in human form He came."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now as Spirit He can enter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the breath of life to man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a seed within our spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ takes root and starts to grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spreading in our inmost being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till His life we come to know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Time is short, oh, brothers, hear it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is longing for His Bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can hasten His returning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Simply by the growth in life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more struggling, no more striving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Simply turn to Christ within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "See the seed begin to blossom."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growing fully into Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Christ will get His kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just by growth—the normal way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not an instant transformation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growth goes on from day to day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This life-seed is all-inclusive—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything we’ll ever need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, our God’s eternal purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is within this precious seed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
