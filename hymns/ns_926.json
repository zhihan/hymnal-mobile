    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, come now, my morning light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I might start again."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day is dawning, night is fading"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And it’s constellation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of fears and failures shall retreat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the presence of this heat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O great consuming light!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Devour all my night."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I long for higher ground,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To live above the world."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freed from all the earthly fetters,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need elevation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There must be something more, I know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Someplace higher to explore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O raise me up to You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more an earthly view."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, go deeper in my being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And set Your anchors there."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take root downward, bear fruit upward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reach your destination"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till all Your life is flowing through"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I’m a branch expressing You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“As deep calls unto deep”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is what I seek."
            }
          ]
        }
      ],
