    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The likeness of Christ they live out each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Manifest His full glory bright;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life like a man, in strength like a lion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In toil, an ox, with eagle's flight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Straight forward each step, discerningly move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living, fresh, in resplendence, bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They've passed through God's fire, been tempered, refined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be man's judgment and his light."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Restrained not by earth, through God do they soar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet still working in human form,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God as their cov'ring, Christ as their boast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expressing God, not self, their norm."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Christ's grace and pow'r, they're joined and attuned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As each functions, no turn they need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like coals do they burn, like torches they shine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They flash with every move and deed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By walking in Spirit, they have God's move"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "High and awesome, with visions full;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ moves in their move, His holy face shows;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They move as one in Spirit full."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With sky crystal clear, and conscience at peace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They all speak, listen quietly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They speak as one man to thus God express"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And rout in full God's enemy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With throne in the heav'ns, what heavenly view:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is reigning as man on high;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He's bright as pure gold, as holy as fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surrounded by a rainbowed sky."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
