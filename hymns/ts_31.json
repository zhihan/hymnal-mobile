      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "燔祭馨香使神喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "素祭叫人满意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "据此再献平安祭─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是基督自己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主人性何柔细，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们吃喝不已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此享受真可喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每逢我们聚集。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "交通何美筵席何富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人同得饱足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐盈盈，平安处处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣民怎不欢呼！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "内脏、脂油最甘美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当先归神回味；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摇祭的胸何宝贝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全体祭司受惠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无酵饼同举祭腿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纯全有能宝贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供职祭司受无愧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "福分拔尖全备。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美基督是平安祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神与人满足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐盈盈，平安处处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣民怎不欢呼！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "胸作摇祭何丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫表复活基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以爱围绕且照护，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我超越脱俗。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "腿作举祭何充足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "描绘升天救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有能历世途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活出他命无误。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得洁众圣聚一堂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督爱筵饱尝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此享受真无双，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来交通无量。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心存感恩来歌唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因主恩典深广；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为使主旨得显彰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿将全人献上。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
