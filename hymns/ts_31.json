              "text": "神圣平安得成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝血功效永坚定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神前我享安宁。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们放胆齐颂称"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"和平借血己成！\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仇敌闻之惊又恐，"
            }
          ]
