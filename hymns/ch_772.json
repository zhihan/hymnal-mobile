          "segments": [
            {
              "chord": "",
              "text": "深 望 與 恩"
            },
            {
              "chord": "Am",
              "text": "主"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "立 即"
            },
            {
              "chord": "G7",
              "text": "在 一"
            },
            {
              "chord": "C",
              "text": "起。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣的目标，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是神为人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫备的圣城；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有蒙宝血"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎的圣人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都能有权利"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受这福分。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，那座圣城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我每一瞻仰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就渴想见我"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主的面光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "巴不得早日"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听见祂呼声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得进入那城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永享祂丰盛。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心所渴慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非甜安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我久所盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也非何福气；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是主自己－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我荣耀盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是我永分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我的奖赏。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，求主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "快照我心愿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来接爱你者"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到你的面前！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在那圣城中"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同住并同荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不再分离。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时的一切"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都因你更新，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新天并新地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "陪新城、新人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神荣耀自己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要作我永分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，荣耀时辰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，快显身！"
            }
          ]
        }
      ]
    }
