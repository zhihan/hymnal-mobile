          "segments": [
            {
              "chord": "F",
              "text": "是 我"
            },
            {
              "chord": "",
              "text": "們 目"
            },
            {
              "chord": "C",
              "text": "標，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 的 永"
            },
            {
