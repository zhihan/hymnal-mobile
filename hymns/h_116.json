    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For us Thou on the Cross wast pierced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And blood and water streamed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That life divine be giv'n to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be redeemed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precious blood has made us clean,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we accepted be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Regenerated by Thy life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We now are one with Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the grain divine that died"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The many grains to bear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which, blent and formed, Thy Body are."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thy nature share."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the increase of Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou our content art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through us Thou livest and dost move"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And manifested art."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since we're Thy Body, Thou may come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And settle down in us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us Thou may obtain Thy home"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we become Thy trust."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heart to satisfy and please,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are Thy counterpart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in one Body with Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying all Thou art."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While in remembrance now we meet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And here the symbols see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy redemption great and full"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're filled with praise to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since we are made Thy Body, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy dwelling place and bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We would give thanks and worship Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy praise abide."
            }
          ]
        }
