    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“One poor wise man” hath cried, O God, to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood is counted precious in Thy sight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He liveth, and His name shall ever be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy praise, Thy glory, Thy supreme delight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Jesus’ blood—that new and living way—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s priests shall now within the holiest stay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The blood of bulls and goats for ages failed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To purge the conscience, burdened sore with sins;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precious blood, O Lamb of God, prevailed—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Thee, sweet Peace her endless reign begins."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy blood hath made redemption e’en for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Complete I stand, O risen Christ, in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The precious blood of Christ, it speaketh peace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To guilty sinners, groaning ’neath their load;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To captive spirits it proclaims release,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Pharaoh’s slaves become the “hosts of God.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His flesh is meat—His blood is drink indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He died, He rose, His people’s cause to plead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, precious blood! poured freely forth for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sins are sunk beneath thy crimson tide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more before th’ Avenger’s sword I flee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the Refuge-City, where I hide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My life’s dark page, blood-sprinkled, gleameth white;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My name shines forth in heaven in words of light."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
