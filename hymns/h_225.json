    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here would I feed upon the Bread of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here drink with Thee the royal wine of heav’n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here would I lay aside each earthly load;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here taste afresh the calm of sin forgiv’n."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have no help but Thine; nor do I need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Another arm save Thine to lean upon;"
