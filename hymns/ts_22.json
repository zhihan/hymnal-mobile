    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "万民要住在祂奇妙光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万族要因祂爱归于‘大同’。"
