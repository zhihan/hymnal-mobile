        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归耶稣，我们的君王。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂国度里完全是和睦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自由必旺盛，强暴被剪除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敌化为友，当祂凯歌同唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "剑变成镰刀，当耶稣为王。"
            }
          ]
