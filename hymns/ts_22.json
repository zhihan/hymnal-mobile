    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "万民要住在祂奇妙光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万族要因祂爱归于‘大同’。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公平与真实出自祂王杖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不法必终止，当耶稣为王。"
            }
          ]
        }
