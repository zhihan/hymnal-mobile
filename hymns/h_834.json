    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou too art the smitten Rock, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man’s thirst by Thee be filled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That frail man may stand upon Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But e’en more, God’s house to build."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Foundation Stone in Zion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tested and secure, Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Rock, the Church supporting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her foundation to impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On Thyself the Church is builded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And though many storms assail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still it stands erect, for ’gainst it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gates of hell cannot prevail."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine authority possessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It doth bind and loose in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing men into Thy kingdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan’s captives setting free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Living Stone of life art Thou, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious, chosen thus to be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living stones Thou too hast made us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in character with Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built together as a temple"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That our God may dwell therein,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we are a holy priesthood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Offering sacrifice to Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art the Son of David"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God’s temple Thou may build;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King and Priest Thou art together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy calling be fulfilled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the King, for God Thou rulest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making men submit to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Priest before God’s presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing men to enter in."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine authority doth issue"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the throne to render peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship is in the river"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To supply and give increase."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When these, balanced, go together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then God’s purpose is fulfilled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King and Priest in Thee combining,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou God’s dwelling place dost build."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art God, yet flesh becamest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God with man in Thee doth dwell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, the Temple for His glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in Thee Himself doth tell."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the Church too is the mingling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into one of God and man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So it is with every member"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the building of God’s plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, the everlasting Dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all ages art our home;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We in Thee enjoy protection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living in Thyself alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou our Sanctuary art, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We and God abide in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, God’s presence art within us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where we worship ceaselessly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Cornerstone, Foundation, Topstone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rock, and Church, and Living Stone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dwelling-place, and Sanctuary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Builder too art Thou, we own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise we give for what Thou art, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Thy wondrousness we see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant that we may be built up, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the living stones in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
