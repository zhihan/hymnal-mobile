{
  "url": "https://www.hymnal.net/cn/hymn/ch/20",
  "title": "深哉、富哉，你的智慧",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父 神，"
            },
            {
              "chord": "",
              "text": "你 曾 憑"
            },
            {
              "chord": "D",
              "text": "你 智"
            },
            {
              "chord": "",
              "text": "慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照 你 所"
            },
            {
              "chord": "D7",
              "text": "愛 心"
            },
            {
              "chord": "G",
              "text": "願，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 子 制 定 永"
            },
            {
              "chord": "D",
              "text": "遠 計"
            },
            {
              "chord": "",
              "text": "畫："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "萬"
            },
            {
              "chord": "A7",
              "text": "有 由"
            },
            {
              "chord": "",
              "text": "祂 充"
            },
            {
              "chord": "D7",
              "text": "滿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "深"
            },
            {
              "chord": "G",
              "text": "哉、 富"
            },
            {
              "chord": "",
              "text": "哉， 你"
            },
            {
              "chord": "D",
              "text": "的 智"
            },
            {
              "chord": "",
              "text": "慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "誰 能 測"
            },
            {
              "chord": "D7",
              "text": "度、 追"
            },
            {
              "chord": "G",
              "text": "尋？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "然"
            },
            {
              "chord": "C",
              "text": "而 父"
            },
            {
              "chord": "",
              "text": "神， 因"
            },
            {
              "chord": "G",
              "text": "這 智"
            },
            {
              "chord": "",
              "text": "慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "C",
              "text": "蒙 恩"
            },
            {
              "chord": "D7",
              "text": "惠、 憐"
            },
            {
              "chord": "G",
              "text": "憫！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你造万有，何其奇妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你心谁能洞鉴？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切由你、靠你、归你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此你智我见。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "深哉、富哉，你的智慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能测度、追寻？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而父神，因这智慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我蒙恩惠、怜悯！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你智让人全圈罪中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为显怜悯之大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人无不心服、口服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除你别无可夸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "深哉、富哉，你的智慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能测度、追寻？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而父神，因这智慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我蒙恩惠、怜悯！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你凭智慧、借十字架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎为我作成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫你的宝贝自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得以置于我灵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
