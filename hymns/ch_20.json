    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "空中执政，借你召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得知你智丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借她，你的万般智慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在天给彼领悟。"
            }
          ]
        }
