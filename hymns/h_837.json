{
  "url": "https://www.hymnal.net/en/hymn/h/837",
  "title": "We praise Thee, Lord, for Thy great plan",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "We praise"
            },
            {
              "chord": "",
              "text": "Thee, Lord, for"
            },
            {
              "chord": "A",
              "text": "Thy"
            },
            {
              "chord": "A7",
              "text": "great"
            },
            {
              "chord": "D",
              "text": "plan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we Thy dwelling- place may"
            },
            {
              "chord": "A",
              "text": "be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Thou live"
            },
            {
              "chord": "",
              "text": "in us, we"
            },
            {
              "chord": "A",
              "text": "filled"
            },
            {
              "chord": "A7",
              "text": "with"
            },
            {
              "chord": "D",
              "text": "Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou in the Son ex"
            },
            {
              "chord": "A",
              "text": "pressed"
            },
            {
              "chord": "A7",
              "text": "might"
            },
            {
              "chord": "D",
              "text": "be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though in Thine image made by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And given Thine authority,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet we are only made of clay"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without a trace of divinity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we receive Thee as our life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy nature we thru grace possess;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingled together, we with Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One Body glorious will express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When flows Thy life thru all our souls,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filling, renewing every part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will be pearls and precious stones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Changed to Thine image, as Thou art."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But, Lord, we fully realize"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These are not wrought men’s praise to rouse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But as material to be built"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together for Thy glorious house."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here, Lord, we give ourselves to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Receive us into Thy wise hands;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bend, break, and build together in Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be the house to meet Thy demands."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Break all the natural life for us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deal Thou with each peculiar way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we no more independent be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with all saints are one for aye."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we shall be Thy Bride beloved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together in Thy chamber abide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoy the fulness of Thy love."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How Thou wilt then be satisfied!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
