        {
          "segments": [
            {
              "chord": "A",
              "text": "我 为"
            },
            {
              "chord": "",
              "text": "甚 么 忧"
            },
            {
              "chord": "E",
              "text": "惧 疑"
            },
            {
              "chord": "",
              "text": "惑？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "A",
              "text": "岂 未"
            },
            {
              "chord": "D",
              "text": "曾 将"
            },
            {
              "chord": "",
              "text": "我 罪"
            },
            {
              "chord": "E",
              "text": "过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "归 祂"
            },
            {
              "chord": "",
              "text": "儿"
            },
            {
              "chord": "E",
              "text": "子"
            },
            {
              "chord": "E7",
              "text": "身"
            },
            {
              "chord": "A",
              "text": "上？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 所 为 我 还"
            },
            {
              "chord": "E",
              "text": "清 的"
            },
            {
              "chord": "",
              "text": "债，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "公"
            },
            {
              "chord": "A",
              "text": "义 的"
            },
            {
              "chord": "D",
              "text": "神 能"
            },
            {
              "chord": "",
              "text": "否 再"
            },
            {
              "chord": "E",
              "text": "来"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "要 我"
            },
            {
              "chord": "",
              "text": "重"
            },
            {
              "chord": "E",
              "text": "新"
            },
            {
              "chord": "E7",
              "text": "清"
            },
            {
              "chord": "A",
              "text": "偿？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的救赎永远完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已还清每一文钱－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所有罪戾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的忿怒不能威胁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我已经洒上宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠恩已经称义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你既为我领得赦免，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既给我白白恩典－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪债一起清算；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神就不会两面讨偿："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "先在我的中保身上…"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "后又要我归还。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所以我心，你当安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的救主所有功绩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已使你得开释；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当信祂的有效宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不怕神再将你弃绝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因主已为你死。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
