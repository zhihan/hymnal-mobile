  "title": "Our God is a God of purpose",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Our God"
            },
            {
              "chord": "",
              "text": "is a"
            },
            {
              "chord": "G",
              "text": "God of"
            },
            {
              "chord": "Em",
              "text": "purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "What He"
            },
            {
              "chord": "Bm",
              "text": "plans, He"
            },
            {
              "chord": "A",
              "text": "will fulfill!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Genesis"
            },
            {
              "chord": "",
              "text": "to"
            },
            {
              "chord": "G",
              "text": "Reve"
            },
            {
              "chord": "Em",
              "text": "lation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Shows His"
            },
            {
              "chord": "",
              "text": "full and"
            },
            {
              "chord": "A7",
              "text": "glorious"
            },
            {
              "chord": "D",
              "text": "will."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "What He's"
            },
            {
              "chord": "D",
              "text": "after"
            },
            {
              "chord": "A",
              "text": "is a"
            },
            {
              "chord": "D",
              "text": "building."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "In cre"
            },
            {
              "chord": "D",
              "text": "a"
            },
            {
              "chord": "A",
              "text": "tion"
            },
            {
              "chord": "E7",
              "text": "He be"
            },
            {
              "chord": "A",
              "text": "gan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "With a"
            },
            {
              "chord": "",
              "text": "simple"
            },
            {
              "chord": "G",
              "text": "garden"
            },
            {
              "chord": "Em",
              "text": "planted—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "This, the"
            },
            {
              "chord": "",
              "text": "setting"
            },
            {
              "chord": "A7",
              "text": "for His"
            },
            {
              "chord": "D",
              "text": "plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man was made, the first step God took"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To achieve His final goal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a vessel, a container,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Three parts—body, spirit, soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, of dust, a body formed him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breath of life into him breathed—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This part is man’s human spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By which God may be received."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the garden God had planted"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every tree He made to grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Good for food, to sight most pleasing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the tree of life also!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Second, then, in God’s intention"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was that man should freely eat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the life-tree in the center"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To obtain His life complete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Third, we see a river flowing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of Eden coming forth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With its flow in four directions—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "East and west and south and north"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As on Christ our life we’re feeding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living water in us flows."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah for this river"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the watering it bestows!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the flowing of the river"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gold, pearl, onyx stone we see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Three materials, raw yet precious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God’s building meant to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Look, these elements are shining’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can we, then, shine as they?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Simply by the Lord, the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Us transforming every day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Father (in this fourth step),"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Source of life, is gold divine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ the Son was wounded by us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To produce the pearl so fine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Spirit brings the stones forth—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transformation of the clay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the flowing of the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Changed we’ll be from day to day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Insufficient are materials"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious though they be and best:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These must be built up together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God’s house they may express."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fifth step: We ourselves hand over"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the building that we be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built into God’s house, His dwelling."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in each locality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Finally, in Revelation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the picture of Christ’s Bride—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consummation of God’s purpose;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is fully satisfied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem, a city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Bridegroom’s counterpart—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So the church built up together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forms the Bride for Christ’s own heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How can we, as those who truly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Long to see God reach His goal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be united and related?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By denial of our soul!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we contact Christ in spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feed on Him as life to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then His life will flow, transform us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His Bride, all glorious!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
