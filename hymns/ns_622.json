    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we fell, our human vessel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was corrupted by the fall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The humanity of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now uplifts, enriches all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ became us, incarnated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring us into Himself;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the Triune God we’re mingled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ our life saves us from self."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you yearn to love as God loves?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grow up into Christ our Head."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would you live the way that God lives?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then choose Christ to live instead."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God gave us the highest living"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the life to live this way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Spirit, God compounded"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything we need today."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Spirit of this Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every step God took became"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Elements that we experience"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And apply through Jesus’ name."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s humanity and living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the cross as our release,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brings in life in resurrection"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our one accord in peace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the church life, in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the building we are one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In one Body and one Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This our calling in the Son."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the heavens, Christ is sitting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Man enthroned and crowned."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The humanity of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the life for glory bound."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our High Priest, this Man in heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithful, merciful and true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was in all respects once tempted;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made like us, He suffered too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His dear blood now gives us boldness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To approach the throne of grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where the Lamb of God receives us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Timely help we must embrace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For the building of the Body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are human Jesusly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Spirit of this Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are built up corporately."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The humanity of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God supplies us day by day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To become God’s holy city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorifying God for aye."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
