      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，何等欢乐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们豫备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候基督来迎娶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着这样荣耀的奖赏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "痛苦试炼不介意！"
            }
          ]
        }
