              "chord": "",
              "text": "我们器皿充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灯都发光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出去迎接祂回来。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐，喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新郎快来到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时候必不再耽搁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久那婚娶之晨临到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们欢唱新诗歌。"
            }
          ]
        }
