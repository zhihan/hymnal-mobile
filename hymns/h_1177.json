    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Christ became the Spirit to speak inside of me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as the speaking Spirit He speaks unceasingly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His speaking is the water that washes me within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Discharging all my oldness, imparting Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, O Lord, speak all You want to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your speaking is Your presence—I must have it constantly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, O Lord, speak-wash my every part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by this metabolic change, make home in all my heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Christ will come, the Bridegroom, for us, His glorious Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By coming from within us the church is glorified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Person is the glory expanding now in us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This glory is our Person—how glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, O Lord, by Your economy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So flood us with Your glory, saturate us thoroughly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come out, come out, break forth in glory here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from the church, O glorious One, in glory soon appear."
            }
          ]
        }
      ],
