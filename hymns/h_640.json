    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life out of death—oh, wondrous resurrection!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seed sown in conscious weakness, raised in power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy life lived out in days of toil and friction,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Not I, but Christ” in me from hour to hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life out of death—a pilgrim path and lonely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trodden by those who glory in the Cross."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They live in fellowship with “Jesus only,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for His sake count earthly gain but loss."
            }
          ]
        }
