      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life out of death—blest mission to be ever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearing the living water brimming o’er."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life abundant from the clear, pure river,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Telling that thirsty souls need thirst no more."
            }
          ]
