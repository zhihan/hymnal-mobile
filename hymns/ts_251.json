    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂没有立下任何的律法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只说园中果子随意吃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是善恶树，万不可接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃了知识果子必定死。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "知识，知识─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知识果子不能随意吃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知识，知识─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知识果子吃了必定死。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在伊甸乐园，摆在人面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有生命树代表神自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是那毒蛇，诡诈又邪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着知识使人心偏离。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "堕落，堕落─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人不幸已中了蛇的毒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "堕落，堕落─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人需要一个完全恢复。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣基督就是生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神成肉身，满足神要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂救赎我们，又重生我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今成了我们的珍馐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣基督是我真食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃喝享受祂就得饱足。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主不是要搞我们的头脑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知识只叫人自高自大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来的目的乃是作筵席，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不重研究乃在吃喝祂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "接受，接受─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作食物，供应真充足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接受，接受─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣乃是我们生命树。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "越多吃喝祂，越不断长大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命、人数必加增不已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要清楚神今天恢复，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督不是宗教，是筵席。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "吃祂，吃祂─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "越多吃祂，祂越要增多；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃祂，吃祂─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃祂的人必因祂活着。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今天的道路是吃喝基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一件事比此重要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会借着吃，新妇得妆饰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迎接新郎带进神荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
