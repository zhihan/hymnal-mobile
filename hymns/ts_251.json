              "chord": "",
              "text": "没有一件事比此重要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃喝，吃喝─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迎接新郎带进神荣耀。"
            }
          ]
        }
