{
  "url": "https://www.hymnal.net/cn/hymn/ch/166",
  "title": "哦主在你名里聚集",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "在 你 名 里"
            },
            {
              "chord": "D",
              "text": "聚 集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "任 何"
            },
            {
              "chord": "G",
              "text": "不 见"
            },
            {
              "chord": "A7",
              "text": "惟 见"
            },
            {
              "chord": "D7",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "你 的"
            },
            {
              "chord": "",
              "text": "同 在 使 我"
            },
            {
              "chord": "C",
              "text": "欢 喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呼 召"
            },
            {
              "chord": "G",
              "text": "我 心"
            },
            {
              "chord": "",
              "text": "来"
            },
            {
              "chord": "D7",
              "text": "归"
            },
            {
              "chord": "G",
              "text": "依。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱我之爱无知其限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除了父对你的爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父神对你所有意念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心宝贵又感戴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父的喜悦、安息、喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切全都在于你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有你心能够测度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父在你身之珍惜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父将祂爱全置于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "称你作祂的爱子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而为我未曾爱惜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我得生要你死。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将来见你如你所是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要如何的欢唱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主耶稣，你的名字，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神心中永馨香！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐音调、不息歌唱、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远赞美的颂辞、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀诗章、永增欢畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直继续到永世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
