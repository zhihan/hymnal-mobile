              "chord": "",
              "text": "我属基督，凭祂活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切就都全胜过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有疑惑、一切颓丧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我栗心全止息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活之日应该欢畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "兴起来赴这筵席。"
            }
          ]
        }
