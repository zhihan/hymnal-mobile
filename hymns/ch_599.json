{
  "url": "https://www.hymnal.net/cn/hymn/ch/599",
  "title": "教会的种子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "召 會"
            },
            {
              "chord": "",
              "text": "的 種 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃 基 督 自 己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "作 生"
            },
            {
              "chord": "",
              "text": "命"
            },
            {
              "chord": "D",
              "text": "子 粒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒 在"
            },
            {
              "chord": "E7",
              "text": "人 心"
            },
            {
              "chord": "A",
              "text": "裡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "要 長"
            },
            {
              "chord": "",
              "text": "成 麥 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "B7",
              "text": "細 麵"
            },
            {
              "chord": "",
              "text": "能 產"
            },
            {
              "chord": "Em",
              "text": "出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "作 食"
            },
            {
              "chord": "",
              "text": "物"
            },
            {
              "chord": "D",
              "text": "使"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 與 人"
            },
            {
              "chord": "A",
              "text": "得"
            },
            {
              "chord": "A7",
              "text": "滿"
            },
            {
              "chord": "D",
              "text": "足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但魔鬼却来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把虚假信徒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒在圣徒中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使圣徒迷糊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像稗子阻碍"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "麦子的生长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使麦子不能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供神、人饱享。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会的生命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应该像嫩菜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从那芥菜种"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "－基督－长出来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "暂时长地上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "式微且不显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却可作食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供饥者饱餐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但魔鬼却来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使式微之菜"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "改变了性质，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也改了形态，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而长成一棵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显耀的大树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给许多恶者"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作栖身之处。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "魔鬼且利用"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变质的‘召会，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进来外邦"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "邪恶的俗规，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同将面酵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "搀在细面里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "败坏其纯洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "破坏神目的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但主作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要变化圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使他们成为"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝石和珍珠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作贵重材料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造成召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有国度之实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光荣又宝贵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "靠主作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会得生长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与基督调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变成祂形像；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像藏地宝贝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和贵重珍珠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "适合主建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进神国度。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主从‘稗子’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我们分出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救我们脱离"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那宗教‘大树，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我们除去"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有的‘面酵，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使得作食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供神人需要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们生长"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你生命里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得以被变化"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造成一体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你的召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彰显你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫你能得着"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度的实际。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
