    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天上人间有一生活；生机联结里，神人同生活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活大能全备供应，模成基督之死，不再是我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随主榜样，步祂脚踪，出宗教营外，幔内过生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同行，服于元首；成宇宙新人，带进神的国。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主！我们再献上自己，一生交你训练手里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "制作、甄陶，不断经历，成神尊贵、荣耀大器！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深愿主恢复的独特，作我生活、工作标记，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造身体，豫备新妇，接你再来，满足你心意！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同作肢体，相互提携，爱里同建造，灵中共勉励；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分赐基督，供应那灵，我们相调和，在主里合一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拼上全人，同心合意，实行活力排，建造主身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "广传福音，教导真理，照着神牧养，达到新复兴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
