    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "锡安大道，心中想往，虽经流泪谷，前进不稍退；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们愿付一切代价，顾到神权益，异象永不违。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不让我主再受迟延，作祂得胜者，铺路迎祂归，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "击败仇敌，与祂同王，神经纶高峰---锡安何华美！"
            }
          ]
        }
      ],
