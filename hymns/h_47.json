      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweet is the confidence Thou giv’st,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though high above our praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts resort to where Thou liv’st"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In heaven’s unclouded rays."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal ages shall declare"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of Thy grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those who with Thy Son shall share"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A son’s eternal place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Absent as yet, we rest in hope,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Treading the desert path,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Waiting for Him who takes us up"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond the pow’r of death."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We joy in Thee, Thy fulness shall"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our endless portion be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Thine own Son, with whom we’ll dwell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In bright eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Holy Father, keep us here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In that blest name of love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Walking before Thee without fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy perfect will to prove."
            }
          ]
        }
      ],
