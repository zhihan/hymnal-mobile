            {
              "chord": "A",
              "text": "grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lift"
            },
            {
              "chord": "G",
              "text": "up our"
            },
            {
              "chord": "",
              "text": "hearts in righteous"
            },
            {
              "chord": "A",
              "text": "ness,"
            }
