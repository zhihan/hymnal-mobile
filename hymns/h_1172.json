      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, how Satan came to damage"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Human life on the earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the Lord in all this ruin"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Raised a man full of worth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the seed of the woman"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God incarnate became"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The man Jesus—the last Adam—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To destroy Satan’s aim!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us stand up in Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His full human life,"
            }
          ]
        },
