  "title": "一道生命的水流",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一 道"
            },
            {
              "chord": "",
              "text": "生 命 的 水 流， 流 自 神 和 羔 羊 宝 座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "历 经 世 代 未 停 歇， 向 前 直 奔 流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千 万 爱 主 青 年，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 断 纵 身 入 这 流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 基 督 的 爱 吸 引， 往 另 一 方 向 追 寻。"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神 永 远 经 纶， 今 向 我 开 启， 神 来 成 为 人， 使 我 们 成 神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "产 生 并 建 造 主 生 机 身 体， 活 出 并 作 出 新 耶 路 撒 冷。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深 入 地 探 究 经 历 中 享 受， 妆 饰 并 豫 备 祂 荣 美 新 妇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这 属 天 异 象， 召 我 跟 从 主， 同 灵 同 魂， 与 职 事 同 步 武。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主 爱 激 励 我 们 献 自 己， 蒙 召 投 身 时 代 水 流 里："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启 示 高 峰， 神 人 生 活， 照 神 牧 养， 达 『新 的 复 兴』； 『荣 耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "托 付』 引 我 们 前 行， 同 著 良 人 开 展 到 全 地， 葡 萄 园 里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献 上 爱 情， 香 草 山 上， 催 促 我 主 快 临！ 临！ 主 耶 稣"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿！ 愿 你 快 再 临！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父爱赦免心，子神牧养灵，因和好职事，与神成为一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为顾神权益，奋力往前行，凭灵同行动，完成神旨意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱中受嘱咐，当彼此洗脚，肢体同背负，相互地代祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建造，爱是极超越的路，成身体模型，使主得满足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱激励我们献自己，蒙召投身时代水流里："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启示高峰，神人生活，照神牧养，达‘新的复兴’；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘荣耀托付’引我们前行，同着良人开展到全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄园里，献上爱情，香草山上，催促我主快临！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣阿！愿你快再临！"
            }
          ]
        }
      ],
      "type": "chorus"
    }
