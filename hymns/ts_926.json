{
  "url": "https://www.hymnal.net/cn/hymn/ts/926",
  "title": "一道生命的水流",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一道生命的水流，流自神和羔羊宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "历经世代未停歇，向前直奔流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千万爱主青年，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不断纵身入这流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因基督的爱吸引，往另一方向追寻。"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神永远经纶，今向我开启，神来成为人，使我们成神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "产生并建造主生机身体，活出并作出新耶路撒冷。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深入地探究经历中享受，妆饰并豫备祂荣美新妇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这属天异象，召我跟从主，同灵同魂，与职事同步武。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱激励我们献自己，蒙召投身时代水流里："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启示高峰，神人生活，照神牧养，达‘新的复兴’；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘荣耀托付’引我们前行，同着良人开展到全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄园里，献上爱情，香草山上，催促我主快临。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "良人爱吸引，童女齐追随，蹿山越岭来，陡岩隐密处；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "金辫加银钉，祂香粉薰透，满园播芬芳，全为祂享受。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠良人上来，切慕听见祂，主坚爱保守，铭刻如印戳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全心得坚固，全人成为祂，良人与佳偶，同显神的国。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父爱赦免心，子神牧养灵，因和好职事，与神成为一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为顾神权益，奋力往前行，凭灵同行动，完成神旨意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱中受嘱咐，当彼此洗脚，肢体同背负，相互地代祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建造，爱是极超越的路，成身体模型，使主得满足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱激励我们献自己，蒙召投身时代水流里："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启示高峰，神人生活，照神牧养，达‘新的复兴’；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘荣耀托付’引我们前行，同着良人开展到全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄园里，献上爱情，香草山上，催促我主快临！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣阿！愿你快再临！"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
  "metadata": {
    "category": "盼望与豫备",
    "time": "4/4",
    "hymn_code": "12314565321666545",
