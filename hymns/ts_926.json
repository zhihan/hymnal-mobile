{
  "url": "https://www.hymnal.net/cn/hymn/ts/926",
  "title": "一道生命的水流",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一 道"
            },
            {
              "chord": "",
              "text": "生 命 的 水 流， 流 自 神 和 羔 羊 寶 座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "歷 經 世 代 未 停 歇， 向 前 直 奔 流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千 萬 愛 主 青 年，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 斷 縱 身 入 這 流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 基 督 的 愛 吸 引， 往 另 一 方 向 追 尋。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神 永 遠 經 綸， 今 向 我 開 啟， 神 來 成 為 人， 使 我 們 成 神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "產 生 並 建 造 主 生 機 身 體， 活 出 並 作 出 新 耶 路 撒 冷。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深 入 地 探 究 經 歷 中 享 受， 妝 飾 並 豫 備 祂 榮 美 新 婦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 屬 天 異 象， 召 我 跟 從 主， 同 靈 同 魂， 與 職 事 同 步 武。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主 愛 激 勵 我 們 獻 自 己， 蒙 召 投 身 時 代 水 流 裡："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "啟 示 高 峰， 神 人 生 活， 照 神 牧 養， 達 『新 的 復 興』； 『榮 耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "託 付』 引 我 們 前 行， 同 著 良 人 開 展 到 全 地， 葡 萄 園 裡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "獻 上 愛 情， 香 草 山 上， 催 促 我 主 快 臨！ 臨！ 主 耶 穌"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿！ 願 你 快 再 臨！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父爱赦免心，子神牧养灵，因和好职事，与神成为一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为顾神权益，奋力往前行，凭灵同行动，完成神旨意。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱中受嘱咐，当彼此洗脚，肢体同背负，相互地代祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建造，爱是极超越的路，成身体模型，使主得满足。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱激励我们献自己，蒙召投身时代水流里："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "启示高峰，神人生活，照神牧养，达‘新的复兴’；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘荣耀托付’引我们前行，同着良人开展到全地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄园里，献上爱情，香草山上，催促我主快临！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣阿！愿你快再临！"
            }
          ]
        }
      ]
    }
  ],
