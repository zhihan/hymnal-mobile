      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All his portion, all his living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything the priests possess—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All is Christ and Christ forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His all-inclusiveness."
            }
          ]
        }
      ]
    },
