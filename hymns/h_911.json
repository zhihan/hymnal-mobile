    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the clothing of his service"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the beauty of the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious splendor do his garments,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Breast and shoulder-piece afford."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O how blessed is the priest's life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to him is all in all:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All his clothing, food, and dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And his portion therewithal."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When in sacrifice he offers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to God as God has willed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then as food he doth enjoy Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And is with His riches filled."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O how blessed is the priest's life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to him is all in all:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All his clothing, food, and dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And his portion therewithal."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Putting on the Lord as clothing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ without he doth express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eating, drinking, with Him mingled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ within doth him possess."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
