          "segments": [
            {
              "chord": "",
              "text": "All his clothing, food, and dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And his portion therewithal."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy, glorious is their dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis the increase of the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here the priests built up together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto God a house afford."
            }
          ]
        }
      ]
    },
