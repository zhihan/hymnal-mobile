{
  "url": "https://www.hymnal.net/en/hymn/ns/223",
  "title": "We are the generation",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the generation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord has waited for."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has sought us and pursued us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we touched Him, He renewed us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the time has come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all the young"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be in touch with Him!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God loves this generation—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He chose us for His plan."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We were young and disillusioned"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the age of mass confusion."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we are His choice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all rejoice—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God we say “Amen.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once we were searching,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always worrying—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When would we end our search?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we’re reborn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our veils are torn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since He brought us into the church!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At last our search has ended;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our praises fill the air."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re the chosen generation!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus loves this generation!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the time has come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all the young"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be in love with Him!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
