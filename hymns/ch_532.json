{
  "url": "https://www.hymnal.net/cn/hymn/ch/532",
  "title": "旧约时代神的律法",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "旧 约"
            },
            {
              "chord": "",
              "text": "时 代 神"
            },
            {
              "chord": "D",
              "text": "的 律"
            },
            {
              "chord": "G",
              "text": "法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃"
            },
            {
              "chord": "A",
              "text": "用 字"
            },
            {
              "chord": "",
              "text": "句 写 在"
            },
            {
              "chord": "A7",
              "text": "石"
            },
            {
              "chord": "D",
              "text": "版；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "但 是"
            },
            {
              "chord": "",
              "text": "现"
            },
            {
              "chord": "C",
              "text": "今 生"
            },
            {
              "chord": "",
              "text": "命 的"
            },
            {
              "chord": "D",
              "text": "律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "G",
              "text": "由 圣"
            },
            {
              "chord": "",
              "text": "灵 写"
            },
            {
              "chord": "D",
              "text": "在 心"
            },
            {
              "chord": "G",
              "text": "坎。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "字句律法要人为善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人的软弱借此显明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的律乃是供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人享受神的大能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "字句律法乃在外面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我对神有所认识；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的律是在里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供我以神更深启示。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "字句律法乃在外面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着死的诫命管治；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的律是在里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着活的知识节制。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个活的生命之律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面多方运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照着里面生命感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我里面管治、规正。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个管治极细、极深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我全人最深之处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来活的生命感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神自己向我供输。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因这活的生命之律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "外面教导，就不需要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神一切活的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我里面，这律教导。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，教我凭这律行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺服它的里面管理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你我有活的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并得享受你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "里面生命的各方面",
