    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的恩典够使我得救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离罪恶，得着新心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "够使我灵、魂、体都圣洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且满有主的圣灵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的恩典够助我经过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各种试炼，无论多凶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的应许抵挡了它们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘我的恩典够你使用。’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，救主一直对我说，"
