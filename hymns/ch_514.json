              "text": "我的能力显于软弱。’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的恩典是够我生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "够来引领，够来扶助；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来被提或经过死谷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的恩典都够眷顾。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到那时当我看见救主－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的美丽、祂的光荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就要俯伏并承认说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的恩典够我使用。"
            }
          ]
        }
      ]
    },
