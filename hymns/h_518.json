              "chord": "G",
              "text": "heav'n but"
            },
            {
              "chord": "C",
              "text": "Thee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None but"
            },
            {
              "chord": "F",
              "text": "Thee!"
            },
            {
              "chord": "G7",
              "text": "None but"
            },
            {
              "chord": "C",
              "text": "Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And this my song through"
            },
            {
              "chord": "G",
              "text": "life shall"
            },
            {
              "chord": "C",
              "text": "be:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for"
            },
            {
              "chord": "F",
              "text": "me!"
            },
            {
              "chord": "G7",
              "text": "Christ for"
            },
            {
              "chord": "C",
              "text": "me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He hath for me the"
            },
            {
              "chord": "F",
              "text": "serpent"
            },
            {
              "chord": "C",
              "text": "trod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "He hath"
            },
            {
              "chord": "",
              "text": "redeemed me \"by His"
            },
            {
              "chord": "C",
              "text": "blood,\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And reconciled my"
            },
            {
              "chord": "F",
              "text": "soul to"
            },
            {
              "chord": "C",
              "text": "God:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for"
            },
            {
              "chord": "F",
              "text": "me!"
            },
            {
              "chord": "G7",
              "text": "Christ for"
            },
            {
              "chord": "C",
              "text": "me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I envy not the rich their joys:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I covet not earth’s glitt’ring toys:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth can no lasting bliss bestow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Fading” is stamped on all below;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mine is a joy no end can know:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though with the poor be cast my lot:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“He knoweth best,” I murmur not:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though “vine” and “fig-tree” blight assail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The “labor of the olive fail,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And death o’er flock and herd prevail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I am now on hostile ground,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sin beset me all around,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let earth her fiercest battles wage,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And foes against my soul engage,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strong in His strength I scorn their rage:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And when my life draws to its close,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Safe in His arms I shall repose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When sharpest pains my frame pervade,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the powers of nature fade,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still will I sing through death’s cold shade;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ for me! Christ for me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
