        {
          "segments": [
            {
              "chord": "",
              "text": "当我要行你的旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我才经历无能力。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有你的荣耀自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能消失在你里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以求主：你的荣耀"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻吸引我离地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主赐我一个心志，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要得着你自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主赐我一个盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再让你心忧戚。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦我的主，我今求你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "紧紧拥我在你怀里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫你的甜美自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成我力量我安息。"
            }
          ]
        }
