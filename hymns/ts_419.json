    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我要求你的上好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我才认识我邪僻；"
            }
          ]
