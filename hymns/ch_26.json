{
  "url": "https://www.hymnal.net/cn/hymn/ch/26",
  "title": "你所给虽然甚多",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 愛"
            },
            {
              "chord": "",
              "text": "所 給 雖"
            },
            {
              "chord": "A",
              "text": "然 甚"
            },
            {
              "chord": "D",
              "text": "多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩 賜 眾"
            },
            {
              "chord": "E7",
              "text": "善 者"
            },
            {
              "chord": "A",
              "text": "哪！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但"
            },
            {
              "chord": "G",
              "text": "在 天"
            },
            {
              "chord": "",
              "text": "上， 還 未 見"
            },
            {
              "chord": "A",
              "text": "過"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚"
            },
            {
              "chord": "D",
              "text": "麼 比"
            },
            {
              "chord": "A",
              "text": "血"
            },
            {
              "chord": "A7",
              "text": "更"
            },
            {
              "chord": "D",
              "text": "大。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "就是我的信心对血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是你爱所给；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不然，恩赐虽合所缺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是虚空无益。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，神的爱，你是深海，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我罪都埋里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的不义，你都遮盖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亏欠，你都赦免。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在宝血里，我已寻出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱心的踪迹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由此我知你的宽恕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并知你的公义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "心会软弱，身会衰颓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我总安然相信；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地虽然都要销毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我锚已经抛稳。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "到了那时，我要证明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱有何价值；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但在今日我的生命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就先靠它扶持。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当赞美你！再赞美你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何不是你给："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵救主，和那使彼"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显为宝贵的力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "敬拜父",
