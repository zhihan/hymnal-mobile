    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy judgments, Lord, we must admit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are holy, righteous, fair."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We own our sins as crimson are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve no excuse to bear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve no argument, no plea;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No veil our sin can hide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, praise Thee, Lord, Thy precious blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to our sin applied!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God has not overlooked our sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But judged it once for all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His righteous fury, not on us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But on His Lamb did fall."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A new and living way is made—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We stand on legal ground;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Surety and our Substitute"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has pardon for us found."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus Lord, we worship Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption now enjoy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precious blood again we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its virtue now employ."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, Thy mercy is so vast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unlimited and free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Lamb of God, we’ll sing Thy praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all eternity!"
            }
          ]
        }
      ],
