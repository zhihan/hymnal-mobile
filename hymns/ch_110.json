      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "子所有的一切光辉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使父荣耀得发挥；"
            }
          ]
        },
        {
