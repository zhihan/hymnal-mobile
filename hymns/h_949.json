    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the hope of glory, He is my history:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life is my experience, for He is one with me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes to bring me into His glorious liberty,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That one with Him completely I’ll ever be."
