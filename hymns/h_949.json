    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the hope of glory, He is God’s mystery;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He shares with me God’s fulness and brings God into me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes to make me blended with God in every way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may share His glory with Him for aye."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes, He comes, Christ comes to glorify me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My body He’ll transfigure, like His own it then will be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes, He comes, redemption to apply!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Hope of glory He will come, His saints to glorify."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the hope of glory, redemption full is He:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption to my body, from death to set it free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes to make my body a glorious one to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And swallow death forever in victory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
