    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For God to gain His army, priesthood, and dwelling place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Defilement must be dealt with, that to Him we’d be chaste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us the same as You, Lord, truly righteous and holy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meeting Your strict requirements, becoming Your army."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In our journey to gain Christ—the good land giv’n by God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hindrances and trials would come when we walk with the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through suff’rings we’d be humbled and in spirit contrite,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be exposed through testing, thus purged and purified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To inherit the good land, we must be renumbered;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make a willing vow to Him to fulfill His standard."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the Lord’s up-to-date move, let’s fight and pay the price,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter and possess the land, our all-inclusive Christ!"
            }
