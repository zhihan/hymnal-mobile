{
  "url": "https://www.hymnal.net/cn/hymn/ch/14",
  "title": "你的信实何等坚定",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父 神，"
            },
            {
              "chord": "",
              "text": "你 是 何"
            },
            {
              "chord": "D",
              "text": "等 信"
            },
            {
              "chord": "",
              "text": "實、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何 等 可"
            },
            {
              "chord": "D7",
              "text": "信、 可"
            },
            {
              "chord": "G",
              "text": "靠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宇 宙 萬 有 都"
            },
            {
              "chord": "D",
              "text": "在 見"
            },
            {
              "chord": "",
              "text": "證，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將"
            },
            {
              "chord": "A7",
              "text": "你 信"
            },
            {
              "chord": "",
              "text": "實 宣"
            },
            {
              "chord": "D7",
              "text": "告。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "的 信"
            },
            {
              "chord": "",
              "text": "實 何"
            },
            {
              "chord": "D",
              "text": "等 堅"
            },
            {
              "chord": "",
              "text": "定！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 此 我"
            },
            {
              "chord": "D7",
              "text": "獻 敬"
            },
            {
              "chord": "G",
              "text": "拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "堅"
            },
            {
              "chord": "C",
              "text": "定 在"
            },
            {
              "chord": "",
              "text": "天， 如"
            },
            {
              "chord": "G",
              "text": "日 之"
            },
            {
              "chord": "",
              "text": "恆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永"
            },
            {
              "chord": "C",
              "text": "遠 為"
            },
            {
              "chord": "D7",
              "text": "我 存"
            },
            {
              "chord": "G",
              "text": "在！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你并无转动影儿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并无任何改迁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "昔在、今在、以后常在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永远不变。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的信实何等坚定！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为此我献敬拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坚定在天，如日之恒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远为我存在！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话像你自己可靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远不能废去；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地虽然都要灭没，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你话永存不渝。"
            }
          ]
        }
      ],
