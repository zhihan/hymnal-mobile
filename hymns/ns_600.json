{
  "url": "https://www.hymnal.net/en/hymn/ns/600",
  "title": "Dear Father God, the Sole “I AM”",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Dear Father"
            },
            {
              "chord": "",
              "text": "God, the"
            },
            {
              "chord": "G",
              "text": "sole \"I"
            },
            {
              "chord": "D",
              "text": "AM\"—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surely in"
            },
            {
              "chord": "A",
              "text": "heav'n Your"
            },
            {
              "chord": "A7",
              "text": "name's pro"
            },
            {
              "chord": "D",
              "text": "claimed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The source of all, and"
            },
            {
              "chord": "A",
              "text": "all that's"
            },
            {
              "chord": "D",
              "text": "real!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "In You"
            },
            {
              "chord": "",
              "text": "a"
            },
            {
              "chord": "D",
              "text": "lone are"
            },
            {
              "chord": "A",
              "text": "we"
            },
            {
              "chord": "A7",
              "text": "sus"
            },
            {
              "chord": "D",
              "text": "tained!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are the only One who is!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing apart from You is real!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If everything should cease to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You would exist forever still."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Matter and time and space exist"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only because You made it so,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Creating all things from Yourself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your own will, formed long ago."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You stretched Your hands and placed the stars,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Causing the universe to form;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, even in its infancy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Newer were You than what was born."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ancient of old, unworn by time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresher than Your creation laid."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No other life is life but Yours;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life cannot diminish, fade."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are beyond all time and space,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inhabiting eternity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are the uncreated One"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who is, who was, and e’er will be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You have no origin or start,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No lineage, parents, infancy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No birth, beginning, dawn, or source,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always existing, timelessly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life is indestructible!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unending! Indissoluble!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There are no limits to Your life!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal, vast, immeasurable!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Alpha, Omega, First and Last,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fuller than all of time itself—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though time has limits, You do not!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You set the bounds, not bound Yourself!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "More mighty than we can conceive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purposeful in Your heart sublime,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jehovah God whom none perceive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Utterly holy, all divine!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We bow our heads in worship here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before Your majesty on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In awe, receiving all You are!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life alone we magnify!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    }
  ],
