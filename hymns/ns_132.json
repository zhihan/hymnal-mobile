            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make home in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The new covenant ministers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are Christ’s own living letters"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inscribed with the Spirit of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To express the rich Christ to others."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, write Yourself in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inscribe in my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may write on others."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make home in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The new covenant ministers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are mirrors of the Christ of glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beholding and reflecting Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So as to be transformed inwardly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I turn my whole heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To focus on You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine in me, transform me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make home in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The new covenant ministers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are earthen vessels that are worthless"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who live by the excellent p’wer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Christ as the treasure—priceless."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You are so precious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give You my whole being;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Break me, renew me, Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make home in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grant me the experiences"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To produce such a ministry."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through revelation and sufferings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, constitute Yourself in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your all-fitting life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I learn to live."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Your sufficient grace,"
            }
          ]
        },
        {
          "segments": [
