    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold how many thousands still are lying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bound in the darksome prison-house of sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With none to tell them of the Savior's dying"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or of the life He died for them to win."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Publish glad tidings, tidings of peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tidings of Jesus, redemption and release."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis yours to save from peril of perdition"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The soul for whom the Lord His life laid down;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beware lest, slothful to fulfill your mission,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You lose one jewel that should deck His crown."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Publish glad tidings, tidings of peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tidings of Jesus, redemption and release."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Proclaim to every people, tongue, and nation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God, in whom they live and move, is love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell how He stooped to save His lost creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And died on earth that men He might approve."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Publish glad tidings, tidings of peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tidings of Jesus, redemption and release."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Give of your sons to bear the message glorious;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Give of your wealth to speed them on their way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pour out your soul for them in prayer victorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all you spend our Savior will repay."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Publish glad tidings, tidings of peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tidings of Jesus, redemption and release."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He comes again; O brothers, ere you meet Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make known to every heart His saving grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let none whom He hath ransomed fail to greet Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through your neglect unfit to see His face."
            }
          ]
        }
      ]
    },
