{
  "url": "https://www.hymnal.net/en/hymn/ns/1032",
  "title": "God’s Only Goal in Time",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s only goal in time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dispensing life to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is what this heart of mine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can absolutely trust;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God Himself in Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The flesh in time became,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now God can be my life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each time I call His name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s purpose and His plan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is more of Christ dispensed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit is the key,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where life and peace are sensed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So I will exercise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit every day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And overcome the world;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be saved from Satan’s sway."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! Call His name today!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! Call Him day by day!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! In His name we pray!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s life dispensed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m convinced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’re God’s goal and way!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s only goal in time"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to pour out His Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Spirit joined to mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Intrinsic’lly made one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fanned into a flame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would spread His fire, divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into my inward parts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This four-part heart of mine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let God’s goal be mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gain Christ while I live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consumed by holy fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My every moment give;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I am assured"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One to whom I pray"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Patrols and guards my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto that coming day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
