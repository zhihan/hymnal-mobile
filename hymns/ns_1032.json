    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! Call His name today!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! Call Him day by day!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! In His name we pray!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s life dispensed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m convinced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’re God’s goal and way!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s only goal in time"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is to pour out His Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Spirit joined to mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Intrinsic’lly made one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fanned into a flame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would spread His fire, divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into my inward parts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This four-part heart of mine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let God’s goal be mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gain Christ while I live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consumed by holy fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My every moment give;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I am assured"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One to whom I pray"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Patrols and guards my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto that coming day."
            }
          ]
        }
      ],
