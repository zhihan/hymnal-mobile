    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, look away to Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep grace your spirit finds;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This world has tribulation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Jesus, peace is thine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man’s life a stormy sea is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Much prone to surging waves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But look away to Jesus—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your heart won’t be dismayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, look away to Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Confused you will not be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If oft to Him your gaze is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll point the way for thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as He leads thee forward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though clouds or fog are there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your head incline before Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You surely will not err."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
