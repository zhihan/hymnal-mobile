    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through His Word, all things have life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything, of Him, to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the heavens now, He stands"
            }
          ]
        },
        {
