{
  "url": "https://www.hymnal.net/cn/hymn/ch/747",
  "title": "国度要求标准严格",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "國 度"
            },
            {
              "chord": "",
              "text": "要 求， 標"
            },
            {
              "chord": "D",
              "text": "準 嚴"
            },
            {
              "chord": "G",
              "text": "格，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遠"
            },
            {
              "chord": "C",
              "text": "超 律"
            },
            {
              "chord": "",
              "text": "法 所"
            },
            {
              "chord": "D",
              "text": "有 要"
            },
            {
              "chord": "",
              "text": "求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "G",
              "text": "的 要"
            },
            {
              "chord": "",
              "text": "求 無"
            },
            {
              "chord": "D",
              "text": "論 大"
            },
            {
              "chord": "G",
              "text": "小，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "無"
            },
            {
              "chord": "C",
              "text": "一 比"
            },
            {
              "chord": "",
              "text": "這 高"
            },
            {
              "chord": "D",
              "text": "而"
            },
            {
              "chord": "D7",
              "text": "難"
            },
            {
              "chord": "G",
              "text": "就。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天国近了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘应当悔改’，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是国度首一要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们心思必须转变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向神一边全面转投。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要进诸天国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须有那超凡的义；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是出乎大能生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远非律法所能为力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要进诸天国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天父旨意必须遵行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是照我心愿所选，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是照祂心意所定。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要进诸天国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须变成孩童样式；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谦卑、简单、顺服、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "易改，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫无自满、自恃、自是。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "诸天国度甚至要求"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与神一样完全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须完全合这标准，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度实际才能实践。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "国度乃是神的掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需要与神性质相合；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有借着神的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能进这神圣之国。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "国度乃是属天管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须合于属天情形；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若要与主有分这国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有借着属天生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
