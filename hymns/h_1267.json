{
  "url": "https://www.hymnal.net/en/hymn/h/1267",
  "title": "We are for the great migration",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "We are"
            },
            {
              "chord": "",
              "text": "for the great mi"
            },
            {
              "chord": "D",
              "text": "gration,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, O"
            },
            {
              "chord": "D7",
              "text": "Lord, we"
            },
            {
              "chord": "",
              "text": "seek Thy"
            },
            {
              "chord": "G",
              "text": "face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who? and when? and"
            },
            {
              "chord": "G7",
              "text": "where? Lord"
            },
            {
              "chord": "C",
              "text": "Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant us"
            },
            {
              "chord": "G",
              "text": "now Thy"
            },
            {
              "chord": "D7",
              "text": "blessed"
            },
            {
              "chord": "G",
              "text": "grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is for Thy house and city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is for Thy kingdom, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To subdue the earth before us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are all in one accord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the Father, through Christ Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Spirit’s flowing free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our spirit, on the church-ground—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This the way of victory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Burden us with Thy great plan, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrated we would be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To fulfill Thy holy purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saturate us thoroughly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Build, O build us all together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us here our lessons learn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Send us forth to many cities"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the church-life there to burn."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Many places need a beachhead"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring in Thy reign and rule."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, build up the local churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy kingdom come in full!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the earth will give Thee glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the devil get the shame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy kingdom’s rule and reigning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All will praise Thy glorious name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessed days are quickly coming;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We rejoice and give Thee praise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the glorious consummation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy royal ruling days."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah to the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah to the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah to the Spirit—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, it is done!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah for the churches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah for the saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah for the meetings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And their holy, sweet constraints!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah we will sing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah to our King!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    }
