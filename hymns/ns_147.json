    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord has regenerated me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling me out of Satan’s kingdom into Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day, He is renewing me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sanctifying, transforming me to be like Him."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a wonderful story"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of me and my glorious Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together we make our history;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A mingling of God and of man—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Becoming the New Jerusalem,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of God’s glory. Hallelujah!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, help me to live a God-man life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At home, with the saints, or wherever I would be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Taking Christ, living Christ as my life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exercising forbearance without anxiety."
            }
          ]
        }
      ]
    },
