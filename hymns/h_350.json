    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So faith bounds forward to its goal in God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love can trust her Lord to lead her there;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upheld by Him, my soul is following hard"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till God hath full fulfilled my deepest prayer."
            }
          ]
        }
