    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Conqu’ror of hell and earth and sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still with the rebel strive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter my soul and work within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And kill and make alive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "More of Thy life, and more I have,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the old Adam dies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bury me, Savior, in Thy grave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I with Thee may rise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Reign in me, Lord; Thy foes control,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who would not own Thy sway;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Diffuse Thine image through my soul;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine to the perfect day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Scatter the last remains of sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And seal me Thine abode;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O make me glorious all within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A temple built by God!"
            }
          ]
        }
      ],
