          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though good it be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have mercy, Lord, to push, to pull, lay hold of me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep me still running toward the prize."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I’ve seen Your purpose."
