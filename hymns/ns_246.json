    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I want Your best."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I want Your full blessing."
            }
          ]
        },
