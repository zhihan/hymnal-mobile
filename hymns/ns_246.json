              "chord": "",
              "text": "Though You I often limit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fail by compromise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep me in the index of Your eyes."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Mold me, shape me, Lord."
