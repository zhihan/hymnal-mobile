          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m desperate, Lord, that You would have Your way with me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Others could touch You then through me."
