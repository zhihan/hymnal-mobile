        {
          "segments": [
            {
              "chord": "",
              "text": "照着麦基洗德，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督作大祭司。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更美之约，更美职事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以饼和酒，供应扶持。"
            }
          ]
        }
