          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何能接触神？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是惟一通路。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵里联着三者─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与宝座并至圣所。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是团体人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非流荡基督徒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要投入身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "勿再单独思虑。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每逢聚集，一同敞开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "环绕宝座，赞美敬拜。"
            }
          ]
