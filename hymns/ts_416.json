    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同奔入至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直达施恩宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "开始于外院子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也经过了圣所。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界丢弃，罪恶消除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入幔内，与神同住。"
            }
          ]
        },
        {
          "segments": [
