    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "叫人活着的是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉体是无益的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我对你们说的话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是灵、是生命。"
            }
          ]
