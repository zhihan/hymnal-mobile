          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要借着话里的水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来把召会洗净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为圣洁，献给主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作荣耀的召会。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（弗五26～27）"
            }
          ]
        }
