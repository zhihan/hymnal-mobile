{
  "url": "https://www.hymnal.net/cn/hymn/ts/211",
  "title": "人活着不是单靠食物",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "经上记着："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人活着不是单靠食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是靠着神口里"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所出的一切话。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（太四4）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "叫人活着的是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉体是无益的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我对你们说的话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是灵、是生命。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（约六63）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我得着你的言语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就当食物吃了。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的话在我心中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我欢喜快乐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（耶十五16）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要拿着灵的宝剑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这灵是神的话─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着多方的祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每次都在灵里。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（弗六17～18）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
