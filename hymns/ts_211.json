          "chord": "",
          "text": "我得着你的言语，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "就当食物吃了。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你的话在我心中，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "是我欢喜快乐。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "（耶十五16）"
