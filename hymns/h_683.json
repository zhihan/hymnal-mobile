    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The very dimness of my sight"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Makes me secure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For, groping in my misty way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I feel His hand; I hear Him say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My help is sure."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot read His future plans;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But this I know:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have the smiling of His face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the refuge of His grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While here below."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enough; this covers all my wants;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And so I rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For what I cannot, He can see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in His care I saved shall be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever blest."
            }
          ]
        }
      ]
