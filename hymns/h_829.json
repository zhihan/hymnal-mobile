    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Satan hath the false believers sown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Among the saints as tares among the wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring confusion and to hinder growth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That they may not fulfill God's plan complete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church's life just as the herb must be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grown out of Christ, who is the mustard seed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hidden and transient, little on the earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But good for food the hungry ones to feed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Satan came and made the little herb"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To change its nature and to change its form,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That fully grown it did a tree become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where many evil ones may lodge and swarm."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan has also used the fallen \"church\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Evil and heathen practice to include,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As leaven mingled with the meal of wheat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus to corrupt its purity as food."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Christ as life would so transform the saints"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That they may be as pearl and precious stone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the materials suitable to build"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into His Church to make His Kingdom known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Such an assembly grown in Christ as life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transformed and built with Christ in them annealed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is as the goodly pearl for preciousness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as the treasure hidden in the field."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, separate us from the devil's \"tares,\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each one deliver from the monstrous \"tree,\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all the \"leaven\" may Thou purify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be as food to man and Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Cause us to grow in life divine each day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be transformed and built by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into a body to express Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou in us Thy Church and Kingdom see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
