{
  "url": "https://www.hymnal.net/en/hymn/h/104",
  "title": "Alas! and did my Savior bleed",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Alas!"
            },
            {
              "chord": "",
              "text": "and did my"
            },
            {
              "chord": "D",
              "text": "Savior"
            },
            {
              "chord": "G",
              "text": "bleed?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And did my Sov'reign"
            },
            {
              "chord": "D",
              "text": "die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "Would"
            },
            {
              "chord": "G",
              "text": "He devote"
            },
            {
              "chord": "",
              "text": "that"
            },
            {
              "chord": "C",
              "text": "sacred"
            },
            {
              "chord": "",
              "text": "head"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For"
            },
            {
              "chord": "D",
              "text": "such a"
            },
            {
              "chord": "",
              "text": "worm"
            },
            {
              "chord": "D7",
              "text": "as"
            },
            {
              "chord": "G",
              "text": "I?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Was it for sins that I had done"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He groaned upon the tree?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amazing pity! grace unknown!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love beyond degree!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Well might the sun in darkness hide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shut his glories in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the incarnate Maker died"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For man, His creature’s sin."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus might I hide my blushing face"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While His dear cross appears"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dissolve my heart in thankfulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And melt mine eyes to tears."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But drops of grief can ne’er repay"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The debt of love I owe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here Lord, I give myself away:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis all that I can do."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
