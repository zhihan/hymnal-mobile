    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He saves us to the uttermost"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His life-giving power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transfusing Himself into us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He saves us hour by hour."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He saved the lost by coming in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s saving now from more than sin:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s saving us to glory!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Lord was constituted priest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be a real life-giver;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life is the nature of this One"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can from self deliver:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life is indestructible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By it He saves us to the full:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise God, He’s fully able!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His life is fully qualified"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring us through to glory;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were it not for His tested life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twould be another story"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life was fully tried on earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To crucifixion from His birth:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He passed through death and Hades."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s pledged to save us to the full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life is operating;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s doing everything for us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis all for our perfecting;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life’s a failure at its best,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only His life can stand the test:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life brings full salvation!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s living now to intercede,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Continuing forever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He undertakes into the age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His priesthood changes never;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He always lives to intercede,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such a High Priest is what we need:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s higher than the heavens."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come forward now to God through Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er shrink back to destruction;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come forward now to get the life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which brings the proper function;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come forward now the life to take,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By life His people us He’ll make,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And swallow death forever."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
