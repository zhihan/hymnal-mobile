    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A purer, deeper lover of Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, keep our hearts so tenderly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach us to trust You and obey."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, soften and renew."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, capture us, appear to us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re matchless in Your beauty and worth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide, we, in Your preciousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re lovers of this living Person."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We thank You, Lord, You’re reality."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So sweet and comely is Your presence."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re precious and You’re lovely, Dear Lord Jesus."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re drawn and captured by You, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve won our hearts so joyously."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can’t but help, Lord, fall in love with You."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We long that You’d be satisfied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grant our hearts for You to burn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Appear to us, Lord, day by day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until we’re fully drawn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We come to You by Your embrace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We cling to You, Lord, by Your might."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grow in us, make home in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, You’re our Beloved Bridegroom."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We love, we love with all of our hearts."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Please make Your home, Lord, more in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep spreading until Your work is done."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re drawn and captured by You, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve won our hearts so joyously."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We cannot help but fall in love with You."
            }
          ]
        }
      ]
    }
