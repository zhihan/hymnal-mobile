            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 所 有 不 过 愁"
            },
            {
              "chord": "C",
              "text": "烦， 人"
            },
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "G",
              "text": "坎 坷"
            },
            {
              "chord": "A",
              "text": "艰"
            },
            {
              "chord": "D",
              "text": "难；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 怨"
            },
            {
              "chord": "G",
              "text": "叹："
            },
            {
              "chord": "C",
              "text": "奋 鬬"
            },
            {
              "chord": "G",
              "text": "努 力"
            },
            {
              "chord": "",
              "text": "竟 换"
            },
            {
              "chord": "D",
              "text": "得 失"
            },
            {
              "chord": "G",
              "text": "望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 感"
            },
            {
              "chord": "Em",
              "text": "伤： 为"
            },
            {
              "chord": "",
              "text": "何"
            },
            {
              "chord": "B",
              "text": "前 景"
            },
            {
              "chord": "",
              "text": "始 终"
            },
            {
              "chord": "Em",
              "text": "凄"
            },
            {
              "chord": "D",
              "text": "凉！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真 的 神"
            },
            {
              "chord": "G",
              "text": "阿， 你"
