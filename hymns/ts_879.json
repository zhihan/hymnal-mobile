      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是耶稣将我寻回，正当我万念俱灰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂平安入我心内，涌出喜乐眼泪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的信终于有了生命的回响，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的心流进神圣安息、盼望！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主耶稣，我感谢你，与我联结为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人像你真情实意，我馀生都给你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何喜乐，不再是我，是基督在我活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂救我脱罪、死、魔，经历死而复活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我高喊：耶稣，耶稣，祂真是爱我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我颂赞：祂赐救恩这大！这博！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，真的神是我耶稣，神是万主之主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心、我命为你倾注，爱着你就满足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
