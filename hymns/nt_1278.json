    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the church of Jesus there is life for you,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Warm as summer sunshine, sweet as morning dew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why should you be fearful, why take anxious thought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the church of Jesus cares for those He bought?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the church of Jesus there is work for you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such as even angels might rejoice to do;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why stand idly sighing for some life work grand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While the church of Jesus seeks your reaping hand?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the church of Jesus there’s a place for you;"
