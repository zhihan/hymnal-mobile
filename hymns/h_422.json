    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart is weak and poor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until it master find:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It has no spring of action sure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It varies with the wind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It cannot freely move"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou hast wrought its chain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enslave it with Thy matchless love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And deathless it shall reign."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My power is faint and low"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till I have learned to serve:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It wants the needed fire to glow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It wants the breeze to nerve;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It cannot drive the world"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until itself be driven;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its flag can only be unfurled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou shalt breathe from heaven."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My will is not my own"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thou hast made it Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If it would reach the monarch’s throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It must its crown resign;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It only stands unbent"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amid the clashing strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When on Thy bosom it has leant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And found in Thee its life."
            }
          ]
        }
