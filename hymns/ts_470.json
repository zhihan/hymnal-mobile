    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天来圣谕普赐万邦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "历代人当称羡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁竟擅用无知言语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阻挡神圣意念？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同宇宙阔长高深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浩瀚洋海无边："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主话真光越照越明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放真理无限。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "先圣迈开追寻旅程，"
            }
          ]
        },
        {
          "segments": [
