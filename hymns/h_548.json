        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "Christ in"
            },
            {
              "chord": "",
              "text": "me the"
            },
            {
              "chord": "A7",
              "text": "treasure"
            },
            {
              "chord": "D",
              "text": "laid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His container I must be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the"
            },
            {
              "chord": "A",
              "text": "content"
            },
            {
              "chord": "",
              "text": "He in"
            },
            {
              "chord": "D",
              "text": "me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In His image I was made,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fit that Christ should all pervade;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the vessel God did form"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the content uniform."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In my spirit He remains,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His power He sustains;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit one with me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is my reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Moving in me day by day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingling with me all the way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my steps He regulates,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every part He saturates."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Him expressing from within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making Him to others seen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I transparent have to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He may be shown thru me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Transformation is my need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be broken more indeed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the clay may change in form,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the treasure to conform."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
