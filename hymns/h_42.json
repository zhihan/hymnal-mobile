    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God of mercy—Father!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The one unchanging claim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The brightest hopes, we gather"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Christ’s most precious name:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What always sounds so sweetly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thine unwearied ear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has freed our souls completely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From all our guilt and fear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The trembling sinner feareth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God can ne’er forget;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But one full payment cleareth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His memory of all debt."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When nought beside could free us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or set our souls at large,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The death of God’s Beloved"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Secured a full discharge."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No wrath God’s heart retaineth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To usward who believe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No dread in ours remaineth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we His love receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Returning sons He kisses,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with His robe invests;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His perfect love dismisses"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All terror from our breasts."
            }
          ]
        }
      ],
