{
  "url": "https://www.hymnal.net/cn/hymn/ch/126",
  "title": "我的救主你爱为何",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 的"
            },
            {
              "chord": "D",
              "text": "救"
            },
            {
              "chord": "G",
              "text": "主， 你"
            },
            {
              "chord": "D",
              "text": "愛 為"
            },
            {
              "chord": "Em",
              "text": "何"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "這"
            },
            {
              "chord": "G",
              "text": "摯！ 這"
            },
            {
              "chord": "",
              "text": "寬！ 這"
            },
            {
              "chord": "D",
              "text": "博！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "Em",
              "text": "然，"
            },
            {
              "chord": "B",
              "text": "我"
            },
            {
              "chord": "Em",
              "text": "心、"
            },
            {
              "chord": "D",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "命、 我"
            },
            {
              "chord": "D",
              "text": "力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "那"
            },
            {
              "chord": "C",
              "text": "肯"
            },
            {
              "chord": "Am",
              "text": "完"
            },
            {
              "chord": "D",
              "text": "全 歸"
            },
            {
              "chord": "G",
              "text": "你！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们爱你，因你自己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上下千秋无匹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们爱你，因你忍受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十字架的耻羞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人爱所夸，不过就是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代友受死的事；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你却为仇敌被杀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁曾如此爱法？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然你有神的形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安居荣耀天乡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你却来成为奴仆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲历忧患、痛苦。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你愿凡事都像世人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（除了罪恶无分，）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫我们完全像你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然前此不一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "像你温柔、像你坚刚、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像你在凡事上！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣上加荣，天天更变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到与你相见。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的主，我们的心"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍藏你的爱情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今后我们对你尊名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永要感激、恭敬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "赞美主",
