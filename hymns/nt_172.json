    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot yield enough to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior, Master, Friend;"
            }
          ]
        },
        {
          "segments": [
