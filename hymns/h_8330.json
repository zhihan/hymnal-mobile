{
  "url": "https://www.hymnal.net/cn/hymn/h/8330",
  "title": "How vast, immense, and measureless",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "How vast,"
            },
            {
              "chord": "",
              "text": "immense,"
            },
            {
              "chord": "Am",
              "text": "and measure"
            },
            {
              "chord": "D",
              "text": "less"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "The"
            },
            {
              "chord": "G",
              "text": "love of"
            },
            {
              "chord": "Am",
              "text": "Christ"
            },
            {
              "chord": "D7",
              "text": "to"
            },
            {
              "chord": "G",
              "text": "me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "How"
            },
            {
              "chord": "G",
              "text": "else could"
            },
            {
              "chord": "C",
              "text": "such a"
            },
            {
              "chord": "A7",
              "text": "wretch as"
            },
            {
              "chord": "D7",
              "text": "I"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be"
            },
            {
              "chord": "G",
              "text": "blessed"
            },
            {
              "chord": "C",
              "text": "so"
            },
            {
              "chord": "Am",
              "text": "gra"
            },
            {
              "chord": "D7",
              "text": "cious"
            },
            {
              "chord": "G",
              "text": "ly?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring me back unto Himself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord His all did spend;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So I would gladly bear the cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And follow to the end."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My all I have forsaken now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This blessed Christ to gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now life or death is no concern—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What else can me restrain?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My dear ones, wealth ambition, fame—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What can they offer me?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My gracious Lord for me was poor;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him I poor would be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My precious Savior now I love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him only would I please."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him all gain a loss becomes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And comfort holds no ease."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art my comfort, gracious Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I've none in heav'n but Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And who but Thee is there on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With whom I love to be?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though loneliness and trials come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My griefs I'd rise above."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This only would I ask Thee, Lord:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surround me with Thy love!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O gracious Lord, I now beseech,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Guide me through every stage;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stand by and strengthen me to go"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through this dark, evil age."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The world, the flesh, and Satan too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do tempt my soul apace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without Thy love and strength'ning power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I may Thy name disgrace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The time, dear Lord, is running short;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From earth my soul set free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou dost come, I'll sing with joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah to Thee!"
            }
          ]
        }
      ]
    }
  ],
