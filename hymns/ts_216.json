{
  "url": "https://www.hymnal.net/cn/hymn/ts/216",
  "title": "喝！吃！看！",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "喝！ 從"
            },
            {
              "chord": "",
              "text": "寶 座 流 出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "純 淨 生 命 河 的 水！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "喫！ 生"
            },
            {
              "chord": "",
              "text": "命 樹 果 子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豐 碩 又 纍 纍 垂"
            },
            {
              "chord": "G",
              "text": "垂！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看！ 那 滿 城 光 輝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 需 燈 光 或 日、"
            },
            {
              "chord": "C",
              "text": "月，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "她 沒"
            },
            {
              "chord": "D7",
              "text": "有 黑"
            },
            {
              "chord": "G",
              "text": "夜！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "來 罷！ 哦， 來 罷！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聖 靈 與 新 婦"
            },
            {
              "chord": "G7",
              "text": "說；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "來 罷！"
            },
            {
              "chord": "",
              "text": "哦， 來 罷！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聽 見 的 人 也"
            },
            {
              "chord": "G",
              "text": "說；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "來 罷！ 哦， 來 罷！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "口 渴 又 願 意"
            },
            {
              "chord": "C",
              "text": "的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "可 白"
            },
            {
              "chord": "D7",
              "text": "白 來"
            },
            {
              "chord": "G",
              "text": "喝！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是我们河水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在里面涌流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是生命树果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供我们享受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督乃是我们的光、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "晨星与白昼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂乃是万有！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！哦，来罢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵与新妇说；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！哦，来罢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听见的人也说；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！哦，来罢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "口渴又愿意的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可白白来喝！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们洗净袍子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有权来吃生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘哦主，阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们真有福！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们操练我们的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来经历基督─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的基督！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
