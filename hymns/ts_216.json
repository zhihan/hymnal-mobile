            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄姊妹同心站住"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "合一的立场；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会乃是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新耶路撒冷豫尝─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的豫尝！"
            }
          ]
        }
