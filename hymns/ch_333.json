  "title": "你是千万人中之第一人",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "E7",
              "text": "你 的"
            },
            {
              "chord": "A",
              "text": "靈 豈"
            },
            {
              "chord": "",
              "text": "非 已 見"
            },
            {
              "chord": "Bm",
              "text": "祂 過？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 的"
            },
            {
              "chord": "E",
              "text": "心 曾"
            },
            {
              "chord": "",
              "text": "否"
            },
            {
              "chord": "E7",
              "text": "被 祂"
            },
            {
              "chord": "",
              "text": "所 奪？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 當"
            },
            {
              "chord": "A",
              "text": "認 祂"
            },
            {
              "chord": "",
              "text": "為 人 中 第"
            },
            {
              "chord": "Bm",
              "text": "一 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "歡 喜"
            },
            {
              "chord": "E",
              "text": "選 那"
            },
            {
              "chord": "",
              "text": "上"
            },
            {
              "chord": "E7",
              "text": "好 的"
            },
            {
              "chord": "",
              "text": "福"
            },
            {
              "chord": "A",
              "text": "分。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 千 萬 人 中"
            },
            {
              "chord": "Bm",
              "text": "之 第"
            },
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "E",
              "text": "人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦， 求"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "開 我"
            },
            {
              "chord": "",
              "text": "眼，"
            },
            {
              "chord": "B7",
              "text": "並 奪"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "E",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "摔 碎"
            },
            {
              "chord": "",
              "text": "眾"
            },
            {
              "chord": "D",
              "text": "偶 像，"
            },
            {
              "chord": "E7",
              "text": "並 歡"
            },
            {
              "chord": "",
              "text": "然"
            },
            {
              "chord": "A",
              "text": "加 冠"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 為"
            },
            {
              "chord": "",
              "text": "千"
            },
            {
              "chord": "A",
              "text": "萬 人"
            },
            {
              "chord": "",
              "text": "中"
            },
            {
              "chord": "Bm",
              "text": "之 第"
            },
            {
              "chord": "E7",
              "text": "一"
            },
            {
              "chord": "A",
              "text": "人！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世界的一切虚荣、珍宝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽都是偶像，使人颠倒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "镀过金，使人不容易淡泊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸过蜜，使人真难超脱。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是千万人中之第一人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，求你开我眼，并夺我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摔碎众偶像，并欢然加冠"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你为千万人中之第一人！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "甚么会使地上的偶像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失去它那美丽的模样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不是灰心、失望或劝勉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是‘无价之宝’的一现！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是千万人中之第一人！"
            }
