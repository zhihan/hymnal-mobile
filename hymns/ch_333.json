          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就会使偶像化成灰土；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是祂荣耀美丽的倾投，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并祂心里柔爱的流露。"
            }
          ]
        }
      ]
    },
