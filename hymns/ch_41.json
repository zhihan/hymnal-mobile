{
  "url": "https://www.hymnal.net/cn/hymn/ch/41",
  "title": "哦神是你召我们",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "哦， 神，"
            },
            {
              "chord": "",
              "text": "是 你 召"
            },
            {
              "chord": "G",
              "text": "我 们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来"
            },
            {
              "chord": "G7",
              "text": "看 你"
            },
            {
              "chord": "",
              "text": "的 儿"
            },
            {
              "chord": "C",
              "text": "子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 是 你 心 的"
            },
            {
              "chord": "G",
              "text": "奇"
            },
            {
              "chord": "C",
              "text": "珍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "G",
              "text": "行 完"
            },
            {
              "chord": "G7",
              "text": "你 意"
            },
            {
              "chord": "C",
              "text": "思；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "们 因"
            },
            {
              "chord": "G7",
              "text": "你 肯"
            },
            {
              "chord": "C",
              "text": "白 舍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "F",
              "text": "的 独"
            },
            {
              "chord": "",
              "text": "一 心"
            },
            {
              "chord": "G",
              "text": "爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才"
            },
            {
              "chord": "C",
              "text": "知 你"
            },
            {
              "chord": "F",
              "text": "心 是"
            },
            {
              "chord": "C",
              "text": "真 切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要"
            },
            {
              "chord": "G",
              "text": "救 我"
            },
            {
              "chord": "G7",
              "text": "们 脱"
            },
            {
              "chord": "C",
              "text": "害。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，圣父，怜悯的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们因子的名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才敢向你常求恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才有永远生命。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你耳所常爱听闻－，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "悠扬如音乐的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已叫我们的灵魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱尽所有猜疑。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "战兢罪人心常怕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你永不忘先前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂一次的受罚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你不再记念。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当无甚么可以使，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们得自由时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父，你爱子的受死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还了我们罪值。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你对我们（信祂的）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心中已无忿怒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现今也无忌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因知你已眷顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "回家儿女你亲嘴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并赐光明衣袍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的慈爱已安慰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们心中苦恼。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，你怎么能喜欢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们这样的人？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们岂非使你难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂非见你就恨？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，真希奇，最希奇！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神圣奥秘！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从前发声如雷的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说：‘罪人，我属你！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
