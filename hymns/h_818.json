    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the very Word of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is God’s explanation true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s full embodiment is He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s own image brings to view."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Image of God invisible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Effulgence of God’s glory fair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s fulness ever dwells in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s testimony He doth bear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church the myst’ry is of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For He is now to man unshown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No man on earth may see Him now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But thru the Church He is made known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church is Christ’s expression full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In her Christ dwelleth bodily;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She is His duplication true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And man in her Himself may see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church the image has of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She is His increase and His spread;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s very self is found in her"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Body, she, to Christ the Head."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus, in the Son the Father is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now the Spirit is the Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit of the triune God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is in the Church and with her one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
