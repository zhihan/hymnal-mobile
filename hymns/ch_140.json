{
  "url": "https://www.hymnal.net/cn/hymn/ch/140",
  "title": "主你是那可爱新郎",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 你"
            },
            {
              "chord": "F",
              "text": "是 那"
            },
            {
              "chord": "",
              "text": "可 愛"
            },
            {
              "chord": "C",
              "text": "新 郎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 所 選 立，"
            },
            {
              "chord": "D",
              "text": "我 所"
            },
            {
              "chord": "G",
              "text": "愛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "你 的"
            },
            {
              "chord": "F",
              "text": "自 己"
            },
            {
              "chord": "",
              "text": "富 有"
            },
            {
              "chord": "C",
              "text": "吸 引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 怎 能"
            },
            {
              "chord": "G",
              "text": "不 愛"
            },
            {
              "chord": "C",
              "text": "戴！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱良人，我爱慕你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的宝贵谁能言！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的爱情，我深珍爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的可爱何无限！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你比美者还要更美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比甜者还更甜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既柔细、你又亲切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是何等的完全！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的衣服满了没药，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的口中满恩惠！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你受苦馨香气中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭爱珍藏你宝贵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神曾用那喜乐的油，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏你胜过你同伴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你那些‘象牙宫’中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发出对你的称赞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已永远赐福与你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已胜过众仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今见你加冕、登极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "权柄、威严，无可比。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是‘万国所羡慕的，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们必知你价值；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃‘超乎万人之上，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远配得我赏识！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "赞美主",
    "time": "4/4",
    "hymn_code": "536176531123565",
    "midi_tune_url": "https://www.hymnal.net/Hymns/Chinese/midi/tunes/c0140_tune.midi",
    "related": [
