{
  "url": "https://www.hymnal.net/cn/hymn/h/1164",
  "title": "Jesus, the all-inclusive land",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Jesus,"
            },
            {
              "chord": "",
              "text": "the"
            },
            {
              "chord": "C",
              "text": "all- in"
            },
            {
              "chord": "D",
              "text": "clusive"
            },
            {
              "chord": "G",
              "text": "land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is every"
            },
            {
              "chord": "D",
              "text": "thing to"
            },
            {
              "chord": "G",
              "text": "me:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A"
            },
            {
              "chord": "D",
              "text": "Christ of"
            },
            {
              "chord": "",
              "text": "brooks, of"
            },
            {
              "chord": "G",
              "text": "depths and"
            },
            {
              "chord": "",
              "text": "streams,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "A",
              "text": "fountains"
            },
            {
              "chord": "A7",
              "text": "bubbling"
            },
            {
              "chord": "D7",
              "text": "free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Springing"
            },
            {
              "chord": "",
              "text": "from"
            },
            {
              "chord": "C",
              "text": "valleys"
            },
            {
              "chord": "G",
              "text": "and from"
            },
            {
              "chord": "",
              "text": "hills,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flowing till"
            },
            {
              "chord": "C",
              "text": "every"
            },
            {
              "chord": "G",
              "text": "part He"
            },
            {
              "chord": "",
              "text": "fills,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He waters"
            },
            {
              "chord": "C",
              "text": "us— how"
            },
            {
              "chord": "",
              "text": "glori"
            },
            {
              "chord": "G",
              "text": "ous—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By"
            },
            {
              "chord": "D",
              "text": "His"
            },
            {
              "chord": "G",
              "text": "life!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is now the land of wheat—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incarnate, crucified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But resurrection life is He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By barley signified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is a land of figs and vines—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blood of the grape, the cheering wine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With such supplies He satisfies—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ our land!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a rich, abundant Christ:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our pomegranate true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The olive tree whose oil is now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anointing us anew."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rich milk and honey He doth bring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweet, satisfying, nourishing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Christ is such; He is so much!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a Christ!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In our good land we eat the bread—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is no scarcity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We never lack one thing in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So rich, so full is He."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is a land so vast, immense;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is complete in every sense."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How He expands—land of all lands—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our heart!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is a land of iron stones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whence comes authority."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must dig out this solid Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bind His enemy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we must through the sufferings pass"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be refined as burnished brass."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With iron bind, as brass refined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is our need."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, how we bless Thee for this land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The all-inclusive Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We've eaten Him, we're filled with Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O how He has sufficed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Teach us to labor constantly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon this vast reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is our joy, this our employ—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ our land!"
            }
          ]
        }
      ]
    }
  ],
