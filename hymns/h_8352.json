    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our heart may be changing often,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But our need He won’t forsake."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though we spurn Him, still He loves us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worldly friends our hearts would break."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He responds with faithful keeping"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that we to Him would trust."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the uttermost He loves us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever loving us He must."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We remain unfair, rebellious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grieve His heart, His love forget,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Quickly bow unto some idol,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strangely never feel regret."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Idols quickly tarnish, vanish,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Powerless to meet our need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He to whom we’ve been ungrateful"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is a changeless friend indeed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He receives us, loves and comforts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brings us closer to His heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He consoles through changing seasons,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His love will ne’er depart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, upon such care reflecting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your love we shout Your praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts melt with grateful worship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give thanks through endless days."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
