      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the Lord's Anointed, reigning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O'er the life He died to win,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily shall reveal more fully"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His great power, without, within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What thou never could'st accomplish"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall His Spirit work through thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While thy soul this witness beareth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis not I, but Christ in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him dwelleth all God's fulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him thou art made complete;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rise, and claim thy heavenly birthright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kneeling at thy Father's feet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will never disappoint thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise Him that the gift is thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then go forth to live each moment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On sufficiency divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I come, and simply resting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Thy faithful, changeless word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I believe the blood doth cleanse me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And that Christ is crowned Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant henceforth a ceaseless outflow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy life and love through me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reaching those who sit in darkness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Winning priceless souls to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
