{
  "url": "https://www.hymnal.net/cn/hymn/ch/511",
  "title": "主已知道你的挫折",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 已"
            },
            {
              "chord": "",
              "text": "知 道 你"
            },
            {
              "chord": "A",
              "text": "的 挫"
            },
            {
              "chord": "D",
              "text": "折！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 已 知"
            },
            {
              "chord": "A",
              "text": "道 你"
            },
            {
              "chord": "D",
              "text": "的 軟"
            },
            {
              "chord": "A",
              "text": "弱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 全 知"
            },
            {
              "chord": "E",
              "text": "道 你"
            },
            {
              "chord": "E7",
              "text": "的 無"
            },
            {
              "chord": "A",
              "text": "告！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 的"
            },
            {
              "chord": "D7",
              "text": "話"
            },
            {
              "chord": "G",
              "text": "說： 我"
            },
            {
              "chord": "A",
              "text": "已"
            },
            {
              "chord": "A7",
              "text": "知"
            },
            {
              "chord": "D",
              "text": "道。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知你能受甚试炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知你是需何恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂早知你所有遭遇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是你主，何必疑惧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然多人讥讽、反对，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲友离弃，旅伴误会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂深知你的一切；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有主知道你可安歇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "重担只要交托给主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叹息只要向祂倾吐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂心爱你，知你忧苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必施恩，祂必看顾。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主既知道，足慰我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主既知道，我便欢欣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主既知道，祂必搭救！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主既知道，我还何求？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
