      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Can a woman’s tender care"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cease towards the child she bare?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, she may forgetful be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet will He remember me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His is an unchanging love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Higher than the heights above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deeper than the depths beneath,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Free and faithful, strong as death."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I shall see His glory soon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the work of grace is done;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Partner of His throne shall be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such is His great love for me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, it is my chief complaint"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That my love is weak and faint;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet I love Thee, and adore:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh for grace to love Thee more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
