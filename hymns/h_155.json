              "text": "healed my"
            },
            {
              "chord": "D",
              "text": "wound;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sought me"
            },
            {
              "chord": "G",
              "text": "wand'ring,"
            },
            {
