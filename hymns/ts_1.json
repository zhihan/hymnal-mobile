{
  "url": "https://www.hymnal.net/cn/hymn/ts/1",
  "title": "开口赞美",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "当 我"
            },
            {
              "chord": "",
              "text": "们 开 口"
            },
            {
              "chord": "D",
              "text": "赞"
            },
            {
              "chord": "D7",
              "text": "美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主"
            },
            {
              "chord": "G",
              "text": "就 得"
            },
            {
              "chord": "",
              "text": "著 荣"
            },
            {
              "chord": "D",
              "text": "耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当"
            },
            {
              "chord": "G",
              "text": "欢 声"
            },
            {
              "chord": "G7",
              "text": "响 彻"
            },
            {
              "chord": "C",
              "text": "云 霄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天"
            },
            {
              "chord": "D",
              "text": "使 拍"
            },
            {
              "chord": "D7",
              "text": "手 叫"
            },
            {
              "chord": "G",
              "text": "好！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 是 活 神"
            },
            {
              "chord": "D",
              "text": "见 证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "该 让 世 人 知"
            },
            {
              "chord": "G",
              "text": "道；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒 但 全"
            },
            {
              "chord": "G7",
              "text": "军 必"
            },
            {
              "chord": "C",
              "text": "溃 散，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "闻"
            },
            {
              "chord": "G",
              "text": "声 四"
            },
            {
              "chord": "D7",
              "text": "处 窜"
            },
            {
              "chord": "G",
              "text": "逃。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们闭口就失败，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "换来魔鬼嘲笑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此为何不开火，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到把他赶跑？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以‘赞美为祭’献上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大大欢呼释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能说这是丢脸？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为神应该发狂！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世界从未助我们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向主献赞美祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从未向祂归荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从未向祂感激。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我们岂需要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得允许而赞美？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喊出！释放你的灵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂赐无限恩惠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄们，不要静默！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "姊妹们，大声喊！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神的得胜祝福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传遍远近四方。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在是赞美之时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任何代价不顾！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂救恩而喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂怜悯欢呼！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
