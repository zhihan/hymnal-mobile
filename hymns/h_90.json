{
  "url": "https://www.hymnal.net/en/hymn/h/90",
  "title": "Lord, accept our feeble song",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "Lord, ac"
            },
            {
              "chord": "F",
              "text": "cept our"
            },
            {
              "chord": "",
              "text": "feeble"
            },
            {
              "chord": "C",
              "text": "song!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pow'r and praise to"
            },
            {
              "chord": "D",
              "text": "Thee be"
            },
            {
              "chord": "G",
              "text": "long;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "We would"
            },
            {
              "chord": "F",
              "text": "all Thy"
            },
            {
              "chord": "",
              "text": "grace re"
            },
            {
              "chord": "C",
              "text": "cord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy, gracious,"
            },
            {
              "chord": "G",
              "text": "loving"
            },
            {
              "chord": "C",
              "text": "Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Rich in glory, Thou didst stoop,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thence is all Thy people’s hope;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wast poor, that we might be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rich in glory, Lord, with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherefore Thou high heaven didst spurn?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherefore Thou to earth didst turn?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why leave heav’n to come to earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lonely, scorned, e’en suffering death?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou in heav’n—the glorious One!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou on earth—the outcast Man!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though this suffering Thou didst know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love would come to bear our woe."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we think of love like this,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joy and shame our hearts possess;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joy, that Thou couldst pity thus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shame, for such returns from us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet we hope the day to see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When from every hindrance free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When to Thee, in glory, brought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall serve Thee as we ought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now, O Lord, we wait for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wait “the blessed hope” to see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we ever for Thee live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thy saints Thou dost receive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
