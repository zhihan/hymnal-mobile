      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s only room for Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One who’s all in all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him, the natural man is null"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And has no place at all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, there is no Jew,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No Greek, no slave, no free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Barbarians and Scythians—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crossed out entirely."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All differences we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In culture, practice, creed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are not in Christ, our Lord and Head—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From oldness these proceed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Distinctions have no place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, nor in the saints."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our nature is the very same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As oneness demonstrates."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God governs and He deals"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all things by the cross."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s God’s unique solution for"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The substitutes in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cross becomes our way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To put off all things old,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To live in resurrection till"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ in us all behold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Put on the one new man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The old man strip away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pass through the cross to take Christ as"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Person now today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit with the cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is our unique supply"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That causes us to be renewed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As one new man thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The practicality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of passing through the cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is in the mingling that blends"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s essence into us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The key is be renewed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have the mind of Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The newness of God’s life, imbued,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renews and rectifies."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Put off the old today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And every day beyond."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But set your mind on spirit now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to God’s life respond."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoy the Lord and drink"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit till you’re new,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To think the one thing with all saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God soaked through and through."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the One we love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One whom we pursue."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s nothing else that we desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Christ, who’s ever new."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God sees us all in Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The status we convey;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ and His cross are all we have—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One Person and one way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
