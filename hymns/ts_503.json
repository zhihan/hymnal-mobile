    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "离开巴比伦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各宗各派之地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从分裂中我们都起来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为巴比伦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非神所立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从分裂中我们都起来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来！起来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从分裂中我们都起来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复最后一行，下同）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从被掳之地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "回耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有神同在，我们都上来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在独一立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作合一见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有神同在，我们都上来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上来！上来！有神同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们都上来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "盘里满基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "碗里满圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将所有的器皿都带来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带到召会里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照神所命定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将所有的器皿都带来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来！带来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将所有的器皿都带来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所选之地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的圣殿我们同建立！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众圣同事奉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都一心一意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的圣殿我们同建立！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建立！建立！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的圣殿我们同建立！"
            }
          ]
        }
      ],
