    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你向我们所施安抚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们怎能用口倾吐？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可怒之子当下火湖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然得救，以神为父！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在地我知罪已抹涂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真是豫享属天美福。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的心满是基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切望倾倒此中丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们诗歌题目，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们心爱救主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们舌头急要唱出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上君王荣耀万古！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你比世上一切众生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都更美丽、都更成圣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你心有爱，你口有恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既受苦、你又舍身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这永受颂赞的神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们敬拜以灵以真。"
            }
          ]
        }
