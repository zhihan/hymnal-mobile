    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy death and resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wast made God's firstborn Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy life to us imparting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was Thy duplication done."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, in Thee regenerated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many sons to God became;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Truly as Thy many brethren,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are as Thyself the same."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once Thou wast the only grain, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Falling to the earth to die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That thru death and resurrection"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou in life may multiply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We were brought forth in Thy nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the many grains became;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As one loaf we all are blended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy fulness to proclaim."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We're Thy total reproduction,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy dear Body and Thy Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine expression and Thy fulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thee ever to abide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are Thy continuation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy life-increase and Thy spread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy full growth and Thy rich surplus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with Thee, our glorious Head."
            }
          ]
        }
