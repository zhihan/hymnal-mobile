    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Old Noah’s age was so corrupt,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In deep depravity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So Noah passed across the flood—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That separating sea."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord! He has brought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the old"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To a new recovered region"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where he built in this land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An altar for his God."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then Abraham was called apart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Godto take a stand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So through the river he was led"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into a new, good land."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Step by step he was led"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Chaldee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the river into Canaan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That good land, there to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The servant of his God."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Israelites in bondage were"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Pharaoh’s choking hand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The God of Hebrews made a way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For them to leave that land."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the sea, they all passed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Egypt fell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! In the good land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They built up God’s own house"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To satisfy His heart."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then wand’ring through the wilderness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The land they could not find;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till through the Jordan they did pass"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To leave themselves behind."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord! In the land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They built up"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s own temple. Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord! There they dwelt,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His people and their God."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But then religion conquered all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So John the Baptist came"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And buried all beneath that flood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Jews were not the same."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Buried all! Buried all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Buried all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Underneath the Jordan River"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Buried all to become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Hebrews passing through."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in the church life, we have left"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world, religion too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we’re the river-crossing ones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying Christ so new!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord! Praise the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have passed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the oldness, Hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into Christ—one new man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now we’re one with Him!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, You’ve taken us across"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fiery sea of glass,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all the worldly things beneath;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Across the sea we’ve passed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord! Praise the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we stand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Hebrews, Hallelujah,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the sea! Praise the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve passed through everything!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
