{
  "url": "https://www.hymnal.net/cn/hymn/ch/634",
  "title": "冲过战士哪冲过",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "衝 過！"
            },
            {
              "chord": "",
              "text": "戰"
            },
            {
              "chord": "G",
              "text": "士 哪，"
            },
            {
              "chord": "D",
              "text": "衝 過！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前 線 正"
            },
            {
              "chord": "G",
              "text": "在 開"
            },
            {
              "chord": "A",
              "text": "火；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但"
            },
            {
              "chord": "D",
              "text": "各 各"
            },
            {
              "chord": "E",
              "text": "他 已"
            },
            {
              "chord": "A",
              "text": "得 勝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "請 你 常"
            },
            {
              "chord": "E",
              "text": "唱 此"
            },
            {
              "chord": "A",
              "text": "歌。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑 暗 權"
            },
            {
              "chord": "A7",
              "text": "勢 應"
            },
            {
              "chord": "D",
              "text": "當 退，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒"
            },
            {
              "chord": "B7",
              "text": "但 陰"
            },
            {
              "chord": "",
              "text": "府 已"
            },
            {
              "chord": "Em",
              "text": "危！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "萬"
            },
            {
              "chord": "A",
              "text": "軍 之"
            },
            {
              "chord": "",
              "text": "主 的 元 帥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "快"
            },
            {
              "chord": "G",
              "text": "要 奏"
            },
            {
              "chord": "A",
              "text": "凱"
            },
            {
              "chord": "A7",
              "text": "歸"
            },
            {
              "chord": "D",
              "text": "回。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘冲过！战士哪，冲过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仰起你头看我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若为我打胜仗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得登我宝座。’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是属灵的交战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不在属世地场；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主已知道仇敌迫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前后四围布满！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘冲过！战士哪，冲过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要登我宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我复活的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "会使你灵超脱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借我你要得权能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借我你要得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借我你要唱凯歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借我你要高升。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘冲过！战士哪，冲过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要登我宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已为你留一席，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要欢喜快乐。’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与祂同复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同升天上坐着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远离战场的喊声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远离绑人罪恶。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "冲过！战士哪，冲过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要登主宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主从灰尘拣选你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要你同祂得国。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的将来乃光明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是黑暗灰心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永与耶稣在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永得祂的爱情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "冲过！欢呼着冲过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前面就是宝座！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你从郇山的高峰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可唱得胜新歌。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被杀羔羊已得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "登基羔羊已胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们欢呼赞美祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂必定得胜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
