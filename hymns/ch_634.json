        {
          "segments": [
            {
              "chord": "D",
              "text": "冲 过！"
            },
            {
              "chord": "",
              "text": "战"
            },
            {
              "chord": "G",
              "text": "士 哪，"
            },
            {
              "chord": "D",
              "text": "冲 过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前 线 正"
            },
            {
              "chord": "G",
              "text": "在 开"
            },
            {
              "chord": "A",
              "text": "火；"
