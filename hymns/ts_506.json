      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她在北面居高华美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃为全地所喜悦！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她在北面居高华美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "锡安─价值何超越！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在锡安有一道河流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "具有无数的分汊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在锡安有一道河流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使这城喜乐增加。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，锡安等候赞美你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，锡安等候赞你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，锡安等候赞美你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因锡安充满了你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶和华在锡安为大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "该受何等大赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在这城中本为大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这城地位何高贵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，当从锡安称颂神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美声音不止息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，当从锡安称颂神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你们凡敬畏神的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神从锡安赐福给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神赐福无量无限；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神从锡安赐福给你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐生命福到永远！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！何等善，何等美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄们都在一起！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！何等善，何等美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和睦同居真合一！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当传说给所有后代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡愿意的都可来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当传说给所有后代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵与新妇都说‘来！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
