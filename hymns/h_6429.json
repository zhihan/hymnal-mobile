    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometimes, in pastures green, the Shepherd’s tender voice I hear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometimes, in valleys deep, my Guide, so wise, may disappear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometimes, upon the sea, my loving Lord asleep appears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Adventure and surprise at every step along the way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve never seen His face; so blurry, yet so clear each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve never seen His face; so blurry, yet so clear each day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day, not as I will, so many challenges I see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need not easy life, self-pity, friends, or sympathy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All power, living bread, and living water, He supplies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He transforms many lives, transferred from darkness into light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pow’r tabernacles o’er; I am afraid, yet strong each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pow’r tabernacles o’er; I am afraid, yet strong each day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What contradictions fill the lives of all those who love You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To men we seem unknown, yet really we are well-known too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As dying, we rejoice in resurrection vict’ry true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In self we’ve only pain; yet boundless wealth in You we gain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Treasure in vessel clay; dishonor, glory every day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Treasure in vessel clay; dishonor, glory every day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I never can assess how I, so common, gained the best;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I live You, by Your life; my walk Your nature manifests;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day romance I find; wondrous, with tears and song entwined!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Your great mercy, Lord, that You have come into my life!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! Thank You! Thank You, Lord! Now You have come into my life!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! Thank You! Thank You, Lord! Now You have come into my life!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
