          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你丰满的身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你的复制品、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你身体并新妇、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你表现、是你丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远让你来居住。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你普及、继续、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你生命的开展、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你长成、是你富馀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你合一永无间。"
            }
          ]
        }
