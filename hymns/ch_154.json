          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就成为神长子；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着重生分赐生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们成为神众子。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你生命繁殖，"
