    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Smooth let it be, or rough,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It will be still the best;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Winding or straight it leads"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Right onward to Thy rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I dare not choose my lot;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would not if I might:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Choose Thou for me, my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So shall I walk aright."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take Thou my cup, and it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With joy or sorrow fill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As best to Thee may seem;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Choose Thou my good and ill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Choose Thou for me my friends,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sickness or my health."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Choose Thou my cares for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My poverty or wealth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not mine, not mine the choice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In things both great and small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be Thou my guide, my strength,"
            }
          ]
        },
        {
          "segments": [
