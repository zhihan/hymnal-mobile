    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Born unclean, contaminated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A totality of sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All discharges foul, contagious;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death exuding from within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can such as I approach Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou most holy, righteous, clean?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy Blood, O Lamb, that cleansed me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expiated, God appeased."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hands once empty now receive Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We to tent of meeting go;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hands are filled with offerings daily,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flame divine remains aglow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ experienced is our offering,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meeting not just our own need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, O Father, Thy deep longing:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Constituting us Thy priests."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecration through enjoyment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily filled with Christ alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweetest fragrance now transcendent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mutual satisfaction known."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujahs now unceasing!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trained to worship and partake."
            }
          ]
        },
        {
