    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dead I was in sin Lord, so lost without You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Helpless, wounded, weary, rebellious, too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Lord, You came! You would not let me go;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blood and water flowed from Your side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Constraining me to tell You..."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thank You Lord, You opened my blind eyes to see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I was lame, but now I can walk; You healed me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My leprosy, Lord, You cleansed all away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My ears were opened to hear Your voice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I follow You ’cause..."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometimes Lord, I’m drawn off by my selfish cares;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the world it draws me with glitter and glare."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, You’ve trapped me. Don’t let me go."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kiss me and woo me, and win my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So, I will always tell You..."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep my heart so soft, Lord, so open to You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It would be the good ground to bear fruit for You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Capture my friends Lord, and build us, I pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Bride, We’d match You in every way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And corporately we tell You:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Come quickly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re waiting for You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re the virgins to You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So single and true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever and ever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your counterpart true."
            }
          ]
        }
      ],
      "type": "chorus"
    }
