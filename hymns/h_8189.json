              "text": "Highest, most glorious Lord!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This song we'll sound forth resoundingly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise ye the Lord! Praise ye the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This subject sing out continually."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest, most glorious Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sing till our hearts leap joyfully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till all earth hears this melody,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till new creation ceaselessly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This song sings eternally."
            }
          ]
        }
      ]
    },
