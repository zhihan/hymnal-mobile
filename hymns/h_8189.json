    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hark! Sounds of singing from heaven's height!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise ye the Lord! Praise ye the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is love; He is also light."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest, most glorious Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All in the world who weep, distressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinners who have no peace or rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whoe'er you are, Christ's done the best;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your debt has been fully paid!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With heart and tongue let His praises soar!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise ye the Lord! Praise ye the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Song never heard from the days of yore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest, most glorious Lord!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Loudly we sing, for the judgment's passed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise ye the Lord! Praise ye the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Risen with Christ, we're to Him joined fast."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest, most glorious Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're standing on the grave's far side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond the reach of death abide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All foes have drowned in sea's strong tide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ we are justified!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With heart and tongue let His praises soar!"
            }
          ]
        },
        {
