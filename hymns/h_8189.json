              "text": "Praise ye the Lord! Praise ye the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Song never heard from the days of yore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest, most glorious Lord!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sing! Christ descends to take up His saints!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise ye the Lord! Praise ye the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His church matured, with no more restraints."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highest, most glorious Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we see Him whom long we've called,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain Him who's long our hearts enthralled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shout, sing for joy, no more forestalled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our future is Christ for aye!"
            }
          ]
        }
      ]
    },
