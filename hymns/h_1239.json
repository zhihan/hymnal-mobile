              "text": "In the spirit we can taste"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the riches of Thy grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy fullness, blessed Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is for those in one accord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the spirit, on the ground—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here is where Thy life is found."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dwelling thus in unity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We enjoy reality!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of death and into life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Done with all divisive strife!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Free indeed to love but Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growing to maturity!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Amen, Jesus,” is our prayer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the purging work, whate’er;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Thy church must desperate be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More the growth in life to see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, make Thy home our heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our true inner man Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God and man are mingled thus—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the church, all glorious!"
            }
          ]
        }
