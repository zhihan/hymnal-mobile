{
  "url": "https://www.hymnal.net/cn/hymn/ch/630",
  "title": "为着你同在",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "為"
            },
            {
              "chord": "A",
              "text": "著 你"
            },
            {
              "chord": "D",
              "text": "同"
            },
            {
              "chord": "Bm",
              "text": "在"
            },
            {
              "chord": "Em",
              "text": "並 你"
            },
            {
              "chord": "A7",
              "text": "活 的"
            },
            {
              "chord": "D",
              "text": "話，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "離 去 前，"
            },
            {
              "chord": "G",
              "text": "讚 美"
            },
            {
              "chord": "D",
              "text": "還 要"
            },
            {
              "chord": "A",
              "text": "向"
            },
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "發；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我"
            },
            {
              "chord": "A",
              "text": "們 已"
            },
            {
              "chord": "D",
              "text": "為 你"
            },
            {
              "chord": "B",
              "text": "寶 貴"
            },
            {
              "chord": "B7",
              "text": "所 吸"
            },
            {
              "chord": "Em",
              "text": "引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "你 有"
            },
            {
              "chord": "",
              "text": "力"
            },
            {
              "chord": "D",
              "text": "信 息"
            },
            {
              "chord": "G",
              "text": "已 抓"
            },
            {
              "chord": "D",
              "text": "住"
            },
            {
              "chord": "A7",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "心。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话对于我，是灵、是生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得餧养，时将我供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将我变化，模成你形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我成熟，满有你身量。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求将你自己，更多供应我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我在灵里行动并生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并将我保守在你交通里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到借你恩，我们再聚集。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
