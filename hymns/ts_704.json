{
  "url": "https://www.hymnal.net/cn/hymn/ts/704",
  "title": "你如今活在召会里",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "你 如"
            },
            {
              "chord": "",
              "text": "今 活"
            },
            {
              "chord": "Am",
              "text": "在 召"
            },
            {
              "chord": "",
              "text": "会"
            },
            {
              "chord": "Dm",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂 不 令 你"
            },
            {
              "chord": "F",
              "text": "欢 天"
            },
            {
              "chord": "G",
              "text": "喜"
            },
            {
              "chord": "A7",
              "text": "地！？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞"
            },
            {
              "chord": "Dm",
              "text": "美 主，"
            },
            {
              "chord": "F",
              "text": "实 在"
            },
            {
              "chord": "",
              "text": "是 荣"
            },
            {
              "chord": "C",
              "text": "耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "我 们"
            },
            {
              "chord": "Gm",
              "text": "终 于"
            },
            {
              "chord": "Am",
              "text": "找 著"
            },
            {
              "chord": "",
              "text": "目"
            },
            {
              "chord": "Dm",
              "text": "标。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从此不再寻寻觅觅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已经回到家里。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄们和睦的同居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真正天伦之乐无比！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神拣选的地方，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神荣脸得以常瞻仰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的名是摆在这里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你住些时，就不一样。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，别无拣选─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从听见祂声音那天。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自深处我们说：‘阿们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们乐意，投身其间。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
  "metadata": {
