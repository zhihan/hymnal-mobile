            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own purpose gave us being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When in Christ, in that vast plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou in Christ didst choose Thy people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en before the world began."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what love Thou, Father, bore us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how precious in Thy sight!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When to Thine own Son Thou gav'st us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thy Son, Thy soul's delight."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though our nature's fall in Adam"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shut us wholly out from God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine eternal counsel brought us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nearer still, through Jesus' blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in Him we found redemption,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace and glory in Thy Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O the height and depth of mercy!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ and His redeemed are one."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hence, through all the changing seasons,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trouble, sickness, sorrow, woe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing changeth Thine affections,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love divine shall bring us through;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon shall all Thy blood-bought children"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Round the throne their anthems raise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, in songs of rich salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shout to Thine eternal praise."
            }
          ]
        }
      ]
    }
