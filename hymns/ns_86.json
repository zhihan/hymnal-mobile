          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those once oppressed, whose bondage ceased."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have proclaimed today to be"
            }
          ]
        },
        {
          "segments": [
            {
