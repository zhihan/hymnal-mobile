      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Lord has been anointed for"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Announcing good news to the poor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Release to captives—ye much more—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blind, their sight He has restored."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He changed my life with one simple call."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gained my heart to love Him o’er all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now I will praise Him, and tell the whole world."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love my Jesus forevermore!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You, Lord, have sent away, released,"
