    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He ever lives above"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me to intercede,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His all-redeeming love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His precious blood to plead."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood was shed for all our race,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sprinkles now the throne of grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Five bleeding wounds He bears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Received on Calvary;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They pour effectual prayers;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They strongly speak for me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forgive him, O forgive, they cry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor let that ransomed sinner die!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father hears Him pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His dear anointed One;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He cannot turn away"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The presence of His Son."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Spirit answers to the blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And tells me I am born of God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To God I’m reconciled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His pardoning voice I hear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He owns me for His child,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can no longer fear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With confidence I now draw nigh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Father, Abba, Father, cry."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
