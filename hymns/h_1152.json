    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His glory broke upon us when we saw Him in the church,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For here are all His riches, here we’ve given up our search;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here He satisfies our longing spirits o’er and o’er,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And every day He’s dearer than He was the day before."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The half cannot be fancied of such a treasure-store,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And every day He’s dearer than He ever was before!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now He’s the living Spirit who within our spirit dwells,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by His sweet anointing, how His life within us swells!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As with the saints we’re meeting, full released our spirits soar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For now our Lord is dearer than He ever was before."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
