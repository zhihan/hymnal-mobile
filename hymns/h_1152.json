      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord has made us one with Him for His recovery:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of this Christ, the church His fullness, men must see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, all we have and all we are, we every day outpour"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His tremendous purpose, ever dearer than before."
            }
          ]
        }
