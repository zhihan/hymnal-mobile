{
  "url": "https://www.hymnal.net/cn/hymn/ch/21",
  "title": "父你智慧同你恩典",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "父， 你"
            },
            {
              "chord": "",
              "text": "智 慧 同"
            },
            {
              "chord": "A",
              "text": "你 恩"
            },
            {
              "chord": "",
              "text": "典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全 在 基 督 集"
            },
            {
              "chord": "D",
              "text": "中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 使 祂 作 我 們 智 慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 祂 我"
            },
            {
              "chord": "E7",
              "text": "蒙 恩"
            },
            {
              "chord": "A",
              "text": "寵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "使 祂"
            },
            {
              "chord": "",
              "text": "作 我"
            },
            {
              "chord": "A",
              "text": "們 智"
            },
            {
              "chord": "",
              "text": "慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因"
            },
            {
              "chord": "D",
              "text": "祂"
            },
            {
              "chord": "G",
              "text": "我"
            },
            {
              "chord": "A7",
              "text": "蒙 恩"
            },
            {
              "chord": "D",
              "text": "寵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的计画全在于祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是你恩之路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂－你这智慧－里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得享你丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂，我们得蒙称义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我们公义；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们借祂也得成圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们圣洁是彼。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "照着你的永远计画，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂也是我救赎；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最终将我身体救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我全人成熟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你神圣经营之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是你的智慧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为祂，我们俯伏敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你献上赞美。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂，我们已经看见"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你智丰富深广；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是还要加富、加深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全在我们身上。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "敬拜父",
