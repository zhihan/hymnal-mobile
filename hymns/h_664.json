    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the wilderness before thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Desert lands where drought abides?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heavenly springs shall there restore thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh from God’s exhaustless tides."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Light divine surrounds thy going,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself shall mark thy way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Secret blessings, richly flowing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lead to everlasting day."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God, thine everlasting portion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feeds thee with the Mighty’s meat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saved from Egypt’s hard extortion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Egypt’s food no more to eat."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Art thou weaned from Egypt’s pleasures?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in secret shall thee keep;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There unfold His hidden treasures,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There His love’s exhaustless deep."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the desert God will teach thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What the God that thou hast found—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Patient, gracious, powerful, holy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All His grace shall there abound."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On to Canaan’s rest still wending,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en thy wants and woes shall bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Suited grace from high descending;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou shalt taste of mercy’s spring."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though thy way be long and dreary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eagle strength He’ll still renew;"
            }
          ]
        },
        {
          "segments": [
