    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不是单独孤立基督徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是团体新人─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神需要她"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全彰显祂自己！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅是一个地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是整个身体─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在这身体里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，荣耀身体！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使撒但战抖的身体！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在身体里我们得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在这身体里！"
            }
          ]
        }
