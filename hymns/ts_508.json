        {
          "segments": [
            {
              "chord": "G7",
              "text": "完 全"
            },
            {
              "chord": "",
              "text": "為 這"
            },
            {
              "chord": "C",
              "text": "身 體！"
            },
            {
              "chord": "",
              "text": "阿 利"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "路 亞，"
            },
            {
              "chord": "",
              "text": "主 使"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "合 為"
            },
            {
              "chord": "G",
              "text": "一！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不是单独孤立基督徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是团体新人─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神需要她"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全彰显祂自己！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅是一个地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是整个身体─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在这身体里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，荣耀身体！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使撒但战抖的身体！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在身体里我们得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在这身体里！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神那完全圣别的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显在七金灯台─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体生活不容"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天然的存在。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们合一且有分神性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "金灯台就照耀─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她正发光且照耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，荣耀身体！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个身体是金灯台！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "处处发光，精光照耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她正发光且照耀！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们如何彰显这合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣别并且照耀？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃主耶稣就是路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是生命树，是吗哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是常新的筵席─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们天天都吃主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们合一借着吃主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们圣别借着吃主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们发光借着吃主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃主耶稣就是路！"
            }
          ]
        }
      ]
    }
