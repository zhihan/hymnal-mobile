      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神那完全圣别的性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显在七金灯台─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体生活不容"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天然的存在。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们合一且有分神性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "金灯台就照耀─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她正发光且照耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，荣耀身体！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个身体是金灯台！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "处处发光，精光照耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她正发光且照耀！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
