    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God is incarnate in the flesh that we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him may receive, experience ourself;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the grace which we receive of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which comes thru Christ and which is Christ Himself."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Paul the Apostle counted all as dung,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas only God in Christ he counted grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this grace—the Lord experienced—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That he surpassed the others in the race."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is this grace—Christ as our inward strength—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which with His all-sufficiency doth fill;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is this grace which in our spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There energizing, working out God’s will."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This grace, which is the living Christ Himself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is what we need and must experience;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, may we know this grace and by it live,"
            }
          ]
        },
