    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I need not tell Thee who I am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sin and misery declare;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself hast called me by my name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Look on Thy hands, and read it there;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But who, I ask Thee, who art Thou?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me Thy name, and tell me now."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In vain Thou strugglest to get free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I never will unloose my hold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Art Thou the Man that died for me?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secret of Thy love unfold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wrestling, I will not let Thee go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till I Thy name, Thy nature know."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yield to me now, for I am weak,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But confident in self-despair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to my heart, in blessings speak,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be conquered by my instant prayer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak, or Thou never hence shalt move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And tell me if Thy name be Love."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Love! ’tis Love! Thou diedst for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I hear Thy whisper in my heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The morning breaks, the shadows flee:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pure, universal Love Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To me, to all Thy mercies move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy nature and Thy name is Love."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lame as I am, I take the prey;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hell, earth and sin, with ease o’ercome."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I leap for joy, pursue my way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, as a bounding hart, I run,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all eternity to prove"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy nature and Thy name is Love."
            }
          ]
        }
      ]
    }
  ],
