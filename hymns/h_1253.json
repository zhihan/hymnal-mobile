    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then another promise followed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "David’s seed upon the throne:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“I’ll rebuild His tabernacle"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by this I will be known.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we thank Thee, Thou art faithful"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To perform Thy promised word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "David’s tabernacle, ruined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon by Thee will be restored."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we are that tabernacle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy rebuilding work on earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, restore Thyself a dwelling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where is seen Thy boundless worth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus shall all of mankind seek Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Gentiles call Thy name."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Thy holy tabernacle"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the earth shall know Thy fame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hasten, Lord, Thy work upon us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To restore and build us now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this work we give ourselves, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here to Thee we make a vow:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Though our strength is weak and feeble,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet our hearts would ever be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From this day, Lord, for Thy building,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now and for eternity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
