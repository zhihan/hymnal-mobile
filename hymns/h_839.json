    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though of clay Thou madest us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst have us be transformed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy life as purest gold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto precious stones conformed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall, through Thy building work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then become Thy loving Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In one Body joined to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy heart be satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What Thy heart desires and loves"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are not precious stones alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But together these to build"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy glory, for Thy home."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, the all-inclusive Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dost a builded Church require,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy glorious riches may"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Radiate their light entire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the person spiritual"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In an individual way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the corporate life expressed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will Thy heart’s desire display."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Members separate and detached"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne’er express Thee perfectly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thy Body tempered, built,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever shall Thy fulness be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Build me, Lord, with other saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Independence ne’er allow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But according to Thy plan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fitly frame and join me now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In experience not my boast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor in gifts would be my pride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy building I give all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou may be glorified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
