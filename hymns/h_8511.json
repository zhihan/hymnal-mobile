      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He knows what trials you can face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He knows how much you need His grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He foreknew all that happens here;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is your Lord; why doubt or fear?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though many mock and ridicule,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loved ones forsake, friends misconstrue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All of these things, the Savior knows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So be at peace, in calm repose."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Cast all your burdens on the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All of your sighs on Him outpour."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His heart of love your sorrow knows;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He cares for you and grace bestows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the Lord knows, my heart’s at peace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the Lord knows, my joy’s complete!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the Lord knows, my rescue’s sure!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the Lord knows, I am secure."
            }
          ]
        }
      ],
