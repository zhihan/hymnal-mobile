    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复兴之律来临，昼夜循环不息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随时随地洋溢赞美，福音遍传四极。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "团体神人生活，在地如同在天，"
            }
          ]
        },
        {
          "segments": [
