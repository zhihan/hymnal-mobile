    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻扎根主里，生活开花发芽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天起来拾取吗哪，爱慕追求主话。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不住恒切祷告，单纯如百合花，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灌满新酒和橄榄油，散发基督荣华。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "新的黎明，新的复兴，主我奉献，奉献今天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你得胜，因你更新，直到恩主显现。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主必加倍补还，蝗虫吃去时光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的复活生命大能，吞灭失败死亡。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂不断显现，步步唱上行诗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今生功名烟消云逝，谱写神圣历史。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
