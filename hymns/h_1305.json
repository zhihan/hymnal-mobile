        {
          "segments": [
            {
              "chord": "",
              "text": "While we amen His voice in matters great or small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we all may be ready to hear Jesus’ call."
            }
          ]
