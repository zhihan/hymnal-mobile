    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The love for all the brothers, in our midst is found,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in these days our love must increase and abound."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord direct our hearts into the love of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And prepare us in full for the day of the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our work of faith must grow exceedingly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The labor of our love increase abundantly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His sanctifying work in us go on and on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While in patience of hope we will watch till He come."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit, soul, and body wholly sanctified—"
