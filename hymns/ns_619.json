    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Morning Star! Ascend before the dawning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In twilight radiate—how clear and bright!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While here we love and wait for Thy dear coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Silently, Thou illuminate our night."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Morning Star! Arise in secret stillness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Break through the gloom, the darkness of this age;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burst forth, Thou Sun of Righteousness, in splendor!"
            }
          ]
