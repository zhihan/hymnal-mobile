    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O lovely Bridegroom, our nat’ral strength e’er fails us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hopeless Thou found us, and one gift Thou gave:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our little pow’r to cling to our Beloved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leaning on Thee and guided all the way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O lovely Bridegroom, have mercy on Thy people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we’d forsake all other loves but Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cleaving to Thee, our dear and faithful Husband;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving Thee solely, unreservedly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O lovely Bridegroom, Thy burning love compels us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we’d be ready for that wedding day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’er we’d adorn the church with all Thy riches;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her beauty then Thou wouldst desire for aye."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O lovely Bridegroom, we yearn to hear Thy speaking:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“You’re altogether beautiful, My love!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Aching for Thee, Thy coming we would hasten"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till at Thy wedding feast we meet above."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
