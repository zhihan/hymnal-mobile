        {
          "segments": [
            {
              "chord": "",
              "text": "But when by temptation so fiercely assailed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They left off believing, and terribly failed."
            }
          ]
        }
      ]
    },
    {
