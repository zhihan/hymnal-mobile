        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I believe, Lord, I believe!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my doubts are buried in the fountain."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"I'll stand to the end,\" I have heard people say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"I'll fight till I die, and will ne'er run away;\""
            }
          ]
