        {
          "segments": [
            {
              "chord": "",
              "text": "Who go to the battle like warriors of steel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But right in the heat of the conflict with sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Instead of believing they faint and give in."
            }
          ]
        }
      ]
    },
