    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How easy when sailing the sea in a calm,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To trust in the strength of Jehovah's great arm;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But somehow I find when the waves swamp the boat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It takes some believing to keep things afloat."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I believe, Lord, I believe!"
