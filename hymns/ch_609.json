{
  "url": "https://www.hymnal.net/cn/hymn/ch/609",
  "title": "主我宝贵你的蓝图",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 我"
            },
            {
              "chord": "",
              "text": "寶 貴 你"
            },
            {
              "chord": "A",
              "text": "的 藍"
            },
            {
              "chord": "D",
              "text": "圖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "G",
              "text": "是 你"
            },
            {
              "chord": "D",
              "text": "所 造"
            },
            {
              "chord": "",
              "text": "的 帳"
            },
            {
              "chord": "A",
              "text": "幕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "說"
            },
            {
              "chord": "D",
              "text": "出 你"
            },
            {
              "chord": "",
              "text": "是 如"
            },
            {
              "chord": "A",
              "text": "何 建"
            },
            {
              "chord": "D",
              "text": "造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "G",
              "text": "何 顯"
            },
            {
              "chord": "D",
              "text": "出 你"
            },
            {
              "chord": "A",
              "text": "的"
            },
            {
              "chord": "A7",
              "text": "榮"
            },
            {
              "chord": "D",
              "text": "耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "约柜乃是帐幕中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "帐幕是给约柜藏身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十条诫命放在约柜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "约柜住在帐幕以内。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "约柜豫表神人基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人相调如金包木；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十诫指神具体表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全住在基督里面。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督也是召会中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会是给基督安身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是住在基督里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督住在召会中间。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "帐幕乃是约柜扩大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "金包木头，同样造法；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会也是基督扩充，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人调和，完全相同。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "竖板相联，搭成帐幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立在银座，基础稳固；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "精金包裹，上带金环，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "环内套闩，众板相联。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会也是圣徒集成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督救赎上面立定；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神性里面圣灵联系，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此配搭，建造一起。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "帐幕上盖四层罩棚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫表基督各种情形；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这位基督显神荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神居所完全遮罩。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这基督遮护之下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣徒才能彼此配搭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受祂的一切功效，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "披祂戴祂，同被建造。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "十诫在柜，柜在帐幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神荣耀来此居住；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在主里，主在召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这蓝图何其宝贵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
