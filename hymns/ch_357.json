    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "联于基督复活的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今居于天府，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架光荣，立时彰显"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无限希奇恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "联于基督完全得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵立即飞腾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠主圣名我一宣告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗权势即逃。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "复活基督，你真庄严！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我与你相联；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你十字架时常得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "败坏撒但凶横。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "联于基督何等尊大！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神的救法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这叫我们永远赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为羔羊真配。"
            }
          ]
        }
