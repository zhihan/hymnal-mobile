    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有时我几乎卧倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知我的软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂叫我向祂倚靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我乐受祂扶托；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂带我走光明途径，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "日过光明生活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以我们就同行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主与我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知我爱祂几多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知我爱浅深；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂是用何爱爱我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我永不能说清；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是一爱永远不衰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "越过越像热火；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以彼此就相爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主与我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我告祂以我痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "告祂以我欢喜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我告祂以我所羡慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "告祂以我刺激；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂告我以所当策励，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "告我以所当作；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们彼此吐心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主与我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂知我心真羡慕"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能救一个灵魂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就叫我为祂外出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去报爱的新闻；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂叫我说祂的奇爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并祂受死经过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们如此常同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主与我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂告我以祂国度"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离此并不太远；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂心切望能够尽速"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把我带到那边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无终幸福，喜乐在望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还有荣耀宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久我们同作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主与我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
