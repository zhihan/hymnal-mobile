{
  "url": "https://www.hymnal.net/en/hymn/ns/661",
  "title": "Lord, My Eyes Are Seeing",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Lord, my"
            },
            {
              "chord": "",
              "text": "eyes are seeing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, my ears are hearing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "All that"
            },
            {
              "chord": "",
              "text": "You've been speaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "My heart's"
            },
            {
              "chord": "",
              "text": "understanding,"
            },
            {
              "chord": "G",
              "text": "too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "Finally,"
            },
            {
              "chord": "",
              "text": "I am turning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Willing"
            },
            {
              "chord": "",
              "text": "to be healed by"
            },
            {
              "chord": "G",
              "text": "You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Thank You"
            },
            {
              "chord": "",
              "text": "for Your waiting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ar"
            },
            {
              "chord": "C",
              "text": "ranging"
            },
            {
              "chord": "",
              "text": "everything I'd"
            },
            {
              "chord": "G",
              "text": "do."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Lord, my"
            },
            {
              "chord": "D",
              "text": "heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cries"
            },
            {
              "chord": "Em",
              "text": "out for"
            },
            {
              "chord": "",
              "text": "Your"
            },
            {
              "chord": "C",
              "text": "loving"
            },
            {
              "chord": "",
              "text": "hand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "G",
              "text": "Lord, A"
            },
            {
              "chord": "D",
              "text": "men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'd be"
            },
            {
              "chord": "C",
              "text": "touched by"
            },
            {
              "chord": "D",
              "text": "You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I’ve been so hardened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Caught in worldly traffic,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drowning out Your words that"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fell upon my wayward heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Somehow, still You got in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soft’ning up my tender parts."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How could I refuse You?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You bore me on Your wounded heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I thought I was willing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shallowly receiving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meanwhile I was sinning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burying my shameful side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the sun exposed me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I can no longer hide."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bare without Your presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For dire help to You I fly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything seemed peaceful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Your words intruded,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anxious thoughts arose and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tried to choke the life away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lifelessly I drifted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Couldn’t tell the night from day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then a ray of light came,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining through a man of clay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the time I wasted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trying to be better."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All along You waited,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just for me to reach my end."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I simply open,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trusting in my truest Friend."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hold me by Your mercy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bear fruit in me until the end."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Lord, my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Overflows with a praising song!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Lord, I know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve been touched by You."
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
