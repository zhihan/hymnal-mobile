    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though we still err, so prone to fail,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s given us a testament"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all He’s done for us to claim."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let’s seize it to the full extent!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we fall short and miss the mark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We take the blood, He paid the cost."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From scarlet stain to pure white snow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How powerful! We’re cleansed, we’re washed!"
            }
          ]
        }
      ],
