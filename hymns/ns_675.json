    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re free, unbound from chains that held."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have returned from slavery."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such joy, such rest! We’re home, how blessed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s Christ! He’s here as Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A feast is spread, it’s Christ Himself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our food, our drink eternally."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No condemnation but a call"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To eat and drink and merry be!"
            }
          ]
        }
