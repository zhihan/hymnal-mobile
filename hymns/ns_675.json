    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We once tried doing what was good"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But right and wrong are just one tree."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Instead, we eat the tree of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And take God in, receive, believe!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer I—I’m crucified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But it is Christ who lives in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No need to try to imitate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is displayed spontaneously!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s no need to struggle!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s no need to strain!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s no need to labor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All self-effort is vain!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s a life of resting!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s a life of feasting!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s a life of enjoying God!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We have been grafted to a tree."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord, the vine, does flow so free"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all His riches into us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Positioned now, we just receive."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the place for us to stay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we remain, much fruit we bear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide in Him, let Him abide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such sweet supply, His life to share!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
