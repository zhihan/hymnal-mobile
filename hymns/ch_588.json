{
  "url": "https://www.hymnal.net/cn/hymn/ch/588",
  "title": "主阿我来就你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "來 就"
            },
            {
              "chord": "D",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 飢"
            },
            {
              "chord": "E7",
              "text": "渴 要"
            },
            {
              "chord": "A7",
              "text": "你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "深 願"
            },
            {
              "chord": "",
              "text": "在 此 喫"
            },
            {
              "chord": "G",
              "text": "你 喝"
            },
            {
              "chord": "",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享"
            },
            {
              "chord": "D",
              "text": "受 你"
            },
            {
              "chord": "A7",
              "text": "的 自"
            },
            {
              "chord": "D",
              "text": "己。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得见你的面目，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是我心所慕！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚愿在此与你接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里得着饱足。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的荣耀面光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心何等欣赏！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真愿留此不再他往，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直向你瞻仰。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这交通里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的恩典！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我心欢，使我灵满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人进入平安。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "还要在此等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要向你寻求！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "读经、祷告交替不休，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到被你浸透！"
            }
          ]
        }
      ]
    }
  ],
