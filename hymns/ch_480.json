            },
            {
              "chord": "D",
              "text": "要 翻"
            },
            {
              "chord": "A",
              "text": "覆？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 们 能 否"
            },
            {
              "chord": "D",
              "text": "相"
            },
            {
              "chord": "A",
              "text": "信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E",
              "text": "神 与"
            },
            {
              "chord": "E7",
              "text": "你 同"
            },
            {
              "chord": "A",
              "text": "在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "就 是"
            },
            {
              "chord": "",
              "text": "灾 祸"
            },
            {
              "chord": "G",
              "text": "忽"
            },
            {
              "chord": "Em",
              "text": "临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "必 定"
            },
            {
              "chord": "A7",
              "text": "不 见"
            },
            {
              "chord": "D",
              "text": "害？"
            }
          ]
        }
