              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Bm",
              "text": "如 果"
            },
            {
              "chord": "",
              "text": "地 要"
            },
            {
              "chord": "A",
              "text": "震"
            },
            {
              "chord": "Bm",
              "text": "动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
