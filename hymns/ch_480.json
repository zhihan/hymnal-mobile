      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你们能否顺从"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所事奉的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不稍软弱、惊恐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也不稍让步？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然你的前途"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像是死路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此时能否顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而不一自顾？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你真能否顺从，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果主召你"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加入前线进攻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "抵御凶仇敌？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你真能否立前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢喜受差遣？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你真能否争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到晚色遍？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "能否？我的弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你神已久等，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当服祂权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "遵行祂命令。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若作主精兵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂再降临，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要题起你名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并说你‘忠心！’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
