          "segments": [
            {
              "chord": "",
              "text": "Nothing could change me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But love and mercy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love, dear Lord, has conquered me."
            }
          ]
        }
