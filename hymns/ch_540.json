{
  "url": "https://www.hymnal.net/cn/hymn/ch/540",
  "title": "与主来往享主生命",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "与 主"
            },
            {
              "chord": "",
              "text": "来"
            },
            {
              "chord": "D",
              "text": "往， 享"
            },
            {
              "chord": "D7",
              "text": "主 生"
            },
            {
              "chord": "G",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需 一 正 确 的"
            },
            {
              "chord": "D",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "使 主"
            },
            {
              "chord": "",
              "text": "一 切， 藉"
            },
            {
              "chord": "D",
              "text": "祂 恩"
            },
            {
              "chord": "D7",
              "text": "典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "全"
            },
            {
              "chord": "D",
              "text": "都"
            },
            {
              "chord": "D7",
              "text": "有"
            },
            {
              "chord": "G",
              "text": "分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "需要一心，凡事纯洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心思纯正、清明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我明白主的心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常存恐惧、战兢。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "需要一心，富有爱情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "情感满了爱火，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对主热切，爱慕追求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不为其他所夺。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "需要一心，诚实、顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "意志降服归顺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要刚则刚，要柔则柔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神旨惟从、惟遵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "需要一心，毫无责备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良心清洁、无亏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事与神和谐相安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借血脱尽定罪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，赐我们这样的心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻将你思恋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得享你的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的丰满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
