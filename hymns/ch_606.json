              "text": "讓 你"
            },
            {
              "chord": "A",
              "text": "有 家"
            },
            {
              "chord": "A7",
              "text": "可 居"
            },
            {
              "chord": "D",
              "text": "住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命供应，活水流通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长进、变化又配搭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "守住等次，尽我功用，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全别人，不践踏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己所经，自己所见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所是、所有并所能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再高估，不再稍偏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接受一切的平衡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "持定元首，联络供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受基督的丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满神的一切丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因神增加得成熟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同尝基督莫测大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赏识基督的阔长；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长大成人，不作婴孩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有基督的身量。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "作神居所，作你身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我愿被建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的团体大器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你来显你荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城景色、新妇荣美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今在此地就彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "透出你的荣耀光辉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你照耀在人间。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
