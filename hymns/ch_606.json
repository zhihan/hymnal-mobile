        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 阿，"
            },
            {
              "chord": "A",
              "text": "我 願"
            },
            {
              "chord": "A7",
              "text": "被 建"
            },
            {
              "chord": "D",
              "text": "造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同 眾 聖 徒"
            },
            {
              "chord": "G",
              "text": "作 你"
            },
            {
              "chord": "D",
              "text": "聖 殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 著"
            },
            {
              "chord": "A",
              "text": "充 滿"
            },
            {
              "chord": "A7",
              "text": "你 榮"
            },
            {
              "chord": "D",
              "text": "耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "救 我"
            },
            {
              "chord": "G",
              "text": "脫 離"
            },
            {
              "chord": "",
              "text": "乖 僻"
            },
            {
              "chord": "D",
              "text": "個 性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脫 離"
            },
            {
              "chord": "E7",
              "text": "驕 傲"
            },
            {
              "chord": "",
              "text": "與 單"
