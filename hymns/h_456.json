    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Living for Jesus who died in my place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearing on Calv’ry my sin and disgrace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such love constrains me to answer His call,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow His leading and give Him my all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus, Lord and Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give myself to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou, in Thy [redemption],*"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Didst give Thyself for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I own no other Master,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart shall be Thy throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My life I give, henceforth to live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Christ, for Thee alone."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Living for Jesus wherever I am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doing each duty in His holy name;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willing to suffer affliction and loss,"
            }
          ]
        },
        {
          "segments": [
