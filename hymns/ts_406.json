    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "更高，更高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主生命里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我何低浅！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你生命我能更高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更高─更高往上面。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我求更高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变化乃我需要─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流中更加丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿认识你生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "长大，长大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主在我里长大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一天过一天。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今流入我的一切生活─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是祂所愿。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，长在我里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "逐日增加不已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知识不足应付，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须长大并成熟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生活，生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是我生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂实际无限！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "小事，大事，任何事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切事─祂都在里面。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每日活出基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻将祂流露，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂名你当呼求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为得基督献所有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人位，人位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主是我的人位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今住在我里。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我的口味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "态度，动作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，何等希奇！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你是我人位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安家在我心内；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我生命一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是何等的联结！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "召会，召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在众地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有圣灵的流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更深，更高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是我生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我被祂占有。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会乃是基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各方面的显出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我愿脱自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着建造你身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "建造，建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会得着建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠经历基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有如此才会产生建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除祂无别路。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我今求告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿被你建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命逐日加增，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着新耶路撒冷。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "快来，快来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督必要快来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "娶祂的新妇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在召会中我们准备等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体得救赎。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，愿你快来─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此声出自心怀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美不住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你快来，主耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
