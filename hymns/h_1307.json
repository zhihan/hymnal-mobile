  "title": "The day approaches; Jesus soon is coming",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "The day"
            },
            {
              "chord": "",
              "text": "approaches; Jesus soon is"
            },
            {
              "chord": "Dm",
              "text": "coming."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeem the"
            },
            {
              "chord": "G",
              "text": "time; it"
            },
            {
              "chord": "G7",
              "text": "must not"
            },
            {
              "chord": "",
              "text": "slip a"
            },
            {
              "chord": "C",
              "text": "way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make us"
            },
            {
              "chord": "Cm",
              "text": "ready"
            },
            {
              "chord": "",
              "text": "for the cry: \"Be"
            },
            {
              "chord": "C",
              "text": "hold Him!\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By using every"
            },
            {
              "chord": "G7",
              "text": "moment"
            },
            {
              "chord": "",
              "text": "of each"
            },
            {
              "chord": "C",
              "text": "day."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus"
            },
            {
              "chord": "G",
              "text": "comes, will"
            },
            {
              "chord": "G7",
              "text": "we go"
            },
            {
              "chord": "",
              "text": "in to"
            },
            {
              "chord": "C",
              "text": "meet Him?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus"
            },
            {
              "chord": "G",
              "text": "comes, will"
            },
            {
              "chord": "G7",
              "text": "we from"
            },
            {
              "chord": "",
              "text": "self have"
            },
            {
              "chord": "C",
              "text": "ceased?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He's coming soon to"
            },
            {
              "chord": "C7",
              "text": "take the"
            },
            {
              "chord": "",
              "text": "wise ones"
            },
            {
              "chord": "F",
              "text": "with Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us"
            },
            {
              "chord": "C",
              "text": "not be"
            },
            {
              "chord": "G7",
              "text": "left outside"
            },
            {
              "chord": "",
              "text": "the"
            },
            {
              "chord": "C",
              "text": "feast."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, help us to redeem these golden moments;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our vessels fill with ointment from above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help us amen each trial and tribulation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase in us; make us abound in love."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He's coming soon—these moments are so precious."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The oil is here—Oh, let us buy the more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amen the trials and welcome tribulations—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom's ours through these afflictions sore."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, ever turn us from our soulish pleasures"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gaze upon Thy tender, loving face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, keep us running forth to meet the Bridegroom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And patiently attending to the race."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus comes, will we be in His presence?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus comes, will we His face behold?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us not return to sloth and folly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But jealously His loving presence hold."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As His dear Bride, let us go forth to meet Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our lamps well-trimmed, our fires burning bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our vessels filled, our eyes set on His glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be with Him completely satisfied."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, satisfied—Christ and His Bride together."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, satisfied—throughout eternity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a rest, what joy, what love, what favor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be His Bride when He comes to His feast!"
            }
          ]
        }
      ]
    }
  ],
