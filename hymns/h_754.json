    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is to those that fear His name"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His healing power the Savior brings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us hide with contrite hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beneath His healing wings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Sun of Righteousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And while to sin our being clings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We cannot know His healing touch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or rest beneath His wings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is His wings that heal our pains"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And soothe the serpent’s poisoned stings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Close to His bosom we must press"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feel His healing wings."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Beneath those healing wings I rest,"
