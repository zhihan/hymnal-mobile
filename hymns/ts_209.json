  "title": "生命树",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "生 命"
            },
            {
              "chord": "",
              "text": "树 果， 甘"
            },
            {
              "chord": "C",
              "text": "甜 之"
            },
            {
              "chord": "G",
              "text": "至，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生 命 全"
            },
            {
              "chord": "A7",
              "text": "丰 全"
            },
            {
              "chord": "D",
              "text": "足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "前"
            },
            {
              "chord": "G",
              "text": "我 死"
            },
            {
              "chord": "G7",
              "text": "枯， 如"
            },
            {
              "chord": "C",
              "text": "今 活"
            },
            {
              "chord": "G",
              "text": "著；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前 饿， 如"
            },
            {
              "chord": "D",
              "text": "今"
            },
            {
              "chord": "D7",
              "text": "吃"
            },
            {
              "chord": "G",
              "text": "喝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是神领我到生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受基督自己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其中滋味，开口一吃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就觉甘甜无比！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是我生命供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作我的食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是惟一纯净享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂外再无满足。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今尽情吃生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为吃就是路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命借吃加我里头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我凭祂而活。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
