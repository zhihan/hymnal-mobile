{
  "url": "https://www.hymnal.net/cn/hymn/ch/150",
  "title": "哦主你是何等包罗",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 是 何"
            },
            {
              "chord": "G",
              "text": "等 包"
            },
            {
              "chord": "D",
              "text": "罗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 竟 得 在 你"
            },
            {
              "chord": "A7",
              "text": "里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "D",
              "text": "要 你"
            },
            {
              "chord": "",
              "text": "作 我"
            },
            {
              "chord": "G",
              "text": "们 永"
            },
            {
              "chord": "D",
              "text": "分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "的 一"
            },
            {
              "chord": "A",
              "text": "切"
            },
            {
              "chord": "A7",
              "text": "是"
            },
            {
              "chord": "D",
              "text": "你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神使你作我们智慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们因你得救；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是惟一得救之路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟一蒙恩之由。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神使你作我们公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神的要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面我得称义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再无何罪可究。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神使你作我们圣洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为将我们变化；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面我被圣别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到与你无差。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神使你作我们救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要我们像你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要改变我们身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就与你无异。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，当我们在此记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你的所是；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真愿催促你快回来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再有所延迟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个豫尝何等甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已足令人满意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我仍望与你同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满享你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "赞美主",
    "time": "3/4",
    "hymn_code": "532177615",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/197",
        "language": "cn",
