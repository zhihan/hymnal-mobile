              "text": "Fulfilling God’s divine economy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Triune is our oneness real"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One corp’rate Body’s what He wants to see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each one grows with the growth of God each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have real building, God display;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem we will be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our glorious eternal destiny."
            }
          ]
