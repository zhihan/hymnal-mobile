    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life that swallows death now has come;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘Tis Christ as our eternal portion."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True Vine, Bread of life, all we need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life’s Author, even life itself indeed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This Tree of Life, to us a promise giv’n,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Closed to us by the fall of man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ us redeemed, re-op’ning the way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then rising, life conquered death for aye."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Highways to life, the path our feet must tread"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By enjoying Christ, we’re safely led."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Check God in living!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him remain, just enjoy Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Therefore disheartened, we dare not to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Firm in heart, now, we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stay in this line continually"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll give Himself faithfully."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily eat and drink, breathe in Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our thirst is quenched, our hunger satisfied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With our spirit pray, touch the Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By pray’r in private, touch the living Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Confess, be dealt with for the genuine growth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life in us may freely flow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have more of Christ wrought into our being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till others receive life’s watering."
            }
          ]
        }
      ],
