      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In fear, O Lord, at first we shudder"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To face a judgment so complete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But as we're daily drawn to Thee, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No cost's too high, no death's too deep."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To have Thy house, yes, we must die, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou may be our all in all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we will know Thy full supply, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou wilt be the building's wall."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We give ourselves for Thy great purpose;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're for Thy house, whate'er it means."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life, our all, we give to You, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A sacrifice, poured out, unseen."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consume us, Lord, upon Thine altar;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring us to ashes thoroughly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That from our offering Thy life's sweet savor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May ever rise in praise to Thee."
            }
          ]
        }
