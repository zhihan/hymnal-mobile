    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "等我归来得见你面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才知救恩如此完全："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如虫世人成为信徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过与你和好初步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到你我联调为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才是与你和好极地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一重幔子我已经过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢然来到你的圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "二重幔子虽已裂开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的经历仍是不逮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你却要引我进入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "至圣所在，享你供输。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "和好还是完全分别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离弃不法，除去不洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉身和灵一切污秽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需你荣光如同雨沛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽都洗去，洗得尽净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每一部分完全成圣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "拯救之日，悦纳时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我与你和好无隔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿竭力靠你大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奔这\"完全和好\"路程，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的恩典不致徒受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的救恩我能全得。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我看见你的心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你所要我到达境地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我又羡慕，我又惊惧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "依我能力我怎能及？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你作工用你恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我不住，不住向前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
