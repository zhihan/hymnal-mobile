{
  "url": "https://www.hymnal.net/en/hymn/ns/1071",
  "title": "And Peter",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I told the Lord, I’d die for Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I thought I was so strong."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet I three times, denied Him then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In weakness, I was wrong."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In shame, I followed far behind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But He looked back at me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He knew I’d fail and fall three times."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now weeping bitterly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter,” means also “and you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter,”—“I really love you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The most beautiful music in the world!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter,”—“I’m thinking of you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter”—“My heart is for you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rise up, and go to see the Lord!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I wait three days in silent guilt"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wish the Lord forgot."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wonder, could He love me still"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is now my only thought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when He speaks my name so soft—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though others note it not—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New hope and joy now fill my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As He these tidings brought:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
