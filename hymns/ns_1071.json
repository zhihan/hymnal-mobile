    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I wait three days in silent guilt"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wish the Lord forgot."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wonder, could He love me still"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is now my only thought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when He speaks my name so soft—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though others note it not—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New hope and joy now fill my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As He these tidings brought:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter,” means also “and you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter,”—“I really love you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The most beautiful music in the world!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter,”—“I’m thinking of you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“And Peter”—“My heart is for you.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rise up, and go to see the Lord!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your words my heart shall ever sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And strengthen me to turn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since willingly You died for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love won’t cease to burn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I failed and fell, yet You still came"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And loved me e’en in sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So now when I feel far away"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I hear these words again:"
            }
          ]
        }
