    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now with Your love and strength’ning power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your sheep I’d shepherd here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with this love You showed me now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d feed the flock, so dear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This feeding builds the church in love—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love I felt that day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord will never give us up."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In faith, these words I say:"
            }
          ]
        }
