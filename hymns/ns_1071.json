    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your words my heart shall ever sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And strengthen me to turn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since willingly You died for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love won’t cease to burn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I failed and fell, yet You still came"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And loved me e’en in sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So now when I feel far away"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I hear these words again:"
            }
          ]
        }
      ],
