    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The martyr first, whose eagle eye"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could pierce beyond the grave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who saw his Master in the sky,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And called to Him to save:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Him, with pardon on his tongue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In midst of mortal pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He prayed for them that did the wrong:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who follows in his train?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A glorious band, the chosen few"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On whom the Spirit came,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Twelve valiant saints, their hope they knew,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And mocked the cross and flame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They met the tyrant’s brandished steel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lion’s gory mane,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They bowed their necks, the death to feel:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who follows in their train?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A noble army, men and boys,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The matron and the maid,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Around the Savior’s throne rejoice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In robes of light arrayed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They climbed by strength divine from heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through peril, toil, and pain:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, to us may grace be given"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To follow in their train."
            }
          ]
        }
