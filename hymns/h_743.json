              "text": "God to contact constantly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep our heart, Lord, in love’s freshness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our spirit strengthen more,"
            }
