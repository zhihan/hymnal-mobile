      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan has our heart corrupted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our spirit death did give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Lord we should not contact"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by self attempt to live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus the Lord in His salvation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heart and spirit has renewed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To recover our receiving"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our loving aptitude."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is by our heart’s renewal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may God in love pursue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in newness of the spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may contact God anew."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever true and pure and single"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Lord our heart must be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Poor in spirit, ever seeking"
            }
          ]
        },
        {
          "segments": [
            {
