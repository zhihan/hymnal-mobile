    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "时走在大草原， 听见亲爱牧者柔声；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时走在山谷间， 智慧领路暂时离开；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时被带到海上， 爱我的主竟然睡着。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "往前的每一步， 常在冒险、惊喜之中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从来没见过祂， 天天糢糊，天天清明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从来没见过祂， 天天糢糊，天天清明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每天非我所愿， 日子多么富于挑战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不许安逸、自怜， 与人同情，与人同行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂供应生命粮、 生命活水、一切动力。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带人走出黑暗， 多少生命因此转换；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能力来覆庇， 天天怯场，天天强壮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能力来覆庇， 天天怯场，天天强壮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你许凡爱你者， 一生充满多少矛盾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "似乎不为人知， 却是诚实，人所共知，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "似乎即将丧命， 却是复活，欢呼得生。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在己里有痛楚， 在你里面无量丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瓦器里有宝贝， 天天羞辱，天天荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瓦器里有宝贝， 天天羞辱，天天荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从来不曾估量， 平凡的我得此上好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以你生命活你， 以你性情行事为人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天罗曼蒂克， 多采多姿，可泣可歌。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你极大怜悯， 今生到我这里来过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主阿，谢谢你， 今生到我这里来过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，主阿，谢谢你， 今生到我这里来过。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
