    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir me, oh, stir me, Lord, till all my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is filled with strong compassion for these-souls;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thy compelling word drives me to pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thy constraining love reach to the poles"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Far north and south, in burning deep desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till east and west are caught in love’s great fire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir me, oh, stir me, Lord, till prayer is pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till prayer is joy, till prayer turns into praise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir me, till heart and will and mind, yea, all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is wholly Thine to use through all the days."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir, till I learn to pray exceedingly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir, till I learn to wait expectantly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir me, oh, stir me, Lord, Thy heart was stirred"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By love’s intensest fire, till Thou didst give"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine only Son, Thy best beloved One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en to the dreadful cross, that I might live."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir me to give myself so back to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou canst give Thyself again through me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stir me, oh, stir me, Lord, for I can see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy glorious triumph-day begin to break;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The dawn already gilds the eastern sky;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Church of Christ, arise, awake, awake."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! stir us, Lord, as heralds of that day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For night is past, our King is on His way."
            }
          ]
        }
