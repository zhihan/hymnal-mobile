    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our fathers, chained in prisons dark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were still in heart and conscience free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And blest would be their children’s fate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If they, like them should die for thee:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith of our fathers! holy faith!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will be true to thee till death!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith of our fathers, we will strive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To win all nations unto thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And through the truth that comes from God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mankind shall then indeed be free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith of our fathers! holy faith!"
            }
          ]
        },
