{
  "url": "https://www.hymnal.net/cn/hymn/ch/22",
  "title": "父我赞美你的怜悯",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "父， 我"
            },
            {
              "chord": "",
              "text": "讚 美 你 的 憐 憫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "如 此"
            },
            {
              "chord": "A7",
              "text": "高 大"
            },
            {
              "chord": "",
              "text": "並 深"
            },
            {
              "chord": "D",
              "text": "闊；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 著 我 的 軟 弱、 失 敗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "你 的"
            },
            {
              "chord": "A7",
              "text": "憐 憫"
            },
            {
              "chord": "",
              "text": "時 加"
            },
            {
              "chord": "D",
              "text": "多。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 今"
            },
            {
              "chord": "",
              "text": "敬 拜、"
            },
            {
              "chord": "D",
              "text": "我 今"
            },
            {
              "chord": "",
              "text": "敬 拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "你 這"
            },
            {
              "chord": "",
              "text": "憐 憫 抬 舉"
            },
            {
              "chord": "A7",
              "text": "我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "D7",
              "text": "這"
            },
            {
              "chord": "G",
              "text": "憐 憫"
            },
            {
              "chord": "A",
              "text": "抬"
            },
            {
              "chord": "A7",
              "text": "舉"
            },
            {
              "chord": "D",
              "text": "我！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对你怜悯我们惊奇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此低就且不移，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然临及我这罪人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且要维持永无已。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何能使我、何能使我"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从这怜悯被遗弃？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们感激你的怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此丰富且充足！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因这怜悯、借着救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾丰厚赐眷顾。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "舍此何能、舍此何能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我如此蒙爱护？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，你怜悯富有感召，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "柔细、可爱又甘甜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你忍耐和你恩慈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正合我需赐恩典。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们宝贵、我们宝贵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这怜悯的完全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今享受你的怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远不旧、永远新；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每日早晨临到我身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如甘露施滋润。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等甜美、何等甜美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满心赞美你怜悯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对你赞美何能止息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你怜悯永持久；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的恩惠、你的眷顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都为我永保守。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可靠怜悯、可靠怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不能叫我蒙羞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
