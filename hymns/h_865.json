{
  "url": "https://www.hymnal.net/cn/hymn/h/865",
  "title": "In spirit and in truth, O Lord",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "In spirit"
            },
            {
              "chord": "",
              "text": "and in"
            },
            {
              "chord": "Am",
              "text": "truth, O"
            },
            {
              "chord": "",
              "text": "Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "C",
              "text": "meet to"
            },
            {
              "chord": "",
              "text": "worship"
            },
            {
              "chord": "D",
              "text": "here;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As"
            },
            {
              "chord": "G",
              "text": "taught by"
            },
            {
              "chord": "",
              "text": "Christ, the"
            },
            {
              "chord": "C",
              "text": "Son of"
            },
            {
              "chord": "",
              "text": "God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "G",
              "text": "now in"
            },
            {
              "chord": "D7",
              "text": "Him draw"
            },
            {
              "chord": "G",
              "text": "near."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thank God, He is a Spirit true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So near, so dear to us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may contact Him in life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In truth to worship thus."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A spirit God has made for us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may worship Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not striving, serving outwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But seeking from within."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Regenerated by the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renewed in mind and heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He dwells within us as our life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True worship to impart."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We worship here according to"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The inner consciousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anointed by His Spirit now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His fulness we express."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In truth we serve and worship too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In shadows nevermore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, the one reality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father we adore."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To God we offer Christ the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whom we experience;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God we too delight in Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His light and sweetness sense."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit and reality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together here we meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To worship, praise, and fellowship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Around the mercy-seat."
            }
          ]
        }
      ]
    }
  ],
