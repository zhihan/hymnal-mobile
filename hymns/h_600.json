              "text": "Portion,"
            },
            {
              "chord": "G",
              "text": "and my"
            },
            {
              "chord": "",
              "text": "Love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My"
            },
            {
              "chord": "C",
              "text": "everlasting"
            },
            {
              "chord": "G",
              "text": "All,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I've none but"
            },
            {
              "chord": "D",
              "text": "Thee in"
            },
            {
              "chord": "G",
              "text": "heav'n above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or on this"
            },
            {
              "chord": "D7",
              "text": "earthly"
            },
            {
              "chord": "G",
              "text": "ball,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or on this"
            },
            {
              "chord": "D7",
              "text": "earthly"
            },
            {
              "chord": "G",
              "text": "ball."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What empty things are all the skies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And this inferior clod!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s nothing here deserves my joys,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s nothing like my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s nothing like my God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee I owe my wealth, and friends,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And health, and safe abode;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thanks to Thy name for meaner things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But they are not my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But they are not my God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How vain a toy is glittering wealth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If once compared to Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or what’s my safety, or my health,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or all my friends to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or all my friends to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Were I possessor of the earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And called the stars my own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without Thy graces and Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I were a wretch undone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I were a wretch undone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let others stretch their arms like seas,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grasp in all the shore;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grant me the visits of Thy grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I desire no more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I desire no more."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
