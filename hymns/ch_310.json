{
  "url": "https://www.hymnal.net/cn/hymn/ch/310",
  "title": "一生聪明未遇敌手",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "一 生"
            },
            {
              "chord": "",
              "text": "聰 明 未"
            },
            {
              "chord": "F",
              "text": "遇 敵"
            },
            {
              "chord": "G7",
              "text": "手，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以"
            },
            {
              "chord": "C",
              "text": "掃、 以"
            },
            {
              "chord": "F",
              "text": "撒 均"
            },
            {
              "chord": "G7",
              "text": "成"
            },
            {
              "chord": "C",
              "text": "往"
            },
            {
              "chord": "G",
              "text": "事；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "C",
              "text": "今 到"
            },
            {
              "chord": "",
              "text": "了 生"
            },
            {
              "chord": "D7",
              "text": "死 關"
            },
            {
              "chord": "G",
              "text": "頭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "雖 然"
            },
            {
              "chord": "C",
              "text": "絕"
            },
            {
              "chord": "G",
              "text": "望"
            },
            {
              "chord": "D",
              "text": "仍"
            },
            {
              "chord": "G",
              "text": "然"
            },
            {
              "chord": "D7",
              "text": "自"
            },
            {
              "chord": "G",
              "text": "恃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "束"
            },
            {
              "chord": "A7",
              "text": "手 就"
            },
            {
              "chord": "Dm",
              "text": "縛 我"
            },
            {
              "chord": "G7",
              "text": "不 能"
            },
            {
              "chord": "C",
              "text": "受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "C7",
              "text": "要 用"
            },
            {
              "chord": "F",
              "text": "力， 我"
            },
            {
              "chord": "Dm",
              "text": "要"
            },
            {
              "chord": "G7",
              "text": "用"
            },
            {
              "chord": "C",
              "text": "謀。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "仿佛我见有人偷营，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心害怕但我倔强："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟恐我的末日已定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用尽全身所有力量；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来摔跤，我要招架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未到死地还要挣扎。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奇哉！我用已往经验，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摔跤一夜祂仍不倒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的力量眼见将减，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是祂像无意回报；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奇哉！又像无法脱身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的胆量又复加甚。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此对手从未得会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂虽告我祂的名字，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我仍不知所战为谁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只知祂有很大赏赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就迫祂向我赐福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迫祂向我赐福、屈服。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "天已黎明难分胜负："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像无法、好像无能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就被迫向我赐福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且称许，说我得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说我新名是以色列；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我起来，我腿已瘸！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有了微光进我暗心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "开始照亮使我领会："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若我有能，为何扭筋？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若我得胜，为何瘸腿？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是祂得胜留下记号，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我愚昧受了警告。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "瞬息之间，光满我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同洪流冲破堤防，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就看见荣耀无尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迫我敬拜、迫我隐藏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我才知道我的大罪、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的不轨、我的污秽。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哎阿，想到：我曾胜过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "造物的主、全能的神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荒谬之极，该当有祸！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "该死之至，该死无恩！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我这双手竟然背叛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "强迫主神不得动弹！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是何等荣耀的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万军之主何等显赫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我一认识你是谁人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并一看见你是如何，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要长号，我要流泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要懊悔，我要下跪。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "怎么可能！怎么可以！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见神的面，与神相持！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我恨不得有缝入地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才可稍微掩我羞耻："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何我不在此以先，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即已毁灭，离世长眠？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我恨自己过于昏沉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为骄傲瞎了眼睛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "想到我是得胜了神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就不禁胆战心惊："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浑身无力，何只一腿？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "百节俱脱，全人崩溃！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今回顾我的一生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是充满败坏事体："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "保全自己，将神牺牲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愚昧的心只知快意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我还以为祝福在于"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "强神来听我的所欲。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我有欲望天来顺服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我出主张天来安排，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我有喜好望神让步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我有工作望神领帅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我若急切天须赶快，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那有一次神不失败！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世界竟有如此邪恶、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "骄傲、顽固、诡诈的人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你知道我是雅各，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满败坏，充满可恨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我无可望，只望怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你来怜悯败坏这心。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今已蒙怜悯一摸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "举步蹒跚，恩典遗迹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我若忘记，新的腿窝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要使我感何等无倚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽许我作以色列，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是雅各永远病瘸。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我服了，是你得胜："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你失败我求失败，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我得胜我来投诚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的软弱领我下拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿一生战战兢兢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "行你旨意，荣耀你名。"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "羡慕",
