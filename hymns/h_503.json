          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I never will despair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know that He is leading,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all the stormy blast;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The day of His appearing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will come at last."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He lives, He lives, Christ Jesus lives today!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He walks with me and talks with me along life’s narrow way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He lives, He lives, salvation to impart!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You ask me how I know He lives?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He lives within my heart."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejoice, rejoice, O Christian,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lift up your voice and sing"
            }
          ]
        },
        {
