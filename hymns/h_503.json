              "text": "Eternal hallelujahs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Jesus Christ the King!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Hope of all who seek Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Help of all who find,"
            }
          ]
        },
