    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Agape love then bids me be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more for my own gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For He who loved and rescued me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has won my life through pain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can one who’s loved not give his all?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Divine love paid the cost."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life that daily dies, then lives,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will ne’er be counted loss."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To know the riches of His grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Old self I gladly yield;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Emotion, mind, and will I place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within His hands, unsealed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life surrendered wholly, grows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His image thus to shine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I sense His will and turn aside"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From what is not divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through consecration’s narrow gate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I walk and yield each choice;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In daily steps, both small and great,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I hear my spirit’s voice."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each time His will defeats my own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A step ahead is won—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each vict’ry o’er my self-bound soul"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leads ever to the Son."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
