            },
            {
              "chord": "D",
              "text": "脫。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 我 救"
            },
            {
              "chord": "A7",
              "text": "主，"
            }
          ]
        },
