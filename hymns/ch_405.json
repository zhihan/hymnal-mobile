            },
            {
              "chord": "A",
              "text": "買；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "D",
              "text": "果"
            },
            {
              "chord": "G",
              "text": "我 愛"
            },
            {
