        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 耶"
            },
            {
              "chord": "A",
              "text": "穌，"
            },
            {
              "chord": "A7",
              "text": "是 現"
            },
            {
              "chord": "D",
              "text": "在！"
            }
