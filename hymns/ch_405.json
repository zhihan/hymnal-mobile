      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，我爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为你先爱我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我在加略"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将赎价已付妥。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱你，是因为"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荆棘冕你肯戴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果我爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，是现在！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "活着我爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到死了也爱你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并要赞美你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要你给气息。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即是死临到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我仍然要表白："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果我爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，是现在！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在那无止境"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐的荣耀里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要在光中"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到永远敬拜你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "头戴荣耀冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我还要唱出来："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果我爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，是现在。"
            }
          ]
        }
      ],
