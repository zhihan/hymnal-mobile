      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "每 次"
            },
            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "打 擊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都 是 真 利"
            },
            {
              "chord": "A",
              "text": "益，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "如 果"
            },
            {
              "chord": "D7",
              "text": "你 收"
            },
            {
              "chord": "",
              "text": "去 的"
            },
            {
              "chord": "G",
              "text": "東 西，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 以"
            },
            {
              "chord": "",
              "text": "自 己"
            },
            {
