      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我要赞美，再要赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美何等甘甜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽我边赞美边流泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘甜比前更加添；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能有甚么比你更好？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比你喜悦可宝？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我只有一个祷告："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你能加增，我减少。"
            }
          ]
        }
      ],
