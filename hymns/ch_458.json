            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如果你我所有苦乐"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能完全相同，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要你喜乐，须我负轭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就愿意多苦痛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我全心要你所要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不惜任何代价；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若喜悦，并得荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我背任何十字架。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
