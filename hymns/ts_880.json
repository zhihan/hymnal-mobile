    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"当信靠主耶稣，当信当信靠主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你和你一家都必得救；\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这蒙恩见证无数，全都在向我说出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神总不会迟误，要听我祈求。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣的爱何大，爱我也爱我全家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我一人信主，全家蒙福；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要全心赞美祂，永远是信实可夸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同来敬拜称祝，这宝贵救主。"
            }
          ]
        }
