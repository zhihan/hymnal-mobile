{
  "url": "https://www.hymnal.net/cn/hymn/ts/616",
  "title": "耶稣聚集我们在一起",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "從 前"
            },
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "C",
              "text": "在 罪"
            },
            {
              "chord": "",
              "text": "中 死"
            },
            {
              "chord": "G",
              "text": "了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 世 界 全"
            },
            {
              "chord": "A",
              "text": "然 一"
            },
            {
              "chord": "",
              "text": "團"
            },
            {
              "chord": "D",
              "text": "糟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "但 神"
            },
            {
              "chord": "G7",
              "text": "使 我"
            },
            {
              "chord": "C",
              "text": "們 一"
            },
            {
              "chord": "",
              "text": "起 復"
            },
            {
              "chord": "G",
              "text": "活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一 起 與 基 督 升"
            },
            {
              "chord": "D7",
              "text": "天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同 坐 寶"
            },
            {
              "chord": "G",
              "text": "座。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶"
            },
            {
              "chord": "G7",
              "text": "穌 聚"
            },
            {
              "chord": "C",
              "text": "集 我"
            },
            {
              "chord": "",
              "text": "們 在 一 起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "請 看"
            },
            {
              "chord": "",
              "text": "看 聖"
            },
            {
              "chord": "A7",
              "text": "徒 同"
            },
            {
              "chord": "",
              "text": "心 合"
            },
            {
              "chord": "D",
              "text": "意！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "主"
            },
            {
              "chord": "G7",
              "text": "愛 使"
            },
            {
              "chord": "C",
              "text": "得 我"
            },
            {
              "chord": "",
              "text": "們 都 一 致，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "達 到"
            },
            {
              "chord": "G",
              "text": "基 督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豐 滿"
            },
            {
              "chord": "D7",
              "text": "身 量"
            },
            {
              "chord": "",
              "text": "的 地"
            },
            {
              "chord": "G",
              "text": "步。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我们能和众圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一起明白基督的爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长阔高深虽然无法测度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但神的丰满"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们一再得着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣聚集我们在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请看看圣徒同心合意！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱使得我们都一致，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "达到基督"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰满身量的地步。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神在历代隐藏的旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已成了显明的奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督，召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今看见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这真叫撒但受辱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羞惭满面！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
