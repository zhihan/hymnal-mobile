              "text": "刚强我们里面的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你安家在我们心里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你爱中生根立基。"
            }
          ]
        }
