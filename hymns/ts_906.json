        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "愛 主！ 我"
        },
        {
          "chord": "C",
          "text": "親"
        },
        {
          "chord": "Ab",
          "text": "你， 我"
        },
        {
          "chord": "F",
          "text": "戀"
        },
        {
          "chord": "G7",
          "text": "你，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "猶 如 朝"
        },
        {
          "chord": "C",
          "text": "鹿 慕"
        },
        {
          "chord": "",
          "text": "溪，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "Dm",
          "text": "乾 旱"
        },
        {
          "chord": "",
          "text": "久"
        },
        {
          "chord": "G7",
          "text": "候 雲"
        },
        {
          "chord": "",
          "text": "霓，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "F",
          "text": "望 眼"
        },
        {
          "chord": "",
          "text": "欲"
        },
        {
          "chord": "C",
          "text": "穿， 此"
        },
        {
          "chord": "",
          "text": "心 欲"
        },
        {
          "chord": "Dm7",
          "text": "碎，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "相"
        },
        {
          "chord": "G7",
          "text": "思 之"
        },
        {
          "chord": "",
          "text": "苦， 何 日 得 慰，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "C",
          "text": "此"
        },
        {
          "chord": "F",
          "text": "情"
        },
        {
          "chord": "G7",
          "text": "垂"
        },
        {
          "chord": "C",
          "text": "聽。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "爱主！我心所好，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你是我至宝；围你魂缭绕。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我真爱你，真慕你，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "深愿时刻在一起，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "形影不分离，虽在睡梦，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "仍然切切把你挂记。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "此情和此境，爱主！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "人间语怎表明？"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我心被你溶化，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "一切为你丢下，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "因宇宙间谁能比你"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "慈爱无涯，怜悯无底？"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主阿！来罢！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "荣主！我心所属，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你是我良牧，有你心满足。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "十架上，你命捐弃，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "流宝血买我归你，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我今把自己，一切，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "今后永远专一奉献作祭，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主阿！快回来"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "享受我所有和情爱，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我的爱如膏倾，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "远超属世人情，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "天长地久，与你连理；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "海枯石烂，此志不移。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "心恳！阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "甜主！我心所系，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "恨不插双翼，飞投你怀里，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "多少次举目望天，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "等候你驾云显现；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "提接你面前，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "谁知荣影无踪，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "云彩依然翩翩。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "天哪！别留祂！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "看我伤心，泪哭无涯！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主！你岂能安息，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "任我思爱成疾？"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "爱主，你何忍再延待？"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "无论如何，求你快来，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "此愿成全！"
        }
      ]
    }
  ],
