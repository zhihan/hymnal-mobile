        },
        {
          "chord": "F",
          "text": "吐 意"
        },
        {
          "chord": "",
          "text": "傾"
        },
        {
          "chord": "Dm7",
          "text": "心，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "述 說 你"
        },
        {
          "chord": "G7",
          "text": "我 闊"
        },
        {
          "chord": "",
          "text": "別 思"
        },
        {
          "chord": "C",
          "text": "念。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "C7",
