    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Christ He is the canopy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To shelter God’s elect,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A hiding place, a shade from heat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s work He does protect."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As virgin’s Son, to us He came—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The universal sign;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Immanuel, God dwells with us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a joy divine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now unto us this child is born,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As firstborn Son He came;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As counselor, He’s wonderful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The mighty God His name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The shadow of a massive rock"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon a wasted soil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A refuge He from storm and wind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A rest from earthly toil."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A twig and branch and Jesse’s root,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fruit of all the earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He grew up as a tender plant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a Christ of worth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Christ, He is the cornerstone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s tested and secure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory of the Father’s house,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon Him resting sure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Although He was despised by man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Acquainted He with grief;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He paid the greatest sacrifice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we should find release."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A peg that’s driven in the wall"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On which all glory rests,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The faithful household steward He,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s wisdom manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal covenant He makes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With David’s mercies sure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thirsty He does satisfy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With living waters pure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To properly portray this One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Bible uses three:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Isaiah, Cyrus, Israel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A threefold Servant He."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Prince of Peace and Mighty God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Savior and the King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The light in the Millennium,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis of this One we sing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since unto us this light has shined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who dwell in Galilee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We evermore declare His praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a Christ is He."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    }
  ],
