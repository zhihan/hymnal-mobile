    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞祂与神同等"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原坐在天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟成为人子为我们受创；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞祂从死复活"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝座上为王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "复活的丰富我们能尽尝。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞祂何丰富充满了一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们竟成祂丰富的显彰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰富的显彰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰富的显彰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞祂今是那灵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活在我灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宗教的仪文我不再凭依；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我可时刻享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受祂自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂一切丰盛都成我经历。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在地方召会我们齐欢畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强的灵中将祂来颂扬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "颂扬祂是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在召会作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "颂扬祂是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在召会作王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂荣耀自己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满在召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会的见证得胜又明亮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满得灵中丰富"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同颂扬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让世人都知这万王之王。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丢弃自己那窄小的天地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自由的灵引我们到地极；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀欢乐的流出祂自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀欢乐的流出祂自己。"
            }
          ]
        }
