    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O holy Father, righteous One,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness upholds Thy throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis a foundation sure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis through this righteousness of Thine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That reigns in Christ the grace divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And peace we thus secure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness has caused Thy Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To die for us that we be won,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption thus was bought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness has justified"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Christ’s redemption was applied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation thus was wrought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou might show Thy righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy forgiveness Thou didst bless"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Men in the ancient age;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thee Thy righteousness to show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remission Thou dost now bestow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On sinners in this age."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All people Thou wilt judge one day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness to all display"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Christ, Thy Son, our Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet fast we’ll stand, for none can move,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness we’ll ever prove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With grace Thou wilt afford."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With justice is Thy kingdom filled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And peace upon it Thou dost build"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all in harmony;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the new heaven and new earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness will be their worth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As promised, God, by Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
