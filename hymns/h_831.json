      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This precious faith of all the saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is constituted solely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Christ and His redemptive work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which are unique and holy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this the saints are truly one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together all agreeing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And it is from this common faith"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church came into being."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church within the universe"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is one as Christ’s possession;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church must therefore locally"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be one in her expression;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all her elements are one—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One God, one Lord, one Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One faith, baptism, Body too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One hope all saints inherit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This oneness is the Church’s ground,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ground of common standing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The only ground of unity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit is demanding."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church in actual practise thus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May keep her vital union,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And her expressions locally"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be built up in communion."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, help us ever strive to keep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This unity by taking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church’s ground of unity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Body-life partaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thy heart’s profound desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May fully be effected,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God’s eternal purpose may"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Completely be perfected."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
