    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How blinded we have been,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shut in with what concerns us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While God’s house lieth waste—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, break through, overturn us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll go up to the mountain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring wood and build the house;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll never say, “Another day!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s time! We’ll come and build!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, against these days,"
