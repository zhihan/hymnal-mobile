            },
            {
              "chord": "G7",
              "text": "Lord, Halle"
            },
            {
              "chord": "C",
              "text": "lujah!"
            },
            {
              "chord": "",
              "text": "Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the"
            },
            {
              "chord": "G7",
              "text": "Lord, praise"
            },
            {
              "chord": "",
              "text": "the"
            },
            {
              "chord": "C",
              "text": "Lord,"
