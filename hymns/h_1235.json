        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'll"
            },
            {
              "chord": "F",
              "text": "never"
            },
            {
              "chord": "G",
              "text": "be"
            },
            {
              "chord": "G7",
              "text": "the"
            },
            {
              "chord": "C",
              "text": "same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A wanderer within the world"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For pleasure ever seeks;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be it in body or in mind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With vanity it reeks."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For self I labored day and night,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My castles built in sand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, praise the Lord, He wrecked them all—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Much better things He planned."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once all for self—confused, alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How could I bear the shame?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now within the local church"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I am a happy member now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the local church."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A wanderer has found his home"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ended all his search."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I was an individualist,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "An island in myself;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now the Lord is building me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With others in Himself."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m drawn together with His own"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship so sweet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve learned from others to receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Christ whene’er we meet."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, Hallelujah! Hallelujah!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll never be the same!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My wanderings have really ceased—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve found the church, God’s best!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secret of my happiness—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying God’s own rest!"
            }
          ]
        }
      ]
    },
