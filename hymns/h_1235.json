          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then hearken"
            },
            {
              "chord": "G7",
              "text": "to the"
            },
            {
              "chord": "C",
              "text": "song he"
            },
            {
              "chord": "",
              "text": "sings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "F",
              "text": "follow"
            },
            {
              "chord": "G7",
              "text": "in his"
            },
            {
              "chord": "C",
