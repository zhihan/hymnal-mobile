    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣我主救世王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱感我衷肠！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "客西马尼备极伤痛，意怆惶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "汗如血点滴地上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺从父旨不忘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "舍身救世，面如坚石，前行壮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "轻看羞辱和苦难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍受罪人顶撞；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "背负十架，往各各他，不延宕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "手足被钉，肋受伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "血、水流出命丧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美哉、善哉、主爱奇哉，深且长！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣我主得胜王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱何等无量！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十架祈祷，怜悯为怀，心何广；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同钉一贼得生望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可知救恩无疆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身负重罪，为神离弃，倍凄凉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "痛彻肺腑，心焦渴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "苦胆、酸醋亲尝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎功成，将灵交神，打胜仗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由死复活升天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代祷犹如馨香；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美哉、善哉、主爱奇哉，深且长！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣我主平安王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱岂能测量！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我犹罪人，你已代死，爱明彰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗我罪孽，医我伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安慰、怜恤多方；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "责备、管教、定我步履、赐我光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敌虽凶恶不足惧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救恩为我城墙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "疲乏、软弱，你加我力，使刚强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仰望我主在天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心被恩感歌唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美哉、善哉、主爱奇哉，深且长！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
