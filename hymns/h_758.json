          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take His word and ask for light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If you seek in deep contrition,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will guide your heart aright."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do not fear to claim His promise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will not your trust betray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When on earth He gladly healed them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He is the same today."
            }
          ]
