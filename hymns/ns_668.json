    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Live through me, Lord; let self no longer bind Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remove all traces of its hold on me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be magnified in every word and action;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In me, Thy living manifested be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Live through me, Lord; my soul be emptied wholly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All pleasures and self-seeking put away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be Thou my aim and satisfaction solely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our loving union e’er through me convey."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Live through me, Lord, and make my heart Thy dwelling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each chamber fully occupied by Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thought, feeling, will, infuse with Thee completely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we’ve one living out unceasingly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Live through me, Lord; stop independent action;"
