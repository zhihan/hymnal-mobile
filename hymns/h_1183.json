          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feet as burnished brass aglow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tender eyes that gazed at Peter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now are as a burning flame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the voice that whispered, “Mary,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many waters now became."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
