    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His appearance, lo, how different"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the One John knew before."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now He’s girt in golden raiment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the robe which then He wore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Girt about the breasts and serving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He the priesthood fully bears;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cherishing the lampstands dearly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He for all the churches cares."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ancient One He is, yet fresher"
