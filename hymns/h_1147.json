      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From Egypt Israel fled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into a desert land;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Egyptian food they left behind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And wandering began."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One day, the manna fell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a wondrous feat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This was the bread the Lord had giv’n"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Israel to eat."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Unique this manna is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It comes with morning dew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The visit of God’s grace it is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever fresh and new."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God is majestic, high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And greater than us all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But that we may partake of Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, He’s fine and small."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though ground, or beat, or baked,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s so available;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As bread and cakes and wafers fresh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We eat Him to the full."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Manna shows Him to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The germ of life, the seed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis God Himself sown into us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The source of all we need."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Between the morning dew"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And cold of winter snow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This manna too is frost which kills"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Things negative below."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How pure and white and clean;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In type our Christ we see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we digest His element,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He washes inwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Manna with honey is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Two lives this type does show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One for the Lord’s redemptive work,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And one His life to grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By eating more of Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll be the less opaque;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll then appear as bdellium,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transparent us to make."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, as we’re eating here"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the manna see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of this glorious Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re filled with praise to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    }
  ],
