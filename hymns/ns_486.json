    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, eternal, builded bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From self she is delivered from independent pride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her righteousness is Christ yet in her daily life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She manifested God, and lived and worked in Christ."
            }
          ]
        }
      ],
