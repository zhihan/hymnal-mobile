    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem! The city and the bride!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Builded up, beautified, and wholly sanctified!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem is builded in the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A company in Christ established in the Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As fellow citizens, God’s kingdom manifest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit live and walk, and enter Sabbath rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
