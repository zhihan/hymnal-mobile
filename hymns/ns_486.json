      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem, the bride who is prepared,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is beautified by Christ, to be His wife, matured;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In nature and in life she must in stature grow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the Body live, the Body-life to know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
