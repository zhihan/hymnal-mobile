              "text": "Even as He is we will be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Little children don’t be led astray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will see Him on judgment day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who is righteous and lives in light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will live Him out as He is right,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even as He is right."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ the love of God abides,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us this perfect love resides,"
            }
          ]
        },
        {
