              "chord": "",
              "text": "Even as He walked."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He who has this hope in Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is purified in how he lives;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By living Christ as righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He lives a life in blessedness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even as He is pure."
            }
          ]
        }
      ]
    },
    {
