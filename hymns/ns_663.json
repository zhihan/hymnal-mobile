      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Christ’s indwelling Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re strong to apprehend"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His magnitude and substance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dimensions without end;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love surpasses knowledge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet naught would He conceal;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He fills us in our spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s fullness to reveal."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our life and person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Head of the one new man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Created in Himself, where"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our corporate life began."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re rooted and we’re grounded"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ, God’s Firstborn Son;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, in His love, enjoy Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, in His life, are one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We exercise our spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Christ indwell our hearts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To spread throughout our being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all our inward parts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life substantiating—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mysterious, unseen—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Him as faith, perceiving"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s bounty unforeseen."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This metabolic process"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is constituting us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ in all His riches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through our enjoyment thus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church in our experience"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is full of God expressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Christ is God embodied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made known and manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Above all we could ask for"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or think of in this age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s work exceeds our measure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He molds us, stage by stage."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s resurrection power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within us operates."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give God all the glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From whom all emanates."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
