          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子带进国度显彰。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
