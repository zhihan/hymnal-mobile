      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 教"
            },
            {
              "chord": "",
              "text": "导"
            },
            {
              "chord": "A",
              "text": "我 祷"
            },
            {
              "chord": "D",
              "text": "告，"
