              "text": "主，铭刻我心上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你深入我心土壤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天有路扩长，"
