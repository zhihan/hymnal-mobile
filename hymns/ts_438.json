      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你在我心中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是奇妙生命之种；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你分赐更丰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面完成所动善工。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，使我心柔软，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你知我心一切为难；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呼求你名不断，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "翻动我心除去硬石阻拦。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你光照明亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "暴露我总让你失望；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你仍赐盼望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子必定发苗生长。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，倒空我所有─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里贫穷毫无保留；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你生命涌流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我浸透生命达到成熟。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，使我心纯洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你充满，作我一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就一无所缺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心思情感意志更新不歇。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
