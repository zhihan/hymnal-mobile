        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 要 外 邦 世"
            },
            {
              "chord": "G",
              "text": "俗 老"
            },
            {
              "chord": "A",
              "text": "套，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "用 天"
            },
            {
