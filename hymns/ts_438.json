      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你长在我里！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命力量无可匹敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必拯救我到底，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以你生命将我更新不已。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，愿你长在我里。"
            }
          ]
        }
