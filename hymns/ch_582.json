{
  "url": "https://www.hymnal.net/cn/hymn/ch/582",
  "title": "主你是话你也是灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "C",
              "text": "话， 你"
            },
            {
              "chord": "D7",
              "text": "也 是"
            },
            {
              "chord": "G",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 赞"
            },
            {
              "chord": "D",
              "text": "美 同"
            },
            {
              "chord": "A7",
              "text": "灵 和"
            },
            {
              "chord": "D",
              "text": "声！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞"
            },
            {
              "chord": "G",
              "text": "美 你"
            },
            {
              "chord": "",
              "text": "话 使"
            },
            {
              "chord": "C",
              "text": "我 知"
            },
            {
              "chord": "",
              "text": "晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬 拜 你"
            },
            {
              "chord": "G",
              "text": "灵 使"
            },
            {
              "chord": "D",
              "text": "我 触"
            },
            {
              "chord": "G",
              "text": "到。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，你是我的一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全在你能与我联结；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以是话，且又是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为能来作我的供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你若是主，而不是话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要知你，有何办法？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若是神，而不是灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要触你，又怎可能？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "话是你的明确启示，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我对你能有认识；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵是你的本身本质，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我接触你的所是。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的生命、亮光、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "道路、真理、活水、灵粮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全借你话向我传递，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并凭你灵使我经历。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话在于所写圣经，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵就是内住圣灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你话进入我心我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也就是灵，且是生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我要明白你的圣经，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也要接触你的圣灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅凭着头脑明了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且要用灵敬拜祷告。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话乃是我心所爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵更是我灵所拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你话中我心欢畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你灵里我灵歌唱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
