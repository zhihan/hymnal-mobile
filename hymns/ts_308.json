{
  "url": "https://www.hymnal.net/cn/hymn/ts/308",
  "title": "专一爱你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，每代你有一人："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如朋友，亚伯拉罕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呼喊者，如撒母耳；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又如大卫，满了颂赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你要得一班。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们巴望就是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "服事你的那一班；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗你脚，合你需要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你舒畅，令你心欢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你密友良伴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无所不谈…"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要颂赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要呼喊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一心转向你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你来掌管，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "专一的爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直爱到底，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿此情不移。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坚定不移…"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你的丰盛怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向我们毫不吝惜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是团体新人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着你的永远旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只望能爱到底，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坚定不移……"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
  "metadata": {
    "category": "爱慕耶稣",
