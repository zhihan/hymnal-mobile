  "raw_sections": [
    "求主 光照、 光 照我，",
    "阿 们！",
    "显明、 显明我 罪过，",
    "阿 利 路 亚！",
    "用血 洗濯， 用 血 洗濯，",
    "使我 污秽全 消没，",
    "阿们！",
    "求主释放、释放我，",
    "阿们！",
    "断开、断开我捆索，",
    "阿利路亚！",
    "败坏鬼魔，败坏鬼魔，",
    "使我自由而超脱，",
    "阿们！",
    "求主复兴、复兴我，",
    "阿们！",
    "消除、消除我软弱，",
    "阿利路亚！",
    "挑旺爱火，挑旺爱火，",
    "使我完全为主活，",
    "阿们！"
  ]
