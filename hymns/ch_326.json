  "raw_sections": [
    "求主 光照、 光 照我，",
    "阿 們！",
    "顯明、 顯明我 罪過，",
    "阿 利 路 亞！",
    "用血 洗濯， 用 血 洗濯，",
    "使我 污穢全 消沒，",
    "阿們！",
    "求主释放、释放我，",
    "阿们！",
    "断开、断开我捆索，",
    "阿利路亚！",
    "败坏鬼魔，败坏鬼魔，",
    "使我自由而超脱，",
    "阿们！",
    "求主复兴、复兴我，",
    "阿们！",
    "消除、消除我软弱，",
    "阿利路亚！",
    "挑旺爱火，挑旺爱火，",
    "使我完全为主活，",
    "阿们！"
  ]
