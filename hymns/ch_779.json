{
  "url": "https://www.hymnal.net/cn/hymn/ch/779",
  "title": "在基督里归一万有",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "在 基"
            },
            {
              "chord": "",
              "text": "督 裏"
            },
            {
              "chord": "D",
              "text": "歸 一"
            },
            {
              "chord": "G",
              "text": "萬 有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "乃 是"
            },
            {
              "chord": "",
              "text": "我 神 的 經"
            },
            {
              "chord": "G",
              "text": "營；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基 督 作 頭"
            },
            {
              "chord": "E",
              "text": "並 作"
            },
            {
              "chord": "Am",
              "text": "中 心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "萬 有"
            },
            {
              "chord": "D",
              "text": "和 諧"
            },
            {
              "chord": "D7",
              "text": "而 安"
            },
            {
              "chord": "G",
              "text": "寧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督元首要作中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在其中作亮光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督和神同坐宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使其心愿全得赏。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督要作生命、内容，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "归一万有于光中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众圣要作祂的器皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远彰显祂光荣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但已将他的自己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "注到人里，毁万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进黑暗、败坏、紊乱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神计画难成就。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督来将祂的自己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分赐与人作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拯救人脱黑暗权势，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗、死亡，再无能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借召会－祂的身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将万有归于一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有都要联得合式，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论大小成一系。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这元首基督之下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有联结而存立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂召会所照光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有全都归于一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有祂作头并作中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有全都能和谐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂身体所有光照，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有相安无间歇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "再无黑暗，再无死亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再无败坏与虚空；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有都要脱离辖制，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远居于自由中。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
  "metadata": {
    "category": "终极的显出",
    "time": "4/4",
    "hymn_code": "553172211776165",
