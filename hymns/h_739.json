{
  "url": "https://www.hymnal.net/en/hymn/h/739",
  "title": "In those regenerated by the Lord",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "In those"
            },
            {
              "chord": "",
              "text": "regene"
            },
            {
              "chord": "D",
              "text": "rated"
            },
            {
              "chord": "",
              "text": "by the"
            },
            {
              "chord": "G",
              "text": "Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is an inner"
            },
            {
              "chord": "A",
              "text": "knowledge"
            },
            {
              "chord": "",
              "text": "bounti"
            },
            {
              "chord": "D",
              "text": "ful;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we the outward"
            },
            {
              "chord": "D7",
              "text": "teachings"
            },
            {
              "chord": "",
              "text": "do not"
            },
            {
              "chord": "G",
              "text": "need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But God we"
            },
            {
              "chord": "C",
              "text": "inward"
            },
            {
              "chord": "D",
              "text": "ly may"
            },
            {
              "chord": "D7",
              "text": "know in"
            },
            {
              "chord": "G",
              "text": "full."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal life, the highest and the best,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Possesses full divine capacity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That by this life God’s knowledge we may have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More than by knowledge given outwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of life is put within our mind"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And on our heart ’tis written sovereignly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inwardly ruling us that God we know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More than by teachings given outwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy anointing in our spirit dwells,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Showing the things of God to mind and heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By this anointing we God’s knowledge have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More than man’s teachings can to us impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We have the triune God indwelling us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living and acting, working all the time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That by the inner sense we have of Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God we may know in magnitude sublime."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This inner knowledge obviates the need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of outward knowledge, human eloquence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in the spirit we must ever live"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And walk according to the inner sense."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we live in Christ, the life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by the inner consciousness behave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we’ll have the inward knowledge true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And on our heart God will His Son engrave."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this living inward knowledge gained"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That fellowship with God in life we hold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this hidden knowledge thus obtained"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God unto us His fulness doth unfold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
