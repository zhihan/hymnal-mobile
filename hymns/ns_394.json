  "title": "The Living Vine, a Reality",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The living vine, a reality"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God and man, one organically"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mutual abode, organism sweet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expression full, mingling complete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we abide, there’s a flow within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As branches we—are expressing Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God needs us, we depend on Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bear much fruit, to bring others in."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, Cultivator—Husbandman,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The source is He."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soil, sunshine and the air—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nutrients complete."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Son, the living vine is—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The embodiment of God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Spirit makes Him real—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the life juice sweet!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
