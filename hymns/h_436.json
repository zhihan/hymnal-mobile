    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Father's home of light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy rainbow-circled throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were left for earthly night,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For wanderings sad and lone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yea, all was left for me, for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have I left aught for Thee?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, hast borne for me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More than my tongue can tell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of bitterest agony,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To rescue me from hell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou suff'redst all for me, for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What have I borne for Thee?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou hast brought to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Down from Thy home above"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation full and free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy pardon and Thy love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Great gifts, great gifts Thou broughtest me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What have I brought to Thee?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let my life be given,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My years for Thee be spent;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "World-fetters all be riven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And joy with suff'ring blent;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou gav'st Thyself for me, for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give myself to Thee."
            }
          ]
        }
      ],
