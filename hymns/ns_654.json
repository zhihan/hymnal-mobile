    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For God’s dispensing, we have been,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made into vessels open to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His element is wrought in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making us living stones, corporately;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Being saved from self, the flesh and its will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s no longer I, but Christ lives in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Members of the Body, built up in love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined to be one, for Him corporately."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, we waste ourselves upon Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our lives for Thine eternal will!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy love, Lord, constrains us all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To make way for Thy house and Thy will!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let’s arise! It’s time to build!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His dwelling place we give all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Standing firm, fulfilling the pleasure of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, as a living sacrifice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will be perfected by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To build Thy Body, seek increase,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the commission now we receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit, soul, we’re one for His goal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The lampstands to spread His recovery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A local being, a global seeing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gospel in hand, the kingdom we’ll preach!"
            }
          ]
        }
      ]
