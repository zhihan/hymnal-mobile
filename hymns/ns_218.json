    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day Two did come and go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But one thing I did know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Things earthly lost their glow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They’re dead to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The atmosphere expanse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lifted my circumstance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That life may thus advance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For growth in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day Three, the land so dry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Emerged from waters high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grass, herbs, and trees did rise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life had sprung."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My death You now recede,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As life do rise in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rise more ’til there’s no sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within my being."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day Four, the sun did shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With rays of healing light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The moon was shining too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church, my home."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The saints as stars with light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine ’midst this darkening night,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Setting my feet aright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To walk Your way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day Five, the fish arrived,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Against the worldly tide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death waters they survived,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life empowered;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From fish to bird I soar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By waiting on You, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your grace to me affords,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strength o’er all things."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day Six, from air to ground,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cattle and beasts around,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then all creation crowned"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With man—like You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through growth expressing Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Your authority,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d reached maturity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your purpose gained."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
