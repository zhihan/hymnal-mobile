    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m mercy’s vessel, this I know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God has chosen me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The riches of His glory shall"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus manifested be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not him who wills can follow now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This way as yet unknown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not him who runs can yet pursue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to whom mercy’s shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Father’s lovingkindness, ’tis,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I am not consumed—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His compassions never fail;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each morning they are new."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through His compassions day by day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give myself to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transformed and built with other saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s Body thus to see."
            }
          ]
        }
      ],
