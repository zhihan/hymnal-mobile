{
  "url": "https://www.hymnal.net/en/hymn/ns/643",
  "title": "Jesus Lord, I’m coming forward unto You",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, I’m coming forward unto You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hiding not, I come just as I am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though reviewing how I’ve lived today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am filled with shame once again."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more myself deceiving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more to You pretending,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Simply opening my heart in full,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my spirit Lord I pray to You."
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To be like Abraham,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Intimate and sweet with You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lingering in fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord I want to know Your heart’s"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Longing and deep desire."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is my plea, reveal to me this mystery."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What privilege, how glorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be one with Your great plan."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Receiving You, dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Letting this life saturate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Listening to Your sweet Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Truly I want to express"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing but only You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I consecrate and give You all my heart and mouth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is, alone, the meaning and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purpose of my prayer, Lord."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now on the earth, freely through us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Carry out Your will, my Lord."
            }
          ]
        }
      ],
      "type": "verse"
    }
  ],
