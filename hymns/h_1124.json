{
  "url": "https://www.hymnal.net/en/hymn/h/1124",
  "title": "What! Not sing of blood divine",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "What! Not"
            },
            {
              "chord": "",
              "text": "sing of blood divine?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "What! Not"
            },
            {
              "chord": "",
              "text": "tell to"
            },
            {
              "chord": "A7",
              "text": "all man"
            },
            {
              "chord": "D",
              "text": "kind?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What! Not speak to hearts unclean"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the"
            },
            {
              "chord": "A",
              "text": "precious"
            },
            {
              "chord": "",
              "text": "living"
            },
            {
              "chord": "D",
              "text": "stream."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By this blood, God’s life released,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blood surpassing any beast’s;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfect, spotless Lamb of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incorruptible His blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Voice it has, this holy blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pow’r possessed to speak with God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks it for us at the throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With its glorious virtue shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Failure on our conscience is—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conscience means a “knowing this”—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Causing us much grief and pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Telling us of every stain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the while we’re unaware"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the blood’s effectual prayer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus’ blood speaks of our case,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we might receive His grace!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We need not dead works to bring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor another offering."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing else could please our God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heav’n is listening for His blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In His blood forgiveness shines;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, ’tis glorious to find!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Israel just atonement knew,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have that and cleansing too."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Heart and mind are now at peace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rest! Our conscience has been reached."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never more we blush in shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are washed from every stain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Fathomless!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that’s in His blood for us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sing we will, and sing we must;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His blood is all our trust!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
