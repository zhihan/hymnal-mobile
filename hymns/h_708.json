    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If in the test of my trouble,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faint be my spirit and heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith, with the star of hope glimm'ring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall all be taken apart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May then Thy faith with Thy life-pow'r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Over me hold its full sway"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all Thy riches of glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I may share and for aye."
            }
          ]
        }
      ]
    },
    {
