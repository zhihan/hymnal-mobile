        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, as the morning sun dawning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Chase all my darkness away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Thy kind wings of healing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn all my night into day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come Thou, O come, Lord of comfort,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come to my sad, weary heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, O Thou blest hope of glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never, O never depart."
            }
          ]
        }
