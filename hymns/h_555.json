    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As in the dawning, o’er the waveless ocean,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The image of the morning star doth rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So in this stillness Thou beholdest only"
            }
          ]
        },
        {
