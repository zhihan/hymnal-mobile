      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Tis by Thy blood we’ve been redeemed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by it sanctified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now is our conscience free from sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From dead works purified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Better than Abel’s, now Thy blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks unto God for us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfect redemption it provides,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meeting God’s righteousness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the eternal Spirit, Thou"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Offeredst Thyself to God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This sacrifice can ne’er grow old;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Timeless is Thy dear blood."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by Thy blood we boldly come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto the throne of grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto our God, the cov’nant new,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to the Holiest Place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, by Thy blood, God is obliged"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His very Self to give;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He must receive us to Himself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He in us must live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, how precious is Thy blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the New Testament!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By it God’s blessings we receive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we with Him are blent."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
