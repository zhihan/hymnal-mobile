    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He held the highest place above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Adored by all the sons of flame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet such His self-denying love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He laid aside His crown and came"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To seek the lost,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And at the cost"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of heavenly rank and earthly fame"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He sought me—Blessed be His name!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It was a lonely path He trod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From every human soul apart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Known only to Himself and God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was all the grief that filled His heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet from the track"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He turned not back,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till where I lay in want and shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He found me—Blessed be His name!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then dawned at last that day of dread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When desolate, yet undismayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With wearied frame and thorn-crowned head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He, God-forsaken, man-betrayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was then made sin"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Calvary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, dying there in grief and shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He saved me—Blessed be His name!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Long as I live my song shall tell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wonders of His dying love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And when at last I go to dwell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him His sovereign grace to prove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My joy shall be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His face to see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bowing there with loud acclaim"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll praise Him—Blessed be His name!"
            }
          ]
        }
      ],
