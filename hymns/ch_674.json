            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "D",
              "text": "是 同"
            },
            {
              "chord": "G",
              "text": "情 的"
            },
            {
              "chord": "A7",
              "text": "耶"
            },
            {
              "chord": "D",
              "text": "穌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能 醫 罪"
            },
            {
              "chord": "A",
              "text": "傷， 能"
            },
            {
              "chord": "Bm",
              "text": "解 憂"
            },
            {
              "chord": "D",
