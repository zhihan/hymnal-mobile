      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 為 你 受"
            },
            {
              "chord": "A7",
              "text": "死 木"
            },
            {
              "chord": "D",
              "text": "上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 將 你 眾"
            },
            {
              "chord": "E7",
              "text": "罪 擔"
            },
            {
              "chord": "A",
              "text": "當，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 尋"
            },
            {
              "chord": "A",
              "text": "你 前"
            },
            {
              "chord": "Bm",
              "text": "來 醫"
            },
            {
              "chord": "D",
              "text": "傷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "速 來"
            },
            {
              "chord": "D",
              "text": "就 這"
            },
            {
              "chord": "A7",
              "text": "耶"
            },
            {
              "chord": "D",
              "text": "穌。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "罪孽虽多，必蒙赦免，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要肯来就耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良心虽亏，必得平安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若你肯来就耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "性情败坏，罪恶染心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得救治，就耶稣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "软弱、叹息、疾病缠身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要蒙医治，就耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "郁闷、痛苦、人生乏味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何不前来就耶稣？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂能赐你医治活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请来一试就耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着医治、释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我接受主耶稣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归给被杀羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今相信主耶稣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我得释，因祂被绑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得医，因祂受伤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得生，因祂命亡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着耶稣。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱救我恩主之名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱之名是耶稣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这名驱尽我的苦情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贝之名惟耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "馨香名，圣徒爱唱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊贵名，天使颂扬！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高超名，万名之上！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣！宝贝耶稣！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "等我被提到祂面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲眼得见我耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀之中更要颂赞"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣！宝贝的耶稣！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
