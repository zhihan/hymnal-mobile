{
  "url": "https://www.hymnal.net/cn/hymn/ts/919",
  "title": "神将得着国度",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "創 造"
            },
            {
              "chord": "",
              "text": "之 神"
            },
            {
              "chord": "D7",
              "text": "有 一"
            },
            {
              "chord": "G",
              "text": "目 的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "使 人"
            },
            {
              "chord": "",
              "text": "活 著"
            },
            {
              "chord": "D",
              "text": "有 意"
            },
            {
              "chord": "G",
              "text": "義；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "按 祂 形 像"
            },
            {
              "chord": "D7",
              "text": "我 們"
            },
            {
              "chord": "G",
              "text": "被 造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "將 祂"
            },
            {
              "chord": "G",
              "text": "權 柄"
            },
            {
              "chord": "D7",
              "text": "顯 於"
            },
            {
              "chord": "G",
              "text": "地。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "人 雖"
            },
            {
              "chord": "B",
              "text": "落 入"
            },
            {
              "chord": "Am",
              "text": "撒 但"
            },
            {
              "chord": "B7",
              "text": "詭 計，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "使 神"
            },
            {
              "chord": "",
              "text": "目 標"
            },
            {
              "chord": "A7",
              "text": "受 蒙"
            },
            {
              "chord": "D7",
              "text": "蔽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "但 神"
            },
            {
              "chord": "",
              "text": "終 將"
            },
            {
              "chord": "D7",
              "text": "得 祂"
            },
            {
              "chord": "G",
              "text": "國 度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "子 必"
            },
            {
              "chord": "G",
              "text": "完 成"
            },
            {
              "chord": "D7",
              "text": "父 心"
            },
            {
              "chord": "G",
              "text": "意。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣基督要得国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但诡计必无路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子长出实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不顾一切的拦阻。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非宗教人士所说，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死后才能进国度；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督正在建造国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们见证且目睹。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神子耶稣，我们救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神亲来成肉体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今成那灵进入人里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作为赐生命之气。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是小小生命子粒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生根在人的灵里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从里到外，不住扩展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到生命全漫溢。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄，时间己经短促，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主正切慕得新妇；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着生命长大成熟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们催促祂脚步。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再挣扎，不再奋鬬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要灵中转向主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事长入元首基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子成国度。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "惟凭生命正常生长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督得着祂国度；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变化并非瞬间即成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "逐日增长是正途。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，让我们发展、取用"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子的丰富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵种子长成国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神旨成功不迟误。"
            }
          ]
        }
      ]
    }
  ],
