    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "应当时常喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当时常喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论如何，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "歌唱总胜叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论如何，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生存总胜死寂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以应当时常喜乐！"
            }
          ]
        }
      ],
      "type": "chorus"
