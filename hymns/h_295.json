      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I believe Thy precious blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which, at the mercy seat of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever doth for sinners plead,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me, e’en for my soul, was shed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I believe were sinners more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than sands upon the ocean shore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast for all a ransom paid,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all a full redemption made."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bold can I stand in every way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For who aught to my charge shall lay?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully, by Thee, absolved I am"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From sin and fear, from guilt and shame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This spotless robe the same appears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When ruined nature sinks in years;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No age can change its glorious hue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its glory is forever new."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou God of power, Thou God of love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let all Thy saints Thy mercy prove;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our beauty this, our glorious dress,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus the Lord, our Righteousness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
