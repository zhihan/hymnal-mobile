    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we stay our feeble efforts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from struggling cease,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unconditional surrender"
