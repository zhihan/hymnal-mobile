      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lean we all our weight on Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who alone can save;"
            }
          ]
        },
        {
          "segments": [
