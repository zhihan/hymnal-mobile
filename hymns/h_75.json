    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Name that to our hearts is nearest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here the stricken soul doth hide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Name that to our hearts is dearest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As in Jesus we confide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Call Him Jesus!” He shall save us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the tyranny of sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From its condemnation save us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From iniquity within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thanks we give, and adoration,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every day and every hour,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For an uttermost salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freedom from sin’s guilt and power."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! sweetest note of any"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the lowly pilgrim’s song;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! the triumphant music"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the bright angelic throng."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth to Him her face upraises,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knows Him as the great I AM!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaven resounds with Jesus’ praises,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory to the bleeding Lamb!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
