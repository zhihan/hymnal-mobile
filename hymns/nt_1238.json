    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day the world goes on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just as it has gone before."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Millions grasp and clutch at life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wond’ring if there could be more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such was I and would be, yet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mercy found me out somehow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With what gratefulness I say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“I’m in God’s own family now.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How delightful ’tis to know;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How subjective, real, and sweet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is this inward joy of grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We experience when we meet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life abundant Jesus gives"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As my full reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise You, Lord, it’s really true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m in Your own family."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At the closing of this age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just before Your kingdom’s dawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May You gain a people, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your dwelling place, Your home."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since for me You gave Your all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything I lay aside;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your church my all I’d give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You would be satisfied."
            }
          ]
        }
