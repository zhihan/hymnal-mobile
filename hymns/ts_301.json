    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱，主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比酒更甜美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你膏油所发香气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我心欢喜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你膏油所发香气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我心欢喜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是园中泉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你又是活水的井，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流自利巴嫩山的溪涧。"
            }
          ]
        },
        {
