    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Go, labor on: ’tis not for nought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy earthly loss is heav’nly gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Men heed thee, love thee, praise thee not;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Master praises, what are men?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Go, labor on; your hands are weak,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your knees are faint, your souls cast down;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet falter not; the prize you seek"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is near, a kingdom and a crown."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Go, labor on while it is day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world’s dark night is hastening on;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speed, speed thy work, cast sloth away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not thus that souls are won."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Men die in darkness at your side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without a hope to cheer the tomb;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take up the torch and wave it wide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The torch that lights time’s thickest gloom."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Press on, faint not, keep watch and pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be wise the erring soul to win;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go forth into the world’s highway,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Compel the wanderer to come in."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Press on, and in thy work rejoice;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For work comes rest, the prize thus won;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon shalt thou hear the Master’s voice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The midnight cry, Behold, I come!"
            }
          ]
        }
      ]
    }
