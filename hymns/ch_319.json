    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的路途真孤苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常疲倦、疲倦不唱诗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不认识我路途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你能使我、使我不迷失。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每一点，每一天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是一样需恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我仍一样是无倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你更多、更多显自己。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的感觉常改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切可厌、可厌无价值；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我眼睛看不见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正是我主、我主最近时。"
            }
          ]
        }
      ],
