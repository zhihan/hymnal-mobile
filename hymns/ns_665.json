    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My habitual, heedless conduct"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of self has ever been."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I abhor that I could stumble"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even one due to this sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I confess that I’m a sinner—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Laying hands on You within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash me clean till I am spotless"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And restore my inner man!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In my spirit, by Your mercy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine upon my wayward heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Break the independent nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of my soul, each inward part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me one who cares for others,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nurturing, to life impart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Buoyant with Your living Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cherishing this fresh new start."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I turn my whole heart, yielding"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To You, for Your masterpiece."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your light comes understanding;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You forgive and joy increase."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My mind setting on my spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can sense Your life and peace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turning to You in my spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I find You, my true release."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’ve been my only comfort."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even now You comfort me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot be lost and mournful."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You increasingly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your dear blood does cleanse me wholly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "White as snow effectively."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I stand with Your inward working,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I in You and You in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I agree with what You’re speaking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my heart, and in Your Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You alone are sanctuary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your dear presence joy assured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What You are imbues me sweetly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will rest in what I’ve heard—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Private, wooing words, like kisses,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Touching depths, with love conferred."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Your precious blood, I come Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Your dear and lovely face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You for You love deeply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holding me in Your embrace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heav’n and earth may bear this witness—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here, the object of Your grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is myself, blood-washed, enlivened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of joy, Your joy to trace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
