    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Thou art God, and Thou art “new”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without Thee all is worn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But all with Thee is ever fresh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though many years have gone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Father, Thou art unchanging,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou never hast grown old;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru countless ages, ever fresh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy newness doth unfold."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each blessing Thou hast given us"
            }
          ]
        },
        {
