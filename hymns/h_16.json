              "text": "Thy newness doth contain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy covenant, Thy ways are new,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ever thus remain."
            }
          ]
        }
