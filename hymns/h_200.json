    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The tender mercy of our God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Caused Thee on us to dawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those in darkness giving light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That shades of death be gone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Morning without clouds,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And as the Morning Light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the tender grass on earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who in Thy rays delight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy shining light with pleasant rays"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increases all the way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It shines within us more and more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the perfect day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It shines thru woe with clearest beams,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As shining after rain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy mercy with Thy love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy shining e’er remains."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou also art the Morning Star"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us as a reward;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While still ’tis dark it shines with light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those who love the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, help us e’er to love Thy light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And see things from afar;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And look for Thee in watch and prayer"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As for the Morning Star."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
