    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He fills the throne—the throne above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its rights to Him belong;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The object of His Father's love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Theme of the ransomed's song."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though high yet He accepts the praise"
            }
          ]
        },
        {
