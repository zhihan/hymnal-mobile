{
  "url": "https://www.hymnal.net/cn/hymn/ts/924",
  "title": "与基督同作后嗣",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "今 在"
            },
            {
              "chord": "",
              "text": "灵 里， 在"
            },
            {
              "chord": "D",
              "text": "召 会"
            },
            {
              "chord": "G",
              "text": "中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "A",
              "text": "见 异"
            },
            {
              "chord": "",
              "text": "象， 高、 深、"
            },
            {
              "chord": "A7",
              "text": "长、"
            },
            {
              "chord": "D",
              "text": "阔："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "定"
            },
            {
              "chord": "C",
              "text": "命 卓"
            },
            {
              "chord": "",
              "text": "越 超"
            },
            {
              "chord": "D",
              "text": "凡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前"
            },
            {
              "chord": "G",
              "text": "所 未"
            },
            {
              "chord": "",
              "text": "见， 超"
            },
            {
              "chord": "D",
              "text": "人 能"
            },
            {
              "chord": "G",
              "text": "度。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅道理，乃是启示"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督自己奇妙、奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超心思所能领略，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但在灵中都成实际。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是丰富、无限、深奥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无法测度、超绝美妙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟需我们得着救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同为后嗣显祂荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已计画，也来创造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要作出新造无穷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已立子作祂后嗣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "执掌祂的神圣行政。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但在神的经纶之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非仅有一子得荣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是长子率众弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同作后嗣，定命与共。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着够格作神后嗣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们必须长大成熟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好与基督同得荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承受神的所是所有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "作神后嗣，随同长兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承受万有，丰富无缺；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更是同伙，一同经营"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"基督、召会\"宇宙大业。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今在灵里，在召会中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得见我们呼召、盼望："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非遥望，等\"上天堂\"，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是在地与主同王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "贫寒如我，竟成君王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有分宝座，承受国度；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡神所是并祂所有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地、万有无不我属。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
