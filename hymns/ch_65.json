{
  "url": "https://www.hymnal.net/cn/hymn/ch/65",
  "title": "耶稣大名荣耀有能",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "耶 穌"
            },
            {
              "chord": "",
              "text": "大 名， 榮 耀、"
            },
            {
              "chord": "A",
              "text": "有 能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 我 投 靠、"
            },
            {
              "chord": "A7",
              "text": "是 我"
            },
            {
              "chord": "D",
              "text": "倚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "『坐 在 天 上，』"
            },
            {
              "chord": "G",
              "text": "我 今"
            },
            {
              "chord": "D",
              "text": "讚 美，"
            },
            {
              "chord": "",
              "text": "你 名"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "就 是"
            },
            {
              "chord": "A7",
              "text": "我 勝"
            },
            {
              "chord": "D",
              "text": "利。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "可颂耶稣、大能救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我所需要在你名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要呼吸耶稣这名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是饮于你生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣大名，荣耀、有能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地宣告祂大能；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而只有蒙恩罪人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知道这名的丰盛！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣！耶稣！最贵之名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "战时兵器、病时膏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你名里生活争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就有喜乐和荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
