    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God is forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life supply in my spirit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s dwelling in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father in the Son came"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Displayed for all to see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son as Spirit flows now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To flow God into me."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m calling His name “Lord Jesus”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s coming in my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s spreading out from my spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all my inward parts."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more I contact daily,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more my heart Christ’s home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with the saints I’m built up"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the church, Christ’s home!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Repeat verse 3)"
            }
          ]
        }
