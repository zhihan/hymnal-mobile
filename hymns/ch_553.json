{
  "url": "https://www.hymnal.net/cn/hymn/ch/553",
  "title": "主阿我要安静在你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "我 要 安"
            },
            {
              "chord": "A",
              "text": "靜 在"
            },
            {
              "chord": "A7",
              "text": "你 面"
            },
            {
              "chord": "D",
              "text": "前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將 我 全 人 收"
            },
            {
              "chord": "E7",
              "text": "回 到"
            },
            {
              "chord": "",
              "text": "我 裡"
            },
            {
              "chord": "A",
              "text": "面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "不 再"
            },
            {
              "chord": "",
              "text": "僅 是 外"
            },
            {
              "chord": "G",
              "text": "面 隨"
            },
            {
              "chord": "",
              "text": "意 禱"
            },
            {
              "chord": "D",
              "text": "告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "乃 是"
            },
            {
              "chord": "",
              "text": "照"
            },
            {
              "chord": "D",
              "text": "著 靈"
            },
            {
              "chord": "",
              "text": "裡 感"
            },
            {
              "chord": "A",
              "text": "覺"
            },
            {
              "chord": "A7",
              "text": "發"
            },
            {
              "chord": "D",
              "text": "表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你好像是在天上听我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实在你是在我里面住着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像是我向你呼求、祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实在是你在我里面发表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有时我虽没有话语达意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我能随那灵深深叹息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是我在外面向你求讨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是你在里面借我发表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿在此吸取你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃你喝你，享受你的供给；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫我能真实与你相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你从我里面得着发表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这交通里面，你光照亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你血也要将我洗得清爽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不仅使我能得彻底光照，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且使你能有清楚发表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此你的膏油多方涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你涂我里面越过越多；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的成分加多，我的减少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就从我得着更多发表。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此向你开启，让你注入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也要向人敞开，让你流出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你活水流中与人相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫你能得着丰满发表！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "祷告",
    "time": "4/4",
    "hymn_code": "3231123453",
    "midi_tune_url": "https://www.hymnal.net/Hymns/Chinese/midi/tunes/c0553_tune.midi",
    "related": [
