{
  "url": "https://www.hymnal.net/cn/hymn/ch/539",
  "title": "神造我们作祂器皿",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 造"
            },
            {
              "chord": "",
              "text": "我 们 作 祂"
            },
            {
              "chord": "A",
              "text": "器 皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "乃 为"
            },
            {
              "chord": "G",
              "text": "彰 显"
            },
            {
              "chord": "",
              "text": "祂 丰"
            },
            {
              "chord": "A",
              "text": "盛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "要 我"
            },
            {
              "chord": "G",
              "text": "爱 祂，"
            },
            {
              "chord": "A",
              "text": "为 我"
            },
            {
              "chord": "D",
              "text": "造 心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 我 接 受，"
            },
            {
              "chord": "A7",
              "text": "且 造"
            },
            {
              "chord": "D",
              "text": "灵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们应该用心爱神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也该用灵接受神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得神作我们生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非此无法能入门。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但败坏我们的心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也弄死了我们灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我不能与神接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反倒靠赖己生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，主在祂救恩里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更新我的心与灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恢复了我爱的心情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并我接受的本能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是借着更新的心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们爱神，渴慕神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且是借着更新的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们拜神，接受神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对神，我们的心应当"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "诚实、清洁又单纯；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且我们的灵该是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "贫穷、寻求且温顺。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神阿，保守我心爱你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常是新鲜、无陈迹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并使我灵刚强、活泼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永以新样接触你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
