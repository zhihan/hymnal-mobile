{
  "url": "https://www.hymnal.net/cn/hymn/ts/603",
  "title": "建造当趁今日",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "记 得"
            },
            {
              "chord": "",
              "text": "大 卫 起"
            },
            {
              "chord": "F♯m",
              "text": "誓："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "『我"
            },
            {
              "chord": "G",
              "text": "不 进"
            },
            {
              "chord": "",
              "text": "我 的"
            },
            {
              "chord": "A",
              "text": "帐"
            },
            {
              "chord": "A7",
              "text": "幕， 不"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "上 我"
            },
            {
              "chord": "",
              "text": "的 床"
            },
            {
              "chord": "F♯m",
              "text": "榻， 不"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "容 我"
            },
            {
              "chord": "",
              "text": "打 盹"
            },
            {
              "chord": "A",
              "text": "闭"
            },
            {
              "chord": "A7",
              "text": "目， 直"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "等 到"
            },
            {
              "chord": "",
              "text": "我 为"
            },
            {
              "chord": "D",
              "text": "耶 和"
            },
            {
              "chord": "",
              "text": "华，"
            },
            {
              "chord": "Em",
              "text": "寻"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "得 安"
            },
            {
              "chord": "F♯m",
              "text": "息 之"
            },
            {
              "chord": "Bm",
              "text": "处。』 全"
            },
            {
              "chord": "G",
              "text": "能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "神 巴"
            },
            {
              "chord": "G",
              "text": "望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有"
            },
            {
              "chord": "D",
              "text": "家 使"
            },
            {
              "chord": "G",
              "text": "属 祂"
            },
            {
              "chord": "A7",
              "text": "者 可"
            },
            {
              "chord": "D",
              "text": "住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们何等眼瞎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只顾自己的事务，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "任凭神殿荒凉─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你必须有路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们情愿上山取木，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建你殿劳碌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "绝不再说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘且等明日，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造当趁今日！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，此时此境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "激动人起来建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正如大卫之日，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自动答应你呼召。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心合意，配搭一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受此托付，多好！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所喜，是你心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们来建造。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，为着你召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我们废寝忘食，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建造献一切─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "专心豫备你居所！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阴间的门不能胜过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已建成的召会。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时候不多，建造我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你能早归回！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（重复最后两行）"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
