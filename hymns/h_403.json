    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrated is Thy temple,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purged from every stain and sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thy flame of glory now be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Manifested from within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the earth in solemn wonder"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "See my body willingly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Offered as Thy slave obedient,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Energized alone by Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Every moment, every member,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Girded, waiting Thy command;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Underneath the yoke to labor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or be laid aside as planned."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When restricted in pursuing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No disquiet will beset;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Underneath Thy faithful dealing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not a murmur or regret."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever tender, quiet, restful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inclinations put away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou may for me choose freely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Thy finger points the way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live Thyself, Lord Jesus, through me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my very life art Thou;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee I take to all my problems"
            }
          ]
        },
