{
  "url": "https://www.hymnal.net/cn/hymn/ch/465",
  "title": "我现在默思葡萄",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "现 在 默"
            },
            {
              "chord": "Am",
              "text": "思"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡"
            },
            {
              "chord": "G",
              "text": "萄 一"
            },
            {
              "chord": "D7",
              "text": "生 的"
            },
            {
              "chord": "G",
              "text": "事："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其 路 并 不 容"
            },
            {
              "chord": "Am",
              "text": "易，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其"
            },
            {
              "chord": "G",
              "text": "境 也"
            },
            {
              "chord": "D7",
              "text": "不 安"
            },
            {
              "chord": "G",
              "text": "逸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "长 不"
            },
            {
              "chord": "D7",
              "text": "像 野"
            },
            {
              "chord": "G",
              "text": "地 野"
            },
            {
              "chord": "",
              "text": "花，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "随"
            },
            {
              "chord": "D",
              "text": "地 随"
            },
            {
              "chord": "D7",
              "text": "意 自"
            },
            {
              "chord": "G",
              "text": "由 吐"
            },
            {
              "chord": "",
              "text": "华；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "成 曲"
            },
            {
              "chord": "D7",
              "text": "径 迷"
            },
            {
              "chord": "G",
              "text": "堂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "成 款"
            },
            {
              "chord": "D7",
              "text": "式 百"
            },
            {
              "chord": "G",
              "text": "样。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "反之，葡萄开花，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非常渺小无华；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人几不能辨省，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它竟也曾有英；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "花尚未曾开得一日，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即已迅速结为果实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不得成为骄葩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自感丰姿可夸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "它是拴在桩上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能随意生长；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它如伸肢展臂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是架上被系；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它就如此从了砾土，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吸取它的养生食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能自由拣选，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能遇难思迁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，绿衣秀美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "春地披上明媚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因着生命丰裕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自然生长有馀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至满身嫩枝细苗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "开始四向飘浮盘绕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在于青蓝空中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尝其甘美无穷。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是园主、园工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对它并不放松；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来刈剪、修刀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要剥它的骄傲；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "毫不顾惜它的细嫩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将它割得又深又准，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有多馀美穗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽都断折破碎。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在它损失期间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它并不敢自怜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是反将自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更为完全彻底"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交付给那剥夺所有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使它成为虚空的手；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它不浪费生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切都为结果。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那些流血的枝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "渐变坚硬木质；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那些存留的穗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也渐结果累累；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "太阳又来迫它枯干，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它叶开始败落四散，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使它果子盛紫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至收成之日。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "它因负重过甚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以致无枝不沉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是长期努力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受尽琢磨来的；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今果实已经全美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自然它可欣喜自慰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是收成就到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欣慰日子何少！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有手要来摘下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有脚要来践踏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄所有宝藏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在于酒醡之上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到丰富、血红的酒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浩荡有如长江大流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终日涌溢不息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐充满大地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是葡萄形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是剥光凄凉："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经给了一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又将进入黑夜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却无谁人向它偿还"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它所给人酣醉之欢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反而将它再砍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使成无枝秃干。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "然而全冬之间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它酒却赐甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给那寒冷之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忧郁愁苦之众；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是葡萄却在外面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "孤独经历雪地冰天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坚定忍受一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切可疑、难解！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到寒冬已过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它又豫备结果，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重新萌芽生枝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再来放绿成姿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不因已往所受磨难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心中有了埋怨不甘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不因所失无限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而欲减少奉献。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "它的所有呼吸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽是高天清气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不半点沾染"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不洁属地情感；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "面向牺牲，依然含笑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再来接受爱的剥削，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有如从未遇过"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "损失、痛苦、折磨。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "葡萄从它肢枝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流酒、流血、流汁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是否因已舍尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它就变为更贫？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世上醉人、人间浪者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从它畅饮，因它作乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是否因了享福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们就变更富？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "估量生命原则，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以失不是以得；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不视酒饮几多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃视酒倾几何；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为爱的最大能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是在于爱的舍弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁苦受得最深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最有，可以给人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁待自己最苛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最易为神选择；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁伤自己最狠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最能擦人泪痕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁不熟练损失、剥夺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁就仅是响钹、鸣锣；"
            }
          ]
