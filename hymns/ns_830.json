    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God has journeyed down to reach man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A child born, our “Christ the Lord,” in Bethlehem!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both divine and human,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The perfect God-man walks on the earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A Man became."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What love is this? Redemption shows its greatness!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love manifest, God in the flesh dies for man’s sins,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can fathom this love?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God shed “His own blood” to purchase us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love reached man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ died and rose, the Spirit thus becoming!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Spirit, now He spreads in our tripartite being!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Men of dust are made stones,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built up as God’s home, His dwelling place!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has entered man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God now transmits life bit by bit within man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Christ and His redeemed can live and walk as one!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus His plan is fulfilled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Body is built, organically;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On earth expressed!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One day in fullness shall appear God’s glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Down out of heav’n from God—the holy city see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself is her light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She’s glorious, bright, eternally!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Triune God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with His bride!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
