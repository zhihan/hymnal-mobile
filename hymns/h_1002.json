    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When He, from His lofty throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stooped to do and die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything was fully done;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hearken to His cry:"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“It is finished!” yes, indeed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Finished every jot:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinner, this is all you need—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tell me, is it not?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Weary, working, burdened one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherefore toil you so?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cease your doing; all was done"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Long, long ago."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
