        {
          "segments": [
            {
              "chord": "",
              "text": "By a simple faith,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Doing” is a deadly thing—"
            }
          ]
        },
        {
          "segments": [
            {
