{
  "url": "https://www.hymnal.net/cn/hymn/ch/530",
  "title": "神的律法在人身外",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "律 法 在 人 身"
            },
            {
              "chord": "D",
              "text": "外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聖 潔、 良 善， 要"
            },
            {
              "chord": "D7",
              "text": "人 遵"
            },
            {
              "chord": "G",
              "text": "行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 要 向 人 確 切 證"
            },
            {
              "chord": "C",
              "text": "明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 所 要"
            },
            {
              "chord": "G",
              "text": "求 人"
            },
            {
              "chord": "D7",
              "text": "難 完"
            },
            {
              "chord": "G",
              "text": "成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在人心思存有一律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人立志愿意为善；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但肢体中另有一律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与其争战，使其难堪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "心思之律乃是良善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原是人在受造之时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得自人的受造生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人善行得以维持。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "肢体之律乃是邪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当人堕落，联于撒但，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来自撒但邪恶生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入人体，借死掌权。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个肢体犯罪之律"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "强过心思为善之律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着撒但邪恶能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "征服善律将人掳去。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在我灵中更有一律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是生命之灵的律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来自神的大能生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我重生即为我具。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个灵中生命之律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是最强，强过所有；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离犯罪之律，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全神律一切要求。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，我们要将心思"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常置于灵的上面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不再放肉体之上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们便脱罪的霸权。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "心思放在肉体之上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是可怕死亡、黑暗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心思置于灵的上面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是有福生命、平安。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是得着释放之路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是最妙成圣途径！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，使我们活在灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭着此灵与你同行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
  "metadata": {
    "category": "里面生命的各方面",
    "time": "3/4",
