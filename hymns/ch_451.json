    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已将祂本性丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都赐给我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但须灵里与祂接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能摸着。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父的一切、子的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都归于灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要与神这灵接触，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须用灵。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神需心思明白、认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也需灵接触；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若不动灵，只凭理智，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "难得满足。"
            }
          ]
        }
