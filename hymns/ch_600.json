  "title": "圣徒实际活在一起",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "聖 徒"
            },
            {
              "chord": "",
              "text": "實 際 活"
            },
            {
              "chord": "A7",
              "text": "在 一"
            },
            {
              "chord": "",
              "text": "起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纔"
            },
            {
              "chord": "D",
              "text": "是 召"
            },
            {
              "chord": "",
              "text": "會 的"
            },
            {
              "chord": "A7",
              "text": "合"
            },
            {
              "chord": "D",
              "text": "一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "內 住 聖 靈 將"
            },
            {
              "chord": "E",
              "text": "這 合"
            },
            {
              "chord": "E7",
              "text": "一"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放"
            },
            {
              "chord": "A",
              "text": "在 所"
            },
            {
              "chord": "",
              "text": "有 聖"
            },
            {
              "chord": "E7",
              "text": "徒"
            },
            {
              "chord": "A",
              "text": "裡。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因"
            },
            {
              "chord": "D",
              "text": "是 出"
            },
            {
              "chord": "",
              "text": "於 聖"
            },
            {
              "chord": "A",
              "text": "靈 自"
            },
            {
              "chord": "",
              "text": "己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "故"
            },
            {
              "chord": "D",
              "text": "稱 聖"
            },
            {
              "chord": "G",
              "text": "靈 的"
            },
            {
              "chord": "A",
              "text": "合"
            },
            {
              "chord": "A7",
              "text": "一；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃"
            },
            {
              "chord": "D",
              "text": "是 根"
            },
            {
              "chord": "",
              "text": "據 所"
            },
            {
              "chord": "A7",
              "text": "有 聖"
            },
            {
              "chord": "",
              "text": "徒"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同"
            },
            {
              "chord": "D",
              "text": "得 之"
            },
            {
              "chord": "",
              "text": "信 而"
            },
            {
              "chord": "A7",
              "text": "有"
            },
            {
              "chord": "D",
              "text": "的。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有圣徒共同所得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一样宝贵的信心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "组成是以基督和祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎工作为成分。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此圣徒真是合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信仰全同，无异议；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由于这个同得之信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "始有召会的存立。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙召会既然是一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主基督的产业；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各地召会也该是一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主表现无分别。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会元素原都是一："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一神、一主并一灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一信、一洗并一身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一望由于神命定。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这‘一’就是召会立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣徒共同的立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是合一独一立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵在我所愿望。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此，召会就能实行"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真正实际的合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她在各地所有出现"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也就因此得建立。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，使我们竭力保守"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个圣灵的合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "站在召会合一立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体生活来经历。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你心中伟大愿望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此就可得实现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神心爱永远计画，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也可完满得成全。"
            }
          ]
        }
      ]
    }
