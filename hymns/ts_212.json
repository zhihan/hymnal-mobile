{
  "url": "https://www.hymnal.net/cn/hymn/ts/212",
  "title": "你何微小",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦， 主"
            },
            {
              "chord": "",
              "text": "耶 稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 在 你 前"
            },
            {
              "chord": "C",
              "text": "称 颂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为 著 杯"
            },
            {
              "chord": "G",
              "text": "饼 我"
            },
            {
              "chord": "D7",
              "text": "们 感"
            },
            {
              "chord": "",
              "text": "激 不"
            },
            {
              "chord": "G",
              "text": "已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同 心 赞 美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 竟 然 成 为"
            },
            {
              "chord": "C",
              "text": "食 物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫 人 多"
            },
            {
              "chord": "G",
              "text": "方 享"
            },
            {
              "chord": "D7",
              "text": "受 你"
            },
            {
              "chord": "",
              "text": "的 自"
            },
            {
              "chord": "G",
              "text": "己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 我 灵 立"
            },
            {
              "chord": "C",
              "text": "即 兴"
            },
            {
              "chord": "",
              "text": "起 赞"
            },
            {
              "chord": "G",
              "text": "美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 何 微"
            },
            {
              "chord": "D",
              "text": "小，"
            },
            {
              "chord": "D7",
              "text": "你 何"
            },
            {
              "chord": "",
              "text": "微"
            },
            {
              "chord": "G",
              "text": "小。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直 至 永 世 还"
            },
            {
              "chord": "C",
              "text": "要 吃"
            },
            {
              "chord": "",
              "text": "喝 不"
            },
            {
              "chord": "G",
              "text": "已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 何 微"
            },
            {
              "chord": "D",
              "text": "小，"
            },
            {
              "chord": "D7",
              "text": "你 何"
            },
            {
              "chord": "",
              "text": "微"
            },
            {
              "chord": "G",
              "text": "小。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等可怜─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当基督来到人群，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满带丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来作生命供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人竟拒绝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反倚靠道理教训，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不懂如何取用祂的丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所需乃是把你吃了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等奇妙，何等逍遥！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们吃主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面就被复苏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长大成人，活出基督。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你降卑来到世上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非为着在外面作君王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃作食物"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供我们享受饱足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面生命引导我们成熟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，赞美你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你实在伟大荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能力无穷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "威严、丰富无限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你竟成"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "微小食物真奇妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们更要高唱直到永远。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
