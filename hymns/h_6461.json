    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Why walk alone the cross’s narrow way?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your words of grace, men with curse repay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Instead of sighs, mockery they make;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why did Your God His dear Son forsake?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Falling tears I cannot stay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You turned, sadly looked my way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Although I said I would die with You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How faithless is my love for You!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Alone, You took the cross’s narrow way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On Calv’ry’s mount, bore my sins away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By piercéd hands, am I yet constrained?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By wounded side’s strong embrace contained?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That first love, I can’t forget;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But that foll’wing heart, I left."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In love, You gave up Your life for Me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What have I given up for Thee?"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With You I take the cross’s narrow way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world forsake, soul-life in the grave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Do you love Me?” “Yes, Lord, I love You!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing I heed, but Your footsteps true."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Go away, all earthly bribes!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Away, blessings false besides!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That long-ago cross’s narrow way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your lovers all should walk today."
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
