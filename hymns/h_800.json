    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Lord has spoken, and His heart disclosed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His Son should have pre-eminence in all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That in His dear Son He might be glorified"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Midst all His creation, either great or small."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Lord has spoken, Christ has been revealed:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is very God and yet is truly man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is all in all, in Him all things subsist,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Center and circumference of th’ eternal plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Lord has spoken, and His mystery shown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ and His expression has His counsel willed:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ with all God’s fulness as the glorious Head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the Church His Body, with His riches filled."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Lord has spoken, and from heaven shown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the triune God would blend with creature-man:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Father in the Son, the Son the Spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dwelling in the Body to fulfill His plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Lord has spoken, revelation giv’n"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of His vast creation and His lowly birth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of His great redemption and salvation full;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May His adoration ever fill the earth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
