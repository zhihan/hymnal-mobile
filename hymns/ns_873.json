    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When the anxious thoughts of life appear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the path grows dim, the way unclear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the whispers, doubts, assail mine ear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I go forth to meet my Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Thou art my Rock and my Shield,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to me, and my faith shall be healed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All trust and hope to Thee I would yield."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the fears are shut away and sealed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I go to meet my Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the days on earth pass swiftly by,"
            }
          ]
        },
        {
