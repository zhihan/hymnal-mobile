        {
          "segments": [
            {
              "chord": "",
              "text": "I will surely meet my Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus—the longing deep in my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en from Thy shadow I’d ne’er depart."
