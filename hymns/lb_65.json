    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, that thirst that gnawed me deep within:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drove me seeking satisfaction."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the many things that I have tried:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Left me thirsting and dissatisfied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this endless search for something new,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the time this cry was just for You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I was blind in trying many things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til I drank You as my living Spring."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I do love You more everyday."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I do love You much more this very day."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You came and filled my inmost being."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the sweetest satisfaction."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the Spirit as my everything,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit in my spirit bubbling."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thank You, Lord, for coming into me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now You’re spreading in me constantly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You’re making home in all my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As my treasure filling every part."
            }
          ]
        }
      ],
