{
  "url": "https://www.hymnal.net/en/hymn/ns/471",
  "title": "Living Christ, Our Victory",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Shout Hosanna, all ye people,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ defeated every evil;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We unite with one accord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise Thee, ever conq’ring Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nevermore we fear the devil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ destroyed him on the cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stripping off the authorities;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we live His victory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God of peace now crushes Satan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Under overcoming feet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our rejoicing overthrows him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shaming every enemy."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All day long sing hallelujahs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the train of vanquished foes;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through our praise we never leave,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seated with Him at the throne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Never let the lies deceive you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ has shut the serpent’s mouth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Claim the fact that we have seen him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the lake of fire now."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon the earth cries out, exalting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our returning, shining Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until then we praise and sing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the glory’s to our King."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Consummated corporate warrior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem are we,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One with our ascended Husband,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord of lords and King of kings."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, Christ the Conqueror,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every day we’re one with Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Walking in Him constantly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living Christ our victory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
