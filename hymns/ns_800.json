        {
          "segments": [
            {
              "chord": "",
              "text": "Call My name and you’ll be saved.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the One I need today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I let You in my heart,"
            }
          ]
        },
