    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“It is I."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is I. Don’t be afraid."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Me in—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To your boat, I’ll calm the waves."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can be in you"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A harbor, warm and safe."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just open up your heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am the way.”"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is the Son of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come as man, full of compassion."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Crucified upon a cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He bore all your sins away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life subdues the power of the grave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will you let Him soothe your aching heart today?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then He’ll say,"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“It is I."
