    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂名发出最美香味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂声成为最甜音乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的同在展我愁眉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我里面尽都欢悦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂若如此不断亲密，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就无何可怕、可求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人快乐与我可比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的春日长年常有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看见祂面我就甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就只求祂的欢喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不论时地有何改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能改变我的心意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要感觉祂的爱恋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宫殿也成可笑玩具，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "监狱可成荣耀宫殿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果基督和我同居。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我主，若我真是属你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若是我诗歌、太阳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请问为何我仍忧悒？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何严冬这样久长？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或将黑云赶离我天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恢复你的欢乐同在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或接我到你的面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无冬昏昧，无云叆叇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
