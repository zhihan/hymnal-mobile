    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂名发出最美香味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂声成为最甜音乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的同在展我愁眉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我里面尽都欢悦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂若如此不断亲密，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就无何可怕、可求，"
