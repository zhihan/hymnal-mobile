              "text": "Thy saints and Thee can part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh teach us, Lord, to know and own"
