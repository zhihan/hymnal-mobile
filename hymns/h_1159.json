      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining One—how clear the sky above me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Son of Man, I see Thee on the throne!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holy One, the flames of God consume me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till my being glows with Thee alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, when first I saw Thee in Thy splendor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All self-love and glory sank in shame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now my heart its love and praises render,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tasting all the sweetness of Thy name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious Lord, my flask of alabaster"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly now I break in love for Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I anoint Thy head, Beloved Master;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, behold, I’ve saved the best for Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dearest Lord, I waste myself upon Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving Thee, I’m deeply satisfied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love outpoured from hidden depths within me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Costly oil, dear Lord, I would provide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Beloved, come on spices’ mountain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I yearn to see Thee face to face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drink, dear Lord, from my heart’s flowing fountain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till I rest fore’er in Thine embrace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not alone, O Lord, do I adore Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with all the saints as Thy dear Bride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Quickly come, our love is waiting for Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, Thou wilt be satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
