      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "\"同 心"
            },
            {
              "chord": "",
              "text": "合 意\"─ 樓"
            },
            {
              "chord": "D",
              "text": "房 上"
            },
            {
              "chord": "",
              "text": "同 聚"
            },
            {
              "chord": "G",
              "text": "集， 耶"
            },
            {
              "chord": "",
              "text": "穌 從"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "者 忠"
            },
            {
              "chord": "A",
              "text": "信 禱"
            },
            {
              "chord": "",
              "text": "告 不"
            },
            {
              "chord": "D",
              "text": "息； 同"
            },
            {
              "chord": "",
              "text": "一 盼"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "望， 每"
            },
            {
              "chord": "D7",
              "text": "魂 儆"
            },
            {
              "chord": "",
              "text": "醒 所"
            },
            {
              "chord": "G",
              "text": "期； 同"
            },
            {
              "chord": "",
              "text": "一 目"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "標， 眾"
            },
            {
              "chord": "D",
              "text": "人 心"
            },
            {
              "chord": "D7",
              "text": "志 如"
            },
            {
              "chord": "G",
              "text": "一。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"同心合意\"─直等五旬能力"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全备灵中降临，浇灌、充溢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众见证人宣扬复活信息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活出神命开拓及于地极。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "\"同心合意\"─神家中何欢畅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！天天赞美颂扬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一心一口，基督荣耀显彰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣尊名传扬达到四方。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那灵浇灌，我们愿再经历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同甘雨，使人复苏、得力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主的子民若真同心合意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "五旬荣景就必重现此地。"
            }
          ]
        }
      ]
    }
