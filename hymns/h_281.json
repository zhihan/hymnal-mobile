    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Love divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glow within this heart of mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Kindle every high desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perish self in Thy pure fire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Power divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill and nerve this will of mine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee may I strongly live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bravely bear, and nobly strive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, the Spirit, Peace divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still this restless heart of mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to calm this tossing sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stayed in Thy tranquillity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
