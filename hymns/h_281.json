              "chord": "",
              "text": "Lord, the Spirit, Joy divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladden Thou this heart of mine;"
            }
          ]
        },
        {
          "segments": [
            {
