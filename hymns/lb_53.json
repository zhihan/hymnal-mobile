    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Worthy is the Lamb Who has been slain to receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The power and riches and wisdom and strength"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And honor and glory and blessing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saints, stand as one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No one should backward turn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The battle Christ has won,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His blood we overcome,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The enemy cast down"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the Lamb is on the throne."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And they overcame him by the blood of the Lamb"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by the word of their testimony,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And they love not their soul-lives unto death."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise You, Lion-Lamb"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Captain of salvation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You have fought the battle"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And destroyed the Devil."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You took away our sins"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And accomplished redemption."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah to our Lamb God on the throne!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah Praise Him! Hallelujah"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah Praise Him! Hallelujah"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I join Your fight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your purpose take my rights!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To You, I now respond,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this age to overcome,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the end make me fight on."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fight on, fight on, fight on!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
