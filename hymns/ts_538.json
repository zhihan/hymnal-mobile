    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱中洗涤，交通无碍─弟兄相爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以爱裹伤，彼此怀搋─弟兄相爱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事相信，凡事忍耐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡事盼望，凡事遮盖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此担就，恩慈相待─弟兄相爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如枝子结果丰盈─弟兄相爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是肢体同命同荣─弟兄相爱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弃绝天然，己命不从，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只随那灵，狭路前行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出死入生在此证明─弟兄相爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "欢然上行，乐歌四起─弟兄相爱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惧怕、忧疑尽都绝迹─弟兄相爱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和睦同居，美善无比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵与生命─坚固根基；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造锡安，达到终极─弟兄相爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命种子生长不已─弟兄相爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"非拉铁非\"涌流、普及─弟兄相爱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主名、主话，持守不离，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣之爱浇灌、充溢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得胜有馀，无何能敌─弟兄相爱！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
