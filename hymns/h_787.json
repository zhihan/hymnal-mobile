      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I must tell Jesus all of my troubles;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is a kind, compassionate Friend;"
            }
          ]
