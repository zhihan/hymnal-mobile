{
  "url": "https://www.hymnal.net/en/hymn/lb/76",
  "title": "That’s Why I Love Him",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What about my sinful past?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my conscience has no rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep within I feel the pain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m condemned from all my guilty stains."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O my life of misery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In this world of vanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I searched for happiness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My reward I received just emptiness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God was far away from me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Great and highest One is He."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet You took on humanity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You came for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hung on a tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bled there to die for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why I love Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why I treasure Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why I give my life and all to Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why I love Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why I treasure Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s why I give my life and all to Him."
            }
          ]
        }
      ],
      "type": "chorus"
    }
