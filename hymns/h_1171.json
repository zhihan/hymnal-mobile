        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "praise the Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For since by the one came death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By this man came living breath;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man the Lord recovereth—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "praise the Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Types and shadows to us show"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is the man to know."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now this man in us must grow—"
            }
          ]
        },
        {
          "segments": [
