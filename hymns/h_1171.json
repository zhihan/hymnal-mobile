    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is th’ acacia wood—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a man, so fine and good!"
            }
          ]
        },
        {
          "segments": [
