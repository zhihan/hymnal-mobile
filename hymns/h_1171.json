              "text": "Praise the Lord, praise the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "praise the Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, wisdom of God’s plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Son of God and Son of Man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A new manhood He began—"
            }
          ]
