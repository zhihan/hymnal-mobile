    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I turn my heart to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take my veils away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purify my heart to see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee through all my days."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I give my heart to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I love Thee so!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make Thy home in all my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through my being flow."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I, my spirit exercise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing outwardly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By my spirit’s function—three—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I may contact Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Touch my conscience thoroughly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I, my sins confess."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter into fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oneness with Thee sense."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Living God, I come to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From dead works save me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purify my conscience, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I might serve Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily, I now exercise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All sins to confess."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That my conscience clear may be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Void of all offense."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I am in Penuel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face to face with God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With an open, loving heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit exercised."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conscience, mind, emotion, will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will dig away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That through me Thou may’st flow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freely day by day."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, Lord, I come to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
