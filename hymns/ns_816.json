    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God’s administration needs"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our fighting prayer to intercede."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We seek God’s heart and stand in death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Allowing Christ to be expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Pass through the cross in prayer to God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Becoming precious to the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By life and light we’re energized,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And weighty prayer is exercised."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At every time renewed and fresh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection we possess"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And claim ascension’s heavenly sphere,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Position, nature, atmosphere."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our prayers will judge and end this age"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we the Kingdom’s warfare wage."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such prayers are bowls with Christ therein,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Added to bring God’s Kingdom in."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Devil will be cast to earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As overcomers come to birth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the throne a loud voice heard,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Rejoice, O heavens! Woe to earth!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“For now is come salvation, power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s Kingdom ’stablished in this hour.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Satan driven from the throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Authority of Christ’s made known."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, our corporate prayer we raise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To overcome, to end this age."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Kingdom come, Your will be done"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On earth in us, as at the throne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Authority and reigning stand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For executing God’s command;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis ours to pray, God’s burden own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till answers pour out from the throne."
            }
          ]
        }
      ],
      "type": "chorus"
    }
