    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once more ’tis eventide, and we"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oppressed with various ills draw near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What if Thy form we cannot see?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We know and feel that Thou art here."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Savior Christ, our woes dispel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For some are sick, and some are sad,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And some have never loved Thee well"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And some have lost the love they had;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "*And some have found the world is vain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet from the world they break not free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And some have friends who give them pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet have not sought a friend in Thee;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "*And none, O Lord, have perfect rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For none are wholly free from sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And they who fain would serve Thee best"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are conscious most of wrong within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Savior Christ, Thou too art Man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast been troubled, tempted, tried;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy kind but searching glance can scan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The very wounds that shame would hide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy touch has still its ancient power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No word from Thee can fruitless fall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hear in this solemn evening hour,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy mercy heal us all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
