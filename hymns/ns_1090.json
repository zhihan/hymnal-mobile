      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Godliness thrives in a garden of God’s love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brotherly love with a source from heav’n above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love so delightful, love steadfast, strong and pure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A blooming love, a love that will endure."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ultimate love is the sweet, eternal fruit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, as true love, through the branch, the trunk, and root;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nobler and higher, such love we now shall be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love growing, shining through eternity."
            }
          ]
        }
      ],
