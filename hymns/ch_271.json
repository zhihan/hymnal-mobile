  "title": "全能的神非受造的",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "全 能"
            },
            {
              "chord": "",
              "text": "的 神， 非 受 造"
            },
            {
              "chord": "C",
              "text": "的 生"
            },
            {
              "chord": "G",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听 我 呼"
            },
            {
              "chord": "D",
              "text": "求， 允"
            },
            {
              "chord": "D7",
              "text": "我 在"
            },
            {
              "chord": "",
              "text": "此 所"
            },
            {
              "chord": "G",
              "text": "请；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "无 限"
            },
            {
              "chord": "",
              "text": "荣"
            },
            {
              "chord": "G",
              "text": "耀， 在"
            },
            {
              "chord": "",
              "text": "你 周"
            },
            {
              "chord": "C",
              "text": "身 围"
            },
            {
              "chord": "Em",
              "text": "绕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生 命 赐"
            },
            {
              "chord": "G",
              "text": "者， 求"
            },
            {
              "chord": "",
              "text": "你 给"
            },
            {
              "chord": "D7",
              "text": "我 所"
            },
            {
              "chord": "G",
              "text": "要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着基督所经历的十架，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂死所成功的击杀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗权势，救我全然脱离，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迁我到你爱子光明国里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从我中心，将我绝对充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满到圆周，满达四周边缘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我周身，直到极边之上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "射出你的荣耀所有光芒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "非造生命，你是至圣的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命之灵，求你今在我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有所创作，使我显你荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且逼我除你别无所要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢父神，我已得你恩赏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同着基督，今在生命作王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已满足，且因基督夸胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂十架，得享丰盛生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
