      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿主为我擘开生命的饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我充满主爱，记念主名！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "释放我的思想脱离自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫我的倾向都在乎你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "惟主解开真理，我才明白"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的一切信息如何警策；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我与你同情，与你同行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我逐日变化，像你荣形。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱主，求你祝福你的真理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像你为饼祝福在加利利；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我捆绑都脱，锁链都落，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自由为你生活，为你工作。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
