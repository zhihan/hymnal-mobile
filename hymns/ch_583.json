            {
              "chord": "D",
              "text": "愿 主"
            },
            {
              "chord": "",
              "text": "为 我 擘 开 生 命 的"
            },
            {
              "chord": "A",
              "text": "饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "就 像"
            },
            {
              "chord": "",
              "text": "当 日 旁 海 对"
            },
            {
              "chord": "E",
              "text": "众"
            },
            {
              "chord": "E7",
              "text": "所"
            },
            {
              "chord": "A",
              "text": "行。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "靠 这"
            },
            {
              "chord": "",
              "text": "圣"
            },
            {
              "chord": "D",
              "text": "书 引"
            },
            {
              "chord": "",
              "text": "导， 我"
            },
            {
              "chord": "E7",
              "text": "寻 求"
            },
            {
              "chord": "A",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 主，"
