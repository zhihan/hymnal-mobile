    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise to the Lord, who o’er all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "things so wondrously reigneth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who, as on wings of an eagle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "uplifteth, sustaineth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hast thou not seen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How thy desires all have been"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Granted in what He ordaineth?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise to the Lord, who hath fearfully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "wondrously, made thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Health hath vouchsafed and, when"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "heedlessly falling, hath stayed thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What need or grief"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever hath failed of relief?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wings of His mercy did shade thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise to the Lord, who doth prosper"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "thy work and defend thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who from the heavens the streams of"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His mercy doth send thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ponder anew"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What the Almighty can do,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who with His love doth befriend thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise to the Lord! Oh, let all that"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "is in me adore Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that hath life and breath, come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "now with praises before Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Amen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sound from His people again;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly for aye we adore Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
