  "title": "My heart is wounded—Lord, I pray",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "My heart"
            },
            {
              "chord": "",
              "text": "is wounded—"
            },
            {
              "chord": "A",
              "text": "Lord, I"
            },
            {
              "chord": "",
              "text": "pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "Stretch out"
            },
            {
              "chord": "",
              "text": "Thy"
            },
            {
              "chord": "D",
              "text": "mighty"
            },
            {
              "chord": "E7",
              "text": "hand to"
            },
            {
              "chord": "A",
              "text": "heal."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But wouldst Thou"
            },
            {
              "chord": "D",
              "text": "not, still"
            },
            {
              "chord": "",
              "text": "with me"
            },
            {
              "chord": "G",
              "text": "stay"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grant me grace to"
            },
            {
              "chord": "A7",
              "text": "love Thy"
            },
            {
              "chord": "D",
              "text": "will."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou know’st the pain of every scar,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lonesome thoughts that come withal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But know them not just from afar:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart’s true Friend, come bear them all!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If in my side a thorn must be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If in my heart enduring pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then may Thy peace be balm to me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grace my weakness still sustain."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My vessel broken past repair"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I bring Thee now, O Potter mine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill with Thyself the breaches there—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Refashion me with life divine."
            }
          ]
        }
      ]
    }
  ],
