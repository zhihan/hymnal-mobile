    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church from her dear Master"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Received the gift divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And still that light she lifteth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er all the earth to shine:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the golden treasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where gems of truth are stored;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the heaven-drawn picture"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Christ, the living Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It floateth like a banner"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before God’s host unfurled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It shineth like a beacon"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Above the darkling world;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the chart and compass"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That, o’er life’s surging sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Mid mists and rocks and quicksands"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still guide, O Christ, to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O make Thy Church, dear Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A lampstand of pure gold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bear before the nations"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy light, that all behold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O teach Thy wandering pilgrims"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By this their path to trace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till, clouds and darkness ended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They see Thee face to face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
