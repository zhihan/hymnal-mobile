    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through shadows, types and figures,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s deepest thought is known;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As typified by Adam,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Husband, Christ, is shown."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A rib brought forth from Adam"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reveals the source of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By which God built a woman:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eve, as the church, His wife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To be His people’s Husband,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take them as His wife:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is what God desires"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To live in marriage life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their sacrifice and worship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Alone could not content;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with them to be married"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was God’s foremost intent."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This romance is the finest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As seen in Song of Songs;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For her Beloved’s kisses"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His seeking lover longs."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love’s work in her produces"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No person of her own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But she becomes the City,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her Person, Christ alone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our coming Bridegroom;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the Church, His Bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Redeemed, regenerated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The issue of His side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In source, in life, in nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And person fully one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His counterpart forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The New Jerusalem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
