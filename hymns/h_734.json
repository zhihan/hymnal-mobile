{
  "url": "https://www.hymnal.net/en/hymn/h/734",
  "title": "The law of God is holy, good",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "The law"
            },
            {
              "chord": "",
              "text": "of God is holy,"
            },
            {
              "chord": "D",
              "text": "good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To practise good it"
            },
            {
              "chord": "D7",
              "text": "doth com"
            },
            {
              "chord": "G",
              "text": "mand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its purpose is to clearly"
            },
            {
              "chord": "C",
              "text": "show"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we can"
            },
            {
              "chord": "G",
              "text": "not meet"
            },
            {
              "chord": "D7",
              "text": "God's de"
            },
            {
              "chord": "G",
              "text": "mand."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in our mind there is a law"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which always tries the good to do;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in our members is a law"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which always doth this law subdue."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law within our mind is good,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis of our human life obtained"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At our creation from the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That good behavior be maintained."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law within our members is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The evil of satanic life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into our members at the fall"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It came thru Satan’s subtle strife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This evil law of Satan is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The law of sin, in us its seat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis stronger than the law of good"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And always brings it to defeat."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But in our spirit is a law,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which is the Spirit’s law of life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis of the very life of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which we from our rebirth derive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This law divine the strongest is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transcending all the others o’er;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From sin’s law freeing, it fulfills"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The full requirement of God’s law."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We then must always set our mind"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the spirit deep within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And not upon the things of flesh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The body ruined by the sin."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To set the mind upon the flesh"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is sin and death and darkest night;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The mind upon the spirit set"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is life and peace and full of light."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the way of true release!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the way of victory!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, may we in the spirit live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by the Spirit walk with Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
  "metadata": {
