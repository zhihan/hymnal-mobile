{
  "url": "https://www.hymnal.net/cn/hymn/ch/545",
  "title": "三一之神荣耀的灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "三 一"
            },
            {
              "chord": "",
              "text": "之 神 榮"
            },
            {
              "chord": "A",
              "text": "耀 的"
            },
            {
              "chord": "D",
              "text": "靈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "現"
            },
            {
              "chord": "G",
              "text": "今 住"
            },
            {
              "chord": "D",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "靈 裡"
            },
            {
              "chord": "A",
              "text": "面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "D",
              "text": "直 想"
            },
            {
              "chord": "",
              "text": "要 從"
            },
            {
              "chord": "A",
              "text": "我 流"
            },
            {
              "chord": "D",
              "text": "出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "G",
              "text": "神 可"
            },
            {
              "chord": "D",
              "text": "以 得"
            },
            {
              "chord": "A",
              "text": "著"
            },
            {
              "chord": "A7",
              "text": "彰"
            },
            {
              "chord": "D",
              "text": "顯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但我外面天然的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常将那灵关闭禁拘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未能让祂得家安居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "反倒成了祂的监狱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂像宝贝放在瓦器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受了遮藏，人难看见；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瓦器必须毁坏、破碎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贝才能得着彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的己必须拆毁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "魂的生命实是捆绑！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天然的人必须破碎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那灵才能得着释放。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这个说明何以主许"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "苦难环境临到我们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要借着一些折磨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "破碎我们外面的人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "外面的人－就是旧魂－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须毁坏、必须受伤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的人－就是新灵－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才与那灵同得释放。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主给我这种破碎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不许我再保全自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我接受一切伤损，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘愿接受，再无异议。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "使我宝贵你的破碎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永不再有怨言、怨意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我看重一切损失，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "过于任何一种利益。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
