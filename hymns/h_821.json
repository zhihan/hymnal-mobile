      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As was the temple to the ark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Receptacle and resting-place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So Christ the Church’s content is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the Church, Christ’s dwelling-place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As Christ is God’s true mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God to explain and God express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So is the Church Christ’s mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ to explain and manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The members of the Church of Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are all primarily of clay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They need to be transformed and made"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transparent, precious day by day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By transformation they are built,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A vessel they to Christ afford;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His all-inclusiveness they hold;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transparent, they express the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru all the transformation work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The triune God performs in them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church a corporate vessel is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And like the new Jerusalem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How precious she in each respect,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transparent too in every phase;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ with God’s fulness she contains,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ with God’s glory she displays."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ as life, with God as light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with the Spirit’s living flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The triune God she manifests"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all the universe to know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
