        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "D7",
              "text": "地， 許"
            },
            {
              "chord": "",
              "text": "到 那"
            },
            {
              "chord": "G",
              "text": "裡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 纔"
