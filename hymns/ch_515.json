      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何以祈求未见答应？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何以将成终又不遂？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何以盼望终成泡影？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日那里，我必领会。"
            }
          ]
        }
