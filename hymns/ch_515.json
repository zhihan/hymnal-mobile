{
  "url": "https://www.hymnal.net/cn/hymn/ch/515",
  "title": "不在此时，许待主回",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "不 在"
            },
            {
              "chord": "",
              "text": "此 时， 许 待 主"
            },
            {
              "chord": "Am",
              "text": "回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "D7",
              "text": "地， 许"
            },
            {
              "chord": "",
              "text": "到 那"
            },
            {
              "chord": "G",
              "text": "里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 们 才"
            },
            {
              "chord": "G7",
              "text": "能 完"
            },
            {
              "chord": "",
              "text": "全 领"
            },
            {
              "chord": "C",
              "text": "会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叹"
            },
            {
              "chord": "Am",
              "text": "息 眼"
            },
            {
              "chord": "D7",
              "text": "泪 所"
            },
            {
              "chord": "",
              "text": "有 意"
            },
            {
              "chord": "G",
              "text": "义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你 当 一"
            },
            {
              "chord": "D",
              "text": "生 信"
            },
            {
              "chord": "A7",
              "text": "靠 救"
            },
            {
              "chord": "D",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "路 虽 阴"
            },
            {
              "chord": "A",
              "text": "暗， 仍"
            },
            {
              "chord": "A7",
              "text": "当 赞"
            },
            {
              "chord": "D7",
              "text": "美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "必 惧"
            },
            {
              "chord": "",
              "text": "怕， 主 在 搀 扶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有"
            },
            {
              "chord": "C",
              "text": "日、 有"
            },
            {
              "chord": "Am",
              "text": "日 都"
            },
            {
              "chord": "D7",
              "text": "要 领"
            },
            {
              "chord": "G",
              "text": "会。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "中断线索，都将接上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一生经过，必有路轨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天能解释各样秘藏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日、那日都必领会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你当一生信靠救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "路虽阴暗，仍当赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不必惧怕，主在搀扶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有日、有日都要领会。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何故厚云遮蔽太阳？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何故寂寞代替安慰？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何故叹息多过歌唱？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有日我们就要领会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
