      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "中断线索，都将接上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一生经过，必有路轨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天能解释各样秘藏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日、那日都必领会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你当一生信靠救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "路虽阴暗，仍当赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不必惧怕，主在搀扶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有日、有日都要领会。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何故厚云遮蔽太阳？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何故寂寞代替安慰？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何故叹息多过歌唱？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有日我们就要领会。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
