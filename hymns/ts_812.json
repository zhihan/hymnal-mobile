    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！我们已经胜过仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为我们放胆见证主话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的话语带给我们生命、能力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这话我们必向敌夸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "（女声）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！哦，弟兄们哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜，当高声喊！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在锡安圣城宣告祂得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全地充满颂赞。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（男声）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！哦，姊妹们哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经完成神旨！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是得胜主，将仇敌征服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远之乐从今开始。"
            }
          ]
        }
