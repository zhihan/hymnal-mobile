              "text": "已 經"
            },
            {
              "chord": "",
              "text": "得 勝！ 基 督 已 經 勝 過 仇 敵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "D",
