            },
            {
              "chord": "",
              "text": "聲 遠"
            },
            {
              "chord": "A7",
              "text": "近 都"
            },
            {
              "chord": "",
              "text": "可 聽"
            },
            {
              "chord": "D",
              "text": "見！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寶"
            },
            {
              "chord": "G",
              "text": "血 有"
            },
            {
              "chord": "",
              "text": "能， 藉"
            },
            {
              "chord": "C",
              "text": "牠 我"
            },
            {
              "chord": "",
              "text": "們 必 得 勝 利，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "G",
              "text": "久 全"
            },
            {
              "chord": "",
              "text": "能 得"
            },
            {
              "chord": "D7",
              "text": "勝 主"
            },
            {
              "chord": "",
              "text": "必 顯"
            },
            {
              "chord": "G",
              "text": "現！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "已 經 得 勝！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦， 弟 兄 們 哪， 已 經 得 勝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "當 高 聲"
            },
            {
              "chord": "D",
              "text": "喊！ 在"
            },
            {
              "chord": "",
              "text": "錫 安 聖"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "城 宣 告 祂 得 勝， 直 到"
            },
            {
              "chord": "D7",
              "text": "全 地"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充 滿 頌"
            },
            {
              "chord": "G",
              "text": "讚。 已"
            },
            {
              "chord": "",
              "text": "經 得 勝！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦， 姊 妹 們"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哪， 基 督 已 經 完"
            },
            {
              "chord": "G7",
              "text": "成 神"
            },
            {
              "chord": "C",
              "text": "旨！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 是 得 勝 主， 將 仇"
            },
            {
              "chord": "G",
              "text": "敵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "征 服， 永 遠"
            },
            {
              "chord": "D",
              "text": "之 樂"
            },
            {
              "chord": "",
              "text": "從"
            },
            {
              "chord": "D7",
              "text": "今 開"
            },
            {
              "chord": "G",
              "text": "始。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！我们已经胜过仇敌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为我们放胆见证主话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的话语带给我们生命、能力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这话我们必向敌夸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "（女声）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！哦，弟兄们哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜，当高声喊！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在锡安圣城宣告祂得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全地充满颂赞。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（男声）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！哦，姊妹们哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经完成神旨！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是得胜主，将仇敌征服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远之乐从今开始。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！仇敌已在我们脚底，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我们虽至死不爱性命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们高喊：‘主阿，你使我们胜利！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归神！赞颂之声不停。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
