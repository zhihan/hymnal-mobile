      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "已经得胜！仇敌已在我们脚底，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我们虽至死不爱性命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们高喊：‘主阿，你使我们胜利！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀归神！赞颂之声不停。"
            }
          ]
        }
