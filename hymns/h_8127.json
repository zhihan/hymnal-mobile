    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He, my King, my Lord, my Savior, my welling Fount of love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Walked the lonely path to dark Gethsemane."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweat like blood-drops for my peril, obeyed His Father’s will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Paid the price to save all men eternally."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Despised, man’s insult’s taking, the sinner’s blame endured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore the cross unto Golgotha willingly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Scarred by nails and scarred by spear, whence blood and water streamed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So immense His love expressed to full degree."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is my King of mercy, with love immeasurable;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cross He prayed, and mercy’s heart was shown."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There a dying thief repented, received salvation’s word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus bore all sins, rejected, left alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What piercing pain and sorrow, with vinegar and gall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto God He did depart victorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resurrected and ascended, our interceding Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He reveals His love so deep and wonderous."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is my King victorious; His love my heart has touched."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this sinner He has died, His love to show."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am healed and cleansed completely, and in His mercies rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Taught by Him and guided, on His path I go."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Temptations fierce unheeding, salvation is my wall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m empowered daily as I go along."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With eyes on Him in glory, I sing with heart renewed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His love is all the message of my song."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
