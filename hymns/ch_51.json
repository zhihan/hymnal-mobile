{
  "url": "https://www.hymnal.net/cn/hymn/ch/51",
  "title": "亲爱父神，我们向你歌唱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "亲"
            },
            {
              "chord": "A",
              "text": "爱 父"
            },
            {
              "chord": "D",
              "text": "神，"
            },
            {
              "chord": "Bm",
              "text": "我"
            },
            {
              "chord": "Em",
              "text": "们 向"
            },
            {
              "chord": "A7",
              "text": "你 歌"
            },
            {
              "chord": "D",
              "text": "唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有 谁 比"
            },
            {
              "chord": "G",
              "text": "你 更"
            },
            {
              "chord": "D",
              "text": "配 我"
            },
            {
              "chord": "A",
              "text": "们"
            },
            {
              "chord": "D",
              "text": "颂"
            },
            {
              "chord": "A7",
              "text": "扬。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "今 要"
            },
            {
              "chord": "D",
              "text": "人 以"
            },
            {
              "chord": "B",
              "text": "灵 以"
            },
            {
              "chord": "B7",
              "text": "『真』 敬"
            },
            {
              "chord": "Em",
              "text": "拜，"
            },
            {
              "chord": "A",
              "text": "我 们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照"
            },
            {
              "chord": "D",
              "text": "此 向"
            },
            {
              "chord": "G",
              "text": "你 献"
            },
            {
              "chord": "D",
              "text": "上"
            },
            {
              "chord": "A7",
              "text": "感"
            },
            {
              "chord": "D",
              "text": "戴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有世界是你借子造成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有也都由祂大能托撑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我却是在你爱子里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你亲近，敬拜何其甘甜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今在这蒙福范围领唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你召会唱诗向你颂扬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等欢乐，祂有弟兄随同，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂同享自由，向你歌颂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们和祂在此同声歌唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦父，使你满足、供你欣赏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你爱子所领赞美之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你可安居，永远享受称颂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
  "metadata": {
    "category": "敬拜父",
