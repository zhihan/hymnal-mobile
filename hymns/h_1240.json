            },
            {
              "chord": "",
              "text": "through and"
            },
            {
              "chord": "G",
              "text": "through,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till in"
            },
            {
              "chord": "D",
              "text": "Thee we're"
            },
            {
              "chord": "D7",
              "text": "wholly"
            },
            {
              "chord": "G",
              "text": "new."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Higher, higher, in the life of Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we are so low."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy life we all can go much higher—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Higher let us go."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, higher yet we pray—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transform us every day—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And richer in the flow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thy life be all we know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Growing, growing, in us He is growing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More and more each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into all our living He is flowing—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is now His way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For growth, O Lord, we pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase in us each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s not enough to know;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Thy life in us must grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Living, living, Christ is all our living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s so practical:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Small things, big things, anything and all things—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s involved in all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live Christ in every way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, live Him out today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His name you now must call,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And give Him your all for all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Person, Person, Jesus is our Person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living now in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s our tastes, our attitudes and actions;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Person, Lord, Thou art"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make home in all our heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As life in every way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be our Person, Lord, each day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Churches, churches, in the local churches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all find the flow:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deeper, higher, Christ as all our living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the church we grow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The churches are today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just Christ in every way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this, from self we cease,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy Body, Thine increase."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Building, building, we will see the building"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the church this way:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ experienced will produce the building—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the only way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, build us, Lord, we pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By growth of life each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, make us now such men"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the new Jerusalem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Coming, coming, Jesus soon is coming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His chosen Bride."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the churches we are all preparing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be glorified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, come again"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This cry is deep within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll praise Thee to the end,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, come back! Come back! Amen!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
