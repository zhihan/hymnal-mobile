    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Where’s the answer? Oh I’m so empty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And plagued by this vanity."
            }
          ]
