        {
          "segments": [
            {
              "chord": "",
              "text": "Deep inside me, My conscience tells me:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need another destiny."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The world and its glitter left me anxious, dark, and bitter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always yearning, my friends, is there something better?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And religion, my friends, is just a Sunday game—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dead teachings and doctrines will leave you just the same."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
