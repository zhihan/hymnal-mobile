          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m cleansed and You entered into me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Lord Jesus, Your name most precious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your Person, dear Lord, I now possess."
            }
          ]
