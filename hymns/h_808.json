    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Often through my heart is pealing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many another voice than Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Many an unwilled echo stealing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the walls of this Thy shrine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Thy longed-for accents fall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Master, speak! and silence all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Master, speak! though least and lowest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me not unheard depart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Master, speak! for oh, Thou knowest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the yearning of my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knowest all its truest need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak! and make me blest indeed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Master, speak! and make me ready,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thy voice is truly heard,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With obedience glad and steady,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still to follow every word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am listening, Lord, for Thee:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Master, speak, oh, speak to me!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak to me by name, O Master,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me know it is to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak, that I may follow faster,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With a step more firm and free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where the Shepherd leads the flock"
            }
          ]
        },
        {
          "segments": [
