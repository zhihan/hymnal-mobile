    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Round Your throne we see a rainbow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like an emerald in our sight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the throne You sit, like jasper,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of life, both green and bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And like sardius in appearance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which redemption signifies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God of glory, You redeemed us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the precious blood of Christ."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the ark reveals salvation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Entrance into Christ Your way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So the rainbow shows commitment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Your covenant today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though the fall of man still grieves You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nevermore will You repent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saying in Your heart, start over,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sending floods till life is spent."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As a sign that You are faithful"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Your cov’nant will be kept,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the clouds You set Your bow and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All can see Your promise yet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Storms may rage, with fierce commotion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But when light breaks forth anew,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stretched across the sky in spangles,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Promise shines in every hue."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your covenanted promise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You cannot deny Yourself."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are faithful in Your nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteous in Your judgments dealt."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your purpose, You commissioned"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man to bear Your holy name"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Your image and dominion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Christ comes, the earth to claim."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Every earthly rainbow tells You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet again what we will be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem eternal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Corporate God-man righteously."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, how we praise the steadfast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purpose of Your heart’s desire."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are faithful to Your word and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must fulfill Your will entire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
