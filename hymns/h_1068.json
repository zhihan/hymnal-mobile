    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He washed the bleeding sin-wounds,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And poured in oil and wine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He whispered to assure me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"I've found thee, thou art Mine:\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I never heard a sweeter voice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It made my aching heart rejoice."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the love that sought me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the blood that bought me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the grace that brought me to the flock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wondrous grace that brought me to the flock!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He pointed to the nail-prints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me His blood was shed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A mocking crown so thorny,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was placed upon His head:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I wondered what He saw in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To suffer such deep agony."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the love that sought me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the blood that bought me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the grace that brought me to the flock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wondrous grace that brought me to the flock!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm sitting in His presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sunshine of His face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While with adoring wonder"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blessings I retrace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It seems as if eternal days"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are far too short to sound His praise."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the love that sought me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the blood that bought me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the grace that brought me to the flock,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wondrous grace that brought me to the flock!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So while the hours are passing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All now is perfect rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm waiting for the morning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The brightest and the best,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When He will call us to His side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be with Him, His spotless Bride."
            }
          ]
        }
      ]
    },
