          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself we breathe in spirit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee we live, in Thee we walk,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy riches we inherit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "21"
