    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the true and heav'nly vine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we in Thee are branches;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee abiding, Thou in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We share in all Thy riches."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "23"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Bridegroom from above"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take the Bride, Thy Body;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be with Thee as one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In life and love and glory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "24"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the ladder Jacob saw,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee the heav'n is open;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we are the house of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And earth is joined to heaven."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "25"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, Thou art the great \"I AM,\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who all our need doth furnish;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying Thee as all in all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's purpose we accomplish."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "26"
    }
