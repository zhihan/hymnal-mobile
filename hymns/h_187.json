            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thirst no more forever."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "19"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the heav'nly bread of life,"
