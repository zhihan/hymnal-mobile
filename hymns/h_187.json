          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The all-inclusive Spirit comes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us with all Thy merit."
            }
          ]
