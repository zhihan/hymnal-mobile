          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our regeneration."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the serpent made of brass,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who saveth us from evil;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou on the tree wast lifted up,"
