          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With living water flowing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We drink of this refreshing stream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy quenching power knowing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "18"
