        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The truth that meets God's pleasure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The truth that brings Thyself to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may know Thy measure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
