      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the Shepherd and the door,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us to leave the sheepfold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee we have full liberty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And share the pasture freehold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "16"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy washing keeps us always clean,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In function like the laver;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we are kept in fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Partaking of Thy favor."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "17"
