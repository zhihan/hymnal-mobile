        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within our hearts in fulness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the very life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which all our spirits quickens;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life which brings us out of death"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all our being strengthens."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art God's reality,"
