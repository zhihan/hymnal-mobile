          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The way of Thy reality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which into vict'ry speeds us."
            }
          ]
        }
