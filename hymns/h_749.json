            },
            {
              "chord": "G",
              "text": "in our"
            },
            {
              "chord": "D",
              "text": "spirit"
            },
            {
              "chord": "",
              "text": "now doth"
            },
            {
              "chord": "A",
              "text": "rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He"
            },
            {
              "chord": "D",
              "text": "ever"
            },
            {
              "chord": "",
              "text": "seeks thru"
            },
            {
              "chord": "A",
              "text": "us to"
            },
            {
              "chord": "D",
              "text": "flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That"
            },
            {
              "chord": "G",
              "text": "God in"
            },
            {
              "chord": "D",
              "text": "Christ may"
            },
            {
              "chord": "A",
              "text": "be"
            },
            {
              "chord": "A7",
              "text": "ex"
            },
            {
              "chord": "D",
              "text": "pressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But by the outward, natural man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit is confined within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Instead of giving Him a home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A prison we’ve become to Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s like a treasure of great worth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Contained in vessels earthen-made;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The vessel must be broken through"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus the treasure be displayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how the Lord our self must break,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our outward man does so impede!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It must be broken thoroughly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus the Spirit will be freed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the reason why the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us a certain measure makes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of circumstantial suffering;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis thus our outward man He breaks."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The outward man, the self, the soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must be consumed, must be decreased;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The inner man, our spirit, then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall with the Spirit be released."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, grant Thy holy brokenness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deliver me from being whole;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make me willing to receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wounds that Thou wouldst give my soul."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, cause me to appreciate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy breaking, never to complain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grant that I may value more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All kinds of loss instead of gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
