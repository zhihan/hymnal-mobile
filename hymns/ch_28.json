    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你并不愿罪人沉沦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你愿他们回转求恳"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你作他们的救主。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在子里拣选我们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离罪和死亡围困，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又使我们蒙永福。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今可来喊‘阿爸，’"
