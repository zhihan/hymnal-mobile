          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "围你宝座，带着他们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前来敬拜并赞美。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时歌唱甜美声浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要达天地最远边疆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发自蒙赎的大会。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是今日我们渴慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，向你敬拜俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心歌唱你恩惠。"
            }
          ]
        }
