              "text": "From the Glorified in heaven"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The inclusive Spirit came;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All of Jesus’ work and Person"
