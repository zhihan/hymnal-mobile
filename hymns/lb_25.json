              "text": "(Repeat 2)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nevertheless, I am continually with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast holden me by my right hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou shalt guide me with Thy counsel and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Afterwards receive me to glory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One thing have I desired of the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That will I seek after,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may dwell in the house of the Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Repeat 4)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
