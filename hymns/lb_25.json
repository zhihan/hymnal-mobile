      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My flesh and my heart faileth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But God is the strength of my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my portion forever."
            }
          ]
        },
        {
          "segments": [
