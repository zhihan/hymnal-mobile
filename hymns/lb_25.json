    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is my refuge"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my fortress;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My God, in Him will I trust."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Repeat 2)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have set the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Always before me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is at my right hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I shall not be moved."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessed are they"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That dwell in the house;"
            }
          ]
        },
        {
          "segments": [
            {
