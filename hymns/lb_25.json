              "text": "I may dwell in the house of the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the days of my life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To behold the beauty of the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to inquire in His temple."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
