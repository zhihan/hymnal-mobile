        {
          "segments": [
            {
              "chord": "",
              "text": "Release my spirit! This is what I ask,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That self-confined or closed I may not be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How deep within myself I long have been,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If Thou deliver not, I’ll ne’er be free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Release my spirit! ’Tis for this I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That from myself I fully may come forth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit then through me may freely flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou Thy presence fully may show forth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Release my spirit! This is what I want,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I from my seclusion may depart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My private seeking poverty has brought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now save from self, Thy wealth to me impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
