    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From the slaughter of the kings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abram did return one night,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er the foe victorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the spoils of the fight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the way this One he met,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who for him did intercede;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King of Righteousness and Peace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meeting Abram in his need."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We too, Lord, the kings have fought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the battle all day long;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thine intercession, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are now victorious, strong."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Round this table here we meet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We Thy church victorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To enjoy the ministering"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the processed God to us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re not sinners, miserable;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our sins are history!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now to us, the fighters true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Thy priestly ministry."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gathered in thanksgiving, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our hearts to Thee we raise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our great Melchisedec,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Render we our highest praise!"
            }
          ]
        }
