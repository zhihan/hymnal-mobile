    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Great Prophet of my God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My tongue would bless Thy name;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee the joyful news"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of our salvation came;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The joyful news of sins forgiv’n,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of death annulled, and Thy life giv’n."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, my great High Priest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Offered His blood, and died;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My guilty conscience seeks"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No sacrifice beside:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His pow’rful blood did me redeem,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis worthy of my heart’s esteem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love my Shepherd’s voice:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His watchful eye shall keep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My wand’ring soul among"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thousands of His sheep:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He feeds His flock, He calls their names,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His bosom bears the tender lambs."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior and my Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Conqu’ror and my King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy scepter and Thy sword,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy reigning grace I sing:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine is the pow’r; behold I sit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In willing bonds beneath Thy feet."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
