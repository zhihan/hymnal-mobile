    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Many have no real joy ’cause they are barren."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That’s the subtle enemy to us today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go forth! Pray, “Oh Lord! In desperation we act!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Lord grow more! Bring many sons to You!” we pray, more and more!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Pay the price and come, be filled with life!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just filled!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life must multiply!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bury not your talent in the ground!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bear much fruit!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase all around!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life, from God to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life, through me for you."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With this balance, God will surely move."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Duplicate Your heart in me to care for others."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I’m nourished, I can nourish others too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! You need us to bear the fruit for the vine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How we need You! Lord, grant the growth in life that they might remain!"
            }
          ]
        }
      ]
    },
