    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God in man, and man in God, a mutual mingling."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grafted into Him, the vine, the rich supply."
            }
