{
  "url": "https://www.hymnal.net/cn/hymn/h/1099",
  "title": "The queen in gold of Ophir",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "The queen"
            },
            {
              "chord": "",
              "text": "in"
            },
            {
              "chord": "G",
              "text": "gold of"
            },
            {
              "chord": "D",
              "text": "Ophir"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thy right hand doth"
            },
            {
              "chord": "A",
              "text": "stand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "King's"
            },
            {
              "chord": "D",
              "text": "daughters"
            },
            {
              "chord": "G",
              "text": "are the"
            },
            {
              "chord": "D",
              "text": "women"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who fill Thy"
            },
            {
              "chord": "E7",
              "text": "honored"
            },
            {
              "chord": "A",
              "text": "band."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "D",
              "text": "church in"
            },
            {
              "chord": "",
              "text": "all her"
            },
            {
              "chord": "G",
              "text": "glo"
            },
            {
              "chord": "D",
              "text": "ry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall match her glorious"
            },
            {
              "chord": "A",
              "text": "King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "D",
              "text": "all the"
            },
            {
              "chord": "G",
              "text": "saints, the"
            },
            {
              "chord": "D",
              "text": "women,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy"
            },
            {
              "chord": "A",
              "text": "likeness"
            },
            {
              "chord": "A7",
              "text": "there shall"
            },
            {
              "chord": "D",
              "text": "bring."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O daughter, now consider,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en now incline thine ear:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remember not thy people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all thine own things here."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy beauty then shall blossom—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Twill be the King's desire;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For He thy worthy Lord is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy worship to inspire."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The daughter's glorious garments"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are made of inwrought gold—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the inner palace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How wondrous to behold!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory of God's nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is given her to wear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all His holy being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She may in life declare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In clothing too embroidered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She'll to the King be led,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In that fine linen garment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be exhibited."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis by the Spirit's stitching"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Christ in us is wrought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with this glorious garment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We'll to the King be brought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What gladness and rejoicing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we the King shall see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We'll shout His worthy praises"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through all eternity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And though the King we worship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or glory in the Queen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all this blest enjoyment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory goes to Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
