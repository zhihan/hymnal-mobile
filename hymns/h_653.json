    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Submit, lay down thine arms,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor question, nor rebel;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So shalt thou hear erewhile"
            }
          ]
        },
        {
          "segments": [
            {
