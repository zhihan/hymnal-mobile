  "title": "来阿你这万福泉源",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A7",
              "text": "來 阿，"
            },
            {
              "chord": "D",
              "text": "你 這"
            },
            {
              "chord": "",
              "text": "萬 福"
            },
            {
              "chord": "A",
              "text": "泉 源！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "調 整"
            },
            {
              "chord": "G",
              "text": "我 心"
            },
            {
              "chord": "A7",
              "text": "來 歌"
            },
            {
              "chord": "D",
              "text": "唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "憐 憫"
            },
            {
              "chord": "D",
              "text": "江 河"
            },
            {
              "chord": "",
              "text": "湧 流"
            },
            {
              "chord": "A",
              "text": "不 斷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "召 我"
            },
            {
              "chord": "G",
              "text": "高 聲"
            },
            {
              "chord": "A7",
              "text": "來 頌"
            },
            {
              "chord": "D",
              "text": "揚。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 本 外 人"
            },
            {
              "chord": "G",
              "text": "離 神"
            },
            {
              "chord": "D",
              "text": "流 浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "Bm",
              "text": "親 來"
            },
            {
              "chord": "G",
              "text": "尋 找"
            },
            {
              "chord": "D",
              "text": "我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "因 要"
            },
            {
              "chord": "D",
              "text": "救 我"
            },
            {
              "chord": "",
              "text": "脫 離"
            },
            {
              "chord": "A",
              "text": "死 亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 竟"
            },
            {
              "chord": "G",
              "text": "為 我"
            },
            {
              "chord": "A7",
              "text": "被 釘"
            },
            {
              "chord": "D",
              "text": "戳。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今天天被你激励，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你恩典来负债；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主，让此恩典维系"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我这流浪的心怀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我认我是趋向流浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "趋向离开爱的神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你用你灵的力量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我荡心来吸引。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着你的救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离罪恶和死亡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿能作脱俗的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出神子的景况。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今建立以便以谢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你一直赐帮助；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你喜悦，我望永得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的带领和眷顾。"
            }
          ]
        }
      ]
    }
