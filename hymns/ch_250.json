      "lines": [
        {
          "segments": [
            {
              "chord": "A7",
              "text": "来 阿，"
            },
            {
              "chord": "D",
              "text": "你 这"
            },
            {
              "chord": "",
              "text": "万 福"
            },
            {
              "chord": "A",
              "text": "泉 源！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "调 整"
            },
            {
              "chord": "G",
              "text": "我 心"
            },
            {
              "chord": "A7",
              "text": "来 歌"
            },
            {
              "chord": "D",
              "text": "唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "怜 悯"
            },
            {
              "chord": "D",
              "text": "江 河"
            },
            {
              "chord": "",
              "text": "涌 流"
            },
            {
              "chord": "A",
              "text": "不 断，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "召 我"
            },
            {
              "chord": "G",
              "text": "高 声"
            },
            {
              "chord": "A7",
              "text": "来 颂"
            },
            {
              "chord": "D",
              "text": "扬。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 本 外 人"
            },
            {
              "chord": "G",
              "text": "离 神"
            },
            {
              "chord": "D",
              "text": "流 浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "Bm",
              "text": "亲 来"
            },
            {
              "chord": "G",
              "text": "寻 找"
            },
            {
              "chord": "D",
              "text": "我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "因 要"
            },
            {
              "chord": "D",
              "text": "救 我"
            },
            {
              "chord": "",
              "text": "脱 离"
            },
            {
              "chord": "A",
              "text": "死 亡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 竟"
            },
            {
              "chord": "G",
              "text": "为 我"
            },
            {
              "chord": "A7",
              "text": "被 钉"
            },
            {
              "chord": "D",
              "text": "戳。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今天天被你激励，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你恩典来负债；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主，让此恩典维系"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我这流浪的心怀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我认我是趋向流浪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "趋向离开爱的神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你用你灵的力量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我荡心来吸引。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着你的救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离罪恶和死亡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿能作脱俗的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出神子的景况。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今建立以便以谢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你一直赐帮助；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你喜悦，我望永得"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的带领和眷顾。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
