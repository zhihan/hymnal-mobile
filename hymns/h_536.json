    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In heaven He sits at the right hand of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where as the High Priest He presented His blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Advocate, bearing our burdens above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Surety, He careth for us in His love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He now is the Spirit, our spirit within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s there as our life, all things bringing with Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s there as our strength and our grace every hour,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Paraclete in us, sustaining with pow’r."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In heaven for us He’s the glorified man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Forerunner entered, fulfilling God’s plan;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man into God bringing and making him one"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God in the heav’nlies, in Him as the Son."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In us all the fulness of God dwells in Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Spirit He brings God Himself thus within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Revealing and making God real unto us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God one with us building in life glorious."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Savior ascended in heaven now dwells,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And soon He’s returning for us His Word tells;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deliverer indwelling, He now in us lives,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And soon will transfigure, His glory to give."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The day soon is coming when heaven and earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will mingle in one in that city of worth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Objective and subjective will in that day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be mingled within us in glory for aye."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
