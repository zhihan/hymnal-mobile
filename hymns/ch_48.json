    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦父，你外我们不需别惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何比你恩爱更为宝贵！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们敬拜，因为我们尝到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那无穷生命丰美味道。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你爱中我爱对你增长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过所有人情、属地捆绑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱借着大能，带领我心"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你的同在与日俱深。"
            }
          ]
        }
