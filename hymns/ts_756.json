        {
          "segments": [
            {
              "chord": "",
              "text": "不管何遭遇，随羔羊前行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论何往不稍离。"
            }
          ]
        }
