        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻转向灵，绝不望领头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "首位惟归主自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
