          "text": "跟随！凭灵中羔羊，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "绝对跟随，凭基督！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "一路紧跟随，直到进国度，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊婚筵乐有分；"
        }
      ]
    },
    {
      "segments": [
