        {
          "segments": [
            {
              "chord": "",
              "text": "绝对跟随，凭基督！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今欢然跟羊群脚踪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受牧者的照应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在众召会中，主今正引领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的发言当聆听。"
            }
          ]
        }
      ],
