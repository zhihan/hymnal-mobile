      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们今全然献给主基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "紧紧跟随不他依；"
