    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在天上位分至尊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天使、天军无不拜顿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却因情爱非常坚强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以至愿意撇弃穹苍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来寻迷羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且受戕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "舍了天福，又失世赏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂寻我，赞美祂的名！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的道路实在孤单，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有同心、没有同伴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的所有患难、忧愁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟祂自己和神知道；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂前走，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不稍退后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直等祂到我的囚牢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂见我，赞美祂的名！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不久，悲惨日子就到："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂被人卖，祂被人告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂就如此－零丁孤苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "头戴荆冕，身受鞭伤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我之故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来髑髅处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍辱、受死，疼痛独当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂救我，赞美祂的名！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一生一世，我要述说，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的爱情超人能度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我至终被提祂前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在祂所豫备的城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心所羡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是见祂面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并要敬拜，高声颂称，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱祂，赞美祂的名！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
