{
  "url": "https://www.hymnal.net/cn/hymn/ch/748",
  "title": "诸天国度祂的实际",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "诸 天"
            },
            {
              "chord": "",
              "text": "国 度， 祂"
            },
            {
              "chord": "A",
              "text": "的 实"
            },
            {
              "chord": "D",
              "text": "际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 于 受 天 管 治 生"
            },
            {
              "chord": "A",
              "text": "活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这 种 生"
            },
            {
              "chord": "A7",
              "text": "活， 性"
            },
            {
              "chord": "D",
              "text": "质"
            },
            {
              "chord": "D7",
              "text": "神"
            },
            {
              "chord": "G",
              "text": "圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全"
            },
            {
              "chord": "A",
              "text": "让 基"
            },
            {
              "chord": "D",
              "text": "督 居"
            },
            {
              "chord": "A",
              "text": "衷"
            },
            {
              "chord": "A7",
              "text": "活"
            },
            {
              "chord": "D",
              "text": "著。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这种生活：灵里贫穷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心里饥渴、哀恸、温柔；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对人总是满了怜恤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神又是清心寻求。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "作神儿子，制造和睦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着公义，忍受逼迫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为主受人辱骂、毁谤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无怨无恨，欢喜快乐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "作盐消杀地上败坏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作光照亮世上黑暗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "存心行动，正直真诚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只爱不恨，像父完全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "自荣自耀全都抛弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远为着神国祷告；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "先求神国和神的义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切需要惟神是靠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对己严格，对人有恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神，又是殷勤求寻；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远遵行天父旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照主话语行事为人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对待撒但，不留地步，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同样拒绝世界人情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只愿顺服诸天管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "接受神的完全权柄。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这种生活征服一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借神大能遵神吩咐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "促进主的再来日子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带进国度实现之福。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "国度",
    "time": "3/4",
