              "text": "直到灵里能相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你召会得建造。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们进到至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
