          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "乃 是"
            },
            {
              "chord": "A",
              "text": "祭 司"
            },
            {
              "chord": "D",
              "text": "體，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 在 你 前"
            },
            {
              "chord": "A7",
              "text": "同 侍"
            },
            {
              "chord": "D",
              "text": "立。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "在 此"
            },
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "D7",
              "text": "同 禱"
