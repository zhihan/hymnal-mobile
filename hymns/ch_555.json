        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "切愿前来作祭司，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你面前供圣职，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用灵来摸你意旨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你完成你设施。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此我们同祷告，"
