  "title": "在此我们同祷告",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "A7",
              "text": "今 聚"
            },
            {
