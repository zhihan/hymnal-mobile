        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "學 習"
            },
            {
              "chord": "",
              "text": "摸 著"
            },
            {
              "chord": "A",
              "text": "你 上"
            },
            {
              "chord": "A7",
              "text": "好，"
            }
          ]
        },
