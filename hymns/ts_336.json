    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心破碎，失去最深渴慕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不要問我：婦人，你為何哭？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除了耶穌，別無滿足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在何處？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "轉過身來，看見復活耶穌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以為是園丁，我竟未認出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以為他知主在何處。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在何處？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何處尋祂─主耶穌？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何處尋祂─愛主？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何處尋祂─指示我路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要取祂，不畏險阻。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我聽見祂對我柔聲輕訴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甜美呼喚進入我心深處。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "熟悉聲音，就是我主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我耶穌！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我已尋見主耶穌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已尋見愛主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已尋見我心所慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶穌，摯愛，我愛你，主。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得見我主，我心喜難述；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要升天，使父心滿意足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂神、祂父成我們神、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我們的父。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你要升天，去見父；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我告訴門徒："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你神已成我們的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你父已成我們的父。"
            }
          ]
        }
      ],
      "type": "chorus"
    }
