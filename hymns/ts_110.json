              "chord": "",
              "text": "膏油涂抹常引领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神在我里涌流！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，感谢赞美主，"
