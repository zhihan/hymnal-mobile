    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！在我的灵里"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是在运行！"
            }
          ]
        },
        {
          "segments": [
