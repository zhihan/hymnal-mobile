    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, my best love Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I was once rebellious and hard,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But I drop it all now to come to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self forsake, that like Thee I’d be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I live, be it Thou, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not self’s will, but God’s I’d obey;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thine heart attuned, Thy delight I’d seek;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more struggling, fully at peace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who in all the world is as fair as Thee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or who else can love so romantic’ly?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, most holy One, now You live in me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, I deeply love Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more trusting self, nor deceived I’d be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d put off my self, just be filled with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let all apart from Thee fade and flee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My one love, my best love, is Thee."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus Lord, my best love Thou art;"
