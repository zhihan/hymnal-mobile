          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would pour my heart out to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love Thee, serve Thee, joined utterly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My eternal portion, dear Lord, is Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My one hope, Thy coming to see."
            }
          ]
