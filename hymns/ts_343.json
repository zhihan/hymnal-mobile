{
  "url": "https://www.hymnal.net/cn/hymn/ts/343",
  "title": "佳偶的歌",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的爱和你美丽自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吸引我快跑跟随你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我重生进你内室，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙你𫗪养到永世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "良人阿！我只属于你。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "佳偶阿！你何等美丽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你我生命、性情是一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱里联结永不分离。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因你，我得有圣别性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我美丽来自你生命。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得更新顺从听命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同良人蹿山越岭。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "单一里注视你如良鸽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荆棘中信靠如百合。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被变化，得你建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你安息、喜乐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在田间随你往前脚踪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿一生爱你而同工。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作王女，满你情衷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更巴望被提得荣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请将我铭刻你心上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你爱如死之坚强。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "朝思暮想，良人，我王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你快来，香草山上！"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
  "metadata": {
    "category": "爱慕耶稣",
