    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He who was the friend of sinners,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeks thee, lost one, now;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sinner, come, and at His footstool,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Penitently bow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who said, “I’ll not condemn thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go and sin no more,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks to thee that word of pardon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As in days of yore."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yesterday, today, forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is the same,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All may change, but Jesus never!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory to His name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory to His name,"
            }
          ]
        },
        {
          "segments": [
            {
