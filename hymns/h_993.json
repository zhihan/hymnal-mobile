              "text": "Glory to His name."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oft on earth He healed the suff’rer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His mighty hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still our sicknesses and sorrows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go at His command."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who gave His healing virtue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To a woman’s touch;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the faith that claims His fulness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still will give as much."
            }
          ]
        }
      ],
