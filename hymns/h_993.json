    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As of old He walked to Emmaus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With them to abide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So through all life’s way He walketh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever near our side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon again we shall behold Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hasten, Lord, the day!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But ’twill still be “this same Jesus,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As He went away."
            }
          ]
        }
