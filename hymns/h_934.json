          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or who can say how great the jubilation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When all the hearts of men with love are filled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But this I know, the skies will thrill with rapture,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And myriad, myriad human voices sing,"
