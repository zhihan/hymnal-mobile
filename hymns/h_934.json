          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When He the Savior, Savior of the world, is known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot tell how all the lands shall worship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When, at His bidding, every storm is stilled,"
