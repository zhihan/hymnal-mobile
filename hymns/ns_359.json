    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You're so sweet, my brook, my pasture green,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Waking me, to righteous paths,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis by faith that I'm empow'red"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To live out Thy righteousness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though the world would bring me woe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tide of age would ebb and flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, Lord, Thy love cannot be swayed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy care, no lack I know."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When my sense of Thy dear presence fades,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I lose all touch with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my heart is caught in doubt,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rod and staff, they comfort me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life by faith, I surely know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shepherd leads me as I go"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here as I feast before my foes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cup of blessing overflows."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Foll'wing Thee, Good Shepherd, I would feed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shepherd those allotted me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'er I'd touch Thy heart's desire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live in Thine economy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O my Lord, All thanks to Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Goodness, mercy follow me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'd ever dwell within Thy house,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Thy Body glorious!"
            }
          ]
        }
      ]
