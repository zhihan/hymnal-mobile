        {
          "segments": [
            {
              "chord": "D",
              "text": "听 我"
            },
            {
              "chord": "",
              "text": "唱， 奇 妙"
            },
            {
              "chord": "Bm",
              "text": "爱："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 耶"
            },
            {
              "chord": "Em",
              "text": "稣， 从"
            },
            {
              "chord": "",
              "text": "天"
            },
            {
              "chord": "A7",
              "text": "来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "十 架"
            },
            {
              "chord": "D",
              "text": "上， 祂"
