            {
              "chord": "",
              "text": "a certain"
            },
            {
              "chord": "A",
              "text": "sense of"
            },
            {
              "chord": "D",
              "text": "life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life of"
            },
            {
              "chord": "E7",
              "text": "every"
            },
            {
              "chord": "A",
              "text": "kind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "G",
              "text": "in th'eternal"
            },
            {
              "chord": "",
              "text": "life in"
            },
            {
              "chord": "A",
              "text": "us It"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "is a"
            },
            {
              "chord": "A",
              "text": "sense"
            },
            {
              "chord": "A7",
              "text": "di"
            },
            {
              "chord": "D",
              "text": "vine."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The higher any life may be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The better is its sense;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life divine the highest is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And has the highest sense."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the sense of life in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the sense of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis in our spirit made alive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And more than sense of good."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the inner sense in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The inmost consciousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Discerning matters inwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s will to thus express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this sense that God we know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sense of inner life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis pow’rful and spontaneous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And not of any strife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The greater is our growth in life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The keener is this sense;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we walk and act in life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more it is intense."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The sense of life when exercised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will make our spirit bold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by this inner sense of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True fellowship we hold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
