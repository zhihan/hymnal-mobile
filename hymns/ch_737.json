      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当今时日在逝逊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切皆能安心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟独切盼那早晨－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无上光明时辰："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时召我到祂身边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂同在，作祂圣伴。"
            }
          ]
        }
      ],
