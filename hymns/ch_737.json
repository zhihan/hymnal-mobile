{
  "url": "https://www.hymnal.net/cn/hymn/ch/737",
  "title": "爱何大寻回我",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "當 我"
            },
            {
              "chord": "",
              "text": "疲 困 罪"
            },
            {
              "chord": "D",
              "text": "惡 境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 以 柔 愛 來"
            },
            {
              "chord": "G",
              "text": "尋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "懷 我、 肩 我 滿"
            },
            {
              "chord": "D",
              "text": "溫 情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "帶"
            },
            {
              "chord": "A7",
              "text": "我 歸"
            },
            {
              "chord": "",
              "text": "祂 羊"
            },
            {
              "chord": "D",
              "text": "群；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千"
            },
            {
              "chord": "D7",
              "text": "萬 天"
            },
            {
              "chord": "G",
              "text": "使 因"
            },
            {
              "chord": "D7",
              "text": "此 歡"
            },
            {
              "chord": "G",
              "text": "騰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚"
            },
            {
              "chord": "A",
              "text": "至 歌"
            },
            {
              "chord": "A7",
              "text": "聲 滿"
            },
            {
              "chord": "",
              "text": "天 響"
            },
            {
              "chord": "D7",
              "text": "應。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "愛 何"
            },
            {
              "chord": "",
              "text": "大， 尋"
            },
            {
              "chord": "D",
              "text": "回 我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "血 何 寶， 贖"
            },
            {
              "chord": "G",
              "text": "回 我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩 何 豐， 帶"
            },
            {
              "chord": "D7",
              "text": "回 我"
            },
            {
              "chord": "G",
              "text": "歸 羊"
            },
            {
              "chord": "D",
              "text": "群！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "奇 妙"
            },
            {
              "chord": "C",
              "text": "恩， 帶"
            },
            {
              "chord": "D",
              "text": "回 我"
            },
            {
              "chord": "D7",
              "text": "歸 羊"
            },
            {
              "chord": "G",
              "text": "群！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "伤重待毙祂见我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "便以油酒敷裹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "柔声细语许我说；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘你要永远属我！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从无声音如此甜美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "伤痛之心顿觉欣慰！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱何大，寻回我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "血何宝，赎回我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩何丰，带回我归羊群！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙恩，带回我归羊群！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "钉痕枪伤祂示我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "血也水也流出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "头戴荆冕利刺戳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羞辱加上痛楚："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我真不知我有何长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂为我这样受戕。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
