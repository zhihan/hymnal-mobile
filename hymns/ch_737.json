              "text": "奇妙恩，带回我归羊群！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今安坐祂面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "瞻仰祂的荣颜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心觉希奇灵感赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "追忆祂的恩眷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "似乎永世所有时间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用来赞祂尚嫌太短。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
