{
  "url": "https://www.hymnal.net/cn/hymn/ch/581",
  "title": "哦主神的活话",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "神 的 活 话， 神 的 真"
            },
            {
              "chord": "A",
              "text": "像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 是"
            },
            {
              "chord": "",
              "text": "神 话 内 容， 神"
            },
            {
              "chord": "E",
              "text": "圣"
            },
            {
              "chord": "E7",
              "text": "宝"
            },
            {
              "chord": "A",
              "text": "藏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "在 你"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "们 看"
            },
            {
              "chord": "",
              "text": "见 神"
            },
            {
              "chord": "E7",
              "text": "的 丰"
            },
            {
              "chord": "A",
              "text": "满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 又"
            },
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "Em",
              "text": "著 圣"
            },
            {
              "chord": "",
              "text": "经 向"
            },
            {
              "chord": "A",
              "text": "我"
            },
            {
              "chord": "A7",
              "text": "显"
            },
            {
              "chord": "D",
              "text": "现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从未有人见神，在你之外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若无圣经你难启示出来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已将神向人清楚表明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而对你认识是借圣经。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神的化身，具体、完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣经是你描述，真实、丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你我们领略神的真像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但借圣经才能将你欣赏。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是生命之灵，你又是话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这话因灵丰盛，无以复加；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你内住之灵摸着这话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就将你丰盛向我赐下。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里面我可与神交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着圣经我能享你无穷；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每凭经中话语向你读祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的丰富就顾我的需要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主教我如何运用我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷读你话，借以受你供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你和经中话语相调为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就作生命吗哪，每日供给。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "读经",
