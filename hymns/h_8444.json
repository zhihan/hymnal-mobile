              "text": "The God"
            },
            {
              "chord": "",
              "text": "of"
            },
            {
              "chord": "A",
              "text": "love,"
            },
            {
              "chord": "D",
              "text": "my Shepherd"
            },
            {
              "chord": "A",
              "text": "is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Grace He"
            },
            {
              "chord": "",
              "text": "doth"
            },
            {
              "chord": "G",
              "text": "give,"
            },
            {
              "chord": "D",
              "text": "me"
            },
            {
              "chord": "A7",
              "text": "He doth"
            },
            {
              "chord": "D",
              "text": "feed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O He is"
            },
            {
              "chord": "G",
              "text": "mine"
            },
            {
              "chord": "D",
              "text": "and"
            },
            {
              "chord": "E7",
              "text": "I am"
            },
            {
              "chord": "A",
              "text": "His,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What"
            },
            {
              "chord": "D",
              "text": "else I"
            },
            {
              "chord": "G",
              "text": "lack?"
            },
            {
              "chord": "D",
              "text": "What"
            },
            {
              "chord": "A7",
              "text": "else I"
            },
            {
              "chord": "D",
              "text": "need?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He lays me down in pastures green,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And leads me to waters of rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No greater satisfaction seen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here I enjoy fellowship blest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He brings me home, though oft I stray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Restores my soul, His will to take;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I yet may fall, He guides the way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On righteous path, for His name’s sake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How marvelous, how could it be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To walk without evil to fear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your rod and staff, they comfort me:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My boast is in Your presence dear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve spread for me a table feast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To confound my adversaries;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My cup runs o’er; oil has not ceased;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My head anoint; O Lord, increase."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your wondrous love, eternal, sweet,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With me abides till all my days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Your house, with joy replete,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll ever dwell, with endless praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
