{
  "url": "https://www.hymnal.net/cn/hymn/ch/185",
  "title": "为着这饼我感谢你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "為 著"
            },
            {
              "chord": "",
              "text": "這 餅 我"
            },
            {
              "chord": "G",
              "text": "感 謝"
            },
            {
              "chord": "C",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 是 神"
            },
            {
              "chord": "D7",
              "text": "聖 表"
            },
            {
              "chord": "G",
              "text": "記；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "C",
              "text": "此， 恩"
            },
            {
              "chord": "G",
              "text": "主， 我"
            },
            {
              "chord": "C",
              "text": "得 看"
            },
            {
              "chord": "F",
              "text": "見"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "C",
              "text": "計 畫"
            },
            {
              "chord": "G",
              "text": "的 奧"
            },
            {
              "chord": "C",
              "text": "祕。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这饼指明你的身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你为我们舍弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分你的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并得你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的身体为我裂开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为将自己分授，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能得你作生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的配偶。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此，这饼也是指明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那奥秘身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是祂活的肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你完全合一。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们虽是许多子粒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却都成为一饼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此这样将你记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从你得到供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这饼我们交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你心满意足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同众圣徒如此交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证你的丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
