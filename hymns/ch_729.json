{
  "url": "https://www.hymnal.net/cn/hymn/ch/729",
  "title": "耶稣，我人的爱人",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "耶 穌，"
            },
            {
              "chord": "",
              "text": "我 人"
            },
            {
              "chord": "A",
              "text": "的 愛"
            },
            {
              "chord": "",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 懷"
            },
            {
              "chord": "",
              "text": "讓 我"
            },
            {
              "chord": "A",
              "text": "來"
            },
            {
              "chord": "A7",
              "text": "藏"
            },
            {
              "chord": "D",
              "text": "身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "驚 波， 駭 濤"
            },
            {
              "chord": "A",
              "text": "滾 滾"
            },
            {
              "chord": "",
              "text": "近！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "狂 風"
            },
            {
              "chord": "",
              "text": "暴 雨"
            },
            {
              "chord": "A",
              "text": "陣"
            },
            {
              "chord": "A7",
              "text": "陣"
            },
            {
              "chord": "D",
              "text": "緊！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藏 我！ 哦， 主，"
            },
            {
              "chord": "G",
              "text": "求 藏"
            },
            {
              "chord": "D",
              "text": "我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直 到 今 生"
            },
            {
              "chord": "G",
              "text": "風 波"
            },
            {
              "chord": "D",
              "text": "過！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引 我 安 全"
            },
            {
              "chord": "A",
              "text": "到 路"
            },
            {
              "chord": "",
              "text": "盡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "至 終"
            },
            {
              "chord": "",
              "text": "求 接"
            },
            {
              "chord": "A",
              "text": "我"
            },
            {
              "chord": "A7",
              "text": "靈"
            },
            {
              "chord": "D",
              "text": "魂！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "别无避所能藏隐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无助之人托你身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不！哦，不要丢弃我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "扶持、安慰，望无辍："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有倚靠寄你身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有救助由你临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "头无遮护身无蔽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你圣翼来覆庇。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，你是我所需，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "够我一切还有馀："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仆，你扶起；弱，你保；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "病，你医治；瞽，你导；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你名至义至圣洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我全不义满罪孽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是邪恶没良善，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩典、真理你充满。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你前我遇恩浩瀚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赦我众罪之恩典；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "医治活水望涌流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洁我衷里并保守；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是永远生命源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "望在我心成活泉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我里头来涌流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直涌流到永久。"
            }
          ]
        }
      ]
    }
  ],
