              "text": "fighting the good fight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Running and finishing the course,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And keeping the faith."
            }
          ]
        },
        {
          "segments": [
            {
