              "text": "And keeping the faith."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the New Testament, faith is both"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Objective and subjective;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The objective faith refers to the things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In which we believe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the subjective faith"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has to do with our action of believing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The subjective faith"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has to do with our action of believing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In order for us to enjoy Christ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As our kingdom reward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must love the Lord’s appearing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which is His appearing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And manifestation to us today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His presence with His people at"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His second coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His presence with His people at"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His second coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By staying on the constricted way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "constricted way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of being watchful in life and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithful in service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By staying on the constricted way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "constricted way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of being watchful in life and"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithful in service"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be constituted as the bride of Christ."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Lord comes again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith will be turned to facts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And praise will replace prayer."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love will consummate in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A shadowless perfection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we will serve Him in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sinless domain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a day that will be!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, come quickly!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we will serve Him in"
            }
          ]
        },
