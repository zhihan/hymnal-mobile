    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "既是身体你可定居，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是你的居所；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在我们得到倚据，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们作你寄托。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你心、怡悦你意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是你的配偶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同你生活、与你一体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你的所有。"
            }
          ]
        }
