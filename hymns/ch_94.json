    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在十架为我裂破，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出你水和血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为将生命分赐与我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并为赎我罪孽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的宝血将我洗净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我蒙神喜悦；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的生命使我重生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我与你联结。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，你救赎何奇妙！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新造故事，何荣耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远丰满有功效！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得我们称道！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是一粒神圣麦子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结出许多子粒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与你同性、同质，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的身体。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们生命、内容，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你借我们生活、行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们把你彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
