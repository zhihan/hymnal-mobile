          "segments": [
            {
              "chord": "A",
              "text": "新"
            },
            {
              "chord": "A7",
              "text": "造 故"
            },
            {
              "chord": "",
              "text": "事，"
            },
            {
              "chord": "D",
              "text": "何 荣"
            },
            {
              "chord": "D7",
              "text": "耀！"
            }
          ]
        },
