    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们在此擘饼记念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看到表记之物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心、灵不禁充满感赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "希奇你的救赎！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我们作你身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并你居所、配偶，"
