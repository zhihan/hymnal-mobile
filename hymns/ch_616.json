  "title": "主阿我爱你的居所",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "",
              "text": "我 爱 你"
            },
            {
              "chord": "A",
              "text": "的 居"
            },
            {
              "chord": "D",
              "text": "所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "E",
              "text": "是 你"
            },
            {
              "chord": "E7",
              "text": "的 召"
            },
            {
              "chord": "A",
              "text": "会！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她"
            },
            {
              "chord": "D",
              "text": "是 你"
            },
            {
              "chord": "A",
              "text": "心 所"
            },
            {
              "chord": "A7",
              "text": "喜 所"
            },
            {
              "chord": "D",
              "text": "乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "G",
              "text": "是 我"
            },
            {
              "chord": "A",
              "text": "心"
            },
            {
              "chord": "A7",
              "text": "所"
            },
            {
              "chord": "D",
              "text": "归。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾为她舍了自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要叫她归你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我也为她献上身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成全你的心意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为她你作我的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫她作我生活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为她我愿脱去个性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让她作你寄托。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "她是你的心爱配偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是你的身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她是我的心情所投，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是我的凭倚。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在她你是我所享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我所见证；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在她我给你所占有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足你的心情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我爱你的居所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是你的召会！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿永在其中生活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再别有所归。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
