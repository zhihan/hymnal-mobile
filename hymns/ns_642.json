    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Priceless ’tis, now I see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To spend time seeking Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Time is precious to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Limited in quantity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I just want to spend"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My time with only Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou art worthy Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d every moment seize,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not one spent without Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But with my love, my Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I spend my time"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That it’d be valuable,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thousand-fold multiplied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever our memorial?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d rather spend a day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee and with Thy saints,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than thousand days away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One thing, that do I seek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To dwell within Thy house"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beholding Thee always."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "New beginning I ask."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my heart, capture more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my time, spent with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my days, on Thee outpoured."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The time, may I redeem,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From many wasted days,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From wand’ring aimlessly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More time I cannot waste;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou long didst wait for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To turn my being to Thee."
            }
          ]
        }
      ]
    }
