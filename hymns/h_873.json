    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Charge, soldiers, charge in battle!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And gaze upon thy Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If thou wilt fight His battle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The throne is thy reward."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This war is of the spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not fought on earthly ground;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord well knows the foe is near,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Encircling us around."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Charge, soldiers, charge in battle!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ's throne awaiteth thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His resurrection power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will lift thy spirit free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Him thou wilt have power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The foe to battle down;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Him thou wilt the triumph sing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And wear the victor's crown."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Charge, soldiers, charge in battle!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou shalt ascend the throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A feast He is preparing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How happy thou to own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him we're resurrected"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Above the battle din;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transcending all that binds us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're far above in Him."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Charge, soldiers, charge in battle!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the royal heir;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord from dust did choose thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That thou His kingdom share."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast no part in darkness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy future, O how bright;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ to dwell forever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in His love delight."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With joyful shouts charge forward!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingdom is before;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the peak of Zion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We'll sing, the battle o'er."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lamb has won the victory!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lamb is on the throne!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With shouts of joy we praise Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For He must overcome."
            }
          ]
        }
      ]
    }
