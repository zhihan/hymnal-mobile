{
  "url": "https://www.hymnal.net/cn/hymn/ch/700",
  "title": "若尽得世界",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "若 尽"
            },
            {
              "chord": "",
              "text": "得 世 界，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而 失 去"
            },
            {
              "chord": "A",
              "text": "救 主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂 值"
            },
            {
              "chord": "A7",
              "text": "得 一"
            },
            {
              "chord": "",
              "text": "日 在 此 活"
            },
            {
              "chord": "D",
              "text": "著？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 这 些 就 要 过 去 之"
            },
            {
              "chord": "A",
              "text": "物 中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安 息"
            },
            {
              "chord": "A7",
              "text": "与 安"
            },
            {
              "chord": "",
              "text": "慰 岂 能 寻"
            },
            {
              "chord": "D",
              "text": "得？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "若 尽"
            },
            {
              "chord": "A",
              "text": "得 世"
            },
            {
              "chord": "",
              "text": "界，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而 失 去"
            },
            {
              "chord": "D",
              "text": "救 主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所 得"
            },
            {
              "chord": "A",
              "text": "的 一"
            },
            {
              "chord": "",
              "text": "切 彀"
            },
            {
              "chord": "A7",
              "text": "用 一"
            },
            {
              "chord": "D",
              "text": "生？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "地 上"
            },
            {
              "chord": "A",
              "text": "所 有"
            },
            {
              "chord": "",
              "text": "的 快 乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "D",
              "text": "不 能"
            },
            {
              "chord": "",
              "text": "比"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那"
            },
            {
              "chord": "A",
              "text": "充 满"
            },
            {
              "chord": "",
              "text": "了 主"
            },
            {
              "chord": "A7",
              "text": "的 生"
            },
            {
              "chord": "D",
              "text": "命！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "纵令你满得财富和爱情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论远或近也都知名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前面仍无望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍无一港口"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你这惊船可以靠停。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若尽得世界，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而失去救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是那为你受死的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是否这世界能供一避所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给你逃进去永远居住？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的虚空！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若没有救主："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上尽都是罪恶、苦难！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永世何黑暗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若没有救主："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑夜与眼泪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "痛苦无边！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若没有救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽暂能活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但到要死时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将要怎办？哦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必要面对那无主幽谷！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且一直无主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永远！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在主得一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的快乐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等能安抚伤痛心田！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并无一罪过祂不肯赦免，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也无一忧患祂不承担！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若你只有主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有主基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地除了祂，你无他物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那，在祂里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就有一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应付你需要，无限丰富。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
