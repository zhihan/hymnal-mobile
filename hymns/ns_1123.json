    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s a God-man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A divine and human God-man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living God as man, He paved the way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God to live in me today."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s a God-man! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s exalted."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s to God’s right hand exalted."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God was incarnated for His plan;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He lived, He died, He rose as man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s exalted! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s our High Priest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s our interceding High Priest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like us tempted, yet He’s without sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We boldly come to God through Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s our High Priest! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s within us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is living now within us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit He is saving me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From now unto eternity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s within us! Wonderful!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What He is: He’s Salvation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Savior, He’s Salvation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When He comes, salvation comes to us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The God-man Jesus, glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s Salvation! Wonderful!"
            }
          ]
        }
