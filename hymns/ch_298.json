{
  "url": "https://www.hymnal.net/cn/hymn/ch/298",
  "title": "愿你逐日维持的力",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "求"
            },
            {
              "chord": "A7",
              "text": "你 长"
            },
            {
              "chord": "D",
              "text": "在 我"
            },
            {
              "chord": "A7",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "外 再"
            },
            {
              "chord": "A7",
              "text": "无 他"
            },
            {
              "chord": "D",
              "text": "求！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 逐"
            },
            {
              "chord": "A7",
              "text": "日 与"
            },
            {
              "chord": "D",
              "text": "你 更"
            },
            {
              "chord": "A7",
              "text": "亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "逐"
            },
            {
              "chord": "D",
              "text": "日 向"
            },
            {
              "chord": "A7",
              "text": "罪 自"
            },
            {
              "chord": "D",
              "text": "由。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿 你 逐 日 维 持 的 力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍"
            },
            {
              "chord": "G",
              "text": "然 顾"
            },
            {
              "chord": "",
              "text": "我 软"
            },
            {
              "chord": "A7",
              "text": "弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 的"
            },
            {
              "chord": "",
              "text": "亮"
            },
            {
              "chord": "A7",
              "text": "光 除"
            },
            {
              "chord": "D",
              "text": "我 阴"
            },
            {
              "chord": "A7",
              "text": "翳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "命 吞"
            },
            {
              "chord": "A7",
              "text": "我 死"
            },
            {
              "chord": "D",
              "text": "涸。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你荣光照我心头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有恶念都消；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘我是无有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是万有，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿常受此教。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你逐日维持的力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍然顾我软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的亮光除我阴翳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命吞我死涸。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你这圣洁、荣耀的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我更多瞻仰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论快乐或是艰苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿作你活像。"
            }
          ]
        }
      ],
      "type": "verse",
