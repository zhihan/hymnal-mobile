    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人 調 和， 阿 利 路"
            },
            {
              "chord": "G7",
              "text": "亞！"
            },
            {
              "chord": "C",
              "text": "神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人 調 和， 阿 利"
            },
            {
              "chord": "G",
              "text": "路 亞！"
            },
            {
              "chord": "",
              "text": "神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人 調 和， 阿 利 路 亞！ 調"
