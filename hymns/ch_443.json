              "chord": "",
              "text": "不再自藏，不再自隐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经向人来显明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "后成那灵，先在肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给人接受作生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等可亲！何等可近！"
