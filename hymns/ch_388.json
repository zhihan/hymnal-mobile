          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "此 歡"
            },
            {
              "chord": "D",
              "text": "呼； 歡"
            },
            {
              "chord": "",
              "text": "呼 基"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "督 給"
            },
            {
              "chord": "G",
              "text": "我 得"
            },
            {
              "chord": "D",
              "text": "到， 何"
            },
            {
              "chord": "A",
              "text": "等 一"
            }
          ]
        },
        {
          "segments": [
            {
