            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我这基督是神羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "担当我的罪愆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又是神的公义太阳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发出医治光线。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我这基督是生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长在神的乐园；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的美果作我食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应丰富、甘甜。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我这基督是生命泉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出活水江河；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面流到永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "解除一切干渴。"
            }
          ]
        }
