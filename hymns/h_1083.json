    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Call upon the name of Jesus, and you will be saved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord Jesus, hallelujah, nevermore enslaved!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may take salvation’s cup by calling on the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation from a host of things does His dear name afford."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! O what a name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord Jesus! Life-giving name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Name victorious, name all-glorious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Name exalted—O what a name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus! Strengthening name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord Jesus! Comforting name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Name to breathe in prayer, calling everywhere,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“O Lord Jesus!” O what a name!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Lord, the Jew, the Greek and everyone’s the same;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is rich unto all men that call upon His name."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord Jesus, what a joy to call and really live;"
