    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the calm of sweet communion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let thy daily work be done;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the peace of soul-outpouring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Care be banished, patience won;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And if earth with its enchantments"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seek thy spirit to enthrall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ere thou listen, ere thou answer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn to Jesus, tell Him all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, as hour by hour glides by thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt blessed guidance know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine own burdens being lightened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst bear another’s woe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst help the weak ones onward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou canst raise up those that fall:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But remember, while thou servest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still tell Jesus, tell Him all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And if weariness creeps o’er thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the day wears to its close,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or if sudden fierce temptation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bring thee face to face with foes;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In thy weakness, in thy peril,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Raise to heaven a truthful call;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strength and calm for every crisis"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, in telling Jesus all."
            }
          ]
