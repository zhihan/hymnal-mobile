      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能登上圣山，国权来执掌？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能住圣所，使神家彰显？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须手洁心清，寻求主面光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "迎接祂进来，居衷作君王。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们抬头，寻求主面光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向荣耀君王，心门全开放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让基督进来，居衷永作王；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让基督进来，居衷永作王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
