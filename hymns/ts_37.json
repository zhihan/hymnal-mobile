    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣城为祂居所，圣民同欢唱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主名何尊大，全地当称扬；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美为祂宝座，欢呼应明朗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂独爱锡安，倾福于其上。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在地方召会，神行动刚强；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享祂作永分，满足又欢畅；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "产业何丰富，我们竟得享！"
