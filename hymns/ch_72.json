{
  "url": "https://www.hymnal.net/cn/hymn/ch/72",
  "title": "主你根源在亘古",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "根 源 在 亘 古，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "在 那"
            },
            {
              "chord": "",
              "text": "无 始"
            },
            {
              "chord": "A7",
              "text": "的 太"
            },
            {
              "chord": "D",
              "text": "初！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 你 就 是 永 远 父，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就 是"
            },
            {
              "chord": "A",
              "text": "自 有"
            },
            {
              "chord": "",
              "text": "永 有"
            },
            {
              "chord": "D",
              "text": "主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽出生人世间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却是与神同永远！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同样的完满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同样的无限！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你乃与神同根源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "早过万有并地天！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有先者比你先，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有前者比你前！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "永不改变永不旧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的年数无尽休！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有久者比你久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有后者比你后！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你与父神无所差，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神一样无可加！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以也是阿拉法，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且也是俄梅嘎！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美你永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们称颂你完全！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赏识你是何丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "希奇你是何无限！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "赞美主",
