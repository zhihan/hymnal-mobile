      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与王同工同作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "工作全归祂不归我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂先用荣耀来搞我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们再把别人搞活。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们能够与王同工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全凭王的能力托着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以责任变成喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告变成赞美颂歌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与王同工同享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高品福音不断传扬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "领成千成万人得救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把国度带到这地上。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界无论甚么酬劳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们连一样也不要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的职业是搞人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到把新妇豫备好。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们一直与王同工，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天搞人，天天发疯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也许冬天还没有到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀的王就要来了。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时我们要围绕祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美快乐，欢呼跳跃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！同掌王权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！直到永远。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
