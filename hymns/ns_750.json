              "text": "Lord, I truly love You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I must"
            },
            {
              "chord": "C",
              "text": "gain— gain"
            },
            {
              "chord": "",
              "text": "only You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your great"
            },
            {
              "chord": "Am",
              "text": "love has"
            },
            {
              "chord": "",
              "text": "reached me, trans"
            },
            {
              "chord": "Bm",
              "text": "forming"
            },
            {
              "chord": "Em",
              "text": "me"
            }
          ]
        },
