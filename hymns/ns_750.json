            },
            {
              "chord": "A",
              "text": "Thy Be"
            },
            {
              "chord": "D",
              "text": "loved."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by"
            },
            {
              "chord": "B",
              "text": "day, unceasing"
            },
            {
              "chord": "Em",
              "text": "ly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweetly"
            },
            {
              "chord": "A",
              "text": "whispering"
            },
            {
              "chord": "",
              "text": "in"
            },
            {
              "chord": "D",
              "text": "me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My whole"
            },
            {
              "chord": "B",
              "text": "heart You"
            },
            {
              "chord": "",
              "text": "melt! My"
            },
            {
              "chord": "Em",
              "text": "spirit"
            },
            {
              "chord": "",
              "text": "with"
            },
            {
              "chord": "G",
              "text": "in"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Re"
            },
            {
              "chord": "C",
              "text": "joices,"
            },
            {
              "chord": "D",
              "text": "Lord, with"
            },
            {
              "chord": "G",
              "text": "Thee!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Love constrains me, draws gradually,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To pour out my all to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my life and future, once held so dear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I yield wholeheartedly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy hands break me faithfully—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The burnt off’ring’s flame burns bright;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only after death does suffering cease;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My soul-life I deny."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Breaking of the outer man frees;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inner life thus is released;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living water, in resurrection life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flows forth abundantly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No more I who live, but Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is Christ who lives in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My humanity now transparently"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expresses only Thee."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Show me, Lord, a vision more clear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw me on, higher, more near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I’d deeply long to see Thee come soon,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And build Thy Body dear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thy glory’s blinded me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I the world no more can see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now unhindered, I must finish the race,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Run swiftly, steadfastly."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "See the prize ahead, very near!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon the Kingdom will appear!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Virgins, quickly rise! Trim your lamps! Behold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here comes Your Bridegroom dear!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Full account the Master makes:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Well done! Well done! Faithful slave!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wedding feast, the Kingdom, New Jerusalem—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal joy and praise"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
