      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Did you know that all the Bible"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is a will, a testament?"
