{
  "url": "https://www.hymnal.net/cn/hymn/ch/721",
  "title": "贫穷软弱悲伤忧愁",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "貧"
            },
            {
              "chord": "C",
              "text": "窮、"
            },
            {
              "chord": "G",
              "text": "軟 弱、"
            },
            {
              "chord": "C",
              "text": "悲 傷、"
            },
            {
              "chord": "G",
              "text": "憂 愁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "親 愛"
            },
            {
              "chord": "C",
              "text": "罪 人"
            },
            {
              "chord": "G",
              "text": "請"
            },
            {
              "chord": "D7",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "來！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶 穌 等 著"
            },
            {
              "chord": "D7",
              "text": "要 施"
            },
            {
              "chord": "G",
              "text": "拯 救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "滿 了 能 力 和 憐"
            },
            {
              "chord": "D",
              "text": "愛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "祂 能"
            },
            {
              "chord": "",
              "text": "救 你！"
            },
            {
              "chord": "C",
              "text": "祂 能"
            },
            {
              "chord": "G",
              "text": "救 你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 肯"
            },
            {
              "chord": "C",
              "text": "救 你，"
            },
            {
              "chord": "G",
              "text": "莫"
            },
            {
              "chord": "D7",
              "text": "疑"
            },
            {
              "chord": "G",
              "text": "猜。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要欢迎，来罢，放心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂不弃绝任何人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实在懊悔，实在相信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就必定能蒙恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不用代价！不用代价！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就可进入得救门。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "莫让良心使你徘徊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或想怎样才配来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已‘配来’，若你理会："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是需要祂的爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无别条件！无别条件！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩门是为罪人开。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你心烦闷，你心悒怏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "疲倦、痛苦、常失败；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果你要等到改良，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就永远不会来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣钉死，耶稣钉死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是为罪人赎罪债。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请你想起客西马尼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主如何流血汗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请你听祂在髑髅地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如何临死大声喊："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘已经成了！’‘已经成了！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪人你今能无感？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的流血已经满足"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你神公义的要求；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应当信服，完全信服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪过就都得免宥；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有耶稣，惟有耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能作罪人的朋友。"
            }
          ]
        }
      ]
    }
  ],
