{
  "url": "https://www.hymnal.net/cn/hymn/ch/177",
  "title": "哦主这是何等神迹",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "这 是 何"
            },
            {
              "chord": "G",
              "text": "等 神"
            },
            {
              "chord": "C",
              "text": "迹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 我 竟 然 联"
            },
            {
              "chord": "F",
              "text": "合 为"
            },
            {
              "chord": "G",
              "text": "一！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 在 你 内， 你"
            },
            {
              "chord": "D7",
              "text": "在 我"
            },
            {
              "chord": "G7",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真"
            },
            {
              "chord": "C",
              "text": "是 希"
            },
            {
              "chord": "F",
              "text": "奇， 真"
            },
            {
              "chord": "G",
              "text": "是"
            },
            {
              "chord": "G7",
              "text": "奥"
            },
            {
              "chord": "C",
              "text": "秘！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为使我能有分于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你竟为我舍了身体；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并为使我脱离罪孽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也为我流了宝血。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你且复活化身圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入我灵作我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我时常将你接领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受你的一切丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们面对桌上表记，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "思念你的可爱自己！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一面感激你的心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一面重温你的经历。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着吃饼，借着喝杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再来享受你的甘美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里吸取，灵里接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里饱尝生命珍馐。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "深愿如此吃你、喝你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用灵接受你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全人被你充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你得到真正记念！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "赞美主",
