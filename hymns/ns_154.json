              "text": "broad, high,"
            },
            {
              "chord": "",
              "text": "and"
            },
            {
              "chord": "D",
              "text": "deep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "In"
            },
            {
              "chord": "G",
              "text": "deed be"
            },
            {
              "chord": "Am",
              "text": "yond"
            },
            {
              "chord": "D7",
              "text": "mea"
            },
            {
              "chord": "G",
              "text": "sure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Else"
            },
            {
              "chord": "G",
              "text": "how could"
            },
            {
              "chord": "C",
              "text": "such a"
            },
            {
              "chord": "A7",
              "text": "sinner"
            },
            {
              "chord": "",
              "text": "as"
            },
            {
              "chord": "D7",
              "text": "me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be with"
            },
            {
              "chord": "G",
              "text": "boun"
            },
            {
              "chord": "C",
              "text": "tiful"
            },
            {
              "chord": "Am",
              "text": "grace"
            },
            {
              "chord": "D7",
              "text": "fa"
            },
            {
              "chord": "G",
              "text": "vored."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord paid a price so great,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To buy me back to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now willing I’m the cross to bear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And follow Him to the end."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I now have forsaken all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In order Christ to gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or life, or death, unworthy a thought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not even one backward glance!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Loved ones, desires, wealth and fame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To me what good are they?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord for me poor and woe became,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him I’d be poor today."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I love my Savior Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I only long for His “Yes”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him no ease can comfort hold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All gains a loss became."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You are my true comfort,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My gracious Lord Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whom but You have I in heaven?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What else I love on earth?"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Suffer, opposed, tossed around,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hence I will all disregard;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only I’d ask my Lord with Your love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit, soul, and body surround."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, I now beseech You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Guide me in grace onward;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stand by and strengthen me all way through,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To pass this dark, evil world."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Satan, the world, and the flesh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oft’n tempt and humiliate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If You don’t add me with more strength"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I may Your name disgrace!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now time is running short,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set me free, O Lord, I pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once You return, I’ll sing with joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Amen!"
            }
          ]
        }
      ]
    }
  ],
