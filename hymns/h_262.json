              "text": "All the evil passions slay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, and every corner fill."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, oh Lord, Great Spirit, come!"
