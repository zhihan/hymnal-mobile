{
  "url": "https://www.hymnal.net/cn/hymn/ch/468",
  "title": "我若稍微偏离正路",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 若"
            },
            {
              "chord": "",
              "text": "稍"
            },
            {
              "chord": "C",
              "text": "微 偏"
            },
            {
              "chord": "G",
              "text": "离 正"
            },
            {
              "chord": "C",
              "text": "路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "要 立"
            },
            {
              "chord": "",
              "text": "刻 舒"
            },
            {
              "chord": "D",
              "text": "服；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但"
            },
            {
              "chord": "G",
              "text": "我 记"
            },
            {
              "chord": "C",
              "text": "念 我"
            },
            {
              "chord": "G",
              "text": "主 基"
            },
            {
              "chord": "D",
              "text": "督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "G",
              "text": "何 忠"
            },
            {
              "chord": "D7",
              "text": "心 受"
            },
            {
              "chord": "G",
              "text": "苦。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今已经撇弃世界，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有关系都解；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然道路越走越窄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我在此是客。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "管他世人怒目白眼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我只求主笑脸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "群众虽然喜欢外貌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我要主的‘好。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我心所望不是伟大，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是今生通达；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿现在卑微事主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日得祂称许。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今每日举目细望"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "审判台前亮光；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我所有生活、工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那日都能耐火。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让你们去得著名声、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "富足、荣耀、友朋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你们去得着成功、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美、从者、兴隆。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但我只愿孤单、贫穷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此不求亨通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心切望忠诚跟从"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主到了路终。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因我知道，主在此世"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过得着一死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以现在我无他望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只望因祂失丧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的荣耀还在将来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今日只得忍耐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我决不肯先我的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此世界得福。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那日我要得着冠冕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主要拭我泪眼！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今日主既仍旧迟延，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要忠心进前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
