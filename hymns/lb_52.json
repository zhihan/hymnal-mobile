      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, take my life, I present it to You!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I had a thousand, I’d pour all on You!"
