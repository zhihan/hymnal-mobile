      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love constrains me to give my all to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I can’t help it; my heart is drawn to You."
