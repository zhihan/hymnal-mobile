    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, keep my love burning brightly for You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A love never dwindling always hot for You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A love, shining brighter all the way for You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A love, so fresh like the day I first touched You."
            }
          ]
        }
