    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The eve of all creation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He mused on His delight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And pondered every feature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Well-pleasing in His sight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Creation sprang to being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But deep in Him did hide"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A heart of depth unfathomed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fixed on a glorious Bride."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus His will was ’stablished"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His counterpart to gain:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This blessed, firm intention,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternally the same."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though sin should e’en beguile man,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then mock his helpless state,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He never could forsake her,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His yearning ne’er abate."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then mercy richly flourished,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And love was, oh, so vast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As graciously He sought her"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With wisdom unsurpassed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love He gave to win her"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God only comprehends!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His life laid down, an offering"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose fragrance yet ascends."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And now in resurrection"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To her He draws most near,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with untold affection"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In glory does appear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As she beholds her Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glory floods her heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til she, His Bride, is raptured,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His longed-for counterpart."
            }
          ]
        }
      ]
