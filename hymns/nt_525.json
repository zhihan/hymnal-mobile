    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how weary were the years"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ere Thy form to me was known;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how gloomy were the fears"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I seemed to be alone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I despaired the storm to brave"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thy footprints touched the wave."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thy presence on the deep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calmed the pulses of the sea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the waters sank to sleep"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the rest of seeing Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my once rebellious will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heard the mandate, Peace, be still!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Thy will and mine are one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heart in heart, and hand in hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the clouds have touched the sun,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the ships have reached the land;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy love has said to me,"
            }
          ]
        },
        {
