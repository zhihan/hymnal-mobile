    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s choice: the pearl of great value!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What is my choice? I will stand with the Lord!"
