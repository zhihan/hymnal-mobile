        {
          "segments": [
            {
              "chord": "",
              "text": "I choose, the church of great value!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I will make this choice, to give all I have for the church!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
