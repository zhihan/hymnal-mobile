  "title": "那日如在眼前",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "必"
            },
            {
              "chord": "A7",
              "text": "快 顯"
            },
            {
              "chord": "D",
              "text": "現，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那 日 如 在"
            },
            {
              "chord": "A7",
              "text": "眼"
            },
            {
              "chord": "D",
              "text": "前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 所 慕 惟"
            },
            {
              "chord": "G",
              "text": "你 \"同"
            },
            {
              "chord": "A7",
              "text": "在\"！"
            },
            {
              "chord": "D",
              "text": "我 主、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 命、 我"
            },
            {
              "chord": "A",
              "text": "愛， 你"
            },
            {
              "chord": "",
              "text": "外"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "無"
            },
            {
              "chord": "A7",
              "text": "可 替"
            },
            {
              "chord": "D",
              "text": "代， 良"
            },
            {
              "chord": "",
              "text": "人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶"
            },
            {
              "chord": "G",
              "text": "穌， 願"
            },
            {
              "chord": "A",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "快"
            },
            {
              "chord": "D",
              "text": "來！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "被提时刻临近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "儆醒听你声音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切盼与你荣中相见。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟当你显荣身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在那婚娶之晨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才识你爱超绝无限。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "时日飞逝如箭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久要见你面─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿们，我主，愿你快回！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只盼早日见你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且永远偕你-"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们全心别无所归。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是的，再过片时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新郎不再延迟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就要迎娶所爱新妇。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祈求终变感赞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "渴望尽成眼见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也必心满意足。"
            }
          ]
        }
      ]
