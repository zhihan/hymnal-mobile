          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Spirit’s dealing, fully grown, he reigned;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er the earth, through Joseph, ruling pow’r obtained."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
