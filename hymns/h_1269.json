          "segments": [
            {
              "chord": "",
              "text": "Still he needed Isaac to fulfill God’s plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Lord God Jehovah called a corporate man,"
