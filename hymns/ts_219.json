{
  "url": "https://www.hymnal.net/cn/hymn/ts/219",
  "title": "活水涌流",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "活水涌流，（涌流！涌流！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命水涌流，（涌流！涌流！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满带神生命，（生命！生命！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的供应，（供应！供应！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我们成形，（成形！成形！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为祂荣形，（荣形！荣形！）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流成祂模样，神和人"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都在此得着满足。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命何丰富，喜乐何满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙甘甜，越过越富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主是何深厚，永不能测透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却流经我身给我享受。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受，享受不尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成长，成长不停，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出宝石、精金，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为神居所荣耀见证。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    }
  ],
  "metadata": {
    "category": "享受基督",
    "time": "3/4",
    "hymn_code": "13555533113555544",
    "midi_tune_url": "https://www.hymnal.net/Hymns/ChineseTS/midi/tunes/ts0219_tune.midi"
  },
  "raw_sections": [
    "活水涌流，（涌流！涌流！）",
    "生命水涌流，（涌流！涌流！）",
    "满带神生命，（生命！生命！）",
    "生命的供应，（供应！供应！）",
    "使我们成形，（成形！成形！）",
    "成为祂荣形，（荣形！荣形！）",
    "流成祂模样，神和人",
    "都在此得着满足。",
    "生命何丰富，喜乐何满足，",
    "奇妙甘甜，越过越富，",
    "主是何深厚，永不能测透，",
    "却流经我身给我享受。",
    "享受，享受不尽，",
    "成长，成长不停，",
    "流出宝石、精金，",
    "成为神居所荣耀见证。"
  ]
}