    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, come into Thy garden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, Beloved, come and eat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freely for Thy satisfaction"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy fruit, abundant, sweet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Yea,” Thou answerest, “I am eating"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Honeycomb with honey pure.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All sweet spices from Thy garden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doth Thy satisfaction, Lord, secure."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All the produce of the garden"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is with resurrection filled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Lord may have a city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fruits of resurrection build."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the garden to the city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Growth transformed to precious stone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is thus expressed, reflected—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in all His glory fully shown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the city, fair and comely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the dawn, triumphantly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is an army strong and mighty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Marching forth in victory."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo, the city and the army—"
            }
          ]
        },
        {
