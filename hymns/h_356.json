  "title": "Thou Magnet of my soul",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Thou Magnet"
            },
            {
              "chord": "G",
              "text": "of my"
            },
            {
              "chord": "D",
              "text": "soul!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me come"
            },
            {
              "chord": "E7",
              "text": "nearer,"
            },
            {
              "chord": "A7",
              "text": "till"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "The life"
            },
            {
              "chord": "",
              "text": "of self pul"
            },
            {
              "chord": "G",
              "text": "sates no"
            },
            {
              "chord": "",
              "text": "more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But"
            },
            {
              "chord": "D",
              "text": "is for"
            },
            {
              "chord": "A7",
              "text": "ever"
            },
            {
              "chord": "D",
              "text": "still."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Sunshine of my heart!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill Thou each crevice there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And let Thy garden yield to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A fragrance sweet and rare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Ransomer from death!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Possess Thy ransomed one:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Appropriate to Thine Own use"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The spoil that Thou hast won."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Lord of Life and Light!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I bow beneath Thy sway,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And count it holy privilege"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precepts to obey."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Gift unspeakable!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Straight from God’s heart of love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I break my heart to give Thee room"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus Thy sweetness prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
