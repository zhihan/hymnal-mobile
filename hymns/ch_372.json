{
  "url": "https://www.hymnal.net/cn/hymn/ch/372",
  "title": "基督是神的中心",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "基 督"
            },
            {
              "chord": "A",
              "text": "是 神"
            },
            {
              "chord": "A7",
              "text": "的 中"
            },
            {
              "chord": "D",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 也"
            },
            {
              "chord": "G",
              "text": "是 神"
            },
            {
              "chord": "D",
              "text": "的 普"
            },
            {
              "chord": "A7",
              "text": "及；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 从"
            },
            {
              "chord": "A",
              "text": "永 远"
            },
            {
              "chord": "A7",
              "text": "到 永"
            },
            {
              "chord": "D",
              "text": "远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是 神"
            },
            {
              "chord": "G",
              "text": "心 爱"
            },
            {
              "chord": "A",
              "text": "与"
            },
            {
              "chord": "A7",
              "text": "欢"
            },
            {
              "chord": "D",
              "text": "喜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督是神的化身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的丰满住祂里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的尊高与神性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人能与祂比拟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神所计画是为祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要祂充满万有中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地宇宙的一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是为祂得尊荣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切创造全为祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有借着祂而有；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有也靠祂而立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是中心并圆周。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是救赎的一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有借祂得复交；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂有效的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有得与神和好。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是一切的元始，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是召会永活头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会生命及内容，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从死首生的元首。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是神国的君王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "执掌所有的权柄；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂荣耀来管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地万有全从命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在新天新地里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要作万有的中心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着神性、为着人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到永远无穷尽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的心意是要祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能在万有居首位；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这一万有的基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今竟作我美味！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
