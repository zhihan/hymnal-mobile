    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me show forth Thy beauty, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like sunshine on the hills;"
            }
          ]
