    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We have received Christ the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through faith and not our merit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Having begun by the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We learn to live by faith."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the sons of the living God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoy the blessings of our Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace to our spirit He doth afford,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From our self-effort freed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It pleases God to rescue us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of this present evil age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to reveal His Son in us—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Most peerless One of all!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh what a joy! Christ now lives in us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer I—how glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s daily growing within us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till He is formed in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We live and walk by the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoy the fruit of the Spirit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him our whole lives we commit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All else is vanity."
            }
          ]
        }
      ],
