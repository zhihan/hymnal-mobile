{
  "url": "https://www.hymnal.net/en/hymn/ns/494",
  "title": "This Opportunity",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, by Your mercy, I would take"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This opportunity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To let You live Yourself in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And let You, Lord, gain me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, save me from the past,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And save me from the future;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yesterday is over,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tomorrow may not be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I only have this day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I only have this moment."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And I would hope that You would take"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This opportunity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To go as far as possible,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As possible in me."
            }
          ]
        }
      ],
