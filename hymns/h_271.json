    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we know the Spirit in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But of life Thy Spirit is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the riches of Thy fulness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may share thru what He is."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet we still require Thy Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the power from on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That for all Thy work and service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may be equipped thereby."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, baptize us with Thy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clothe us with Thy pow’r of might;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With this “mantle” of Thy power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may then the battle fight."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thy wind now blow upon us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Giving us the tongues of fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That, as witnesses anointed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll fulfill Thy heart’s desire."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With the power of Thy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still we need the gifts to share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That as members we may function"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy testimony bear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy Spirit’s full outpouring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, impart the gifts we need,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the building of Thy Body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy blessing might proceed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy glory and Thy kingdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May Thou hear Thy Body’s cry!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now fulfill Thy holy purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our hunger satisfy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we all partake Thy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him apply in many ways;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His infilling, His outpouring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His gifts to share always."
            }
          ]
        }
      ]
