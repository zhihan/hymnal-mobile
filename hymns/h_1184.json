    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit hear His trumpet voice;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must be turned to see His choice—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The seven lampstands golden fair;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son of Man is walking there."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The great high priestly robe He wears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For every church He fully cares:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He trims the lamp, the oil supplies;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He makes them burn, flames in His eyes."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A golden girdle on His breast—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His work is done, and from His rest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He unto all the churches pours"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself in love, the treasure store."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His head, His hair is white as wool—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ancient One with youth is full."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His face is shining as the sun"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To burn and lighten every one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, when this living One we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll fall as dead, we’ll finished be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But then the Lord His comfort gives—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He once was dead, but now He lives."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let every church just love Him more"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His riches then He will outpour."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All other loves now lay aside;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let’s take this Jesus, none beside."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
