            },
            {
              "chord": "",
              "text": "此 让 主 安 家， 我 全"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人 得 变 化─"
            },
            {
              "chord": "C",
              "text": "对"
            },
            {
              "chord": "G",
              "text": "主 话"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "要 说"
            },
            {
              "chord": "",
              "text": "\"阿"
            },
            {
              "chord": "G",
              "text": "们\"。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神自己在我里成就我所不能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我对主话说\"阿们\"；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这改变何真实，众人皆能印证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我对主话说\"阿们\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我流荡得止息，永不再走迷途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我对主话说\"阿们\"；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "老爱好、旧思虑不觉间尽消除，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我对主话说\"阿们\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凭信心过生活，我已寻得秘诀："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要对主话说\"阿们\"；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主于我既真实又宝贵，胜一切─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要对主话说\"阿们\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱弟兄，无虚假，相调中，益亲热，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我对主话说\"阿们\"；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为建造主居所，与众圣相结合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我对主话说\"阿们\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的主，我的爱，惟愿你快显现─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你话我要说\"阿们\"；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我朝夕所思慕是见你面对面─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你话我要说\"阿们\"。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "对你话我要说\"阿们\"，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你话我要说\"阿们\"。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你说，\"我必快来！\"我全心说\"阿们\"；"
            }
          ]
        },
