{
  "url": "https://www.hymnal.net/en/hymn/h/851",
  "title": "How lovely is Thy dwelling place",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "How lovely"
            },
            {
              "chord": "",
              "text": "is Thy"
            },
            {
              "chord": "A",
              "text": "dwelling"
            },
            {
              "chord": "D",
              "text": "place!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within Thy courts I"
            },
            {
              "chord": "G",
              "text": "long to"
            },
            {
              "chord": "A",
              "text": "be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy presence,"
            },
            {
              "chord": "D",
              "text": "Lord, my"
            },
            {
              "chord": "",
              "text": "spirit"
            },
            {
              "chord": "A",
              "text": "craves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For"
            },
            {
              "chord": "D",
              "text": "this my"
            },
            {
              "chord": "",
              "text": "heart cries"
            },
            {
              "chord": "A",
              "text": "out to"
            },
            {
              "chord": "D",
              "text": "Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thy burnt-offering altar, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And at Thine incense altar blest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even the sparrow finds a home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And swallow there prepares her nest."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Men, as the sparrow, frail and small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When living in Thy house find rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Relying on the altar’s blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying there the incense blest."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How blessed are those men indeed!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trusting in Thee they are made strong;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highways to Zion in their hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The way they care not, rough or long."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Passing the weeping valley they"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make it a place of springing wells;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The rain with blessings covers it"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the way God’s mercy tells."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From strength to strength they go, and all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the Lord in Zion meet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus ever seeking Thine own self,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They need Thy care and grace replete."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Better a day within Thy courts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than days a thousand I would tell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’d rather at Thy threshold stand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than in the wicked’s tents to dwell."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art a sun, Thou art a shield,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou grace and glory wilt supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy presence and Thy very self"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My need in fulness satisfy."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not one good thing wilt Thou withhold"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From those who walk in uprightness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bless’d is the man that trusts in Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With grace and glory measureless."
            }
          ]
        }
      ]
    }
  ],
