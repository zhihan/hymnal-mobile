      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "因 著"
            },
            {
              "chord": "",
              "text": "你 將 我 吸 引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 纔"
            },
            {
              "chord": "Bm",
              "text": "能 跟"
            },
            {
              "chord": "",
              "text": "隨 緊"
            },
            {
              "chord": "A",
              "text": "緊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "知 你"
            },
            {
              "chord": "D",
              "text": "是 包"
            },
            {
              "chord": "",
              "text": "容 無"
            },
            {
              "chord": "G",
              "text": "限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 一"
            },
            {
              "chord": "D",
              "text": "生 經"
            },
            {
              "chord": "A7",
              "text": "歷 不"
            },
