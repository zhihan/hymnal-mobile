      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Work, for the Day is coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Darkness will soon be gone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then o’er the night of weeping"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day without end shall dawn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What now we sow in sadness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we shall reap in joy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hope will be changed to gladness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise be our blest employ."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Work, for the Day is coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made for the saints of light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Off with the garments dreary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On with the armor bright:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon will the strife be ended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon all our toils below;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to the dark we’re tending,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to the Day we go."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Work, for the Lord is coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Children of light are we;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Jesus’ bright appearing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Powers of darkness flee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Out of the mist, at His bidding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Souls like the dew are born:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er all the East are spreading"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tints of the rosy morn."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Work, then, the Day is coming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No time for sighing now;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prize for the race awaits thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wreaths for the victor’s brow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now morning Light is breaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon will the Day appear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Night shades appall no longer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, our Lord, is near."
            }
          ]
        }
      ]
