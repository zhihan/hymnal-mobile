  "title": "救主基督已经高升",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "救 主"
            },
            {
              "chord": "",
              "text": "基 督 已 經 高 升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "坐 在"
            },
            {
              "chord": "G",
              "text": "諸 天"
            },
            {
              "chord": "D",
              "text": "的 上"
            },
            {
              "chord": "G",
              "text": "面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "從 祂 父 神 也 已 得 著"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "尊 貴、"
            },
            {
              "chord": "",
              "text": "榮 耀 為 冠"
            },
            {
              "chord": "D",
              "text": "冕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 要 祂 作"
            },
            {
              "chord": "G",
              "text": "萬 有"
            },
            {
              "chord": "",
              "text": "元 首，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "使 祂"
            },
            {
              "chord": "",
              "text": "尊 高"
            },
            {
              "chord": "D7",
              "text": "得 彰"
            },
            {
              "chord": "G",
              "text": "顯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从这升到神前基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵已经浇下来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浇在祂的身体上面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给祂肢体都穿戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使那在天万有之主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂召会得敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督借着成为肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神带到人里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂也借着死而复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将人带进神中间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与人的完全调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面得成全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今已升高天之上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "登上荣耀的宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万主之主，万王之王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有主权全得着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着浇下祂的圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已将这事证确凿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借将祂灵浇灌下来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在召会又降临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂这位圣灵里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给全召会来施浸；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此完成的这灵浸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有信徒都有分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，已经完成，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一次永远的完成！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，此浸我承，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大小信徒都得承！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已将祂所有肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "早都浸在祂的灵！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
