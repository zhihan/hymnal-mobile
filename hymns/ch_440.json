              "chord": "",
              "text": "你同基督要升天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隐藏之光要照远方，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每一圣徒都像太阳。"
            }
          ]
        }
      ],
