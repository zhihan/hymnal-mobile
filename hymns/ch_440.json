      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "他们里面却有神的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主的话语已将他们重生；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们已被神圣爱火所焚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为属新耶路撒冷的人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们都是光中圣徒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常将甜美诗辞歌赋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彼此颂扬最高之神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发出深处最妙之音。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "他们行在地上，住在天上；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无力，却能暗中将地执掌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为难，深处却有神赐平安；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "贫穷，却有万有效力成全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽被打倒，不至死亡，"
