    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Long years have passed and few have heard"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Jesus Christ has bled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That they might feed on Him who died"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be that Living Bread."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gods of stone and wood they cry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet they are never fed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For they have been omitted"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the breaking of the Bread."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I would give them the Bread of Life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Living Water too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart cries out, “Oh, here am I,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ready, Thy will to do.”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Great God, who gave Thine only Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help us, now Spirit-led,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To tell the story of Thy love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To those who ask for bread."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then gladly will we go or send,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till this blest news has spread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And they have been included"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the breaking of the Bread."
            }
          ]
        }
      ]
    },
