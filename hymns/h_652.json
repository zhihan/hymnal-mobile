          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be of good cheer; has He not said,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“I will be with you, fear no ill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis I, ’tis I, be not afraid“?"
            }
          ]
        }
      ],
