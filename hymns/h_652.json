    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O anxious soul, lay down thy load,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, hear His voice, He speaks to thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Be still and know that I am God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And cast thy every care on Me.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Be still, O troubled soul, be still;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fear not, thy Father’s arms enfold thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take up thy cross, lay down thy will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be silent unto God, and let Him mold thee."
            }
          ]
        }
      ],
      "type": "chorus"
