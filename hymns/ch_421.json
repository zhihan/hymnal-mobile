    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无你，我就无法想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这路何等的长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是疲倦身不强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叹息代替诗章；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我怎可以能无你？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我并不能识路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你识路直到底，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不肯让我迷途。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无你，我就无法想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣，亲爱救主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是我眼无印象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仍亲近无误；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等孤单何等痛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这生疏人地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若无甘甜的交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若无你的安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无你，我就无法想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人能够认识"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵奇深的意向，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将它需要解释；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心秘密的角落，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人能够进入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来慰、来静并来托，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只有你能，我主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无你，我就无法想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "年日已经不多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是须与人同样"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "孤独渡河而过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你永远不离开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不管浪有几多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我知你仍要施爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并低声说：‘是我。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
