    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In darkness once I groped,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A person with no hope."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But light in darkness shined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart enlightened."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You came to me as Light"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shattered all my night."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your glory, what a sight!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You made me, Lord, so bright."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To You my heart was drawn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It wasn’t on my own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your beauty made me turn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And caused my heart to burn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You touched my hardened heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And softened every part."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I saw Your shining face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now nothing can erase."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I couldn’t, Lord, believe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, Lord, You still appeared."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life in me conceived,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, I now believe."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You called not being as being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In me conceiving."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your life transfusing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m now reacting."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God of glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re now my story."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear One, I can’t refuse!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By You, I’ve been transfused."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Like father Abraham,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To You, dear Lord, he ran."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your glory has infused,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Lord, we can’t refuse."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You came to fallen man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As, Lord, the Great I Am."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us dispensing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blessing to mankind."
            }
          ]
        }
      ],
