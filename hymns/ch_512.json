    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父是知道，何等保证！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "沿途试炼有何害？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纵然它们随我一生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不容易忍耐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主已在望，莫大鼓励，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我安息不动摇！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的同在何其甜蜜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我天父知道。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我父每日都知道我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看守我在爱里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "艰难来袭，祂来助我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我往上看。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久旅程到达止境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今生就要告终了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我将如何进入光明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这事父知道。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时我在主的面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲眼看见祂慈颜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满心欢喜，俯伏朝见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢祂恩典。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂甜美同在之前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再无今生的搅扰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的应许全得应验，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这事父知道。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
