    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit, Stream by Thee, the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is opened to us crystal pure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forth flowing from the heavenly throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To waiting hearts and spirits poor;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Athirst and weary do I sink"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beside Thy waters, there to drink."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit turns to Thee and clings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All else forsaking, unto Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forgetting all created things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Remembering only “God in me.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy living Stream, Thy gracious Rain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None wait for these, and wait in vain."
            }
