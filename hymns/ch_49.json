{
  "url": "https://www.hymnal.net/cn/hymn/ch/49",
  "title": "父阿我们在你面前",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父 阿，"
            },
            {
              "chord": "",
              "text": "我 們 在 你 面"
            },
            {
              "chord": "C",
              "text": "前 拜"
            },
            {
              "chord": "G",
              "text": "禮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊 敬 鄭"
            },
            {
              "chord": "D",
              "text": "重；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "現 在 我"
            },
            {
              "chord": "G",
              "text": "們 這"
            },
            {
              "chord": "",
              "text": "些 兒"
            },
            {
              "chord": "C",
              "text": "女 聚"
            },
            {
              "chord": "G",
              "text": "集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "D",
              "text": "要 稱"
            },
            {
              "chord": "G",
              "text": "頌："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "奇 恩"
            },
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "A",
              "text": "何 帶"
            },
            {
              "chord": "A7",
              "text": "領 我"
            },
            {
              "chord": "",
              "text": "們 回"
            },
            {
              "chord": "D7",
              "text": "家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "與 你"
            },
            {
              "chord": "",
              "text": "兒"
            },
            {
              "chord": "C",
              "text": "子 一"
            },
            {
              "chord": "",
              "text": "同 親"
            },
            {
              "chord": "D",
              "text": "近 阿"
            },
            {
              "chord": "G",
              "text": "爸！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "知爱的人都知这里的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的深；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从祂身上你爱已经布开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我父我神！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今祂在你的面前带同"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有称颂你爱的人称颂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂领诗歌，你耳何等乐听祂的颂称；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你岂不也是一样爱聆"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们和声；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你心爱祂远在创世之前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也定规我们作祂同伴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
  "metadata": {
    "category": "敬拜父",
