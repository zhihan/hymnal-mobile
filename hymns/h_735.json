          "segments": [
            {
              "chord": "G",
              "text": "The law"
            },
            {
              "chord": "",
              "text": "of letters"
            },
            {
              "chord": "D",
              "text": "God de"
            },
            {
              "chord": "G",
              "text": "fines,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is His"
            },
            {
              "chord": "D",
              "text": "testi"
            },
            {
              "chord": "A7",
              "text": "mony"
            },
            {
              "chord": "D",
              "text": "true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It"
            },
            {
              "chord": "C",
              "text": "shows how"
            },
            {
              "chord": "G",
              "text": "loving,"
            },
            {
              "chord": "",
              "text": "holy, just,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is"
            },
            {
              "chord": "C",
              "text": "God, with"
            },
            {
              "chord": "G",
              "text": "whom we"
            },
            {
              "chord": "D",
              "text": "have to"
            },
            {
              "chord": "G",
              "text": "do."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "According to His nature shown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's law requires that we must live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He our souls may justify"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And unto us His blessing give."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law can never give us life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor any strength to us supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But doth its full demands exact"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all our weakness show thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It was not for God's final plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But for man's sin was introduced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man by breaking it might know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Himself, his sin to him adduced."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis by the law all mouths are stopped"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all are shut up under sin;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It brings us to the Christ of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God may bless us all in Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law is but a type of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who God's full testimony is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who fully has expressed His love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His holiness and righteousness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis Christ, God's testimony real,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who doth with life divine supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That with the law's demands we may"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be more than able to comply."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God's living testimony, He;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By whom God's potent life we share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Him we're dead unto the law,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in His Spirit fruit we bear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
