    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While here below I stay, indeed I know—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You will return one day; I must all things forgo."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I set my all on You—You who are true;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My life is set towards You, e’en the things I’ll do."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I just see no hope on this dull, dark earth;"
