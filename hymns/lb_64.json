    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling is opposed as it was then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the camp of religion."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But His witnesses kept calling Him:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They weren’t stopped by opposition."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must be like Stephen then;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus was his everything."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even while they martyred him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He was calling on the highest name."
            }
          ]
        }
      ],
