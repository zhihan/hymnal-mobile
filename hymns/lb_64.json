            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God outpoured His Spirit on all flesh"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the application"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of His rich salvation to all men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But we must call upon Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling brings the Jubilee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus comes to you and me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling sets the captives free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re enjoying God in liberty."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
