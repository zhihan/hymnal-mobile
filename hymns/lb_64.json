{
  "url": "https://www.hymnal.net/en/hymn/lb/64",
  "title": "It is God’s commandment and desire",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is God’s commandment and desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His people call on Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And it is the joyful way to drink"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the fount of God’s salvation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, this is a joyful way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To delight oneself in Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God becomes our enjoyment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just by calling on His precious name."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling Him is not a new practice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the New Testament."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It began way back in Genesis,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And throughout the Old Testament."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enosh, Job, and Abraham—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All these ones called on Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Moses, Samuel, and David—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And many others did the same."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is such a jubilant practice"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Joel prophesied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And this was fulfilled at Pentecost,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So Peter testified:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All who call upon the name"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the Lord shall be saved."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All who call upon the name"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the Lord Jesus shall be saved."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
