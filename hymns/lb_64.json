    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling was a major practice then"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the early Christians."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It became a popular sign"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Christ’s believers then."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, this is a joyful way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To delight oneself in Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God becomes enjoyable"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just by calling on His precious name."
            }
          ]
        }
      ],
