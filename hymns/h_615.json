          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to thy fellow men;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to the creatures of His hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to the glorious One."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Take thy first walk with God!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Him go forth with thee;"
            }
          ]
        },
        {
          "segments": [
