      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Sing a new song at morn!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Join the glad woods and hills;"
            }
          ]
        },
        {
          "segments": [
