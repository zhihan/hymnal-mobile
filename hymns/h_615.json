              "chord": "",
              "text": "By stream, or sea, or mountain path,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seek still His company."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
