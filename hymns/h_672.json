    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is Thy perfect love that casts out fear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know the voice that speaks the It is I,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in these well-known words of heavenly cheer"
            }
          ]
