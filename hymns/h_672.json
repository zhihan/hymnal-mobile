      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Name is Love! I hear it from yon Cross;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Name is Love! I read it in yon tomb:"
