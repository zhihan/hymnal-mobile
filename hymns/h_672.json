          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All meaner love is perishable dross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But this shall light me through time’s thickest gloom."
            }
          ]
