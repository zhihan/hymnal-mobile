            },
            {
              "chord": "D",
              "text": "One."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus we all have"
            },
            {
              "chord": "G",
              "text": "been a"
            },
            {
              "chord": "D",
              "text": "nointed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With th'a"
            },
            {
              "chord": "A",
              "text": "nointing"
            },
            {
              "chord": "A7",
              "text": "of the"
            },
            {
              "chord": "D",
              "text": "Son."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in Christ, in the anointing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the anointed ones."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how blessed is this ointment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Poured upon the many sons!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah, the anointing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto us God’s essence brings;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is now abiding in us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And it teaches us all things."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re the Lord’s peculiar treasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purchased by His precious blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has put His seal upon us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are those marked out by God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day we’re under sealing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may His likeness share."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the impress of His Person"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will Jesus’ image bear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we have the pledge, the foretaste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the Christ we soon will see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are longing for the full taste—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, our feast eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God has wrought us for this purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Giving us the earnest here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Guarantee of full enjoyment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of our Lord Himself, so dear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The anointing, seal, and earnest—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our spirit are all three."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such a wondrous, blest deposit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God has given you and me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
