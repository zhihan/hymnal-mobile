      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的儿子，你曾忍受"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讥诮、妒恨与苦害！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀的王，为我愆尤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荆棘冠冕你竟戴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受死为要将我救援，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离罪的锁链："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千千万万的赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵救主，惟你配！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人所堆在你身羞辱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你全无声的忍受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚至忍受死的痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为使救赎得成就。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的降卑令人惊奇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟肯来到受死之地："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千千万万的赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵救主，惟你配！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因着你曾降卑尘埃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因着你死使我生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心中赞美、灵里敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主，全都向你呈。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有忧患你已担当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有祝福我今得享："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这要成为我诗题，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远赞美你不已。"
            }
          ]
        }
      ],
