{
  "url": "https://www.hymnal.net/cn/hymn/ch/175",
  "title": "在此分享这福杯",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "",
              "text": "分 享"
            },
            {
              "chord": "A",
              "text": "這 福"
            },
            {
              "chord": "D",
              "text": "杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎 能 閉 口"
            },
            {
              "chord": "A",
              "text": "不 讚"
            },
            {
              "chord": "D",
              "text": "美？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 為"
            },
            {
              "chord": "A",
              "text": "我 流"
            },
            {
              "chord": "",
              "text": "的 寶"
            },
            {
              "chord": "D",
              "text": "血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "價 值"
            },
            {
              "chord": "A",
              "text": "誰 能"
            },
            {
              "chord": "E",
              "text": "盡 領"
            },
            {
              "chord": "A",
              "text": "會！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦 主， 你 血"
            },
            {
              "chord": "D",
              "text": "何 寶"
            },
            {
              "chord": "",
              "text": "貴！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "我 的"
            },
            {
              "chord": "",
              "text": "問 題 全 應"
            },
            {
              "chord": "G",
              "text": "付；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 你 有 效"
            },
            {
              "chord": "D",
              "text": "的 寶"
            },
            {
              "chord": "",
              "text": "血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "一 切"
            },
            {
              "chord": "D",
              "text": "憂 懼"
            },
            {
              "chord": "A",
              "text": "都 消"
            },
            {
              "chord": "D",
              "text": "除。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借这有效的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新约为我得成立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着这个更美约，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是稳固的根基。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已蒙神救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非凭着金或银，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是凭着你宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是在此我所饮。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为使我罪得洗净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗罪之血你已流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这血为我满足神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切公义的要求。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用你有力洁净血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你将我罪已洗尽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且洗净我良心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我事奉永活神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借你分别的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们都已得成圣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你保守的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣别成为我见证。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你赎罪的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们都已得称义；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你救赎的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我得与神无距离。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借你十架所流血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已与神和好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能以接触神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神平安的相交。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借著有分你的血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得着你生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭你宝血和生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受自由和安宁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在天你所洒的血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我说出更美事；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这血的护庇下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我脱撒但的攻势。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你得胜的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们胜过那仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此对那控告者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就能得胜利。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们借着你的血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与众圣徒同交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你这血遮盖下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵自由无惊恐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们何能用话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说尽你血的故事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们需要那永世，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来说你血的价值。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
