          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the Rock, is riven;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Living water's flowing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But within my heart now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is blocked from going."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I will dig by praying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig the dirt entirely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus release the Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the stream flow freely."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There's no need again that"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the Rock, be riven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But unto the digging"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I should be given."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What I need most deeply"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the Spirit's filling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the living water"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my heart be welling."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig till there is nothing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Left to block the passage;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig until the stream flows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the living message."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Spring up, well, with water;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig Thou, Lord, completely;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig away all barriers"
            }
          ]
        },
        {
          "segments": [
            {
