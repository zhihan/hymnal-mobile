    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how sweet is this assurance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Midst the conflict and the strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Although sorrows past endurance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow me through life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Home in prospect can still cheer me:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, and give me sweet repose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While I feel His presence near me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my Father knows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, He sees and knows me daily,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Watches over me in love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sends me help when foes assail me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bids me look above."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon my journey shall be ended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life is drawing to a close;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I shall then be well attended—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This my Father knows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I shall then with joy behold Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face to face my Savior see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fall with rapture, and adore Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His love to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing more shall then distress me—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the land of sweet repose:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus stands engaged to bless me—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This my Father knows."
            }
          ]
