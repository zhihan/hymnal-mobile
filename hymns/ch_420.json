    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "住在你里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你富我享受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你所是一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得借我流露；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿作你身上常新的枝子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彰显你生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结果永不止。"
            }
          ]
        }
