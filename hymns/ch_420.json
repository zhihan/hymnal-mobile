      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "住在你里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪、己失权能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再无法胜过你内住生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你相结联，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深处互交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵就能管治魂一切活动。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "住在你里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得知你心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸着你同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入你秘密；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐与平安要将我充溢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你话的供应也作我能力。"
            }
          ]
        }
