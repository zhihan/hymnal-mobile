    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian life is God in Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A priceless treasure and our life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We turn, behold, reflect, and see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en as He is, we all shall be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian life, a broken life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life no longer I, but Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Christ our fragrance and our taste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Spirit: holy, pure, and chaste."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian life, a grafted life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is found in our Lord Jesus Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by His cutting on the Tree"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A place was made for you and me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian life, a grafted life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Christ’s desire, and God’s delight;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Organic union with the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We live in Christ in one accord."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian life, a growing life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined to the resurrected Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Spirit grows organically,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be His Body practically."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Christian life, maturing life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Christ in all to be applied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tis not exchanged but mingled in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The richest life with mine does blend."
            }
          ]
        }
      ],
      "type": "chorus"
    }
