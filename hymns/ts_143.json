    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来覆罩！神来与人相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "覆庇、加力又照料！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来覆罩！神恩如云围绕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来安慰和荣耀！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "云中又有烈火不断的闪烁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来焚烧！来焚烧！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪肉体魂生命再无处可躲；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来焚烧！来焚烧！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来焚烧！神圣嫉妒烈火"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "烧遍全人每角落！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来焚烧！神外一切尽脱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天然、旧造都灭没！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "火中发出金银合金显光耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在显耀！在显耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎之神经历宝贵又高超；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在显耀！在显耀！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在显耀！我们今已尝到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羔羊神丰美味道！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在显耀！救赎之神荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彰显于人何奇妙！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "风云、火金的经历将人点活；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多又多！多又多！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿这循环将我重构永不辍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多又多！多又多！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "风吹到！云覆罩！火焚烧！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "金银合金显荣耀！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿与主如此全然相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主荣形得显照！"
            }
          ]
        }
      ],
      "type": "chorus"
    }
