      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I am the Lord’s! Yet teach me all it meaneth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All it involves of love and loyalty,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of holy service, absolute surrender,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And unreserved obedience unto Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I am the Lord’s! Yes; body, soul, and spirit,"
