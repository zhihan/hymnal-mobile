        {
          "segments": [
            {
              "chord": "",
              "text": "I am the Lord’s! It is the glad confession"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wherewith the Bride recalls the happy day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When love’s “I will” accepted Him forever,"
            }
          ]
