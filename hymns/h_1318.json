        {
          "segments": [
            {
              "chord": "",
              "text": "Has prepared His tents of love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He wants His fair Rebekah by His side."
            }
          ]
        }
      ]
    },
