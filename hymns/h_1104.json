            },
            {
              "chord": "D",
              "text": "food."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ"
            },
            {
              "chord": "A",
              "text": "is our"
            },
            {
              "chord": "",
              "text": "peace! Christ"
            },
            {
              "chord": "D",
              "text": "is our"
            },
            {
              "chord": "",
              "text": "peace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "G",
              "text": "praise Thee,"
            },
            {
              "chord": "B7",
              "text": "blessed"
            },
            {
              "chord": "Em",
              "text": "Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our"
            },
            {
              "chord": "A",
              "text": "peace with"
            },
            {
              "chord": "A7",
              "text": "God, our"
            },
            {
              "chord": "D",
              "text": "peace with"
            },
            {
              "chord": "",
              "text": "man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have"
            },
            {
              "chord": "G",
              "text": "fully"
            },
            {
              "chord": "A7",
              "text": "been re"
            },
            {
              "chord": "D",
              "text": "stored."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a peace it gives us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To see the sprinkled blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The blood of our peace offering"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has brought us peace with God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With boldness we're proclaiming—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now hear this, enemy—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Peace by the blood of Jesus!\""
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is our victory."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Based on the burnt oblation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the meal offering too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We now may offer Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As our peace offering true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we eat and drink Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His humanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we may enjoy Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While feasting corporately."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What fellowship, what fellowship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God and man we share!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a joy, O what a feast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all God's people here."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here God enjoys His portion—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis inward, hidden, sweet—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all the priestly family"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May here the wave breast eat."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The offering priest—how precious—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May of the best partake:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gets the right heave shoulder"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And one unleavened cake."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our peace! Christ is our peace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We praise Thee, blessed Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our peace with God, our peace with man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have fully been restored."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How sweet to eat the wave breast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The all-embracing love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Christ in resurrection!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It sets us all above."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What strength to eat the shoulder"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the ascended One"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with the cake be nourished"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To walk as He has done."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With all the cleansed ones feasting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How rich the Christ we eat!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, this is true communion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The only way to meet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We bring our full thanksgiving"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And e'en would make a vow—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're for the Lord's recovery"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As He is for us now."
            }
          ]
        }
      ]
    }
  ],
