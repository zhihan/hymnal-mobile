              "text": "基 督"
            },
            {
              "chord": "",
              "text": "已 經 將 我"
            },
            {
              "chord": "C",
              "text": "釋 放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 也"
            },
            {
              "chord": "D",
