    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿 利"
            },
            {
              "chord": "Am",
              "text": "路 亞！"
            },
            {
              "chord": "D7",
              "text": "榮 耀"
            },
