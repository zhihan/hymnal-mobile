      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在基督里我得释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离今世所有辖制；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前途事业尽都撇弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为祂见证活在灵里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！荣耀释放！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人同工，成祂旨意。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "丰富基督住在灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候我来把祂经历；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每当释放灵中基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能力智慧无不我属。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
