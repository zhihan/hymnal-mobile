              "chord": "",
              "text": "我心是你宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的一生一世，基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要为你生活。"
            }
          ]
        }
