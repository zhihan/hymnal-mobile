              "chord": "",
              "text": "因你为我代死时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给的是你自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从此，我无别的主，"
            }
          ]
        },
        {
          "segments": [
