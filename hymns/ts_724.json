    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是一群有雄心的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出口者的灵在我们里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前不应用，将它束缚关闭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今我们愿意释放这灵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！众人释放这灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有聚会再也不沉寂；"
            }
          ]
