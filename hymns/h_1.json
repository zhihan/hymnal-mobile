      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As we view the vast creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Planned with wondrous skill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So our hearts would move to worship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be still."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But, our God, how great Thy yearning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To have sons who love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Son e’en now to praise Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love to prove!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas Thy thought in revelation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To present to men"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Secrets of Thine own affections,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Theirs to win."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So in Christ, through His redemption"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Vanquished evil powers!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast brought, in new creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worshippers!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory be to God the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to Christ the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory to the Holy Spirit—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever One."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
