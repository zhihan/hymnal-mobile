            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "Outward"
            },
            {
              "chord": "",
              "text": "work God"
            },
            {
              "chord": "E7",
              "text": "never"
            },
            {
              "chord": "A",
              "text": "reckons,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But what's"
            },
            {
              "chord": "D",
              "text": "from the"
            },
            {
              "chord": "E7",
              "text": "inmost"
            },
            {
              "chord": "A",
              "text": "part;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "It is"
            },
            {
              "chord": "D",
              "text": "not to"
            },
            {
              "chord": "",
              "text": "serve in"
            },
            {
              "chord": "G",
              "text": "letter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But life's newness"
            },
            {
              "chord": "A7",
              "text": "to im"
            },
            {
              "chord": "D",
              "text": "part."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just by the outward teachings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by His anointing moved;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just by the outward pattern,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by inward vision proved."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by human rules or rituals,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by heaven’s rule within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by human-made decisions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by guidance giv’n of Him."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not a dead religion serving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in Christ as life to live;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not theology dispensing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But a living Christ to give."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the knowledge of mere doctrine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the message Christ should be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the gifts, the forms, the teachings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But God’s Christ—reality."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not objectively to worship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But to serve Him inwardly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to preach a Christ objective,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Himself subjectively."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not just by the Scripture serving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But in spirit and in life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not by flesh, but by the Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filling, freeing from all strife."
            }
          ]
        }
      ]
    }
  ],
