{
  "url": "https://www.hymnal.net/cn/hymn/ts/436",
  "title": "惟夸荣耀十架",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "基 督"
            },
            {
              "chord": "Bm",
              "text": "所 賜"
            },
            {
              "chord": "A",
              "text": "豐 滿"
            },
            {
              "chord": "D",
              "text": "福 分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "A7",
              "text": "否"
            },
            {
              "chord": "D",
              "text": "渴 慕"
            },
            {
              "chord": "A7",
              "text": "能 得"
            },
            {
              "chord": "D",
              "text": "著？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主 所"
            },
            {
              "chord": "Bm",
              "text": "命 定"
            },
            {
              "chord": "A",
              "text": "得 勝"
            },
            {
              "chord": "D",
              "text": "生 活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祕"
            },
            {
              "chord": "A7",
              "text": "訣"
            },
            {
              "chord": "D",
              "text": "是 否"
            },
            {
              "chord": "A7",
              "text": "已 掌"
            },
            {
              "chord": "D",
              "text": "握？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "答 案 明 示"
            },
            {
              "chord": "G",
              "text": "於 祂"
            },
            {
              "chord": "D",
              "text": "聖 言："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"基 督 是 我"
            },
            {
              "chord": "G",
              "text": "們 生"
            },
            {
              "chord": "A",
              "text": "命；\""
            },
            {
              "chord": "D",
              "text": "只 要"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Bm",
              "text": "向 祂"
            },
            {
              "chord": "A",
              "text": "敞 開"
            },
            {
              "chord": "D",
              "text": "心 懷，"
            },
            {
              "chord": "",
              "text": "憑"
            },
            {
              "chord": "A7",
              "text": "信"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "取 用"
            },
            {
              "chord": "A7",
              "text": "祂 豐"
            },
            {
              "chord": "D",
              "text": "盛。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督受死将你救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且要居衷掌王权；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你里外显祂能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "日复一日时加添。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你不能，在祂都能─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂灵要作工你身；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"不再是我，乃是基督\"─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要见证此深恩。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的丰满住祂里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在祂里得丰盛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来，取用儿子名分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切勿辜负父恩情。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是恩典，绝不迟误，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要赞美来领受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣供备永无不足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭祂而活何饶优。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主我前来，单纯信靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的圣言永不变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信你救赎洗罪有能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "信你得胜、得荣冕。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿你那无穷生命"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带爱从我流不息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "临及暗中无望人群，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引领多人来归依。"
            }
          ]
        }
      ]
    }
  ],
