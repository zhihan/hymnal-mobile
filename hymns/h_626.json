              "text": "Thou dost give Thyself to me."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m ashamed, my Lord, for seeking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self to guard alway;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though Thy love has done its stripping,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet I’ve been compelled this way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, according to Thy pleasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully work on me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heeding not my human feelings,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only do what pleases Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
