          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grateful praises all day long."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast made Thyself more precious"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than all else to me:"
            }
          ]
        },
        {
          "segments": [
