      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "If Thy mind and mine should differ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still pursue Thy way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If Thy pleasure means my sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still my heart shall answer, “Yea!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis my deep desire to please Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I suffer loss;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en though Thy delight and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mean that I endure the cross."
            }
          ]
        }
