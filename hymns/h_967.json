    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art coming, Thou art coming;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall meet Thee on Thy way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall see Thee, we shall know Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall bless Thee, we shall show Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our hearts could never say:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What an anthem that will be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ringing out our love to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pouring out our rapture sweet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Thine own all-glorious feet."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art coming, at Thy Table"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are witnesses for this;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While rememb’ring hearts Thou meetest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In communion clearest, sweetest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earnest of our coming bliss,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Showing not Thy death alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy love exceeding great,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thy coming and Thy throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All for which we long and wait."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the joy to see Thee reigning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee, my own beloved Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every tongue Thy Name confessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worship, honor, glory, blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought to Thee with one accord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thee, my Master and my Friend,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vindicated and enthroned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto earth’s remotest end"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorified, adored, and owned!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
