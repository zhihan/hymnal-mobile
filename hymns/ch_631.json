{
  "url": "https://www.hymnal.net/cn/hymn/ch/631",
  "title": "恩主，在我们尚未散会前",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "恩 主，"
            },
            {
              "chord": "",
              "text": "在 我 們"
            },
            {
              "chord": "A",
              "text": "尚 未"
            },
            {
              "chord": "A7",
              "text": "散 會"
            },
            {
              "chord": "D",
              "text": "前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "為 著 你"
            },
            {
              "chord": "A",
              "text": "榮 耀、"
            },
            {
              "chord": "E",
              "text": "豐 厚"
            },
            {
              "chord": "E7",
              "text": "的 顯"
            },
            {
              "chord": "A",
              "text": "現，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "並 為"
            },
            {
              "chord": "",
              "text": "你 所 賜 新 鮮 的 恩"
            },
            {
              "chord": "A",
              "text": "典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "從"
            },
            {
              "chord": "G",
              "text": "心 中"
            },
            {
              "chord": "",
              "text": "再 向"
            },
            {
              "chord": "A",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "感"
            },
            {
              "chord": "D",
              "text": "讚。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你的恩中，聚会虽将完，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你的同在永远不间断；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那在你灵里维持的能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因爱你必要不停的供给。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你的同在与我们同去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分担我心中一切的罣虑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能时刻享受你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到我有分再一次聚集。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
  "metadata": {
    "category": "聚会",
