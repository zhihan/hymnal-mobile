    "current_key": "F Major",
    "original_key": "D Major",
    "capo": 3,
    "related": [
      {
        "url": "https://www.hymnal.net/en/hymn/h/868",
        "language": "en",
        "category": "h",
        "number": "868",
        "title": "E868"
