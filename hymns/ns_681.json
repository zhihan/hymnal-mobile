{
  "url": "https://www.hymnal.net/en/hymn/ns/681",
  "title": "Just to enjoy Thy word",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Just to"
            },
            {
              "chord": "",
              "text": "en"
            },
            {
              "chord": "G",
              "text": "joy Thy"
            },
            {
              "chord": "D",
              "text": "word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I come to"
            },
            {
              "chord": "E7",
              "text": "Thee, dear"
            },
            {
              "chord": "A7",
              "text": "Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Spirit"
            },
            {
              "chord": "",
              "text": "and life, I"
            },
            {
              "chord": "G",
              "text": "need to"
            },
            {
              "chord": "",
              "text": "gain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through"
            },
            {
              "chord": "D",
              "text": "Thee, O"
            },
            {
              "chord": "A7",
              "text": "living"
            },
            {
              "chord": "D",
              "text": "Word!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Testaments for man—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spoken through men by Spirit borne—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reveal Thy hidden plan."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prophets spoke from of old"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The coming Savior of God’s plan;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now through the Son ‘tis told."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s covenant to share;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s promises made real through faith,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Laid hold of by my prayer."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s God expressed, defined;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit with His Spirit joined,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s grace I’ll surely find."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy constant, written word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingled with prayer, becomes in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine instant, spoken word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy words anticipate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cry out at dawn, and hope in them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On them to ruminate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The living God to see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As hart doth pant for cooling streams,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pant, O God, for Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flooding my path with light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let it pierce through, illuminate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dispel my heart’s dark night."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do make my heart, good ground!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Thy word’s seed take root and grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That from me fruit abound."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou Thyself didst say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man shall not live by bread alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by Thy word each day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Coming as crumbs, so small,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reaching me in my lowest state,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be my all in all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy lips bring words of grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweeter than honey to my mouth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how it cheers always!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I ate the words I found,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And they became the gladness, joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That makes my heart resound!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit’ual food to me—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As guileless milk, then solid food—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto maturity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A two-edged sword to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which divides spirit from the soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My thoughts, intents to see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "16"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Word instructeth me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is God-breathed to make complete"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The man of God in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "17"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s proclaimed Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From sin released, to land returned—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re made God’s family!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "18"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which each day fresh does fall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As heaven’s manna coming down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be our all in all."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "19"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save from fall’s sin and stain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reconstitute with manna pure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy holy people gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "20"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our daily, sure supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eating this manna heavenly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy church we’ll build thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "21"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hold forth the word of life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s luminaries, blameless, shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amidst this world of strife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "22"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With it, go forth to sow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Watering men’s hearts faithfully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God may cause to grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "23"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts with love o’erflow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With one another, Christ we share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Body thus doth grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "24"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Christ’s word richly dwell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak, teach, admonish, sing with grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To saints and God as well."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "25"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The speaking Spirit, hear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Son of Man midst lampstands moves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cares for His churches dear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "26"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy truth doth sanctify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Become our full reality,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And oneness bring thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "27"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be prepared His bride;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re by its washing, cleansing pow’r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made holy, glorified!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "28"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit’s sword receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By means of prayer, petitioning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We victory achieve."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "29"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Richly, in many ways,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till it is our memorial,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout eternal days."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "30"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to enjoy Thy word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Faithful Thy surety;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though heav’n and earth shall pass away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It stands eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "31"
    }
  ],
