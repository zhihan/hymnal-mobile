{
  "url": "https://www.hymnal.net/en/hymn/h/158",
  "title": "Lord, Thy love has sought and found us",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Lord, Thy"
            },
            {
              "chord": "",
              "text": "love has"
            },
            {
              "chord": "C",
              "text": "sought and"
            },
            {
              "chord": "G",
              "text": "found us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wand'ring"
            },
            {
              "chord": "Em",
              "text": "in this"
            },
            {
              "chord": "C",
              "text": "de"
            },
            {
              "chord": "D7",
              "text": "sert"
            },
            {
              "chord": "G",
              "text": "wide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Thou hast"
            },
            {
              "chord": "",
              "text": "thrown Thine"
            },
            {
              "chord": "G",
              "text": "arms around"
            },
            {
              "chord": "D",
              "text": "us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "For us"
            },
            {
              "chord": "D",
              "text": "suffered,"
            },
            {
              "chord": "A",
              "text": "bled, and"
            },
            {
              "chord": "D7",
              "text": "died."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Sing, my"
            },
            {
              "chord": "D",
              "text": "soul! He"
            },
            {
              "chord": "G",
              "text": "lovéd"
            },
            {
              "chord": "D",
              "text": "thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "Jesus"
            },
            {
              "chord": "C",
              "text": "gave Him"
            },
            {
              "chord": "G",
              "text": "self"
            },
            {
              "chord": "D7",
              "text": "for"
            },
            {
              "chord": "G",
              "text": "me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hark! what sounds of bitter weeping"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From yon lonesome garden sweep;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis the Lord His vigil keeping,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While His followers sink in sleep."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ah, my soul, He lovéd thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, He gave Himself for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He is speaking to His Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tasting deep that bitter cup,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet He takes it, willing rather"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our sakes to drink it up."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what love! He lovéd me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gave Himself, my soul, for thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then that closing scene of anguish:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All God’s waves and billows roll"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Over Him, there left to languish"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cross, to save my soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Matchless love! how vast, how free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus gave Himself for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hark again! His cries are waking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Echoes on dark Calvary’s hill;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God, my God, art Thou forsaking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him who always did Thy will?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ah, my soul! it was for thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes! He gave Himself for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we joy, Thy toils are ended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glad Thy suff’ring time is o’er;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thy Father’s throne ascended,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There Thou liv’st, to die no more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, my soul, He lives for thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who gave Himself for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we worship and adore Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy rich, Thy matchless grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfect soon in joy before Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We shall see Thee face to face."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet e’en now our song shall be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus gave Himself for me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
