{
  "url": "https://www.hymnal.net/cn/hymn/ch/475",
  "title": "转眼将耶稣观看",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "暗 中"
            },
            {
              "chord": "",
              "text": "摸 索， 无 一 线"
            },
            {
              "chord": "A",
              "text": "光 明！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何"
            },
            {
              "chord": "D",
              "text": "等 疲"
            },
            {
              "chord": "",
              "text": "乏！"
            },
            {
              "chord": "A7",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "劳"
            },
            {
              "chord": "D",
              "text": "形！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 一 仰 望 基 督 你"
            },
            {
              "chord": "A",
              "text": "的 王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚"
            },
            {
              "chord": "E",
              "text": "么 都"
            },
            {
              "chord": "",
              "text": "必 照 耀 辉"
            },
            {
              "chord": "A7",
              "text": "煌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "转 眼"
            },
            {
              "chord": "A7",
              "text": "将 耶"
            },
            {
              "chord": "",
              "text": "稣"
            },
            {
              "chord": "D",
              "text": "观"
            },
            {
              "chord": "D7",
              "text": "看！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "注"
            },
            {
              "chord": "G",
              "text": "目 仰"
            },
            {
              "chord": "",
              "text": "望 祂 的 荣"
            },
            {
              "chord": "A7",
              "text": "面！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所 有"
            },
            {
              "chord": "D",
              "text": "事 物"
            },
            {
              "chord": "",
              "text": "在 祂 荣"
            },
            {
              "chord": "G",
              "text": "耀 光"
            },
            {
              "chord": "",
              "text": "中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都 要"
            },
            {
              "chord": "D",
              "text": "次 第"
            },
            {
              "chord": "",
              "text": "变"
            },
            {
              "chord": "A7",
              "text": "色 成"
            },
            {
              "chord": "",
              "text": "曚"
            },
            {
              "chord": "D",
              "text": "昽。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "经过死亡就必得生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已前去，我们随行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪的权势今已经过去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已经得胜有馀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "转眼将耶稣观看！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "注目仰望祂的荣面！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有事物在祂荣耀光中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要次第变色成曚昽。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的应许终不至落空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若信靠祂，事事亨通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以应当坚定不灰心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你必经历祂的救恩。"
            }
          ]
        }
      ],
