  "title": "God’s kingdom is God’s reigning",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "God's kingdom"
            },
            {
              "chord": "G",
              "text": "is God's"
            },
            {
              "chord": "D",
              "text": "reigning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glory to main"
            },
            {
              "chord": "A",
              "text": "tain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It"
            },
            {
              "chord": "D",
              "text": "is His"
            },
            {
              "chord": "G",
              "text": "sovereign"
            },
            {
              "chord": "D",
              "text": "ruling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His order"
            },
            {
              "chord": "E7",
              "text": "to sus"
            },
            {
              "chord": "A",
              "text": "tain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "He"
            },
            {
              "chord": "D",
              "text": "exercises"
            },
            {
              "chord": "G",
              "text": "ful"
            },
            {
              "chord": "D",
              "text": "ly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His own authori"
            },
            {
              "chord": "A",
              "text": "ty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With"
            },
            {
              "chord": "D",
              "text": "in His"
            },
            {
              "chord": "G",
              "text": "kingdom"
            },
            {
              "chord": "D",
              "text": "ever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "A",
              "text": "to e"
            },
            {
              "chord": "A7",
              "text": "terni"
            },
            {
              "chord": "D",
              "text": "ty."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon the throne, the center"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of government divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God reigns, and with His purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brings everything in line."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s headship and His lordship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He only can maintain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As King within His kingdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er everything to reign."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By reigning in His kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God worketh all His will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And under His dominion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His purpose doth fulfill."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis only in God’s kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blessing we may know;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis from His throne almighty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The stream of life doth flow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Submitted to God’s ruling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All virtue thus will win;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rebellion to His Headship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is but the root of sin."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The evil aim of Satan—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s throne to overthrow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our aim and goal is ever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His rule to fully know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Within God’s sovereign kingdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Christ is magnified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Christ in life is reigning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father’s glorified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When God is in dominion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are truly blessed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Christ for God is reigning."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s glory is expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In fulness of the seasons"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s Christ will head up all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then all will own His reigning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And worship, great and small."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such reign in life and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church e’en now foretastes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to His rule submitting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto His kingdom hastes."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
