  "raw_sections": [
    "我 时刻 呼 喊 主 名，",
    "当 我 往 前行，",
    "我 时 刻呼 喊主 名，",
    "祂 使我 欢腾；",
    "虽 然 黑 云 笼 罩 天 空，",
    "遮 蔽我 路程，",
    "我 只 要呼 喊主 名，",
    "祂 必显 权能。",
    "祂 是 我 朋友，",
    "最 信实 忠诚，",
    "我 可 倚 靠祂，",
    "直 走完 路程。",
    "虽 然 黑 云 笼 罩 天 空，",
    "遮 蔽我 路程，",
    "我 只 要呼 喊主 名，",
    "祂 必显 权能。"
  ]
