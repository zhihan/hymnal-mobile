      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主是祷告的俄梅嘎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的最大‘阿们，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我祷告停息之时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发出同感声音。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但在首尾两端之间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂让我们接联，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用那不清似吃话语，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "译出祂所欲言。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你这首先、末后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我所有祷告"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你心愿完全结合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "说出你之所要。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不能道出之祈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全有你作其始；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们简短不清之祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其终愿你也是！"
            }
          ]
        }
      ],
