          "segments": [
            {
              "chord": "D",
              "text": "祂 灵"
            },
            {
              "chord": "",
              "text": "教 自 我"
            },
            {
              "chord": "A",
              "text": "灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "F♯m",
              "text": "知 如"
            },
            {
              "chord": "C♯",
              "text": "何 祷"
            },
            {
              "chord": "F♯m",
              "text": "告，"
