    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, before time had begun,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We were marked and called out by You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We had no choice, we were trapped by You, Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We had no place we could run."
            }
          ]
