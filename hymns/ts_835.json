      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主已救我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求也记念我家人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已担当他们罪过愆尤；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今切求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你应许成为真："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘信主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全家都必得救。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你听我："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切要得着我全家！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也要垂顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心为此如焚："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘我和我家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要事奉耶和华！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世世代代敬拜我真活神！"
            }
          ]
