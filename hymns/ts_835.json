  "title": "全家得救",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "何 大"
            },
            {
              "chord": "",
              "text": "怜 悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 眼 得 开 识"
            },
            {
              "chord": "Am",
              "text": "真 神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "喜 脱"
            },
            {
              "chord": "",
              "text": "黑 暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得"
            },
            {
              "chord": "D7",
              "text": "享 光"
            },
            {
              "chord": "",
              "text": "明 自"
            },
            {
              "chord": "G",
              "text": "由！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何 奇 恩 典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G7",
              "text": "能 白"
            },
            {
              "chord": "",
              "text": "白 得"
            },
            {
              "chord": "C",
              "text": "救 恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "不 需"
            },
            {
              "chord": "",
              "text": "善"
            },
            {
              "chord": "Em",
              "text": "行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也"
            },
            {
              "chord": "Am7",
              "text": "不 需"
            },
            {
              "chord": "D7",
              "text": "我 苦"
            },
            {
              "chord": "G",
              "text": "修！"
            }
