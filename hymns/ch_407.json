{
  "url": "https://www.hymnal.net/cn/hymn/ch/407",
  "title": "救主耶稣我的太阳",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "救 主"
            },
            {
              "chord": "",
              "text": "耶"
            },
            {
              "chord": "Bm",
              "text": "稣， 我"
            },
            {
              "chord": "A",
              "text": "的 太"
            },
            {
              "chord": "D",
              "text": "阳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有 你 同"
            },
            {
              "chord": "Bm",
              "text": "在 夜"
            },
            {
              "chord": "A7",
              "text": "也"
            },
            {
              "chord": "D",
              "text": "明"
            },
            {
              "chord": "A",
              "text": "亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "勿 让 人"
            },
            {
              "chord": "Em",
              "text": "世 有"
            },
            {
              "chord": "D",
              "text": "云 遮"
            },
            {
              "chord": "A",
              "text": "掩"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "仆 人"
            },
            {
              "chord": "",
              "text": "心"
            },
            {
              "chord": "D",
              "text": "眼 不"
            },
            {
              "chord": "A",
              "text": "见"
            },
            {
              "chord": "A7",
              "text": "慈"
            },
            {
              "chord": "D",
              "text": "颜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "倦眼欲合，频频催眠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "睡如甘露，润我夕荐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深愿今晚最后思念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是永世息你胸前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与我同在自晨至夕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离你我觉生无意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无你我惧死荫临到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你相偕自晚至朝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我睡醒，求主赐福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "扶我行走人生路途，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直至那日被提你旁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "溶化在你爱的海洋。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
