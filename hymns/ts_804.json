      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "爱，作得最快，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱，作得最好！"
            }
          ]
        },
