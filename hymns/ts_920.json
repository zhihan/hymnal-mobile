        },
        {
          "chord": "D",
          "text": "時！ 要"
        },
        {
          "chord": "",
          "text": "及"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "時！ 要 及 時！ 羔 羊"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "婚 筵 今 在 卽， 要 及"
        },
        {
          "chord": "A",
          "text": "時！"
        },
        {
          "chord": "A7",
          "text": "魂 的"
        }
