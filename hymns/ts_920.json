        {
          "chord": "",
          "text": "魂的生命肯离弃，让灵浸透且漫溢，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "就必够格来坐席─要及时！"
        }
      ]
    }
