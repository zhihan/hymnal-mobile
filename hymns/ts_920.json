    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及 时！ 要 及 时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羔 羊 婚 筵 今 在 即， 要 及"
