    },
    {
      "segments": [
        {
          "chord": "D",
          "text": "生 命"
        },
        {
          "chord": "",
          "text": "肯 離 棄， 讓 靈"
        },
        {
          "chord": "G",
          "text": "浸 透"
        },
        {
          "chord": "",
          "text": "且 漫 溢， 就 必"
