              "chord": "",
              "text": "来 坐"
            },
            {
              "chord": "A7",
              "text": "席─ 要"
            },
            {
              "chord": "",
              "text": "及"
            },
            {
              "chord": "D",
              "text": "时！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "精明童女主所期，豫备新油当积极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切莫轻忽神心意─要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "买油代价不容易，必须我们对付己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "器皿充满且洋溢─要及时！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羔羊婚筵今在即，要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "魂的生命肯离弃，让灵浸透且漫溢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就必够格来坐席─要及时！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "忠信奴仆主所期，运用恩赐作生意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "莫因懒惰被撇弃─要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一他连得不藏匿，克服松懒的己意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭主事奉不乏力─要及时！"
            }
          ]
        }
      ],
