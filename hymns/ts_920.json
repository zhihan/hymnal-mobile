          "chord": "",
          "text": "及"
        },
        {
          "chord": "D",
          "text": "時！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "精明童女主所期，豫备新油当积极，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "切莫轻忽神心意─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "买油代价不容易，必须我们对付己，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "器皿充满且洋溢─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "要及时！要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊婚筵今在即，要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "魂的生命肯离弃，让灵浸透且漫溢，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "就必够格来坐席─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "忠信奴仆主所期，运用恩赐作生意，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "莫因懒惰被撇弃─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "一他连得不藏匿，克服松懒的己意，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "凭主事奉不乏力─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "要及时！要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊婚筵今在即，要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "魂的生命肯离弃，让灵浸透且漫溢，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "就必够格来坐席─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "成熟麦子主所期，初熟部分先被提，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "大体庄稼仍在地─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "勿向世界再寻觅，属地水分不留遗，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "生命成熟讨主喜─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "要及时！要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊婚筵今在即，要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "魂的生命肯离弃，让灵浸透且漫溢，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "就必够格来坐席─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "得胜信徒主所期，为祂万事不足惜，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "起初的爱总不弃─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "与主联结成为一，胜过所有的死寂，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "奔向标竿尽全力─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "要及时！要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊婚筵今在即，要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "魂的生命肯离弃，让灵浸透且漫溢，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "就必够格来坐席─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "看哪，基督要来地，属天国度将临及，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "服主权柄莫迟疑─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "悖逆的己须脱离，顺服功课当学习，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "让主掌权登至极─要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "要及时！要及时！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "羔羊婚筵今在即，要及时！"
        }
      ]
