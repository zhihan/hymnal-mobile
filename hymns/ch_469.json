          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂路岂非走错了么？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不然那有许多苦？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不！不！这段虽然崎岖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂仍前进平安过；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们若要同祂高举，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也得前进不畏祸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
