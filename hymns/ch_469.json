              "chord": "",
              "text": "园中孤单受磨炼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但全军都来攻逼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这样光景真难遣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我们并不失败，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因有天使来服事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并说：‘应当注目赏赉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "争战不过此一时。’"
            }
          ]
