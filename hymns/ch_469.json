          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天乐悠扬的清音；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣在彼迎接我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要慰百创的这心。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不过，再过几里，朋友！"
