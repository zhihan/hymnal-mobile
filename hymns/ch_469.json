    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "经拿撒勒，这条道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们越走越窄小，"
            }
          ]
        },
        {
          "segments": [
