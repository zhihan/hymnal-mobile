              "chord": "",
              "text": "不再有罪，不再有忧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主要擦干你眼泪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听祂正用柔声说道："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘勿恐，勿馁，仍力前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为也许明朝未到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "旅程就已到终点。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
