              "chord": "",
              "text": "多年劳碌无人领悟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常受羞辱，常无聊。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但神借此教训我们："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此苦难，是因为"
