            },
            {
              "chord": "D7",
              "text": "會 在"
            },
            {
              "chord": "",
              "text": "此 顯"
            },
            {
              "chord": "G",
              "text": "為 實"
            },
            {
              "chord": "",
              "text": "際；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦 主， 求"
            },
            {
              "chord": "D",
              "text": "你 加"
            },
            {
              "chord": "",
              "text": "添"
            },
            {
              "chord": "A7",
              "text": "自"
            },
            {
              "chord": "D",
              "text": "己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦 主， 今"
            },
            {
              "chord": "A7",
              "text": "日 聖"
            },
            {
              "chord": "",
              "text": "化 我"
            },
            {
              "chord": "D",
              "text": "們，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "捨 此 無"
            },
            {
              "chord": "Em",
              "text": "路 滿"
            },
            {
              "chord": "",
              "text": "足"
            },
            {
              "chord": "E7",
              "text": "神"
            },
            {
              "chord": "A7",
              "text": "心。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟 願 你"
            },
            {
              "chord": "D",
              "text": "作 人"
            },
            {
              "chord": "D7",
              "text": "位， 擴"
            },
            {
              "chord": "",
              "text": "展 徧"
            },
            {
              "chord": "G",
              "text": "及 四"
            },
            {
              "chord": "",
              "text": "圍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦 主， 今"
            },
            {
              "chord": "D",
              "text": "日 聖"
            },
            {
              "chord": "",
              "text": "化"
            },
            {
              "chord": "A7",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "們。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，洁净我们，向我们心说话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗涤我们全人，直至圣别无瑕。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你活话扩长，来将我们圣化；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，求你洁净圣化。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日洁净我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不容天然生命留存。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美丽、荣耀添加，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "皆因你的说话；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日洁净我们。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，滋养我们，惟你是真食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只需吃饱喝足，变化自然显出。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有得你餧养；我们才真满足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，求你滋养眷顾。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日滋养我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "老旧、天然洗涤净尽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你来施洁净，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又将我们充盈；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日滋养我们。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，顾惜我们，以你柔爱养育；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你温情抚慰，眷顾我们所需。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "软化刚硬石心，好来施情占据；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日顾惜我们。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日顾惜我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "冷淡、死沉全都驱尽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当你怀搋紧紧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们能不欢欣？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日顾惜我们。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，荣化我们，借你内里运行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非为个人明亮，乃为召会得荣。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你得着新妇，成就你爱经营；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，求你在我运行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日运行我身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "妆饰新妇迎你再临。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你开展扩充，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会荣上加荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，今日荣化我们。"
            }
          ]
        }
      ],
      "type": "chorus"
    }
