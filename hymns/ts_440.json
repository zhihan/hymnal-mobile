            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "聖 化 我 們， 加 添 你"
            },
            {
              "chord": "A",
              "text": "的 自"
            },
            {
              "chord": "",
              "text": "己；"
