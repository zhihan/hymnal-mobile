{
  "url": "https://www.hymnal.net/en/hymn/ns/206",
  "title": "Lord, do unveil",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, do unveil"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more we strive, the more we fail"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the strife—they all come out to no avail."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, they’re just not for your need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By “self”, we won’t succeed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we confess"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are not able, Lord, unless"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have You; You’re all in all—You’re our success!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All we need, O Lord, is You"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Cause nothing else will do."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, we pray"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Increase Thyself in us each day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the “self”—decrease it ’til it’s done away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we want the growth in life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We don’t want all the strife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, life’s begun"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Two spirits mingled into one"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day, walk in the spirit and we’ve won!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the “self” will be decreased"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Christ in us increased."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
