{
  "url": "https://www.hymnal.net/cn/hymn/ch/201",
  "title": "井阿涌上水来",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "井 阿，"
            },
            {
              "chord": "",
              "text": "涌 上 水 来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 愿"
            },
            {
              "chord": "",
              "text": "被 挖"
            },
            {
              "chord": "D",
              "text": "透！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挖 去 一 切 障 碍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "活 水"
            },
            {
              "chord": "",
              "text": "好 涌"
            },
            {
              "chord": "D",
              "text": "流！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "磐石已经裂开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水已流出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流到我的心怀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然被堵住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我要祷告挖井，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挖去我泥土；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到挖出圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水能流出。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告还要祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挖了还要挖！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到挖得透了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祷告得练达。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不需磐石再开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要我挖透；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不需活水再来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要我涌流。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵降在我身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过是浇灌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵住在我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才是活水泉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我所急切需要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅求浇灌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更是透彻祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挖通活水泉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "挖到再无事物"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能将灵阻隔；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挖到泉源涌出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水的江河！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "井阿，涌上水来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿被挖透！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挖去一切障碍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水好涌流！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
