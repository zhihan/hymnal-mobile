{
  "url": "https://www.hymnal.net/cn/hymn/ch/635",
  "title": "战士哪你就当站住",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "当 你"
            },
            {
              "chord": "",
              "text": "苦 受 撒 但"
            },
            {
              "chord": "A",
              "text": "试 探，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "四 围"
            },
            {
              "chord": "D",
              "text": "无 处"
            },
            {
              "chord": "A7",
              "text": "不 黑"
            },
            {
              "chord": "D",
              "text": "暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "邪 灵 劝 你 稍 为"
            },
            {
              "chord": "A",
              "text": "自 循，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将 来"
            },
            {
              "chord": "D",
              "text": "冠 冕"
            },
            {
              "chord": "A7",
              "text": "听 命"
            },
            {
              "chord": "D",
              "text": "运；"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "战 士"
            },
            {
              "chord": "",
              "text": "哪， 你 就 当 站 住！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "思 念"
            },
            {
              "chord": "D",
              "text": "你 的"
            },
            {
              "chord": "",
              "text": "得 胜 主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶 稣 已 经 胜 过"
            },
            {
              "chord": "A",
              "text": "撒 但，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "故 当"
            },
            {
              "chord": "D",
              "text": "奋 勇"
            },
            {
              "chord": "A7",
              "text": "去 争"
            },
            {
              "chord": "D",
              "text": "战。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你同伴逡巡、摇动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你怀贰和敌通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的乡邻讥你、欺你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "竟然同敌联一气；"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当这世界用它福乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "暗中为你张网罗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要借虚荣、世俗、人情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你狂放失信心；"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你困于烦琐事务，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然劳碌无所补，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "损失、病痛，使你艰苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身灵疲惫难担负；"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不久，争战就要过去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但、邪灵要受拘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久，召会要听号声，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得荣耀，要得胜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "战士哪，故你当站住！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "思念你的得胜主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣已经胜过撒但，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "故当奋勇去争战。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "此后，我王就要凯旋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这世界掌王权；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此后，万国都要归顺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "颂扬耶稣并敬尊。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "属灵的争战",
