              "text": "God is with us to be our supply."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Even in all of our troubles,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Some may come to us in need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In their seeking we can help them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come to God, and let Him take the lead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through our speaking of God’s vision,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the more we’ll be released!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak the “dreams” that God has shown you."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speak with God’s full authority!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the secret to our reigning"
