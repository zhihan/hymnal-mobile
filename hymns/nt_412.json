    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Inwardly I want the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But my conduct hateful is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I would, I cannot change,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what real bondage ’tis!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By God’s law my sin’s revealed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the law of sin doth bind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I struggle to be free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No release my soul can find."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Many times I fall and rise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oft resolve, and often fail;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Craving vict’ry, I retreat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my sad defeat bewail."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Truly I am sold to sin"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And completely powerless;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s no good within my flesh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All is dark and sinfulness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I know myself in part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And confess my helplessness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my temperament is odd,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my life corrupted is."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Subtle self I cannot trust,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor to fleshly strength can cling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my trust and all my hope"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is in Jesus Christ my King."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May the Cross put me to death"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That on Christ I may rely;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May His Holy Spirit fill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Himself I may apply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May His death so work in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Daily deeper than before,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That my self may be destroyed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His life thru me may pour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O how bitter is my case!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who this wretched slave can free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who deliver from this death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To a life of victory?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus shed His blood for me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is now my holiness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I receive Him as my life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my portion measureless."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m wholly sanctified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Selfless, I obey His word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nevermore to feel ashamed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I come before the Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How transcendent is this life!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grace thru faith He gives to me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord, He heard my cry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And has made me wholly free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
