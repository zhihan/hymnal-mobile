{
  "url": "https://www.hymnal.net/cn/hymn/ts/537",
  "title": "献上自己建造方舟",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "當 日"
            },
            {
              "chord": "",
              "text": "挪 亞 照 神 吩 咐， 努"
            },
            {
              "chord": "C",
              "text": "力 建"
            },
            {
              "chord": "",
              "text": "造 方"
            },
            {
              "chord": "G",
              "text": "舟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多 人 觀 看， 他 的 話 卻 無"
            },
            {
              "chord": "A7",
              "text": "人 留"
            },
            {
              "chord": "",
              "text": "意、 接"
            },
            {
              "chord": "D",
              "text": "受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟"
            },
            {
              "chord": "G",
              "text": "獨 挪"
            },
            {
              "chord": "",
              "text": "亞 蒙 恩， 聽 見 神"
            },
            {
              "chord": "C",
              "text": "話 語"
            },
            {
              "chord": "",
              "text": "謹 遵"
            },
            {
              "chord": "G",
              "text": "守，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全"
            },
            {
              "chord": "C",
              "text": "心 建"
            },
            {
              "chord": "",
              "text": "造 方 舟， 不 浪 費"
            },
            {
              "chord": "D",
              "text": "任 何"
            },
            {
              "chord": "D7",
              "text": "的 時"
            },
            {
              "chord": "G",
              "text": "候。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今 日 耶 穌 的"
            },
            {
              "chord": "C",
              "text": "見 證，"
            },
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "A7",
              "text": "向 我"
            },
            {
              "chord": "",
              "text": "們 顯"
            },
            {
              "chord": "D",
              "text": "明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "見"
            },
            {
              "chord": "G7",
              "text": "證 的"
            },
            {
              "chord": "",
              "text": "方 舟"
            },
            {
              "chord": "C",
              "text": "建 立"
            },
            {
              "chord": "",
              "text": "在 眾"
            },
            {
              "chord": "G",
              "text": "地 方"
            },
            {
              "chord": "D7",
              "text": "召 會"
            },
            {
              "chord": "G",
              "text": "中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那时的世代堕落、弯曲、悖谬又腐朽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上的罪恶甚大，人心邪恶无可救；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但挪亚持守异象，抵挡放荡的潮流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不计较任何代价，建造见证的方舟。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日耶稣的见证，已向我们显明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证的方舟建立在众地方召会中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当时也有多人说他们是在敬拜神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们事奉、献祭，却不能有分神救恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神所渴望建造，他们不耻、不愿过问，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "思念属地之事，以致与恶者同浮沉。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日耶稣的见证，已向我们显明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证的方舟建立在众地方召会中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一日，方舟建成，神将八人关入里头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上窗户尽都敞开，大雨倾泻不休；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "水势浩大，但方舟内挪亚安息无忧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地虽淹没，他却漂浮其上，安全得救。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日耶稣的见证，已向我们显明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证的方舟建立在众地方召会中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这方舟就是当代神在地得胜见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是一个团体的人，将神荣耀全显明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神也要我们同被建造，显出祂丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神显现于肉体，在众地方召会中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日耶稣的见证，已向我们显明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证的方舟建立在众地方召会中。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "儆醒！莫随洪流浮沉而偏离神心意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当让耶稣的见证如火在我心燃起！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地方召会乃是方舟，将神见证无遗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为此我们献上自己，现今世代远离。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今日耶稣的见证，已向我们显明："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证的方舟建立在众地方召会中。"
            }
          ]
        }
      ]
    }
  ],
