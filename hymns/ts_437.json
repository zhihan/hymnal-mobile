    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话犹如众星发亮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光芒四射辉煌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天程旅客在此光中"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属天，家乡直往。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你话又如军器库房，"
            }
          ]
