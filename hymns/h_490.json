              "text": "Lord, when"
            },
            {
              "chord": "",
              "text": "the Father"
            },
            {
              "chord": "G",
              "text": "ne'er was"
            },
            {
              "chord": "D",
              "text": "known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father"
            },
            {
              "chord": "A",
              "text": "came through"
            },
            {
              "chord": "A7",
              "text": "Thee be"
            },
            {
              "chord": "D",
              "text": "low,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we who lived in"
            },
            {
              "chord": "A",
              "text": "igno"
            },
            {
              "chord": "D",
              "text": "rance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Might through"
            },
            {
              "chord": "",
              "text": "Thy"
            },
            {
              "chord": "D",
              "text": "self the"
            },
            {
              "chord": "A",
              "text": "Fath"
            },
            {
              "chord": "A7",
              "text": "er"
            },
            {
              "chord": "D",
              "text": "know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But, Lord, when Thou wast here on earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How scarce were those Thyself who knew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A veil there was ’twixt Thee and them;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They crowded ’round, but saw not through."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now as the Spirit Thou hast come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E’en as the Father came in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we through Thee the Father know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now through the Spirit we know Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not with the flesh Thou now art clothed—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then must Thou walk with toil around;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But as the Spirit in our heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost supply Thyself unbound."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, the Father once wast called,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now the Holy Spirit art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit is Thine other form,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself to dwell within our heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By knowing Thee as Spirit, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We realize Thy life’s outflow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy glory and Thy character,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all Thy being’s wonders know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise to Thy Name now floods our heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is no one as dear as Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For since we know how real Thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No other one could lovelier be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
