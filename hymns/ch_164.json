{
  "url": "https://www.hymnal.net/cn/hymn/ch/164",
  "title": "恩主你是神的儿子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "恩"
            },
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "G",
              "text": "是 神"
            },
            {
              "chord": "D7",
              "text": "的 兒"
            },
            {
              "chord": "G",
              "text": "子， 是"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 完"
            },
            {
              "chord": "A7",
              "text": "滿 的"
            },
            {
              "chord": "D",
              "text": "表 現；"
            },
            {
              "chord": "",
              "text": "藉"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "你， 神"
            },
            {
              "chord": "Em",
              "text": "向 我"
            },
            {
              "chord": "B",
              "text": "們 說"
            },
            {
              "chord": "Em",
              "text": "話， 將"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "祂 說"
            },
            {
              "chord": "",
              "text": "得 詳"
            },
            {
              "chord": "D7",
              "text": "而"
            },
            {
              "chord": "G",
              "text": "全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆你是神的本体真像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神荣耀的光辉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也就是神的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神自己的发挥。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宇宙万有借你而造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是由你来托住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来且都归你承受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是神立的基督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已洗净我们的罪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今坐高天神右边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候仇敌作你脚凳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的旨意得成全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "更尊之名你已承受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超所有的天使；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已叫你从死复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显明你是祂儿子。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的国权公义、正直，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的宝座到永远。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喜乐的油神曾膏你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过膏你的同伴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆你也真是一个人子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "具有我们的人性；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借恩为我尝了死味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我能有你生命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已得了尊贵、荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有向你全降服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这神的救恩元帅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得以完全，因受苦。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆你已借死毁坏魔鬼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我从死得释放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今借生命使我成圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还要带我进荣光。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今向我们－你的弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此传扬父的名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在会中颂扬父神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们和声同响应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆好像造者之于房屋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比摩西更尊荣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是使徒，神所差来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配得更多的敬重。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们真约书亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带领我们进安息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们完满救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们信心全在你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们属天安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今住在我灵里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我进入，享你丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "犹如进入那美地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆蒙神选召作大祭司，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你比亚伦更尊荣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣洁、无疵，高过诸天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "体恤、代祷圣所中。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "14"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那真麦基洗德，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着生命的大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正在我们需要时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以‘饼和酒’来供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "15"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们更美祭物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着永远的圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "曾经为我向神献上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我今享其功能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "16"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆更美之约你为我立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你的更美血；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你我今得有分于"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个可靠的新约。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "17"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是这约合法立者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此资格惟你有；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是其胜任赐者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我一切能承受。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "18"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你今更是其执行者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着复活的生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是其有力中保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我成全神命定。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "19"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你今已在幔内，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我惟一的先锋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我靠你出到营外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠诚跟随你脚踪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "20"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆你是我信的创始者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也是我信成终主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借信与爱，随你前行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你我要永降服。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "21"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "☆你的价值无可比拟，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们珍爱你所是；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是如此完美、全备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超人所能赏识。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "22"
    }
  ],
