    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And He shall make His Church all heavenly fair,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With gold and pearls, and every radiant stone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And reign in holiness and glory there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shine as suns and stars have never shone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He shall lead His Bride, His joy and care,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With blissful singing to His Father’s throne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And then the blest communion shall have come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God’s dear children meeting from afar;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within His burning love they blend as one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet each, according as His counsels are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall have peculiar glory of his own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As one star differeth from another star."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And God is all in all in that great day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And He is their exceeding great Reward;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their stream of life, their beautiful array,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their food, their joy, their radiance, Christ the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The music of their wondrous song shall say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How great the joy that passeth thought or word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And this is that eternal life of heaven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Laid up with Christ in God, the mystery"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of resurrection life which He hath given:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A fount of living waters full and free;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life by which the gates of death are riven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life which on the throne of Christ shall be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And here in this waste wilderness begun,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So soon as we believe in Christ aright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And quickened by the Spirit of the Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Receive Him as our only life and light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As all the branches in the vine are one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So we are one forever in His sight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now come, Lord Jesus, quickly from above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do Thou sustain us on the desert road,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And draw us after Thee by might of love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Fatherland art Thou, O love of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once safe in Thee, no more shall we remove,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Thou our everlasting sure abode."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
