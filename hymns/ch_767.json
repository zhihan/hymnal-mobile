            {
              "chord": "",
              "text": "指 望"
            },
            {
              "chord": "G7",
              "text": "進 入"
            },
            {
              "chord": "C",
              "text": "神 子"
            },
            {
              "chord": "",
              "text": "自 由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脫 離 虛"
            },
            {
              "chord": "F",
              "text": "空"
            },
            {
              "chord": "C",
              "text": "與"
            },
            {
              "chord": "G7",
              "text": "敗"
            },
            {
              "chord": "C",
              "text": "壞。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切受造都在叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "劳苦服在虚空下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "指望得着完全释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离败坏的管辖。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "甚至我们也在叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候儿子的名分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们须有基督身量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为长大成熟人。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为此圣灵替我叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我变成神子像；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂使万事互相效力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我模成主模样。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神要将我带进荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时我要被荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂自己将我浸透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全然圣别成新造。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有受造要被释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得进‘荣耀’的自由；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豹子与山羊羔同卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "狮子吃草好像牛。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "长大与主同作后嗣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承受儿子的名分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂弟兄与祂同荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀显我身。"
            }
          ]
        }
      ]
    }
