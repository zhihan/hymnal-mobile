  "title": "受造之物切望等候",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "受 造"
            },
            {
              "chord": "F",
              "text": "之 物"
            },
            {
              "chord": "C",
              "text": "切 望"
            },
            {
              "chord": "",
              "text": "等 候"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 的"
            },
            {
              "chord": "F",
              "text": "众 子"
            },
            {
              "chord": "G",
              "text": "显"
            },
            {
              "chord": "D7",
              "text": "出"
            },
            {
              "chord": "G",
              "text": "来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "指 望"
            },
            {
              "chord": "G7",
              "text": "进 入"
            },
            {
              "chord": "C",
              "text": "神 子"
            },
            {
              "chord": "",
              "text": "自 由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱 离 虚"
            },
            {
              "chord": "F",
              "text": "空"
            },
            {
              "chord": "C",
              "text": "与"
            },
            {
              "chord": "G7",
              "text": "败"
            },
            {
              "chord": "C",
              "text": "坏。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "一切受造都在叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "劳苦服在虚空下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "指望得着完全释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离败坏的管辖。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "甚至我们也在叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等候儿子的名分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们须有基督身量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为长大成熟人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为此圣灵替我叹息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我变成神子像；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂使万事互相效力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我模成主模样。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神要将我带进荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时我要被荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用祂自己将我浸透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全然圣别成新造。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有受造要被释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得进‘荣耀’的自由；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豹子与山羊羔同卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "狮子吃草好像牛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "长大与主同作后嗣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承受儿子的名分；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂弟兄与祂同荣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀显我身。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
