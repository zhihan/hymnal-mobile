{
  "url": "https://www.hymnal.net/cn/hymn/ts/34",
  "title": "赞美基督，救恩成功",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "來 向"
            },
            {
              "chord": "",
              "text": "基 督 讚"
            },
            {
              "chord": "F",
              "text": "美 歌"
            },
            {
              "chord": "C",
              "text": "頌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "F",
              "text": "神 使"
            },
            {
              "chord": "",
              "text": "救 恩 藉 祂"
            },
            {
              "chord": "G7",
              "text": "成"
            },
            {
              "chord": "C",
              "text": "功；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得 救 惟 靠 神"
            },
            {
              "chord": "F",
              "text": "聖 生"
            },
            {
              "chord": "C",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "F",
              "text": "律 法"
            },
            {
              "chord": "",
              "text": "規 條 一 無"
            },
            {
              "chord": "G7",
              "text": "所"
            },
            {
              "chord": "C",
              "text": "成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人"
            },
            {
              "chord": "F",
              "text": "雖 努"
            },
            {
              "chord": "C",
              "text": "力 不"
            },
            {
              "chord": "F",
              "text": "能 得"
            },
            {
              "chord": "C",
              "text": "勝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 聖 生 命 纔"
            },
            {
              "chord": "D7",
              "text": "有 大"
            },
            {
              "chord": "G",
              "text": "能；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將"
            },
            {
              "chord": "F",
              "text": "人 改"
            },
            {
              "chord": "",
              "text": "變 帶 來"
            },
            {
              "chord": "G7",
              "text": "重"
            },
            {
              "chord": "C",
              "text": "生。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂赐下生命能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂将信徒拯救到底；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣生命注入人里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供应救恩时刻不息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人虽失丧祂来临及，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拯救罪人脱离仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带领众子进荣耀里。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是祭司为神所立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐人生命带来实际；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的生命就在祂里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拯救世人脱罪胜己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远生命不朽不已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所施救恩全备无比；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美我主完全能力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的生命足能担保，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带领我们达到荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若非祂曾得胜宣告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有何可以信靠。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂受试验屹立不摇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终于十架始于马槽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不受死亡阴间缠绕。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作凭质供人接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "担保信徒完全得救；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全备供应包罗万有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲自成全终能成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属人生命失败、老旧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟祂生命坚定永久；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作生命完全拯救。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督今日高过诸天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忠信代求直到永远；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不受软弱、死亡阻拦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祭司职分无需更换；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长远活着，立于神前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代求满足神、人心愿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已高升远超诸天。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来到神前，靠主宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "绝不退缩而遭毁坏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来到神前，得着生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各尽功用不作婴孩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来到神前，享受生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂子民，蒙祂所爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命作王，死亡不在。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
