    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou glorious light of courts above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joy of the saints below,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us still manifest Thy love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we its depths may know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To us Thy cross with all its shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With all its grace be giv’n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though earth disowns Thy lowly name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God honors it in heav’n."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who suffer with Thee, Lord, today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall also with Thee reign:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then let it be our joy to pay"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Price, this goal attain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To us Thy cross is life and health;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas shame and death to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our present glory, joy and wealth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our everlasting stay."
            }
          ]
        }
      ],
