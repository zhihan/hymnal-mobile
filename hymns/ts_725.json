            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每一步都听凭祂指示！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要向东，我们就向东，"
