    {
      "segments": [
        {
          "chord": "C",
          "text": "不 受"
        },
        {
          "chord": "",
          "text": "老 套 拘 束，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "G",
          "text": "主 有"
        },
        {
          "chord": "",
          "text": "帶 領"
        },
        {
