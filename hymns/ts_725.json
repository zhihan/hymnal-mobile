    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "负祂的轭，一步一步走，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "学祂样式，跟随祂举止；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是小牛犊，"
            }
          ]
        },
        {
          "segments": [
