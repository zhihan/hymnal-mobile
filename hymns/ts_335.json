{
  "url": "https://www.hymnal.net/cn/hymn/ts/335",
  "title": "上好之爱来爱你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "人 的"
            },
            {
              "chord": "",
              "text": "心 哪， 你 愛"
            },
            {
              "chord": "A",
              "text": "甚 麼？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "若 非"
            },
            {
              "chord": "G",
              "text": "基 督，"
            },
            {
              "chord": "",
              "text": "無 安"
            },
            {
              "chord": "A",
              "text": "息。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦， 主，"
            },
            {
              "chord": "G",
              "text": "求 你"
            },
            {
              "chord": "A",
              "text": "悅 納"
            },
            {
              "chord": "D",
              "text": "我 心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "上 好 之 愛，"
            },
            {
              "chord": "A7",
              "text": "來 愛"
            },
            {
              "chord": "D",
              "text": "你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今将世界全都抛弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主耶稣最美丽；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "最美事物也无可比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟你使我心欢喜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的荣脸，明亮辉煌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发光照耀永无已；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是可爱、甘甜、柔细，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怜悯、恩典全洋溢。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主！是你爱先来临及，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流血拯救你仇敌；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你之爱我，永不止息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心岂可不爱你？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "保守我心忠诚向你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我同你藏神里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在世一切所经所历，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你荣耀留足迹。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "爱慕耶稣",
    "time": "4/4",
    "hymn_code": "31555117136714332",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/547",
        "language": "cn",
        "category": "h",
        "number": "547",
        "title": "E547"
      }
    ]
  },
  "raw_sections": [
    "人 的心 哪， 你 愛甚 麼？",
    "若 非基 督，無 安息。",
    "哦， 主，求 你悅 納我 心，",
    "上 好 之 愛，來 愛你。",
    "今将世界全都抛弃，",
    "我主耶稣最美丽；",
    "最美事物也无可比，",
    "惟你使我心欢喜。",
    "你的荣脸，明亮辉煌，",
    "发光照耀永无已；",
    "你是可爱、甘甜、柔细，",
    "怜悯、恩典全洋溢。",
    "主！是你爱先来临及，",
    "流血拯救你仇敌；",
    "你之爱我，永不止息，",
    "我心岂可不爱你？",
    "保守我心忠诚向你，",
    "使我同你藏神里，",
    "在世一切所经所历，",
    "让你荣耀留足迹。"
  ]
}