{
  "url": "https://www.hymnal.net/cn/hymn/ch/180",
  "title": "在此我要主与你面",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "",
              "text": "我 要， 主，"
            },
            {
              "chord": "A",
              "text": "與 你"
            },
            {
              "chord": "A7",
              "text": "面 對"
            },
            {
              "chord": "D",
              "text": "面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 此 我"
            },
            {
              "chord": "A",
              "text": "要 用"
            },
            {
              "chord": "E",
              "text": "信 把"
            },
            {
              "chord": "E7",
              "text": "握 不"
            },
            {
              "chord": "A",
              "text": "見，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "在 此"
            },
            {
              "chord": "",
              "text": "我 要 更 深 認 識 恩"
            },
            {
              "chord": "A",
              "text": "典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "將 我"
            },
            {
              "chord": "",
              "text": "疲"
            },
            {
              "chord": "G",
              "text": "勞 都"
            },
            {
              "chord": "",
              "text": "息 在"
            },
            {
              "chord": "A",
              "text": "主"
            },
            {
              "chord": "A7",
              "text": "腳"
            },
            {
              "chord": "D",
              "text": "前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此我要吃主所赐美物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此我要饮主所递福杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此我要忘记一切难处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再尝一次赦罪平安滋味。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我虽有罪，但你却有公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我虽污秽，但你却有宝血；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，你的宝血将我清洗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的公义对付我的罪孽。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "除你之外，我无别的帮助；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你赐恩，我就不求人惠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你的爱，我已心意满足；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠你能力，我要站住地位。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "以下三节在擘饼后唱"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "席撤何速，表记的物已尽！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "酒饼虽无，拯救的爱未亡！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宴筵已过，你仍在此亲近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲近有加，作我万有君王！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，云柱今又离地上升，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这野地又要乘夜前征；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你正招呼，我们紧紧随行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久我们就到光明天城。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "上席罢席，次次我们聚散，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此聚散，遥指天上佳筵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时虽未至，我们却已豫尝"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他日天上羔羊婚娶喜宴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "赞美主",
