          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，愿这平安，你也能亲尝到！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "等主救了你，请也告诉别人："
