    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我有一天父，住在光明之家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "许我一盼望，既永远，又有据；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不久要接我到天上去会见祂："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，愿祂施恩，你也能同我去！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我有一喜乐，这乐涌如海波，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为我救主已担去我罪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且祂现今还在我里面活着："
