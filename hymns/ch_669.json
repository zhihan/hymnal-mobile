        {
          "segments": [
            {
              "chord": "",
              "text": "我主曾如何也把你来拯救；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且要祈求，求你主也救他们："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主听我祈求，也必听你祈求！"
            }
          ]
        }
