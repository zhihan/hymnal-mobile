    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人若倚靠耶和华，真有福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必定走属天的道路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若时时不断的仰望主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必能有稳健的脚步。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "务要靠主，专心靠主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡你所行，都要认定主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必指引你的路。"
            }
          ]
        },
        {
