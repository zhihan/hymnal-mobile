      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "真是有福，有天父来扶助，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且有救主来照顾；"
