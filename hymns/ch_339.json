  "title": "为我荆棘冠冕你肯",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "得 著 我 一 生，"
