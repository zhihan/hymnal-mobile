{
  "url": "https://www.hymnal.net/cn/hymn/ch/339",
  "title": "为我荆棘冠冕你肯",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "得 著 我 一 生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "使 它"
            },
            {
              "chord": "",
              "text": "歸 你 成 為"
            },
            {
              "chord": "C",
              "text": "聖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得 著 我 日 與 我"
            },
            {
              "chord": "F",
              "text": "時，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "歸 你"
            },
            {
              "chord": "G7",
              "text": "使 用"
            },
            {
              "chord": "",
              "text": "永 無"
            },
            {
              "chord": "C",
              "text": "止。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "F",
              "text": "為 我"
            },
            {
              "chord": "",
              "text": "荊 棘 冠 冕 你 肯"
            },
            {
              "chord": "C",
              "text": "戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "F",
              "text": "為 我"
            },
            {
              "chord": "",
              "text": "釘 死 苦 架 你 受"
            },
            {
              "chord": "Gsus4",
              "text": "害；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "為 你"
            },
            {
              "chord": "",
              "text": "我 願 獻 上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "F",
              "text": "我 命"
            },
            {
              "chord": "",
              "text": "與 我"
            },
            {
              "chord": "C",
              "text": "愛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "事 你、"
            },
            {
              "chord": "G7",
              "text": "愛 你"
            },
            {
              "chord": "",
              "text": "到 萬"
            },
            {
              "chord": "C",
              "text": "代。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得着我手与我足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "勤作你工，奔你路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着我口与我舌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传扬你话，颂你德。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为我荆棘冠冕你肯戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我钉死苦架你受害；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你我愿献上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我命与我爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "事你、爱你到万代。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "得着我金与我银，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "分文不由我留存；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着我才与我智，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "运用全照你指示。"
            }
          ]
        }
