            },
            {
              "chord": "D",
              "text": "ty."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Hid in every aspiration,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In whate’er man doth contrive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is the longing for fulfillment;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this man doth ever strive."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For with nothing here to live for,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How long could man be sustained?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus within the old creation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man’s existence is maintained."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For this, old creation’s needed:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s the bridge of space and time,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till God brings forth new creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His eternal realm sublime."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This implanted sense of purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sown within the heart of man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Working throughout all the ages,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is for God’s eternal plan."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep in man’s a God-shaped vacuum,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Something only God can fill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s a human spirit longing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To know God’s eternal will."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are but temporary;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vanity of vanities"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But th’eternal life assuageth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thirsty sinners who believe."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though the nations think they’re seeking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joy, peace, love, security,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ alone can fill their longing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the one reality."
            }
          ]
        }
      ]
    }
  ],
