    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，在这蒙福的境地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神与人联调成为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "留在基督这美地里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受基督作实际；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "珍惜这无上的权利，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建造主生机的身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作基督显身团体大器，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将见证普及在各地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿神这永远经纶异象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "定住我心中每个方向，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光照我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我灵里发旺，更刚强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好模成基督荣耀形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在生命中作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将圣城撒冷带到地上。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "站在这异象的高峰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心里真欢欣，灵却重："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我需要复活的大能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需要真实的复兴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时时照着那灵而行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "处处为那灵来撒种，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为神在地团体模型，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同主当日所实行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
