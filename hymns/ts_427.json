      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 呼"
            },
            {
              "chord": "",
              "text": "召 我 們 在"
            },
            {
              "chord": "Bm",
              "text": "這 裡，"
            }
          ]
        },
        {
          "segments": [
