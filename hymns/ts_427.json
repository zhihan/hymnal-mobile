            },
            {
              "chord": "F♯m",
              "text": "心 中"
            },
            {
              "chord": "",
              "text": "每 個 方"
            },
            {
              "chord": "Bm",
              "text": "向，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光 照 我，"
            }
          ]
        },
        {
          "segments": [
