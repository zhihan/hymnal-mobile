    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我向自己死，向神活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭调和的灵而活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "旧生命从此全摆脱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪、肉体、世界消没；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我愿作个得胜者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以此为目标、为警策，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与众圣徒过神人生活，"
            }
          ]
        },
        {
          "segments": [
