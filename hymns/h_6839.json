{
  "url": "https://www.hymnal.net/en/hymn/h/6839",
  "title": "Cloud of Witnesses",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I no longer squander my life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now that this cloud’s met my sight;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the barrens, dark as the night,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From afar off, came its light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which, like fiery pillar bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Floods my pathway with might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my life, new hope ignites,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every footstep it guides."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, how rich my life has become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I pursue this bright cloud;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Universal pillar of truth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the long ages unbowed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This, the operating God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the flesh manifest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gives me faith beyond compare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Matchless comfort and rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With great boldness I can press on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I possess this bright cloud;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brothers’, sisters’ powerful love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bolsters, upholds and surrounds."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Truth my spirit ’lluminates;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How exhaustless this grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more sighs and wand’ring days;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now my heart’s found its place."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With you all I’m joined blent as one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Part of this bright cloud today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a glorious, splendid sky;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of crooked age unafraid."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me boldly forward press,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Testimony upraised;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May it, more magnificent,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine from age to age."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord! O Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All encumb’ring weights, I’d lay down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Live in this radiant cloud."
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
