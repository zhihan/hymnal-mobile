    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在灵中同过召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在召会地方立场；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄们同过召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已经回家；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随众召会同过召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到全地都同唱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦阿利路亚！基督美地！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘我要把我的召会"
            }
