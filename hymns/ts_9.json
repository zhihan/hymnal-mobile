{
  "url": "https://www.hymnal.net/cn/hymn/ts/9",
  "title": "神兴起，仇敌四散",
  "lines": [
    {
      "segments": [
        {
          "chord": "A",
          "text": "神 興"
        },
        {
          "chord": "D",
          "text": "起， 使"
        },
        {
          "chord": "",
          "text": "仇 敵"
        },
        {
          "chord": "A",
          "text": "四 散，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "叫 恨"
        },
        {
          "chord": "D",
          "text": "祂 的"
        },
        {
          "chord": "A",
          "text": "人 逃"
        },
        {
          "chord": "D",
          "text": "跑；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "A",
          "text": "惡 人"
        },
        {
          "chord": "D",
          "text": "見 神"
        },
        {
          "chord": "",
          "text": "面 就"
        },
        {
          "chord": "A",
          "text": "消 滅，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如 同"
        },
        {
          "chord": "D",
          "text": "蠟 被"
        },
        {
          "chord": "A",
          "text": "火 熔"
        },
        {
          "chord": "D",
          "text": "掉。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "Em",
          "text": "惟 有"
        },
        {
          "chord": "",
          "text": "義 人 必 歡"
        },
        {
          "chord": "A",
          "text": "喜，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "D",
          "text": "大 聲"
        },
        {
          "chord": "",
          "text": "誇 勝"
        },
        {
          "chord": "A",
          "text": "永 不"
        },
        {
          "chord": "D",
          "text": "已，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "A",
          "text": "唱 詩"
        },
        {
          "chord": "D",
          "text": "歌 頌，"
        },
        {
          "chord": "",
          "text": "唱 詩"
        },
        {
          "chord": "A",
          "text": "歌 頌，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "唱 詩"
        },
        {
          "chord": "D",
          "text": "歌 頌"
        },
        {
          "chord": "A",
          "text": "祂 名。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂坐车行过旷野地，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "将缺乏之民带回，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂是一切孤儿的父，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "也是寡妇的护卫─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "乃是在祂圣所里，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "哦，这救恩何希奇！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "孤独者在此可安家，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "寂寞者寻得住处；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "被囚者从捆绑得释，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "并且享受无穷福。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为祂羊群神豫备，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "这个住处─何恩惠！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "现今主以大能夸胜，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "发出胜利的捷报，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们‘妇女们’报喜信："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "‘统兵君王逃跑了！’"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不用流汗不劳苦，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们在家分掠物！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "看，基督已升上高天，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "领着长串的俘虏！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂将这些作成恩赐，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为着神与人同住。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "弟兄姊妹，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们是那变化了的俘虏！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "愿颂赞归神到永远，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂天天满载美物；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂是拯救我们的神，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "颂赞之声当远布。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "曾在阴间里漫游，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂打破仇敌的头！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神阿，我们看见了你，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在你圣所中行走，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你凯旋的队伍游行，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "作乐的跟随在后。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "看，歌唱的行在前，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "赞美一遍又一遍，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "领先的是小便雅悯，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "接着是犹大支队，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "忧患之子在神右边，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "狮子掌权执王圭。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "西布伦，拿弗他利，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "传扬大喜的信息："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "圣民哪，你们的能力，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "出自荣耀的圣殿；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神阿，求你刚强我们，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "直到我们被成全。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我们要赞美不停，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "直到地极都响应："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿利路亚，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "阿利路亚，阿们！"
        }
      ]
    }
  ],
