    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have come to the Fountain of Joy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His joy is the strength of my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My delight is unmixed with alloy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My sunshine can never depart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fig tree may wither and die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Earth’s pleasures and prospects decline;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But my fountains can never be dry—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My portion, my joy is divine."
            }
          ]
        }
      ],
