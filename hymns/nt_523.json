    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have come to the Fountain of Blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That for guilt and uncleanness doth flow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I have washed in its sin-cleansing flood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my garments are whiter than snow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I count not my righteousness mine—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis Jesus that lives in my soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I partake of His nature divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Him I am perfectly whole."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, come to the Fountain of Life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fountain that never runs dry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, drink of the boundless supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Christ is the Fountain of Life."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I have come to the Fountain of Health,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A boundless and endless supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis a secret man’s wisdom or wealth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can never discover or buy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the secret my Lord hath revealed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the fountain that flows from His side,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the stripes by whose pain we are healed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Himself as He comes to abide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
