{
  "url": "https://www.hymnal.net/cn/hymn/h/980",
  "title": "Throughout the whole of Holy Writ",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Throughout"
            },
            {
              "chord": "",
              "text": "the whole of"
            },
            {
              "chord": "A",
              "text": "Holy"
            },
            {
              "chord": "D",
              "text": "Writ"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The saints in type are"
            },
            {
              "chord": "G",
              "text": "mani"
            },
            {
              "chord": "A",
              "text": "fest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As like a"
            },
            {
              "chord": "D",
              "text": "bride, God's"
            },
            {
              "chord": "",
              "text": "heart to"
            },
            {
              "chord": "A",
              "text": "please,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "D",
              "text": "as a"
            },
            {
              "chord": "",
              "text": "building"
            },
            {
              "chord": "A",
              "text": "for His"
            },
            {
              "chord": "D",
              "text": "rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The types and figures of the Church"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Old Testament are these:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A building meet for life and rule,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A bride the man to match and please."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God's people in the ancient times"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were called by God His very spouse;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Among them and with them were built"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's ruling city and God's house."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Incarnate God, the God-man, Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Bridegroom for the Bride has come;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His own life He quickened her,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That she His counterpart become."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection Christ doth now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As David's Son, God's temple build,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God may have a resting place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And there accomplish all He willed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church is thus the Bride of Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In whom His full delight doth rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is a dwelling place to God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where He may live and be expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The new Jerusalem will be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The full perfection ultimate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all the types of house and bride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th' eternal plan to consummate."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the Bride which matches Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru whom He may Himself express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is God's tabernacle too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In which our God can rule and rest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ultimate completion 'tis"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God's work in humanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His full expression glorious"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru His redeemed eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
