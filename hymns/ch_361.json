{
  "url": "https://www.hymnal.net/cn/hymn/ch/361",
  "title": "主你启示一个奥秘",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "啟 示 一"
            },
            {
              "chord": "A",
              "text": "個"
            },
            {
              "chord": "A7",
              "text": "奧"
            },
            {
              "chord": "D",
              "text": "祕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就 是 我 同 你 死 的"
            },
            {
              "chord": "A",
              "text": "理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "不 用"
            },
            {
              "chord": "",
              "text": "別 法， 不"
            },
            {
              "chord": "A",
              "text": "用"
            },
            {
              "chord": "A7",
              "text": "別"
            },
            {
              "chord": "D",
              "text": "能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 就 看 見 完"
            },
            {
              "chord": "A",
              "text": "全"
            },
            {
              "chord": "A7",
              "text": "得"
            },
            {
              "chord": "D",
              "text": "勝。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的十架就是我的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其光照耀我生命里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一信与你同钉那里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界失去它的能力。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我既与你十架同钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜过罪恶、自己、人情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就怎能尚追求地物？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就怎能再盼望世福？"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此，我便到你那里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同站十架死地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你命、你权，全是我的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我与你合而为一。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你既是来败坏撒但"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切作为、势力、死权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我自然可和你同胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天经历你的大能。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我主，我们只能"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "靠着你的十架得胜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你走的路，我们当走，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到与你见面时候。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今接受你的同钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你所赐永远的灵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我更懂你死意义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离罪、己、肉体。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿得胜像你得胜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你同王，同得权能！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "背负十架，我们若肯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这些荣耀必定有分！"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "与基督的联合",
    "time": "2/2",
