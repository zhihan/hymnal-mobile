    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we praise Thee for the picture:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecration’s ram we see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Burnt for God’s full satisfaction,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eaten and enjoyed to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art now our ram, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Offered for the will of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy consecration, faultless,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may walk where Thou hast trod."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As we eat Thyself, Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrated we become;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy wondrous life within us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy obedience is our own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more need we strive and struggle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrated try to be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecration dwells within us—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our part to eat of Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we praise Thee, consecration"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is nought else but Thee as food:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we eat Thee and enjoy Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are all made one with God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One in will and one in purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We become by eating Thee:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we take and eat Thyself, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consecrated we will be."
            }
          ]
        }
      ],
