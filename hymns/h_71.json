    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name encircles every grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God as man could show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There only could He fully trace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A life divine below."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus—it speaks a life of love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of sorrows meekly borne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It tells of sympathy above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whatever makes us mourn."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the One who knew no sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made sin to make us just;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou gav'st Thyself our love to win,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our full confiding trust."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The mention of Thy name shall bow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts to worship Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The chiefest of ten thousand Thou,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose love has set us free."
            }
          ]
        }
      ],
