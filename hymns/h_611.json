{
  "url": "https://www.hymnal.net/cn/hymn/h/611",
  "title": "God's glorious substance Spirit is",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "God's glorious"
            },
            {
              "chord": "",
              "text": "substance"
            },
            {
              "chord": "A",
              "text": "Spirit"
            },
            {
              "chord": "D",
              "text": "is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His essence, holy"
            },
            {
              "chord": "E",
              "text": "and"
            },
            {
              "chord": "E7",
              "text": "di"
            },
            {
              "chord": "A",
              "text": "vine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "To contact"
            },
            {
              "chord": "",
              "text": "God and"
            },
            {
              "chord": "B7",
              "text": "Him en"
            },
            {
              "chord": "Em",
              "text": "joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "His Spirit"
            },
            {
              "chord": "D",
              "text": "I must"
            },
            {
              "chord": "A",
              "text": "touch with"
            },
            {
              "chord": "D",
              "text": "mine."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The spirit is the innermost,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The part of man most deep and real;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If he would contact God in life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis with the spirit he must deal."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The worship which the Father seeks"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is in the spirit's strength alone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Spirit into man's would come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That His and man's may thus be one."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Spirit unto spirit calls"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The two commingle and are one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man's spirit is the Spirit's home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit doth man's life become."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man's spirit must God's Spirit touch"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If in God's fulness he would live;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis only with the spirit thus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That he to God may worship give."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In ministry and fellowship"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man to the spirit we must bring;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All ministry should turn to prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit to spirit answering."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit we must pray and serve,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit touch the life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit grow, in spirit build,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Christ thru us may fully shine."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, to the spirit I would turn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And learn to truly contact Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit thus will flow with mine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And overflow eternally."
            }
          ]
        }
      ]
    }
  ],
