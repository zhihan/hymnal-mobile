{
  "url": "https://www.hymnal.net/en/hymn/h/887",
  "title": "The name of Jesus is our stand",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "The name"
            },
            {
              "chord": "",
              "text": "of Jesus is our stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It"
            },
            {
              "chord": "A",
              "text": "is our"
            },
            {
              "chord": "A7",
              "text": "victo"
            },
            {
              "chord": "D",
              "text": "ry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not on ourselves do we rely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But,"
            },
            {
              "chord": "E7",
              "text": "mighty"
            },
            {
              "chord": "",
              "text": "Lord, on"
            },
            {
              "chord": "A",
              "text": "Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "Our"
            },
            {
              "chord": "D",
              "text": "weapons"
            },
            {
              "chord": "",
              "text": "are not"
            },
            {
              "chord": "A",
              "text": "arms of"
            },
            {
              "chord": "D",
              "text": "flesh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But ours the Spirit's"
            },
            {
              "chord": "A",
              "text": "sword,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "And"
            },
            {
              "chord": "D",
              "text": "God's whole"
            },
            {
              "chord": "",
              "text": "armor putting"
            },
            {
              "chord": "G",
              "text": "on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "D",
              "text": "battle"
            },
            {
              "chord": "A",
              "text": "in"
            },
            {
              "chord": "A7",
              "text": "the"
            },
            {
              "chord": "D",
              "text": "Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold, the foe doth meet and plot,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stand firm in one accord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though war be fierce and darkness thick,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Resist him in the Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If one thru fear should backward turn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He undermines the rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, do not let your brothers down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor by you be distressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The devil knows his time is short,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the more enraged,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by his wiles would weaken us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the battle’s waged."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The trials now more numerous are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The suff’ring e’en more sore,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The force of hell opposing us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More dreadful than before."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What should our posture be today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In such a desperate hour?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Should we our ease and pleasure seek"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And let the foe devour?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or with increasing conflict strong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Courageous to endure?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis here that life or death is won!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who will God’s praise secure?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Christ the Lord we then would stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Conqueror!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him we would endure the pain"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the fight is o’er."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The hour of triumph soon we’ll see—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord will come again;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If now we suffer for His sake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then we with Him shall reign."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
