{
  "url": "https://www.hymnal.net/en/hymn/h/1303",
  "title": "The kingdom of God is at hand",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "The kingdom"
            },
            {
              "chord": "",
              "text": "of God is at hand:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "Ten"
            },
            {
              "chord": "D",
              "text": "virgins"
            },
            {
              "chord": "",
              "text": "with"
            },
            {
              "chord": "A7",
              "text": "lamps lit"
            },
            {
              "chord": "",
              "text": "a"
            },
            {
              "chord": "D",
              "text": "rise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To go forth to meet the Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "But"
            },
            {
              "chord": "D",
              "text": "only"
            },
            {
              "chord": "",
              "text": "five"
            },
            {
              "chord": "A7",
              "text": "virgins"
            },
            {
              "chord": "",
              "text": "are"
            },
            {
              "chord": "D",
              "text": "wise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wise have abundance of"
            },
            {
              "chord": "G",
              "text": "oil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "D",
              "text": "foolish"
            },
            {
              "chord": "",
              "text": "are empty in"
            },
            {
              "chord": "A7",
              "text": "stead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "D",
              "text": "wise used"
            },
            {
              "chord": "",
              "text": "their time to buy oil,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "The"
            },
            {
              "chord": "D",
              "text": "others"
            },
            {
              "chord": "",
              "text": "their"
            },
            {
              "chord": "A7",
              "text": "chance forfeit"
            },
            {
              "chord": "D",
              "text": "ed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, Thy message is clear:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re coming for those who are wise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who buy up their oil today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who deal with all hindering ties."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those virgins whose souls are transformed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose vessels much oil contain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who love not their lives unto death—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They in Thy great kingdom shall reign."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our lamps to shine forth must be trimmed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By calling on Thee every day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit we must exercise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To burn all the oldness away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But there is a much deeper need:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reality in us must grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until it makes home in our hearts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till oil in our vessels o’erflows."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We see how this age is so dark,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We know that blest hour is near."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Lord may return anytime—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, strike in us this holy fear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may each moment redeem"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By taking Thy Word in by prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By learning each lesson You give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus for that hour prepare."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, how blest to be those"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who bring in Thy kingdom to earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Affording Thee rule over all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And showing to all Thy great worth!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How blest to be those at the feast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where Thou wilt be one with Thy Bride!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make us wise virgins for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who e’er in Thy presence abide."
            }
          ]
        }
      ]
    }
  ],
