              "chord": "D",
              "text": "didst"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At Calv'ry's cross once come to"
            },
            {
              "chord": "A",
              "text": "rest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "Yet Thou"
            },
            {
              "chord": "",
              "text": "art working"
            },
            {
              "chord": "G",
              "text": "still to"
            },
            {
              "chord": "A",
              "text": "day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "But in"
            },
            {
              "chord": "",
              "text": "another"
            },
            {
              "chord": "A",
              "text": "form"
            },
            {
              "chord": "A7",
              "text": "ex"
            },
            {
              "chord": "D",
              "text": "pressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy saving pow'r Thou still dost show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou still dost speak, enlighten, guide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou and the Spirit in one stream"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweep many in Thy living tide."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Him Thy power's not withheld;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Him Thy working does not cease;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou still dost comfort and command,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Encourage, strengthen, and release."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thou art with the Spirit one"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His coming means that Thou hast come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His indwelling is Thine own,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thou the Spirit hast become."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He executes within my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy desires and Thy demands,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As for the Father here on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast performed all His commands."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By knowing Him we know Thyself;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Obeying Him we Thee obey;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Allowing Him ourselves to fill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We're filled with Thee, O wondrous way!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art not far away in heav'n,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leaving us here alone, apart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thou art still on earth; how grand!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou livest right within my heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
