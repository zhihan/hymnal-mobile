    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must enjoy, experience, and take Christ as our Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We live to Him, we die to Him, bought by His precious blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are the Lord’s, His life outpoured becomes our strength within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then all our labor in the Lord is absolutely Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must enjoy, experience, and take Christ as our Head;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Christ, the resurrected One, we constantly are led;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This fourfold power to the church becomes our heav’nly link,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abundantly supplying all, more than we ask or think."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must enjoy, experience, and take Christ as our Spouse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Husband, the pneumatic Christ, will build our spiritual house;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Affectionate and personal, our Husband is our Friend,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Advocate, our Comforter, our Shepherd without end."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Husband, Head, our Lord and King, is Christ, the glorified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By life His Body will be built, His Bride be beautified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The gates of hell cannot prevail when we are built in Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This Christ enjoyed will usher in the New Jerusalem!"
            }
          ]
        }
      ],
