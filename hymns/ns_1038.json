{
  "url": "https://www.hymnal.net/en/hymn/ns/1038",
  "title": "Let the Amen Sound Again",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, You are the great I Am,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our pathways set by Your own hand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain more ground and bear more fruit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each day, grow in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Defeat your enemy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Amen sound again—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Amen sound again—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Amen sound again—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amen, Amen! Amen, Amen!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I have no confidence"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In who I am or what I do."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only You are able to"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Endure and overcome;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sustain with just one word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How we need Your life each day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To wash our oldness all away."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Renew me to be Spirit-filled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By your abundant grace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will run this race."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Shining in the darkest hour,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Comfort us in every trial;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hold us in Your very hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Body life is real,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord You are so near."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Saving us from emptiness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Broken cisterns holding less,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deceitful riches, grasping air,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only You are preciousness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will love You with our best."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord we praise You for Your way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To free the flow of life each day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every joy or suffering"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Experienced, not vain—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We would not be put to shame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let our Amen sound again—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let our Amen sound again—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let our Amen sound again—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Amen, Amen! Amen, Amen!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Amen Amen! Amen!)"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
