      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bread and cup set on the table,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which we all partake as one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Clearly manifest in symbol"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the work of Thy dear Son."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cross, His body broken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made a new and living way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We come forward, now 'tis open,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly \"Abba, Father\" say."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious blood has flowed out for us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sins, transgressions, cleared away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteousness and anger toward us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more claim on us can lay."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood stands before Thee ever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Better things it does proclaim."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus He's silenced the accuser"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And released us from self-blame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lower than the angels' measure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What is man, O God, to Thee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou visit, even treasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reconciling him to Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only man receives forgiveness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the angels who rebelled."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thee, Father, praise ne'er ceases"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy grace unparalleled."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
