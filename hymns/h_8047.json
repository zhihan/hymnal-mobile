              "text": "Thou art"
            },
            {
              "chord": "D7",
              "text": "on the"
            },
            {
              "chord": "",
              "text": "throne re"
            },
            {
              "chord": "G",
              "text": "joicing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine e"
            },
            {
              "chord": "Am",
              "text": "ternal"
            },
            {
              "chord": "D7",
              "text": "plan is"
            },
            {
              "chord": "G",
              "text": "done:"
            }
          ]
        },
        {
          "segments": [
            {
