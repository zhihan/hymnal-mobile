    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主使我作福音的出口，让福音火焚烧我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交出我家作福音出路，让主骑驴驹经过。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "抓住机会尽福音本份，到所有居人地带，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祝福万族催促主再来，带进国度的时代。"
            }
