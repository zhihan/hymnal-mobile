    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在素质上并在经纶上，被终极的灵充溢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "传好信息给困苦的人，使被囚的得开释；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宣扬救主悦纳人禧年，让世人都归向祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在正是拯救的日子，主！得着我的全家！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "福音号角在吹响，真理旌旗在飘扬。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来，神福音勤奋的祭司！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来！起来！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凡我所行都是为福音，我不以福音为耻！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺从恩膏不住的祷告，真正福音的服事！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "放下自己同心并同魂，进入福音的交通。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天被真理的话构成，开展福音的行动。"
            }
