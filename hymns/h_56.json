    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art Thyself the very God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost embody Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee is manifested God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we see God therein."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Effulgence of God’s glory, Thou,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee God shines on us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Expression of His substance, Thou,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee He’s real to us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee God is the life to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee He is the light;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee His nature we partake"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Him we unite."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee the grace of God subsists,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God we enjoy in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His truth in Thee is also found,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His full reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee God’s fulness we receive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which fills from grace to grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee with God we’re mingled here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till one in every phase."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord our God, we worship Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we have our all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself we treasure in our heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Name we love to call."
            }
          ]
        }
      ],
