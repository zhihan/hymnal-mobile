    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You’ve the right to take all that I love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But replace it with Yourself much more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are what I need, give Yourself to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do not give all that I want."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything is sure to pass away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everyone is going their own way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But I still have You and You have me too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving one another’s sweet."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I give You the first place in all things by faith."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let nothing take Your place in all my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Infuse me with Yourself abundantly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Til we meet, dear Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll love You with the best love."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I treasure my time alone with You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to gain the best love You long for."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My dearest Husband, draw me with Yourself"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into Your chambers right now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be the first in all my work and life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be the first in all my service too."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In relationships, You must be the first;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have preeminence in me."
            }
          ]
        }
      ],
