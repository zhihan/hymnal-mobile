              "text": "And I am not my own."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Weary soul, give up the struggle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cease at length thyself to own;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Give yourself away to Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And belong to Him alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Once He gave His all to win thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now He asks as much of thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All He has He fully gives thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let thy love His portion be."
            }
          ]
