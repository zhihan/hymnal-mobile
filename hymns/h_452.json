    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the blessed rest it brings us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To belong to Christ alone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can draw on all His fulness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we’ve nothing of our own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessed Jesus, take me, own me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me, keep me wholly Thine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deign to find in me Thy portion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While I joy to call Thee mine."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
