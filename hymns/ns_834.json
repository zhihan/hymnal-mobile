{
  "url": "https://www.hymnal.net/en/hymn/ns/834",
  "title": "What a Mystery, Mystery of Mysteries",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What a mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mystery of mysteries,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God is Triune,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God is one yet three!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, Son, and Spirit flow in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord for His divine Trinity!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Father planned for His purpose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God the Son died and redeemed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We were sealed with God, the Holy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the Triune God has a plan, economy!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What a mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wonderful mystery,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God is Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He flows the Son to me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling Jesus’ name, we get all three,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Lord for His divine Trinity!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How I love His name, “Oh Lord Jesus!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I call He comes to me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Spirit from and with the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, the Triune God reaches me, even me!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
