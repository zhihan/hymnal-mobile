{
  "url": "https://www.hymnal.net/cn/hymn/ch/19",
  "title": "圣父我们向你下拜",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "圣 父，"
            },
            {
              "chord": "F",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "向 你"
            },
            {
              "chord": "C",
              "text": "下 拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献 上 同 声"
            },
            {
              "chord": "D",
              "text": "的 歌"
            },
            {
              "chord": "G",
              "text": "颂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "你 何"
            },
            {
              "chord": "F",
              "text": "圣 别、"
            },
            {
              "chord": "",
              "text": "你 何"
            },
            {
              "chord": "C",
              "text": "超 凡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "配 得 永 远"
            },
            {
              "chord": "G",
              "text": "的 尊"
            },
            {
              "chord": "C",
              "text": "崇。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱父神，你心是爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的作为是公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你性情却是圣别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分你自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你已借着基督宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我永远成圣洁；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也借着你的真理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我全人被分别。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾借着你的圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我圣别归于你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "叫我完全得以成圣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人，灵、魂与身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你恩，我已得到"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督圣洁的生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此使我得以有分"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你那圣别的性情。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将来在那圣城之中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全有分你圣别，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远要作极峰见证："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是如何的圣洁！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
