{
  "url": "https://www.hymnal.net/cn/hymn/ch/57",
  "title": "哦主你曾成为人子",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 曾 成"
            },
            {
              "chord": "D",
              "text": "为 人"
            },
            {
              "chord": "G",
              "text": "子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "有 了"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "们 人"
            },
            {
              "chord": "A",
              "text": "的 性"
            },
            {
              "chord": "D",
              "text": "情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "穿"
            },
            {
              "chord": "G",
              "text": "上 我"
            },
            {
              "chord": "D7",
              "text": "们 血"
            },
            {
              "chord": "G",
              "text": "肉 之"
            },
            {
              "chord": "",
              "text": "体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为"
            },
            {
              "chord": "D",
              "text": "一 贞"
            },
            {
              "chord": "",
              "text": "洁 童"
            },
            {
              "chord": "C",
              "text": "女"
            },
            {
              "chord": "D7",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "生。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虚己取了奴仆形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "行走在这艰苦尘世；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尝尽人生所有苦味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍受苦难从无所辞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生在马槽，作一婴孩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长在干地，出身寒门；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "劳苦工作如一木匠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "终被处死像一犯人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神虽使你从死复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仍带着我们人性；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽穿上神圣形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是一人上升天庭。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今在宝座掌管一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀之中仍是一人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣光中与神同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以人身位满足神心。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "带着荣耀，你要回来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是一人显于众目；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万王之王、万主之主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍带人性为人所睹。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "将来你在新天、新地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要作万有一切中心；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然你是神圣之主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍带人性永远长存。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
