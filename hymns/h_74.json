    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There is a name that’s still more precious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That stirs our hearts with fondest love:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is the charming name of Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The name all other names above."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It tells me that He is my Savior"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From sin and sickness and the grave."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love the precious name of Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I am one He came to save!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though dear to us the name of Jesus,"
