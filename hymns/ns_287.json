{
  "url": "https://www.hymnal.net/en/hymn/ns/287",
  "title": "There are Times",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There are times in my life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When my heart is embittered."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There are questions unanswered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, You’re drawing me"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To enter"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into Your blessed sanctuary"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And turning my eyes heavenward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The questions of constant inquiry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are changed to these words,"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Whom do I have in heaven"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You, dear Jehovah."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My flesh and my heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Constantly fail,"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But God’s still"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The strength of my heart and my portion;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him forever I’ll draw near."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve made Jehovah my sweet refuge."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So now throughout the years"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn my view to see You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I need to see Jesus!!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I don’t understand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ways that You take;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A babe and suckling always praising."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying Your worth day by day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let each experience constitute me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So Your life I’ll display"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every way."
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
