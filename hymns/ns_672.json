    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word we speak is the Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him who we’ve known, we testify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Building up the church as prophesied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we speak, Satan flees;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaking God defeats the enemy."
            }
          ]
        }
      ],
