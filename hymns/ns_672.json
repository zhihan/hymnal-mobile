    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word received is life and Spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit we must exercise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To receive the life embodied in the Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Read, eat, breathe, everyday;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take God in His Word is necessary."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So let the Word of Christ dwell in you (richly!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all wisdom, teaching, admonishing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each one the other with psalms and hymns;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Singing with grace, sing with grace to God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "in your hearts to God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(on last chorus)"
            }
          ]
        },
        {
