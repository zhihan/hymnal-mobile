{
  "url": "https://www.hymnal.net/en/hymn/ns/672",
  "title": "Richly!",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word is living, a divine Person—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ the Son of God, the living God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It is God defined, explained, and expressed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Word comes, God comes."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Word is present, God is present."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So let the Word of Christ dwell in you (richly!)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all wisdom, teaching, admonishing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each one the other with psalms and hymns;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Singing with grace, sing with grace to God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "in your hearts to God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(on last chorus)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(To God.)"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word received is life and Spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit we must exercise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To receive the life embodied in the Word."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Read, eat, breathe, everyday;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take God in His Word is necessary."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
