          "segments": [
            {
              "chord": "",
              "text": "得 勝！ 得 勝！ 阿 利 路 亞！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基"
            },
            {
              "chord": "C",
