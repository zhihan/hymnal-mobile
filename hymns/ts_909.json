    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那古蛇，大龙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是魔鬼已经被摔下去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但和他的使者"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能再迷惑设骗局，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们颂赞之声"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同雷鸣将主永高举。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘救恩、能力、国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并祂基督的权柄到了！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因那昼夜控告我们弟兄的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已被摔倒，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如今召会正在地上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "执行天上的宣告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们胜过那控告者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为宝血有功效，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着口中的话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们宣告："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘一切都成了！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们虽至于死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "魂生命也不爱惜计较。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！弟兄们，姊妹们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "请听天上又发声音："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘巴比伦倾倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倾倒了！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "─怎能不令人欢欣。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已从她出来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等有福又可庆幸！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奥秘大巴比伦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她乃是众淫妇的母亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们极其憎恶"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "她所装满的污秽邪淫；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但神已加倍罚她，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我们灵欢欣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "救恩、荣耀、权能，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都属我们的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主！祂凭真实公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "讨罪伸冤，审判了淫妇。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那烧她的烟直往上冒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们欢呼！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘神的众仆，无论大小，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当赞美神，’祂嘱咐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同众水的声音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又如雷鸣，群众同欢呼："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的神全能者"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作王作主！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现在我们应当欢喜"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "快乐向神归荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羔羊婚娶时候到了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新妇也已豫备好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙了救恩穿上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光明洁白的细麻义袍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "魔鬼身在火湖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是约翰目睹的事实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今后不要怕他信口雌黄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或造谣生事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大胆宣告他的判辞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是圣徒得胜之路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！最大的奇景─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新耶路撒冷由天降！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督新妇妆饰整齐"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "模成基督的模样；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人调和建造一起"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出神荣耀形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神在人间支搭帐幕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人永同住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的圣洁、荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从人身上完全的显出！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "听哪！主在宣告："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘都成了！’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神已心满意足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！阿利路亚！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督已经得胜！"
            }
          ]
        }
      ]
    }
