          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I've made exchange of masters now,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The vows of glory bind me,"
            }
          ]
        },
