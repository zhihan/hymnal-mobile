    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I've left the old sad life of sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its follies all forsaken;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My standing place is now in Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His holy vows I've taken;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beneath the standard of the cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world henceforth shall find me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I've passed in Christ from death to life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And left the world behind me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
