    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who is this that comes in glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the trump of jubilee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord of battles, God of armies,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has gained the victory;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who on the cross did suffer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who from the grave arose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He has vanquished sin and Satan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He by death, He by death, He by"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "death has spoiled His foes."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While He lifts His hands in blessing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is parted from His friends;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While their eager eyes behold Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He upon the clouds ascends;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He who walked with God and pleased Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Preaching truth and doom to come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He, our Enoch, is translated"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His home, to His home, to His"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "everlasting home."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our heavenly Aaron enters,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His blood, within the veil;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joshua now is come to Canaan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the kings before Him quail;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now He plants the tribes of Israel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In their promised resting-place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our great Elijah offers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of His grace, of His grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "double portion of His grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He has raised our human nature"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the clouds to God's right hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There we sit in heav'nly places,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There with Him in glory stand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus reigns, adored by angels;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Man with God is on the throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mighty Lord, in Thine ascension"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We by faith, we by faith, we by"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "faith behold our own."
            }
          ]
        }
      ]
    }
