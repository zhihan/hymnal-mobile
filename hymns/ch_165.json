{
  "url": "https://www.hymnal.net/cn/hymn/ch/165",
  "title": "你是一切的祭物",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "你 是"
            },
            {
              "chord": "",
              "text": "一 切 的"
            },
            {
              "chord": "G",
              "text": "祭 物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为"
            },
            {
              "chord": "G7",
              "text": "我 神"
            },
            {
              "chord": "",
              "text": "所 豫"
            },
            {
              "chord": "C",
              "text": "备；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦， 其 意 义 何"
            },
            {
              "chord": "G",
              "text": "丰"
            },
            {
              "chord": "C",
              "text": "富、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何"
            },
            {
              "chord": "G",
              "text": "其 荣"
            },
            {
              "chord": "G7",
              "text": "耀、 甘"
            },
            {
              "chord": "C",
              "text": "美！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成"
            },
            {
              "chord": "G",
              "text": "全 父"
            },
            {
              "chord": "G7",
              "text": "神 的"
            },
            {
              "chord": "C",
              "text": "旨 意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满"
            },
            {
              "chord": "F",
              "text": "足 祂"
            },
            {
              "chord": "",
              "text": "心 所"
            },
            {
              "chord": "G",
              "text": "愿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应"
            },
            {
              "chord": "C",
              "text": "付 我"
            },
            {
              "chord": "F",
              "text": "们 的"
            },
            {
              "chord": "C",
              "text": "需 要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所"
            },
            {
              "chord": "G",
              "text": "缺 全"
            },
            {
              "chord": "G7",
              "text": "都 补"
            },
            {
              "chord": "C",
              "text": "满！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是馨香的燔祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "焚于神圣火焰；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作神甜美的香气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足神的心愿。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾行在神面前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神旨是你所顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献上无瑕的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我作神食物。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是甜美的素祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "调油加上乳香；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纯净、柔细又完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘美供神欣赏。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是完全平安祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和平为我成就；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且作食物何丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "供我同神享受。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的赎罪祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我你曾成罪；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借死成功了救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要将我赎回。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是我赎愆祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "担当我众罪愆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足我神的公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得蒙赦免。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你也是我的摇祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经从死复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阴府、死亡并黑暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都为我胜过。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你更是我的举祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我升到神前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我天界的食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得到饱满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
