      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing in my hands I bring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Simply to Thy cross I cling;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Naked, come to Thee for dress,"
            }
          ]
