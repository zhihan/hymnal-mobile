          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Foul, I to the fountain fly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash me, Savior, or I die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
