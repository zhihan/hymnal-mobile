              "chord": "",
              "text": "Could my tears forever flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All could never sin erase,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou must save, and save by grace."
            }
          ]
