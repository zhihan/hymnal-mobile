              "text": "Not the labor of my hands"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can fulfill Thy law's demands;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Could my zeal no respite know,"
            }
          ]
