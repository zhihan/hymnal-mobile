{
  "url": "https://www.hymnal.net/cn/hymn/ch/423",
  "title": "意志薄弱能力软弱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "意 志"
            },
            {
              "chord": "",
              "text": "薄 弱， 能"
            },
            {
              "chord": "A",
              "text": "力 软"
            },
            {
              "chord": "",
              "text": "弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "盼 望"
            },
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "D",
              "text": "经 全"
            },
            {
              "chord": "E7",
              "text": "都 消"
            },
            {
              "chord": "A",
              "text": "灭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 有 信"
            },
            {
              "chord": "D",
              "text": "托 你"
            },
            {
              "chord": "",
              "text": "的 工"
            },
            {
              "chord": "G",
              "text": "作"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将 我 这 人 温"
            },
            {
              "chord": "A7",
              "text": "柔 提"
            },
            {
              "chord": "D",
              "text": "挈。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "尽我所有，所有失败，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失败至今，失败频仍；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无何可信，信你能耐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能够抓我听你命令。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我的心稍微高仰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就近乎跌倒危地；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我不敢作，我不敢想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "事事处处，我需要你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是救主…刚强…体贴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我今寻求你面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然我是弱中弱者，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的能力是你恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
