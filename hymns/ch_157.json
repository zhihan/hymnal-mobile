  "title": "你之所是正合我需",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "主， 當"
            },
            {
              "chord": "",
              "text": "我 們 把"
            },
            {
              "chord": "C",
              "text": "你 思"
            },
            {
              "chord": "",
              "text": "念，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因"
            },
            {
              "chord": "D",
              "text": "你 所"
            },
            {
              "chord": "D7",
              "text": "是 我"
            },
            {
              "chord": "",
              "text": "們 敬"
            },
            {
              "chord": "G",
              "text": "拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 如 此 豐 富、 奇"
            },
            {
              "chord": "C",
              "text": "妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何 其 可"
            },
            {
              "chord": "G",
              "text": "寶、 何"
            },
            {
              "chord": "D7",
              "text": "其 可"
            },
            {
              "chord": "G",
              "text": "愛！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "之 所"
            },
            {
              "chord": "",
              "text": "是 正 合 我"
            },
            {
              "chord": "G",
              "text": "需！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 對 你 讚 美 洋"
            },
            {
              "chord": "D7",
              "text": "溢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "G",
              "text": "之 所"
            },
            {
              "chord": "",
              "text": "願 你 全 滿"
            },
            {
              "chord": "C",
              "text": "足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "綽 綽 有"
            },
            {
              "chord": "G",
              "text": "餘， 應"
            },
            {
              "chord": "D7",
              "text": "付 不"
            },
            {
              "chord": "G",
              "text": "已！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "实实在在你真是神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是那是光是爱之神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神，你作我们生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是神，你向我们赐恩。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你之所是正合我需！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心对你赞美洋溢！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我之所愿你全满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "绰绰有馀，应付不已！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "实实在在你也是人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是一柔细、纯良的人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是人，你使神心喜悦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是人，你能得着我心。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
