      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "荣 耀"
            },
            {
              "chord": "",
              "text": "归"
            },
            {
              "chord": "A",
              "text": "于 我"
            },
            {
              "chord": "D",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天 地 齐"
            },
            {
              "chord": "G",
              "text": "来 欢"
            },
            {
              "chord": "A",
              "text": "呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "向 祂"
            },
            {
              "chord": "",
              "text": "赞"
            },
            {
              "chord": "A",
              "text": "美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 的 恩"
            },
            {
              "chord": "D",
              "text": "典、 慈"
            },
            {
              "chord": "",
              "text": "爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "除 我"
            },
            {
              "chord": "",
              "text": "死"
            },
            {
              "chord": "D",
              "text": "亡、 悲"
            },
            {
              "chord": "",
              "text": "哀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高 唱 直 到 万 代，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "『羔 羊"
            },
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "D",
              "text": "配。』"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙恩人们都来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "环绕宝座敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向祂赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我宝血流出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神和好无阻；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞颂之声四布，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘羔羊是配。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "被赎族类都来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心向主敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向祂赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因祂我得欢乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "发出感恩诗歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来，口唱心和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘羔羊是配。’"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "事物虽然改迁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我依旧不变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向祂赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "诗歌不绝颂扬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊祂我主我王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢声上达穹苍，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘羔羊是配。’"
            }
          ]
        }
