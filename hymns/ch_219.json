              "chord": "",
              "text": "好叫对人我是证明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你乃是归荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，我奉子名祷告，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我信祷告已答应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今赞美答应可靠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安息只因话足凭。"
            }
          ]
        }
