      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今向你承认我的"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有失败和邪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有自满，所有刚愎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有心里的隐慝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父阿，救我脱离自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离化装的骄傲；"
