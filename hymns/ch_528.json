  "raw_sections": [
    "暗 过必 明 亮，",
    "苦 过必甜；",
    "弱 过 必刚 强，",
    "难 过 必安；",
    "损 过 必 有 益，",
    "风 过必静；",
    "劳 过必安 息，",
    "雨 过必晴。",
    "压过必高升，",
    "忧过必乐；",
    "死过必复生，",
    "失过必得；",
    "累过必轻松，",
    "困过必苏；",
    "迫过必从容，",
    "贫过必富。",
    "荡过必安居，",
    "孤过有伴，",
    "与主再无距，",
    "直到相见，",
    "十架变冠冕，",
    "叹息变赞，",
    "信望变眼见，",
    "再无疑难。"
  ]
