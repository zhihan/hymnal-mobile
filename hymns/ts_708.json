            {
              "chord": "D",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "同"
            },
            {
              "chord": "G",
              "text": "聲 歌"
            },
            {
              "chord": "",
              "text": "唱 歡"
            },
            {
              "chord": "D",
              "text": "呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 與"
            },
            {
              "chord": "A",
              "text": "王 一"
            },
            {
              "chord": "",
              "text": "同 居"
            },
            {
              "chord": "D",
              "text": "住！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "異 象 清 楚， 向"
            },
            {
              "chord": "Em",
              "text": "主 絕"
            },
            {
              "chord": "",
              "text": "對，"
            }
