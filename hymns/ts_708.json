    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们听见大雷声响，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众圣站住地方立场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！我们欢呼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "聚会中赞美主不止住。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不再流荡不定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸索寻找天上的星；"
            }
