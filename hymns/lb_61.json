{
  "url": "https://www.hymnal.net/en/hymn/lb/61",
  "title": "The Good Samaritan",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Part 1:"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A certain man was going down"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Jerusalem to Jericho,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Getting farther away from God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To this place of curse he’d go."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And as he went, among the robbers he fell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who stripped and beat him ’til he bled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, having taken everything that he owned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They left him lying there half dead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A certain priest was also going down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On that same road to Jericho."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He saw him and passed on the opposite side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A Levite did the same also."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "You know this man who was going down,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This man is me; this man is you,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who living in our fallen life away from God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were beaten sore and bled from many wounds."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We were stripped of all that we should have:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our virtue, honor, righteousness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We could not stand upright nor hold onto life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Toward God: no boldness nor access."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Religious ones observing our poor estate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Being the same could be no help."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They passed us by, not daring to come close."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We only heard we’d go to hell."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As sinners under the law condemned,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which left us beaten and disgraced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We all were robbed and dying from so many hurts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From small transgressions to our sins so great."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Part 2:"
            }
          ]
        }
      ],
      "type": "verse"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But a certain Good Samaritan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Despised, of Whom they said,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Don’t give me Jesus!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bound up all our wounds,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pouring oil and wine upon them,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brought us to the inn and said,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Take care of him.”"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He had to take a journey to come down"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just to reach us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though God, He was so willing to become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A human babe."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He came through human living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Observed our dire condition,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, moved with deep compassion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He died and rose to save!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He came and bound our wounds up;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He healed these damaged persons."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He poured in oil and wine—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Spirit and His life divine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He placed us on His donkey"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To carry us so lowly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And brought us to the church life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With blessing for our care."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We love this dear Man-Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Divine One, fully human"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose tender care, so merciful"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bountiful to save"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Condemned and dying sinners,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reveals the highest standard"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of His morality seen in His precious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saving grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Take care..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And whatever you spend in addition on him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I return, I will repay you.”"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
  "metadata": {
    "category": "Experience of Christ",
    "time": "4/4"
  },
