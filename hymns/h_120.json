        {
          "segments": [
            {
              "chord": "G",
              "text": "The Lord"
            },
            {
              "chord": "",
              "text": "is ris'n; and death's dark"
            },
            {
              "chord": "D",
              "text": "judgment"
            },
            {
              "chord": "G",
              "text": "flood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is passed, in Him who"
            },
            {
              "chord": "A",
              "text": "bought us"
            },
            {
              "chord": "A7",
              "text": "with His"
            },
            {
              "chord": "D",
              "text": "blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The"
            },
            {
              "chord": "G",
              "text": "Lord is"
            },
            {
              "chord": "",
              "text": "ris'n: we stand beyond the doom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of"
            },
            {
              "chord": "C",
              "text": "all our"
            },
            {
              "chord": "",
              "text": "sin, through"
            },
            {
              "chord": "D",
              "text": "Jesus'"
            },
            {
              "chord": "D7",
              "text": "empty"
            },
            {
              "chord": "G",
              "text": "tomb."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is ris'n: with Him we also rose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in His grave see vanquished all our foes."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is ris'n: beyond the judgment land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him, in resurrection-life we stand."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is ris'n: and now redeemed to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We tread the desert which His feet have trod."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is ris'n: the sanctu'ry's our place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where now we dwell before the Father's face."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is ris'n: the Lord is gone before."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We long to see Him, and to sin no more."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is ris'n: our triumph-shout shall be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Thou hast prevailed! Thy people, Lord, are free!\""
            }
          ]
        }
      ]
    }
