{
  "url": "https://www.hymnal.net/cn/hymn/ch/295",
  "title": "只要是你道路",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "只 要"
            },
            {
              "chord": "",
              "text": "是 你 道"
            },
            {
              "chord": "Am",
              "text": "路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "D",
              "text": "論 如"
            },
            {
              "chord": "D7",
              "text": "何 黑"
            },
            {
              "chord": "G",
              "text": "暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 管 怎 樣 艱"
            },
            {
              "chord": "Am",
              "text": "苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求 你 為"
            },
            {
              "chord": "G",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "揀"
            },
            {
              "chord": "G",
              "text": "選。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "平坦或是崎岖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必定都是上好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "笔直或是弯曲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安息都必引到。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不敢自作选择，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即可，我也不愿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你为我定夺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脚步不偏。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "以苦或是以乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我杯由你充满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照你看为最妥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祸福为我拣选。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为我选择友人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "选择疾病、健康；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我选择责任，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "选择衰贫、隆昌。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "事情不论大小，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不随我的爱好；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的引导，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我智慧、至宝。"
            }
          ]
        }
      ]
    }
  ],
