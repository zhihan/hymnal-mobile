      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有主的约柜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "走在我们前头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要领我们走新路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向来没有走过。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，约但河水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已经立起如垒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们这一代应该"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "打断世界的潮流！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "走，走，走！我们大伙儿"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浩浩荡荡往前走！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美主，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们到了吉甲；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "老旧已经埋葬了，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "肉体也被割下。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃了迦南土产，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吗哪不再稀罕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不再像从前"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全靠神迹度日。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吃，吃，吃！为着争战"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天吃迦南产物！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "与主同站在一边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不怕没主同在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照着主吩咐去行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为主是元帅！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论关得多紧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这城耶利哥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等我们大声呼喊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你就非倒塌不可！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "去，去，去！我们出去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "把各城一一夺取。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这全地不为别的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是为着召会！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们奉献一切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你能早归回。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若还不满意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们也不满意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "疯，疯，疯！为着全岛"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们要继续发疯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到神所应许的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "没有一句话落空。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
