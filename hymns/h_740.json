    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To God, the man is His expression,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And man is of God’s life possessed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The man is wholly God’s possession,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God thru man is thus expressed."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Redemption is accomplished fully"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In man, God’s wisdom thus to show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation is expounded wholly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By man, that all creation know."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s service in this dispensation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Requires that man should work with Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus God and man in close relation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And joint dependence work therein."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is not God Himself to labor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor man to try to serve alone,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But God and man to work together"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each moment that His plan be shown."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The principle of incarnation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all our work we must apply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all our gift and operation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we as one may serve thereby."
            }
          ]
        }
