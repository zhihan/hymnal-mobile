    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今投靠于洗罪泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗净一切污秽罪愆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借主宝血我罪得赦免，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洁白如雪立于神前。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙神称义非凭我优点，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃因基督活我里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属天性情我取用无间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面我得完全。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请来畅饮于活水泉源，"
