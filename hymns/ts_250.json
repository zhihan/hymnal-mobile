    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今投靠于洗罪泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洗净一切污秽罪愆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借主宝血我罪得赦免，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洁白如雪立于神前。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙神称义非凭我优点，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃因基督活我里面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属天性情我取用无间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面我得完全。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请来畅饮于活水泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无须代价只要你愿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活水供应甘甜丰富无限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因主自己就是这泉。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主也是我医治泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我秘诀供应无限；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超人智慧所及所见，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也非财富可以兑现。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这医治活泉神圣完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流自救主被刺肋边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂受鞭伤使我得康健，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又来安家在我心间。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
