        {
          "segments": [
            {
              "chord": "",
              "text": "也非财富可以兑现。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这医治活泉神圣完全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流自救主被刺肋边；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂受鞭伤使我得康健，"
            }
          ]
        },
        {
          "segments": [
