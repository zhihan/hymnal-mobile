              "chord": "",
              "text": "活水供应甘甜丰富无限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因主自己就是这泉。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主也是我医治泉源，"
