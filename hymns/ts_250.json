    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱畅饮于喜乐泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我力量溢我心田；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主是我日光辉煌灿烂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的欢欣在祂里面。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "草木荣华转眼即凋残，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人间宴乐短似云烟；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主作我喜乐从未消减，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以神为乐在地如天。"
            }
          ]
        }
