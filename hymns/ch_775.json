  "title": "哦主耶稣你的赎民",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主"
            },
            {
              "chord": "",
              "text": "耶 穌， 你 的"
            },
            {
              "chord": "A",
              "text": "贖 民"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "是 你"
            },
            {
              "chord": "A",
              "text": "身 體"
            },
            {
              "chord": "A7",
              "text": "並 新"
            },
            {
              "chord": "D",
              "text": "婦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作 你 豐 滿、 作 你"
            },
            {
              "chord": "A",
              "text": "表 現，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "使 你"
            },
            {
              "chord": "A7",
              "text": "彰 顯"
            },
            {
              "chord": "",
              "text": "你 豐"
            },
            {
              "chord": "D",
              "text": "富。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "你 永"
            },
            {
              "chord": "A7",
              "text": "是 她"
            },
            {
              "chord": "D",
              "text": "一 切"
            },
            {
              "chord": "",
              "text": "一 切，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "她 是"
            },
            {
              "chord": "A7",
              "text": "你 恩"
            },
            {
              "chord": "D",
              "text": "的 宣"
            },
            {
              "chord": "",
              "text": "告；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 要 將 她"
            },
            {
              "chord": "G",
              "text": "完 全"
            },
            {
              "chord": "D",
              "text": "浸 透，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "要 她"
            },
            {
              "chord": "D",
              "text": "有 分"
            },
            {
              "chord": "A7",
              "text": "你 榮"
            },
            {
              "chord": "D",
              "text": "耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看 哪， 神 的 聖"
            },
            {
              "chord": "A",
              "text": "城！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "滿 了"
            },
            {
              "chord": "A7",
              "text": "神 的"
            },
            {
              "chord": "D",
              "text": "光 明！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 是 神 完"
            },
            {
              "chord": "G",
              "text": "滿 的"
            },
            {
              "chord": "",
              "text": "表 現，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "永 顯"
            },
            {
              "chord": "A7",
              "text": "於 人"
            },
            {
              "chord": "D",
              "text": "性。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是神与人完全相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "大哉，敬虔的奥秘；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的荣耀，丰满、灿烂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人作神居，荣无比。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是一宇宙伟大器皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全然表现神丰满；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全调着神的圣洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使神荣美得彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪，神的圣城！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满了神的光明！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是神完满的表现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永显于人性。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是神所变化的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一个永活的组合；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同珍珠、宝石珍贵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神荣形相符合。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从神宝座－她的中心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流出生命的活水；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督在此作生命树，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "结出鲜果，丰而美。"
            }
          ]
        }
      ],
