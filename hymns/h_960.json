    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm longing for His presence blest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And dare not slothful be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While waiting for my Lord's return,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His own dear self to see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My only hope—that He may come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And change my faith to sight;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is no other joy on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which gives my heart delight."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart is always with Himself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My eyes are heavenward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My lips would utter nothing else"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than meeting with my Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The coming of the Lord draws nigh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His coming is for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His promise ever standeth firm"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And soon fulfilled I'll see."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior, all Thy holy words"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can never doubted be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With them encouraged day by day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I'm faithful unto Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may Thy glory soon appear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The foe be overthrown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy promises be realized,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we brought to Thy throne."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy saving arm a refuge is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior God, to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou as the Father keepeth them"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who put their trust in Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sheep and shepherd are of one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The head and body same;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None e'er can pluck from out Thy hand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The child who trusts Thy Name."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A thousand hands won't hinder me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor will ten thousand eyes;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thorns upon the road but help"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Me onward to the prize."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Arise, my spirit and my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And let the world go by;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord of life will take me soon"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be with Him on high."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou healing sun! Thou hope of man!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I really love Thy ray."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, righteous Lord! oh, glorious King!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I bow to Thee and pray:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may Thou soon ascend Thy throne"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And quickly show Thy face;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heav'nly kingdom may Thou found"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grant all men Thy grace."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The truth should triumph and be king,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And freedom should be queen;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But falsehood, which has rampant run,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Head of the world be seen."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We ask Thee, Truth, to quickly come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bring Thy light from heav'n;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The foe be crushed and all Thy sons"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into Thy bosom giv'n."
            }
          ]
        }
      ]
    }
  ],
