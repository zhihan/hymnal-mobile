  "title": "Serve Him!",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "Serve Him!"
            },
            {
              "chord": "",
              "text": "Serve Him! We can serve Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "In this"
            },
            {
              "chord": "G",
              "text": "age and"
            },
            {
              "chord": "D",
              "text": "in the"
            },
            {
              "chord": "G",
              "text": "next!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For eternity we'll serve Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "How we'll"
            },
            {
              "chord": "",
              "text": "serve Him, He knows"
            },
            {
              "chord": "D",
              "text": "best!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a priv'lege!"
            },
            {
              "chord": "G",
              "text": "What an"
            },
            {
              "chord": "",
              "text": "honor!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "As His"
            },
            {
              "chord": "",
              "text": "priests we"
            },
            {
              "chord": "D7",
              "text": "are so"
            },
            {
              "chord": "G",
              "text": "blessed!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As His priests we must come forward,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To enjoy our precious Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we spend time in His presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh what grace He does afford!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So that when we serve together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will serve in one accord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the basis of our service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood is our surety!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It shuts up the mouth of Satan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Giving us full liberty!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is now our priestly clothing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Stately robes” for service, He!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now the key for all our service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is not our ability."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To “Serve Him!” we must in spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come to Him continually!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit with our spirit working,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined as one eternally!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
