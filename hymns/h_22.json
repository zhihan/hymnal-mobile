      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Loving is Thy heart, dear Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteous ever are Thy ways;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But how holy is Thy nature,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, to us Christ it conveys."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast ever sanctified us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the blood of Christ our Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast separated sinners"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru the truth which is Thy Word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast, by Thy Holy Spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made us holy unto Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our spirit, soul, and body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wholly sanctified will be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh! the holy life of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Thy grace we now possess;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt make us e'en partakers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy very holiness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When within that holy city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy full holiness we'll share,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the uttermost forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"Thou art holy,\" we'll declare."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
