    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the sinner’s death hast died,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou for us wast crucified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our sins Thy flesh was torn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou our penalty hast borne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, Surety, Lamb of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast bought us with Thy blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast wiped the debt away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing left for us to pay;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing left for us to bear,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing left for us to share"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the pardon and the bliss,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the love, the light, the peace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I to Thee will look and live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And, in looking, praises give;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Looking lightens, looking heals,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Looking all the gladness seals."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
