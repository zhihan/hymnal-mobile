    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name we love, Lord Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It tells God’s love unbounded"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To ruined man, ere time began,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or heav’n and earth were founded:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine is a love eternal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That found in us its pleasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That brought Thee low to bear our woe"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make us Thine own treasure."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name we love, Lord Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It tells Thy birth so lowly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy patience, grace, and gentleness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy lonely path, so holy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wast the “Man of Sorrows”;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our grief, too, Thou didst bear it;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our bitter cup Thou drankest up;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thorny crown, didst wear it."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name we love, Lord Jesus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s Lamb—Thou wast ordained,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bear our sins (Thyself all clean)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And hast our guilt sustained."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We see Thee crowned in glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Above the heavens now seated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The vict’ry won, Thy work well done,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our righteousness completed."
            }
          ]
        }
      ]
    }
