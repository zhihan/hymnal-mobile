            {
              "chord": "D",
              "text": "叩 门，"
            },
            {
              "chord": "",
              "text": "叩 门， 谁 在 外？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "等 著，"
            },
            {
              "chord": "",
              "text": "等 著，"
            },
            {
              "chord": "A7",
              "text": "何 忍"
            },
            {
              "chord": "",
              "text": "耐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "远 来"
            },
            {
              "chord": "",
              "text": "佳 客 君 尊 气 概，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生 平 未 见 这 丰"
            },
            {
              "chord": "A",
              "text": "采；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 的"
            },
            {
              "chord": "",
              "text": "心 阿， 既 感 奇 哉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "何 不"
            },
            {
              "chord": "Em",
              "text": "立 即"
            },
            {
              "chord": "A7",
              "text": "把 门"
            },
            {
              "chord": "D",
              "text": "开？"
            }
          ]
        }
