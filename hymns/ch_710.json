    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "叩门，叩门，还在外！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等着，等着，真忍耐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是这门还是难开，"
            }
          ]
        },
        {
          "segments": [
            {
