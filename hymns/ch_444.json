            },
            {
              "chord": "A",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 常"
            },
            {
              "chord": "",
              "text": "𫗪"
            },
            {
              "chord": "G",
              "text": "养，"
            },
            {
              "chord": "D",
              "text": "祂"
            },
            {
              "chord": "A7",
              "text": "常 施"
            },
            {
              "chord": "D",
              "text": "恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 是 属"
            },
            {
              "chord": "G",
              "text": "我，"
            },
            {
              "chord": "D",
              "text": "我"
            },
            {
              "chord": "E7",
              "text": "是 属"
            },
            {
              "chord": "A",
              "text": "祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何"
            },
            {
              "chord": "D",
              "text": "来 需"
            },
            {
              "chord": "G",
              "text": "要？"
            },
            {
              "chord": "D",
              "text": "何"
            },
            {
              "chord": "A7",
              "text": "来 缺"
            },
            {
              "chord": "D",
              "text": "乏？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂带我到嫩草地场，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我感觉满足欢畅；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又带我到平静溪流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "交通不断，安息无忧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我时迷路，祂来截回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再侧我心受祂支配；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我常摇动，不甚坚定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂引导，是为己名。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等不明，何等可疑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怎能行走无所顾忌？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你竿扶持，你杖引领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的同在满我途径。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我能大胆夸胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敌虽四布，享恩如恒："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我头油润，我杯酒溢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我神从来不曾吝惜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的甘甜、奇妙的爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "测量我的一生年代；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你爱既然永不改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的赞美还要加添。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
