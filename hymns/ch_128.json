    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当时我心因罪恶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "纠缠得真难过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我并未求解脱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你却前来寻我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当时我虽听见你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我总是不理，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且多次反对你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实是你的仇敌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我实不知为何故，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你竟为我罪辜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "钉死在十字架上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得着平康！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的罪恶比人多，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我为肉体活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的性情比人坏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你为甚么要爱？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你生马槽何寒微！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的生活何卑！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你到加略受折磨！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的全是为我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在何处看上我？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为何又爱上我？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以才如此受苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要使我得福？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我比别人有何长？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有何比人高尚？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此使你离天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我十架命丧？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，当我想自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "实在无一可以"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "邀你青眼，使你喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就只得希奇！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无他，我今只能说："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是无故爱我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，你是无故爱我！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，这恩真难说！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，不是因自己好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是因自己高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是你要爱罪魁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无故的爱罪魁！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我既如此的蒙恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自然应当认真"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱你、念你、顺服你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才可对得住你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是，可怜到如今"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心仍冷如冰！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然明知你恩、爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是对你懈怠！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽为我舍性命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我对你仍无情；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽为我离天庭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我对你只半心。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "隐藏世界离不得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你道路嫌太窄！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "微小自己舍不得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你生命苦太默！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我想到这里时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心若有所失，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自恨性情太败坏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自恨生活太歹。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是，主，你岂不知"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心将要如此！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既豫知我冷淡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当初何必恩湛？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "难道你为我舍命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "担当痛苦、罪、病，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "受尽人世的艰辛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是为此冷心！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既知道我如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何苦为我受死？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你既知道我无良，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何竟为我受伤？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽豫知我冷淡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对你刻变时翻，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你仍然要爱我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我死，为我活。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我想到这样爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不知泪从何来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满心感激我救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "希奇你的无故！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，对于你大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我真明白不来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一面我希奇不迨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一面我要敬拜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上福乐虽无比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心并不在彼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我爱作个唱诗人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美我主我神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在那光明荣耀中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要不住称颂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要感谢你恩、爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要永远敬拜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我望我能在天城，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主恩、爱标本，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱虽难答，恩难报，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿赞美得好！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    }
  ],
