            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是天天更宝贝。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主已使我们合而为一"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着祂恢复，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督的丰富并祂丰满─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会─全显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们所有、所是，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全倾于祂而不别归，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着祂的伟大计画"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比从前更宝贝。"
            }
          ]
        }
      ],
