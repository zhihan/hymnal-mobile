{
  "url": "https://www.hymnal.net/cn/hymn/ts/201",
  "title": "祂是天天更宝贝",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "的 心 天 天 被 吸 引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "更 亲"
            },
            {
              "chord": "",
              "text": "近 耶"
            },
            {
              "chord": "G",
              "text": "稣；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 比 世 人 更 美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新 鲜 胜"
            },
            {
              "chord": "A7",
              "text": "过 清"
            },
            {
              "chord": "",
              "text": "晨 甘"
            },
            {
              "chord": "D",
              "text": "露。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世"
            },
            {
              "chord": "G",
              "text": "上 最"
            },
            {
              "chord": "",
              "text": "美 言 辞"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还 不 能"
            },
            {
              "chord": "C",
              "text": "尽 说"
            },
            {
              "chord": "",
              "text": "祂 价"
            },
            {
              "chord": "G",
              "text": "值，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "C",
              "text": "是 天"
            },
            {
              "chord": "",
              "text": "天 更 加 宝 贝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今"
            },
            {
              "chord": "D",
              "text": "日 远"
            },
            {
              "chord": "D7",
              "text": "胜 昨"
            },
            {
              "chord": "G",
              "text": "日。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如 此 丰 富 的"
            },
            {
              "chord": "C",
              "text": "宝 库，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一"
            },
            {
              "chord": "A7",
              "text": "半 都"
            },
            {
              "chord": "",
              "text": "难 领"
            },
            {
              "chord": "D",
              "text": "会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "昨"
            },
            {
              "chord": "G7",
              "text": "日， 今"
            },
            {
              "chord": "",
              "text": "日， 到"
            },
            {
              "chord": "C",
              "text": "永 远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 是"
            },
            {
              "chord": "G",
              "text": "天 天"
            },
            {
              "chord": "D7",
              "text": "更 宝"
            },
            {
              "chord": "G",
              "text": "贝。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是在召会里面"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看见祂的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰富全都在此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不再他找，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂使我们渴慕的灵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一再得着饱足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是天天更加宝贝，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现在远胜当初。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此丰富的宝库，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一半都难领会；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "昨日，今日，到永远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是天天更宝贝。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如今祂是活灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在我们的灵里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂甜美的涂抹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里生命更充满！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当与圣徒一同聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵如插翅飞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为如今我们的主"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比从前更宝贝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此丰富的宝库，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一半都难领会；"
            }
          ]
