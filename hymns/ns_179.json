    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How blinded we have been:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“We’ll build Your habitation”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we are short of Christ—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need Your saturation!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, You care for our house!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a blessed word!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As You’re to God, You’d be to us—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A mutual abode."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s nothing that we are"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or have or do well-pleasing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need Thee, glorious Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inwrought into our being."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Lord, our heart’s still vacant now!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come in and settle down."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come saturate and permeate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And fill us with Yourself."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit You have filled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At our regeneration,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But mind, emotion, will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Await Your saturation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How much of You is built in us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To make our heart Your home?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O Triune God, we welcome You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come build, oh, build in us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Into our innermost"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Intrinsic constitution,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, Lord, Yourself dispense"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By constant, fresh infusion;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transform us, Lord, and work Yourself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As God’s embodiment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into our heart, and life each part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Your reality."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To build Your house today,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Self-effort You’re refusing—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All stubble, wood, and hay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gold, silver, gems, You’re using."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The consummated Triune God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Transmitted into us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now builds Himself into a home—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His dwelling, glorious."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Repeat the last four lines)"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
