              "chord": "",
              "text": "Swept on o’er every field;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The faith by which they conquered death"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is still our shining shield."
            }
          ]
        }
      ],
