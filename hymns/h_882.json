            {
              "chord": "",
              "text": "Let tents of ease be left behind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And onward to the fray."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation’s helmet on each head,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With truth all girt about,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The earth shall tremble ’neath our tread,"
            }
          ]
        },
        {
          "segments": [
