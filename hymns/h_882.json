    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His banner over us is love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our sword the Word of God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We tread the road the saints before"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With shouts of triumph trod."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By faith, they like a whirlwind’s breath,"
            }
          ]
        },
        {
          "segments": [
