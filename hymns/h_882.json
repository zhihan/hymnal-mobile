      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On every hand the foe we find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Drawn up in dread array;"
            }
          ]
        },
        {
