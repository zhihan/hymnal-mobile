{
  "url": "https://www.hymnal.net/cn/hymn/ch/321",
  "title": "你这神的隐藏的爱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "你 這"
            },
            {
              "chord": "",
              "text": "神 的 隱"
            },
            {
              "chord": "D7",
              "text": "藏 的"
            },
            {
              "chord": "G",
              "text": "愛！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "長 闊"
            },
            {
              "chord": "",
              "text": "高"
            },
            {
              "chord": "G",
              "text": "深 無"
            },
            {
              "chord": "A7",
              "text": "人 知"
            },
            {
              "chord": "D",
              "text": "悉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "遠 遠"
            },
            {
              "chord": "D",
              "text": "我"
            },
            {
              "chord": "Em",
              "text": "見"
            },
            {
              "chord": "G",
              "text": "你"
            },
            {
              "chord": "Am",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "光"
            },
            {
              "chord": "Em",
              "text": "彩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "我 就"
            },
            {
              "chord": "",
              "text": "歎"
            },
            {
              "chord": "G",
              "text": "息"
            },
            {
              "chord": "Em",
              "text": "望"
            },
            {
              "chord": "D",
              "text": "得 安"
            },
            {
              "chord": "G",
              "text": "息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "我 心"
            },
            {
              "chord": "",
              "text": "痛"
            },
            {
              "chord": "G",
              "text": "苦， 不"
            },
            {
              "chord": "D",
              "text": "能 安"
            },
            {
              "chord": "G",
              "text": "息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "除 非"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "C",
              "text": "心"
            },
            {
              "chord": "Am",
              "text": "安"
            },
            {
              "chord": "D",
              "text": "息"
            },
            {
              "chord": "D7",
              "text": "於"
            },
            {
              "chord": "G",
              "text": "你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的声音，仍然隐招"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我来负你甜美的轭；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我虽几乎前来应召，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是惧怕前途阻隔；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我志虽定，我情却离，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我欲向你，反而背你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "全是恩典！使你吸引"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心向你追求安息；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我虽追求，不能亲近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流荡的我无所凭倚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，要何时不再流荡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有脚踪向你而往？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "日下有无甚么东西，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你相争来分我心？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "呀，我求你把它割弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你作王无人与竞；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心才会不再拘泥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当它借你得了安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，我求你埋藏这己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主（非我）从我而活！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恶欲邪情钉死绝迹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不私留一宝贝罪恶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除你之外，在凡事上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我无求，使我无望！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，给我无上之助，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救我脱离无用之虑；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赶出己意离我心府，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "离我全人隐密之域；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我作个顺命的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不断称颂，时常感恩。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求你使我时刻离地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谦卑等候听你吩咐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你对我时常题起："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘我是你爱、你命、你主；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来听你声，来觉你力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来尝你爱，是我所期。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
