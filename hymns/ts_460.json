    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我的脚不能离十架的窄路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因那是我爱主所走过路途；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然是有眼泪也多有痛苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我仍愿前进不稍有回顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然是有眼泪也多有痛苦，"
            }
          ]
        },
