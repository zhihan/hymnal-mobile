  "title": "神的国度今在地上",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "国 度 今"
            },
            {
              "chord": "D",
              "text": "在 地"
            },
            {
              "chord": "G",
              "text": "上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是"
            },
            {
              "chord": "A",
              "text": "神 掌"
            },
            {
              "chord": "",
              "text": "权 在 我"
            },
            {
              "chord": "A7",
              "text": "心"
            },
            {
              "chord": "D",
              "text": "里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "乃 是"
            },
            {
              "chord": "",
              "text": "基"
            },
            {
              "chord": "C",
              "text": "督 活"
            },
            {
              "chord": "",
              "text": "我 里"
            },
            {
              "chord": "D",
              "text": "面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作"
            },
            {
              "chord": "G",
              "text": "主 作"
            },
            {
              "chord": "",
              "text": "王 统"
            },
            {
              "chord": "D",
              "text": "治 管"
            },
            {
              "chord": "G",
              "text": "理。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督生命同祂权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂登极在我心中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "管理全人每一部分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "规律一切言语行动。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "基督在我心中登极，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就在我心建祂国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "稳定祂的全权统治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着神旨各方铺路。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂在我心执政，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂将生命向我供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我让祂作主作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就得享祂的丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂在里面管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的丰满在我建起；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂里面国度掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的身体就得建立。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂里面属天管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我像天上国民活着；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着我肯服祂权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的国度实现于我。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在这属天范围活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着祂这属天王权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属天光中行动、争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到国度在地实现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
