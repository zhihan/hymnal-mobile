    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As I run the race, His grace o'erflows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From you saints, so rich in time of need!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By your love for Him, you spur me onward—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With this same love profound you all love me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I'm weak, you weep before the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I fail, in the midst of you I'll fall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day, my heart's profoundly grateful"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my growth and my joy are with you all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis for you my heart's full of praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All you saints most precious to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit, soul, entire being,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I entrust to you whole-heartedly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We've become His living sacrifice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Serving, pleasing Him is all our care;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where'er He sends, we go with boldness,"
            }
