              "text": "am."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "I do"
            },
            {
              "chord": "D",
              "text": "not"
            },
            {
              "chord": "Gm",
              "text": "know,"
            },
            {
