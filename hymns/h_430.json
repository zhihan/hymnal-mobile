            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Gm",
              "text": "How"
            },
            {
              "chord": "Dm",
              "text": "weak"
            },
            {
              "chord": "A",
              "text": "I"
            },
            {
              "chord": "Dm",
              "text": "am."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When in the world I have my life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I cannot sense my failure rife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But boasting in my earnest strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I forward press."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When I within the darkness dwell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My shallow state I cannot tell,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I only think how I excel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And proudly dream."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But when at last I come to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy searching light uncovers me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I see what I could never see—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My self exposed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I wither ’neath Thy piercing ray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all my strength dissolves away,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My self-esteem in dust I lay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lowly bow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How blind and foolish is the pride"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With which my soul was fortified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my dark heart, self-satisfied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It issued forth."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s not a thing that pride can claim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s not a member but is lame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s only deep regret and shame,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can I pray?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy blood from judgment saveth me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy life from wrath delivers me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How filthy yet in poverty"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I really am."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I want to pray, but faith have not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I fain would seek Thee as Thou art."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, canst Thou e’er renew my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Have mercy, Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
