    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "请来同喊主耶稣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂必使你得释放─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不管你的心多疏远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或如野马脱缰。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要简单的喊主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不管你在何地方；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一呼喊立刻祂就来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂原近在你口旁。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "呼喊我们的救主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每次祂都必垂听。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何不来投靠祂胸怀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重担立变轻盈！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我们的山寨，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是喜乐、安息、力量；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要你尝尝便知道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂恩典真是无量。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "上好乃是主自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等着你白白接受。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们向祂全敞开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让祂生命拯救！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂再来的时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不惊惶失措，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且要面见祂荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若一直让祂成熟。"
            }
          ]
