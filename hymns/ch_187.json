    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "依然是酒、依然饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借此信心却看明"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱心神圣的小影，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着你曾召我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "举目仰望你救恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着信心近你身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着你曾发命令，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我记念你行径－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等温柔、何等贫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着你曾用慈爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引我想家在天外－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘行此直等到我来，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到祂来，我擘饼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "表明祂作我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我睡了、为我醒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到祂来，我饮杯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "表明祂赐福全备，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我站在新地位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着再来的嘱咐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着那日的紧速，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着荣耀和国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们感谢你。"
            }
          ]
        }
      ],
