              "chord": "G",
              "text": "血、 见"
            },
            {
              "chord": "",
              "text": "证 的"
            },
            {
              "chord": "D7",
              "text": "话、 灵"
            },
            {
              "chord": "",
              "text": "与 召"
            },
            {
              "chord": "G",
              "text": "会。 来"
            }
          ]
        }
