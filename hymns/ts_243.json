          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "D",
              "text": "了。 剛"
            },
            {
              "chord": "",
              "text": "強 去 爭 戰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 必 得 勝！ 來 得"
            },
            {
              "chord": "D7",
              "text": "這 地，"
            },
            {
              "chord": "",
              "text": "何"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等 榮"
            },
            {
              "chord": "G",
              "text": "耀！ 來"
            },
            {
              "chord": "",
              "text": "得 這 地， 哦，"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "姊 妹 們 哪！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "投 身 其 中， 緊"
            },
            {
              "chord": "G7",
              "text": "緊 跟"
            },
            {
              "chord": "C",
              "text": "隨； 祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正 在 呼 召， 祂 走"
            },
            {
              "chord": "G",
              "text": "在 前"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "頭， 所 需"
            },
            {
              "chord": "D",
              "text": "一 切"
            },
            {
              "chord": "",
              "text": "祂"
            },
            {
              "chord": "D7",
              "text": "已 賜"
            },
            {
              "chord": "G",
              "text": "給！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有血，基督是无瑕疵的祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂舍自己，使神完全满意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所以我们到神面前，坦然无惧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要我们宝血不断支取。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有话，神话乃是我们食物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们用信调话并说‘阿们，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在每日中，圣灵再向我们说话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂从里面规律调整我们。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们有灵，这灵乃是实际的灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不以我们的感觉作根据。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "内住的灵，教导我们住在祂里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引导我们进入一切实际。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们还有召会，她是何等宝贝！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历丰满，圣徒不可或缺！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同聚必得这包罗万有主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是我们一切中的一切！"
            }
          ]
        }
      ]
    }
