              "chord": "G",
              "text": "来 得"
            },
            {
              "chord": "",
              "text": "这 地， 神 已 将 这 地 赐 我 们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "平"
            },
            {
              "chord": "D",
              "text": "日 生"
            },
            {
              "chord": "",
              "text": "活， 可"
            },
            {
              "chord": "A7",
              "text": "满 基"
            },
            {
              "chord": "",
              "text": "督 丰"
            },
            {
              "chord": "D",
              "text": "富。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来"
            },
            {
              "chord": "G",
              "text": "得 这"
            },
            {
              "chord": "",
              "text": "地， 所"
            },
            {
              "chord": "C",
              "text": "需 装"
            },
            {
              "chord": "",
              "text": "备， 一 样 不 缺─ 宝"
