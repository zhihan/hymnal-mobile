      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy redemption we may come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the holiest place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit now anointing us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We touch the throne of grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit only we would pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ourselves by Thee possessed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That from our spirit Christ the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As incense be expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace and mercy as a stream"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From out the throne does flow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Refreshing in the hour of need—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How rich, how sweet to know!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though for our needs we do not ask"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But by Thy Spirit pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our every need is known to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re in Thy care alway."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though griefs and trials on us press,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will not anxious be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But all our care upon Thee cast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And set our spirit free."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O may I concentrated be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship with Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My prayer and incense offering,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit leading me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
