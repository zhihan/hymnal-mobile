      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "大能的主，前来拯救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丰盛生命赐给我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你同在直到永久，"
            }
          ]
        },
        {
          "segments": [
