    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，向我吹你圣灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吹进烦扰的心里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我有分你的丰盛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受应许的安息。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从我除去罪的爱好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除去一切的捆绑；"
