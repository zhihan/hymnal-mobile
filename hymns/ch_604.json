{
  "url": "https://www.hymnal.net/cn/hymn/ch/604",
  "title": "主你不仅是陶人",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "不 僅"
            },
            {
              "chord": "A",
              "text": "是 陶"
            },
            {
              "chord": "D",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更 是 榮 耀 建 造"
            },
            {
              "chord": "A",
              "text": "主；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 僅"
            },
            {
              "chord": "D",
              "text": "要 把"
            },
            {
              "chord": "A",
              "text": "我 陶"
            },
            {
              "chord": "D",
              "text": "甄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更 是"
            },
            {
              "chord": "E",
              "text": "要 把"
            },
            {
              "chord": "E7",
              "text": "我 建"
            },
            {
              "chord": "A",
              "text": "築。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 也"
            },
            {
              "chord": "D",
              "text": "不 僅"
            },
            {
              "chord": "",
              "text": "是 土"
            },
            {
              "chord": "G",
              "text": "人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更 是"
            },
            {
              "chord": "D",
              "text": "新 造"
            },
            {
              "chord": "",
              "text": "的 活"
            },
            {
              "chord": "A",
              "text": "石；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 僅"
            },
            {
              "chord": "D",
              "text": "為 作"
            },
            {
              "chord": "G",
              "text": "你 器"
            },
            {
              "chord": "D",
              "text": "皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "更 是"
            },
            {
              "chord": "D",
              "text": "為 作"
            },
            {
              "chord": "A7",
              "text": "你 宮"
            },
            {
              "chord": "D",
              "text": "室。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 僅 為 作 你 器"
            },
            {
              "chord": "G",
              "text": "皿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "更 是"
            },
            {
              "chord": "D",
              "text": "為 作"
            },
            {
              "chord": "A7",
              "text": "你 宮"
            },
            {
              "chord": "D",
              "text": "室。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你虽用土造我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却要我们能变质，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你生命的精金，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "变成珍珠与宝石。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再经建造在一起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你心爱的配偶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你联合成一体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给你占有并享受。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你心所爱并所要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "非仅珍贵的材料，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更要材料被建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给你安居显荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这万有的基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "需要建造的召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使你荣耀的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出完全的光辉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "并非单独的属灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就能博得你称羡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是团体的生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能成全你心愿。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并非脱节的肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就能彰显你完全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是配搭的身体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能成为你丰满。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求不再容我单独，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立即来把我建造；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切全照你蓝图，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "联络、结合，精而牢。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属灵不再为自高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "恩赐不再为自傲；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都为供你建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都为显你荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
