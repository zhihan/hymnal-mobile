    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us now redeem each moment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More the precious oil to buy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And have our vessels filled with ointment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ere we hear the midnight cry."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, wondrous day! Oh, glorious morning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When the Christ we love shall come:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With vessels filled and lamps all burning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us welcome His return."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rejoice! Rejoice! Our Bridegroom’s coming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the time will not be long"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Before we hail that wedding morning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lift up the glad new song."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a joy it is preparing"
