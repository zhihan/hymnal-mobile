    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有事曾使我惊恐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今不再扰我安息；"
            }
          ]
        },
        {
          "segments": [
