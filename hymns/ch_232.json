    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我是永远只属祂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能使祂与我分？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在我心来安家，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有福、安息满我心。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天地可以都废去，"
            }
          ]
        },
        {
          "segments": [
