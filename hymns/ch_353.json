    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前我已献全身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽劳碌，不为金，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而今却为世俗用，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "却随世界浮沉！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从前守节今流连，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是放纵，说消遣！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多年流浪不懊悔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何日才会生厌？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前我心专爱主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂外，无所慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常想念热如火，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论梦寐醒苏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世俗、人情皆无意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切事都丢弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今则追求属地物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与俗复有何异？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "追想昔日跪主前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何满足，何甘甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应许你说：‘从今后，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我只听你差遣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿意顺服失自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你外，无他求；’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "至今为时并不久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此心已归乌有！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你外劳碌总是空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如捉影，如捕风，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "多年流落羊群外，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无你怎能亨通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世界情欲快过去，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂可再受驾御？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱主多年在等候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂可依然犹豫？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "晨星将现夜已阑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生越过，时越暂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立即脱离堕落处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "重来求你喜欢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拒绝世俗和魔鬼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再来尝天滋味，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱心已失今再得，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍站从前地位。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今再行窄路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虚空世界不顾；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前面荣耀快现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿忠心受苦。"
            }
          ]
        }
      ],
      "type": "chorus"
    }
  ],
