    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人生短日，转瞬就已入暮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地乐灯残，世荣花谢草枯；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "四境所见，尽是变迁朽腐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你，不变者，求来与我同住。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "莫带威严，有如王中之王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只带慈良，并你施医翅膀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "泪来洗忧，心来听我求诉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来，罪人友，如此与我同住。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的同在，时时我都需要；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除你恩典，何能使魔败逃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有谁像你，将我引导扶助；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或阴或晴，求你与我同住。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "有你赐福，我就不怕敌凶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "病而不苦，流泪也不酸痛；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甚么毒钩！甚么死亡、坟墓！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我都胜过，若你与我同住。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "若我临终，愿你在我身边，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照明幽谷，指我仰望你面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或到你来，天晓，地影尽无；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论如何，求你与我同住。"
            }
          ]
        }
