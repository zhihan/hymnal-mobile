    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must flee these youthful lusts—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we really want to grow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praying, speaking, fellowshipping—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the sense of life to know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Your love is sweet and tender."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day, I’m drawn to You."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I touch You I am recovered."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep me turning back to You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God is working now within me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every moment, every day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By obeying His anointing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Oh Lord Jesus” is the way!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, strengthen and constrain us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep increasing, grow in us."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Break through every kind of blockage"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life is so mysterious!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus is reality."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’s the only One we need."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sin, death, doubts: we’re now set free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is life and peace to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, in us, continue growing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You’re the all-sufficient One!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep our spirits burning and flowing—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will love You ’til You come!"
            }
          ]
        }
      ],
      "type": "chorus"
    }
