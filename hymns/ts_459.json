  "title": "主，你旨意我愿凭",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "旨 意 我"
            },
            {
              "chord": "G",
              "text": "愿"
            },
            {
              "chord": "D",
              "text": "凭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主， 你 圣"
            },
            {
              "chord": "A7",
              "text": "言 我"
            },
            {
              "chord": "D",
              "text": "听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 让 闲 话 漏"
            },
            {
              "chord": "G",
              "text": "生"
            },
            {
              "chord": "D",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不"
            },
            {
              "chord": "Bm",
              "text": "让 俗"
            },
            {
              "chord": "A7",
              "text": "务 扰"
            },
            {
              "chord": "D",
              "text": "灵。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求 你 向 我 多 吸 引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "G",
              "text": "我 与"
            },
            {
              "chord": "",
              "text": "你 更"
            },
            {
              "chord": "A",
              "text": "亲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "让"
            },
            {
              "chord": "D",
              "text": "我 常"
            },
            {
              "chord": "",
              "text": "见 你"
            },
            {
              "chord": "G",
              "text": "荣"
            },
            {
              "chord": "D",
              "text": "形，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "紧"
            },
            {
              "chord": "Bm",
              "text": "紧 跟"
            },
            {
              "chord": "A7",
              "text": "随 你"
            },
            {
              "chord": "D",
              "text": "行。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你道路我愿走，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不管风狂雨骤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然有忧也有愁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主恩却更深厚。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今追求虽不够，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有时会贪优游，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你仍把我收留，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "用爱把我浸透。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你十架我愿负，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "面向你的国度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然流泪虽然苦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你手却常搀扶。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前面路程已不长，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "属天家乡在望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有朝，父怀我安躺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就喜乐欢畅。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你荣耀快显现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是我心所羡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的应许不改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你来将不迟延。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主使我能自勉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不向世界流连，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我眼能常望着天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心能向你恋恋。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
