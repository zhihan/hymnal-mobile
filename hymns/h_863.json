    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the way and Christ the light of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him we walk and by Him we are led;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the living water and the food;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Him we drink and we with Him are fed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the truth, 'tis Him we testify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the life, 'tis Him we minister;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the Lord, 'tis Him we magnify,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the Head, and we exalt Him here."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the All in all to God and man—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him both we and God are satisfied;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the reality within the Church—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Him are life and numbers multiplied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By all the hymns and prayers we offer here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ the reality we would express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the activities in fellowship—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ thus in operation manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis in His Name we meet, in Spirit act,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With nothing in our mind to formalize;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis by His pow'r we pray, in unction praise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Himself in spirit exercise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All things forgetting, cleaving unto Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Applying Him until maturity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us count everything but loss for Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Him, our All in all, eternally."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
