  "title": "Man is a being of three parts",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Man is"
            },
            {
              "chord": "",
              "text": "a"
            },
            {
              "chord": "Bm",
              "text": "being"
            },
            {
              "chord": "A",
              "text": "of three"
            },
            {
              "chord": "D",
              "text": "parts,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The body,"
            },
            {
              "chord": "Bm",
              "text": "soul, and"
            },
            {
              "chord": "A7",
              "text": "spir"
            },
            {
              "chord": "D",
              "text": "it"
            },
            {
              "chord": "A",
              "text": "too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Th'eternal"
            },
            {
              "chord": "Em",
              "text": "purpose"
            },
            {
              "chord": "D",
              "text": "to ful"
            },
            {
              "chord": "A",
              "text": "fill"
            },
            {
              "chord": "G",
              "text": "With"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God's in"
            },
            {
              "chord": "D",
              "text": "heri"
            },
            {
              "chord": "A",
              "text": "tance"
            },
            {
              "chord": "A7",
              "text": "in"
            },
            {
              "chord": "D",
              "text": "view."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The body is the outward part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man a world-sense may possess;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus he may touch the outward things"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bodily himself express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The soul within—the inward part—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is but the very self of man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sense of self it gives to him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To touch the psychic world of man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The spirit is the inmost part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With which the Lord he may receive;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sense of God it gives to man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That he the spirit-world perceive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the soul of man there are"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The mind, emotion, and the will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These are the functions for the man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His human nature to fulfill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the spirit of the man"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are found the conscience, fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And intuition, which thereby"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The man to worship God equip."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The man must exercise his soul"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To choose that God he may possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And by his spirit God partake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thru his body God express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Man’s spirit has to be reborn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With life divine to him conveyed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His soul must be transformed by God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His body like Christ’s body made."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by these steps of work divine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In each of man’s three separate parts"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That man is mingled with the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His expression full imparts."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
