    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, we need no goodness more than Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor do we seek a love that's less than Thine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How we adore Thee now that here we know"
            }
          ]
        },
        {
