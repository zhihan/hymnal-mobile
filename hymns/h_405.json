    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Having seen the world's fair beauty,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I would be blind once more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lest I lose the loving Presence"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Delight I knew before."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I no more would be delivered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my thorn, but look for grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While within the veil His glory"
            }
          ]
        },
