    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在我魂间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的生命在溢漫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不断扩展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带来生命和平安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "进入我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂要浸透并充填，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更新、变化，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我属土成属天；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "浸透我，浸透我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的生命深深浸透我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我全魂更新过，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "自己、天然都消没，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等释放，"
            }
          ]
        },
        {
          "segments": [
            {
