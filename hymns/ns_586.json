    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God rescues us, His flock that was scattered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Driven away from refuge and battered;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer prey nor scattered abroad,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are in Christ, well fed by God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Cov’nant of peace, God’s purpose bespeaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Binds us to Him, secure in His keeping."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God fills our hearts and makes us a place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where all receive His life through grace!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ as our life yields fruit bearing, increase,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship, building, blending, and real peace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freedom from self, life conquering death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Day after day and breath by breath."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God gives the Spirit, gives not by measure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pours out Himself, a limitless treasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Given in Christ Who Spirit became,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life-giving gift we fan to flame."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God as the Spirit is our true blessing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He shepherds us to pastures, expressing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both tender love and bounteous supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessings in Christ to multiply."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s house is filled with glorious radiance—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled with His speaking, filled with His presence;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built up in oneness, life we express,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that God is, in Christ, possess."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God of salvation, come we now, seeking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prayerful in worship, joyfully singing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessing Your name, Your blessings express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that You are is our bequest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Showers of blessing come in their season;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We ask, You come, abundantly given;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are the hope Who fills us with joy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we’d abound, Your pow’r employ."
            }
          ]
        }
      ],
      "type": "chorus"
    }
