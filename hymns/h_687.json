    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Where dost Thou, dear Shepherd, resort with Thy sheep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To feed them in pastures of love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Say, why in the valley of death should I weep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or alone in this wilderness rove?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, why should I wander, an alien from Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or cry in the desert for bread?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy foes will rejoice when my sorrows they see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And smile at the tears I have shed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ye daughters of Zion, declare, have you seen"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Star that on Israel shone?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Say, if in your tents my Beloved has been,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And where with His flocks He is gone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Shepherd! I hear, and will follow Thy call;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I know the sweet sound of Thy voice;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Restore and defend me, for Thou art my all,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thee I’ll ever rejoice."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
