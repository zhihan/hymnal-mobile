    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ministers of the new covenant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Captives of God are, in Christ’s victory move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fragrance of Christ they spread in every place,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweet savor of His knowledge ever prove."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ministers of the new covenant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inscribe the Spirit as the element"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the hearts of all those who believe—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Letter of Christ to all men evident."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ministers of the new covenant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mirrors, behold the glory of the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Infused with all He is, they are transformed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Even as from the Spirit of the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The ministers of the new covenant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Worthless and fragile vessels made of earth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet what a priceless treasure they contain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious Christ in vessels without worth!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a high and holy ministry!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who for these things is fully competent?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only of God can we enabled be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As ministers of His new covenant."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, in this ministry we would take part;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The all-inclusive Christ we would supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This ministry unique we would fulfill:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The church to build, the Body edify."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
