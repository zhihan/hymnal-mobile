          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we love and contact our dear Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are conformed into His image."
            }
          ]
        }
      ],
