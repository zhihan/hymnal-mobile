    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s intention is to be the tree of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For our enjoyment and our life supply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We live the Christian life by eating the Lord"
            }
          ]
        },
        {
          "segments": [
