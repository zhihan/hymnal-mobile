{
  "url": "https://www.hymnal.net/cn/hymn/ts/873",
  "title": "同祂步武，迈向荣耀",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！我王坐车前往，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "刚强无不得胜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光辉夺人，引我跟随，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就此一定永定。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凯旋行列，撒香俘虏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢呼同祂前行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世途舍弃竭力拼上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂行动见证。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "站住奉献地位，只听主号令；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作初熟果，迈向荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建成新耶路撒冷。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主爱牧养，柔细顾惜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是我全备供应；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我脱离天然、自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显大复活生命。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "相爱、相倚，众人如一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟凭灵中交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督身体，建造扩展，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "新人实际完成。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "站住奉献地位，只听主号令；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作初熟果，迈向荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建成新耶路撒冷。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣经纶，独一异象，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今投身其中。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "海口启程，宣扬佳音，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地灯台照明。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主新妇，荣耀军队，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敌前显祂得胜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "诸王、万国无不俯伏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "和声尊大主名。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
