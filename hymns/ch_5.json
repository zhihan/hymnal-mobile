  "raw_sections": [
    "赞 美父 乃 祝福 之源，",
    "赞 美 子 将 救赎 成全，",
    "赞美 灵来 实 施、 运行，",
    "赞 美 圣父、 圣子、 圣灵！",
    "赞美父是永活源头，",
    "赞美子作生命涌流，",
    "赞美灵已流入我心，",
    "赞美三一神是我分。"
  ]
