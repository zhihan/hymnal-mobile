              "chord": "E7",
              "text": "得 著"
            },
            {
              "chord": "",
              "text": "门"
            },
            {
              "chord": "A",
              "text": "徒；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 祂"
            },
            {
              "chord": "D",
              "text": "为 我"
