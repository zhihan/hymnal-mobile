            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "全 备"
            },
            {
              "chord": "",
              "text": "供"
            },
            {
              "chord": "Bm",
              "text": "应 也"
            },
            {
              "chord": "",
              "text": "满 足"
            },
            {
              "chord": "A7",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "需"
            },
            {
              "chord": "D",
              "text": "要。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "单独、孤立基督徒，无论如何刚强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在仇敌诡计之下仍然难以抵挡、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们活在身体中，就坚，定站立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，仇敌必不能胜过身体！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每天生活中都会经历属灵争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "走主道路者必定遇见试炼、艰难"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在一切境遇中，为我们代祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的全备供应也满足我们需要。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神为我们所命定旨意何等美妙；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历变化，与基督同王，真是荣耀！"
            }
