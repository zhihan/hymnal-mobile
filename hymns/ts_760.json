          "segments": [
            {
              "chord": "",
              "text": "的"
            },
            {
              "chord": "D",
              "text": "全 備"
            },
            {
              "chord": "",
              "text": "供"
            },
            {
              "chord": "Bm",
              "text": "應 也"
            },
            {
              "chord": "",
              "text": "滿 足"
            },
            {
              "chord": "A7",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "需"
            },
            {
              "chord": "D",
              "text": "要。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "单独、孤立基督徒，无论如何刚强，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在仇敌诡计之下仍然难以抵挡、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们活在身体中，就坚，定站立；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，仇敌必不能胜过身体！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每天生活中都会经历属灵争战，"
