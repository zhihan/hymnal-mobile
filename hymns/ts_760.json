        {
          "segments": [
            {
              "chord": "A",
              "text": "救 主"
            },
            {
              "chord": "D",
              "text": "耶 稣"
            },
            {
              "chord": "",
              "text": "受 死 前， 曾 对 彼 得 嘱 咐："
