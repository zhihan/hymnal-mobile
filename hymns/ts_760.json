        {
          "segments": [
            {
              "chord": "A",
              "text": "救 主"
            },
            {
              "chord": "D",
              "text": "耶 穌"
            },
            {
              "chord": "",
              "text": "受 死 前， 曾 對 彼 得 囑 咐："
