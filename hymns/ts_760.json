              "chord": "",
              "text": "走主道路者必定遇见试炼、艰难"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂在一切境遇中，为我们代祷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的全备供应也满足我们需要。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
