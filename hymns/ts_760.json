            {
              "chord": "",
              "text": "利"
            },
            {
              "chord": "D",
              "text": "路 亚，"
            },
            {
              "chord": "",
              "text": "仇"
            },
            {
              "chord": "Bm",
              "text": "敌 必"
            },
            {
              "chord": "",
              "text": "不 能"
            },
            {
              "chord": "A7",
              "text": "得 著"
            },
