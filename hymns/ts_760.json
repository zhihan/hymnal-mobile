            {
              "chord": "",
              "text": "利"
            },
            {
              "chord": "D",
              "text": "路 亞，"
            },
            {
              "chord": "",
              "text": "仇"
            },
            {
              "chord": "Bm",
              "text": "敵 必"
            },
            {
              "chord": "",
              "text": "不 能"
            },
            {
              "chord": "A7",
              "text": "得 著"
            },
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "們！"
            },
