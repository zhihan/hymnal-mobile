    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The appearance of that rainbow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brightly in its splendor’s shown"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Round the Lamb-God of redemption,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seated there upon the throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His righteousness and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His holiness He shines!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Colors blue and red and yellow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Show forth heaven’s hues divine!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo! The open door in heaven;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "See the jasper God enthroned."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That same firm, majestic rainbow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still surrounds the reigning One."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though He must judge fallen sinners,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the rainbow He is crowned!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He must spare us as He promised;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His cov’nant He is bound!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "New Jerusalem’s foundation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is adorned with precious stones;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the colors of a rainbow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rests the building God would own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now His steadfastness eternal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For that City is secured!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We the saved ones joy to witness:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Yes! God’s faithfulness endures!”"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God is faithful, who has called us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To His Son’s communion real;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we share in Christ our wisdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He on us His image seals;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Attributes of God wrought in us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us righteous, holy, bright!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon we, too, will be a rainbow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His pleasure, His delight!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May the meaning of the rainbow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be our full reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the church and in our living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God expressed for all to see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Round the throne in that bright City,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grateful voices we shall raise:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“God is faithful in salvation!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shout to His eternal praise!”"
            }
          ]
        }
      ]
    }
