            {
              "chord": "D",
              "text": "基 督"
            },
            {
              "chord": "",
              "text": "要 从 我 灵 深 处"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向 外"
            },
            {
              "chord": "A",
