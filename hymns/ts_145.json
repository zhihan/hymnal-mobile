            },
            {
              "chord": "A7",
              "text": "并 征"
            },
            {
              "chord": "D",
              "text": "服─ 心"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "思、 情 感、 意 志 各 部， 尽"
