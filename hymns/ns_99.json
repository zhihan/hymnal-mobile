    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As I love You I set my being—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit, my soul and body."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With my heart, my mind, and my strength,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Absolutely on Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I let my entire being"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be occupied by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As I enter in Your heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I sense a fellowship sweet."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Occupied and lost in You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Lord, You’re my everything."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship so intimate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit Lord I enjoy Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord there’s none in heav’n nor on earth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I desire but Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my heart and flesh faileth, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou ever my portion will be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All is vanity, all is dung;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I count all other things loss;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything else drains my love"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You have captured my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I’ve seen Thy preciousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy worth, Thy reality."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now, my Lord, I must confess"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart is only for Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
