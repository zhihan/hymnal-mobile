  "title": "哦主者丰富请进",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "A",
              "text": "帶"
            },
            {
              "chord": "D",
              "text": "著 豐"
            },
            {
              "chord": "Em",
              "text": "富"
            },
            {
              "chord": "A",
              "text": "請"
            },
            {
              "chord": "D",
              "text": "進，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "眷"
            },
            {
              "chord": "G",
              "text": "顧 我"
            },
            {
              "chord": "D",
              "text": "這 復"
            },
            {
              "chord": "E7",
              "text": "甦 之"
            },
            {
              "chord": "A",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "良"
            },
