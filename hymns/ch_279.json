      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不让甚么分我心情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因我与你已经同钉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今向神活着。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我向世界和它妖姿，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并它偶像、娱乐已死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让你作我荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不灭之渴向我惠顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐我无限渴望羡慕，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我心所爱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "少于你者，请勿赐给，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必须你来作我恩惠；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带你所是而来！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从前一切失丧于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今后一切是你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我们永分。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙召有分于你交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你外不再有所爱锺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦来，恩上加恩！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
