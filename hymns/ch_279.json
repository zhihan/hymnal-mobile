        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將"
            },
            {
              "chord": "D",
              "text": "你 自"
            },
            {
              "chord": "",
              "text": "己 向"
            },
            {
              "chord": "A",
              "text": "我 供"
            },
            {
              "chord": "D",
              "text": "應，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "Bm",
              "text": "我 享"
            },
            {
              "chord": "G",
              "text": "受"
            },
            {
              "chord": "D",
              "text": "你"
            },
            {
              "chord": "Em",
              "text": "的 豐"
