  "title": "我们呼吸天上空气",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 们"
            },
            {
              "chord": "",
              "text": "呼 吸 天"
            },
            {
              "chord": "C",
              "text": "上 空"
            },
            {
              "chord": "G",
              "text": "气，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "香 味 从"
            },
            {
              "chord": "A7",
              "text": "天 而"
            },
            {
              "chord": "D",
              "text": "来；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "但"
            },
            {
              "chord": "G",
              "text": "愿 每"
            },
            {
              "chord": "G7",
              "text": "魂 脱"
            },
            {
              "chord": "C",
              "text": "离 肉"
            },
            {
              "chord": "G",
              "text": "体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每 灵 都"
            },
            {
              "chord": "D",
              "text": "充"
            },
            {
              "chord": "D7",
              "text": "满"
            },
            {
              "chord": "G",
              "text": "爱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，使我们心心相联，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满有圣洁情意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不至有日彼此改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不爱你或你的。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
