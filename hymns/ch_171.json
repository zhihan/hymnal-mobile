{
  "url": "https://www.hymnal.net/cn/hymn/ch/171",
  "title": "耶稣只要一想到你",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "耶 稣，"
            },
            {
              "chord": "",
              "text": "只"
            },
            {
              "chord": "D",
              "text": "要 一"
            },
            {
              "chord": "D7",
              "text": "想 到"
            },
            {
              "chord": "G",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 就 满 甘"
            },
            {
              "chord": "D",
              "text": "甜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "但 这"
            },
            {
              "chord": "",
              "text": "甘 甜 还"
            },
            {
              "chord": "D",
              "text": "远 不"
            },
            {
              "chord": "D7",
              "text": "及"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "亲 眼"
            },
            {
              "chord": "",
              "text": "看"
            },
            {
              "chord": "D",
              "text": "见"
            },
            {
              "chord": "D7",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "面。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "无口能唱，无心能思，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也无记性能忆"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一种声音比你名字"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更为甘甜、可喜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是痛悔者的希望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "温柔者的喜乐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你对寻求者何善良，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跌倒者何仁德。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但对寻得你者如何？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无口无笔能述；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣的爱，其深、其阔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟被爱者略熟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣！你是世人之光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是生命之源！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超一切我之所享、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切我所能羡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你外我无别的源头"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能解我心干渴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无穷宝泉！活水涌流！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "别流全都干涸。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣，你今是我喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来是我赏赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的荣耀、诗歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从今直到永世。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
