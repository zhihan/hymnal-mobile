    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Long the blessed Guide has led me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the desert road;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I see the coming splendor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Splendor of my God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There amidst the love and glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is waiting yet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On His hands a name is graven"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He can ne’er forget."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who is this, who comes to meet me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the desert way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Morning Star foretelling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s unclouded day?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He it is who came to win me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cross of shame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His glory well I know Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Evermore the same."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O the blessed joy of meeting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the desert past;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O the wondrous words of greeting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He shall speak at last!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He and I together ent’ring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fair realm above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He and I together sharing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the Father’s love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Where no shade nor stain can enter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor the gold be dim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His holiness unsullied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I shall walk with Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Meet companion then for Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Him, for Him, made—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory of God’s grace forever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There in me displayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He who in His hour of sorrow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bore the curse alone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I who through the lonely desert"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Trod where He had gone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He and I, in that bright glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One deep joy shall share—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mine, to be forever with Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His, that I am there."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
