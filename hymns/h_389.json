    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each time when I dream of the goodness of life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pray Thee, dear Lord, that Thou in it may be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O do not allow me to choose by myself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor seek any pleasure that’s other than Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each night when alone in the stillness I lie,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pray Thee, Lord Jesus, that Thou wilt be near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Each morning ere dawn comes, while still in my sleep,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then whispering call me and open my ear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each time, Lord, when reading in Thy holy Word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pray that Thy glory may shine on each line,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That clearly I’ll see what a Savior I have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And how great salvation that Thou hast made mine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When helpless I come, Lord, to kneel at Thy throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pray Thee to hear me and grant me Thy grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If thru my shortcomings Thou hear not my prayer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Withdraw not Thy presence, O hide not Thy face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Each time when of heavenly blessings I think,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O let my heart long to be raptured to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My only hope here is Thy coming again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My only joy there, Lord, Thy presence will be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, teach me each day in Thy presence to live,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From morning to evening my one world Thou art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O let not my heart be contented or rest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When loving or seeking what with Thee doth part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
