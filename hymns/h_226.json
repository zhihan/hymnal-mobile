              "text": "We give Thee thanks, O Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For the words that turn our eye"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the cross of Calvary,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bidding us in faith draw nigh,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give Thee thanks, O Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For the words that fragrance breathe"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These plain symbols underneath,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Words that His own peace bequeath,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give Thee thanks, O Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy words in Spirit, shown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy will to us made known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Do ye this until I come,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give Thee thanks, O Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Till He come we take the bread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Type of Him on whom we feed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Him who liveth and was dead!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give Thee thanks, O Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Till He come we take the cup;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we at His table sup,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eye and heart are lifted up!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We give Thee thanks, O Lord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For that coming, here foreshown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For that day to man unknown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the glory and the throne,"
            }
          ]
        },
        {
          "segments": [
            {
