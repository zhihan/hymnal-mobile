    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I’m not strange, I just can’t change"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s not from lack of effort though"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more I try, the more I find"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I need for You to grow."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where I have failed, Lord You’ve prevailed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The secret of success I know:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all I need is life indeed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I pray for You to grow."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Jesus now grow in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I want for You to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pleased to be in me what You want to be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And when it gets too hard feel free"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To grow some more in me."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
