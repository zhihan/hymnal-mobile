{
  "url": "https://www.hymnal.net/cn/hymn/ch/535",
  "title": "在神所重生圣徒的灵中",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "在 神"
            },
            {
              "chord": "",
              "text": "所 重 生"
            },
            {
              "chord": "D",
              "text": "聖 徒"
            },
            {
              "chord": "",
              "text": "的 靈"
            },
            {
              "chord": "G",
              "text": "中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "裡 面 的 認 識"
            },
            {
              "chord": "A",
              "text": "實 際"
            },
            {
              "chord": "",
              "text": "又 豐"
            },
            {
              "chord": "D",
              "text": "富；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所 以 不 需 要"
            },
            {
              "chord": "D7",
              "text": "外 面"
            },
            {
              "chord": "",
              "text": "的 教"
            },
            {
              "chord": "G",
              "text": "導，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃 是 在"
            },
            {
              "chord": "C",
              "text": "裡 面"
            },
            {
              "chord": "D",
              "text": "對 神"
            },
            {
              "chord": "D7",
              "text": "有 領"
            },
            {
              "chord": "G",
              "text": "悟。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "永远的生命，最好也最高，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "具有各种样神圣的功能；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这生命对神的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超过外面知识的供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "生命的律法放在我心里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由神的圣灵写在我心上；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里面的管治，使我认识神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "远超过外面教导的影响。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩膏的涂抹住在我灵中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神的事情向我心显明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这涂抹我能认识神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "超过借外面教导之所能。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "三而一的神住在我里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻在运行、生活并行动；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借神在里面运行的感觉，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神的认识高超且深宏。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今既有这里面的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就不需要外面的知识；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只需要时刻活在灵里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "行事与为人全照灵指示。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们越活在基督的里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "越凭着里面感觉而行动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就越有里面的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神越将基督铭刻我心中。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这里面生命的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们能维持与神的交通；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着这里面隐藏的认识，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神性的丰满要输供无穷。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
  "metadata": {
    "category": "里面生命的各方面",
    "time": "4/4",
    "hymn_code": "5565117123",
