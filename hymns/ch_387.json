    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "遇到试炼，无论大小，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有了罣虑，无论多少，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即使脚步尽都跌倒，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你总是够用！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "属地事物悦意称心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "光天化日路途平顺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安逸竟成遮光之云，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你当然够用！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "即使忧苦终日为患，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "失望、灰心、前途黑暗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心麻、灵木、欲祷无言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你仍是够用！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "不论我的环境如何，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你手都在将我托着，"
