    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou art Head o'er all things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast the highest fame."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Man, Thou art exalted;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supreme Thy glorious name!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Supreme Thy love, for Calv'ry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has shown its mighty power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love was proved victorious"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In sorrow's darkest hour."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon every heart shall prize Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All tongues Thy name shall praise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soon all shall recognize Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shouts of welcome raise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What blessing now to know Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In boundless love to bask,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And offer praise unceasing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To praise is all we ask."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy name all names excelleth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy fame all fame transcends."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love all love exceedeth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And never, never ends."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With joy we sing Thy praises"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As one with Thee above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal are Thy glories;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal is Thy love."
            }
          ]
        }
