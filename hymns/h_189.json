    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art before all creatures,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee all things consist;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all Thou art the center,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thee all things subsist."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the sole beginning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Firstborn from the dead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And for the Church, Thy Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the glorious Head."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Because it pleased the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All fulness dwells in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou might have the first place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all we ever see."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things Thou reconciledst"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God by Thy shed blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To thus present us holy"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And blameless unto God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee God’s fulness dwelleth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art God’s mystery;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The treasures of all wisdom"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And knowledge are in Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the hope of glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In us Thou dost abide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thee we are perfected"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God is satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are but a shadow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which unto us reveal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself, in whom we’re rooted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The only One that’s real."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enjoying all Thy riches,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy fulness we will be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll hold Thee, as Thy Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And grow with God in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thee in God we’re hidden,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art in us our life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy peace in us presiding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We rest from all our strife."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the new man, Thy Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the all in all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our all-inclusive Savior,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thyself we’ll ever call."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
