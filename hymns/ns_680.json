          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The building’s our only goal."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pattern cheers, and we respond, renewed;"
            }
          ]
        },
        {
          "segments": [
            {
