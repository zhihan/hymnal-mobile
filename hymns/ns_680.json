      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Your love constrains, You gently urge,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are drawn as You adjure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To go in faith, as mothers, nurse,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feed, cherish, raise up, mature;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In love pay the price, work gladly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praying, bear men to the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Together tried, fear not defeat;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your coming is our reward."
            }
          ]
        }
      ],
