          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With God wrestles tirelessly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your hand touched my stubborn places,"
            }
          ]
