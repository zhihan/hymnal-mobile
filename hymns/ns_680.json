      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, arise! In steps of the flock we move!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Pour out all and work with You, Lord, in love;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We, step by step, towards the goal, run the race;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life for God’s dream consecrate."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
