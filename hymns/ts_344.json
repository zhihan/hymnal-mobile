{
  "url": "https://www.hymnal.net/cn/hymn/ts/344",
  "title": "爱中牧养",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "祂 寻"
            },
            {
              "chord": "",
              "text": "我 如 同 寻"
            },
            {
              "chord": "C",
              "text": "找 迷"
            },
            {
              "chord": "",
              "text": "羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 赎"
            },
            {
              "chord": "D7",
              "text": "我 舍"
            },
            {
              "chord": "",
              "text": "了 性"
            },
            {
              "chord": "G",
              "text": "命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 能 得 祂 生"
            },
            {
              "chord": "Am",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经 历"
            },
            {
              "chord": "D7",
              "text": "祂 享"
            },
            {
              "chord": "",
              "text": "受 不"
            },
            {
              "chord": "G",
              "text": "尽。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦， 我 主， 我 真 爱"
            },
            {
              "chord": "C",
              "text": "你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不 自"
            },
            {
              "chord": "A7",
              "text": "禁 消"
            },
            {
              "chord": "",
              "text": "失 你"
            },
            {
              "chord": "D7",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 你 的"
            },
            {
              "chord": "G7",
              "text": "爱 困"
            },
            {
              "chord": "",
              "text": "迫 激"
            },
            {
              "chord": "C",
              "text": "励，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Am",
              "text": "愿 一"
            },
            {
              "chord": "D7",
              "text": "生 奉"
            },
            {
              "chord": "",
              "text": "献 给"
            },
            {
              "chord": "G",
              "text": "你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你甘美如草场、如溪水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我苏醒来走义路；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭信心生活有力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "引导我能活出义。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但世界时来搅扰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世代流行如浪潮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而你的爱永不动摇，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "牧养顾惜不减少。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "忽不觉你宝贵的同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摸不着可爱的你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的心不住犹疑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你杖竿安慰不已。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "深领会凭信而活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我牧人引我行走，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "面对仇敌享你筵席，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真经历福杯满溢。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我牧长，我愿意跟随你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "牧养你托付羊群，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "体贴你心中美意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远活在经纶里。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，我主，我感谢你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你恩慈随我不离，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿永住在你的殿里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "彰显你荣耀身体。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
