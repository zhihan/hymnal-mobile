            {
              "chord": "",
              "text": "Galbanum and frankincense—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These are Thy elements,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus my Lord!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stacte doth sons produce,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Onycha from sin doth loose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Galbanum all death repels,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In spirit, Lord."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Equal proportion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In resurrection;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seasoned with salt are they."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ground into powder fine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consumed with fire divine—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what an incense this,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus my Lord!"
            }
          ]
        }
      ],
