      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ointment is Christ for us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exceeding glorious!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incense is Christ for God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wholly for Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ointment flows down to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is our portion thus;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Incense ascends to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fragrant to Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by th’ anointing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ we experience"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then the incense burn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ in our prayer and praise—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O what a Christ we raise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From our experience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Precious to God."
            }
          ]
        }
      ],
