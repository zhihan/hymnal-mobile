      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "穌 基 督， 滿 有"
            },
            {
              "chord": "F",
              "text": "那"
            },
            {
              "chord": "C",
              "text": "靈， 宗"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "教 之 外 神 顯"
            },
            {
              "chord": "G7",
              "text": "明； 死"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "而 復 活， 衝 破 幽 冥， 神"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "眾 子 中 作 長"
            },
            {
              "chord": "C",
              "text": "兄。 作"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂 召 會， 我 們 聚 集， 老"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "套 規 條 已 全"
            },
            {
              "chord": "F",
              "text": "棄； 長"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "兄 榮 面，"
            },
            {
              "chord": "D7",
              "text": "我 們"
            },
            {
              "chord": "C",
              "text": "所"
            },
            {
              "chord": "A7",
              "text": "喜，"
            },
            {
              "chord": "D",
              "text": "祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作 中 心"
            },
            {
              "chord": "G7",
              "text": "和 目"
            },
            {
              "chord": "C",
              "text": "的。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "长兄复起，我们亦同，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "欢喜聚集复活中；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天然生命，惟愿消踪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主喜乐并得荣。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣基督，满有那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宗教之外神显明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死而复活，冲破幽冥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神众子中作长兄。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作祂召会，我们聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "老套规条已全弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "长兄荣面，我们所喜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作中心和目的。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祷读圣言，享受不已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天遇见主自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里火热，同来聚集，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被主充满且洋溢！"
            }
          ]
