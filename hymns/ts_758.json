            },
            {
              "chord": "Dm",
              "text": "兄─"
            },
            {
              "chord": "F",
              "text": "祂"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心 所 愛，"
            },
            {
              "chord": "G7",
              "text": "復 活"
            },
            {
              "chord": "C",
              "text": "所 生，"
            },
