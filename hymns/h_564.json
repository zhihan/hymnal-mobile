              "chord": "",
              "text": "All my will is yielding to Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His Spirit reigns within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His precious blood each moment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keeps me cleansed and free from sin."
            }
          ]
        }
