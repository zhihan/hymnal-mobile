        {
          "segments": [
            {
              "chord": "",
              "text": "I have ceased from all my struggling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis no longer I, but He."
            }
          ]
        },
        {
          "segments": [
