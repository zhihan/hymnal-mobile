              "text": "All my fears and griefs I tell Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my cares from day to day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my strength I draw from Jesus,"
            }
          ]
        },
        {
          "segments": [
