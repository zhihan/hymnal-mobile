    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All is in Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s dear Son is Lord of all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessings are imparted to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the shameful cross He bore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By His suffering inglorious"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have peace forevermore."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the Cross we have forgiveness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life eternal, endless mercy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By God’s Son is freely giv’n"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything in earth and heav’n."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All is in Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s dear Son is Lord of all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In me there is naught but weakness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I am worthless, full of sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stricken by its mortal sickness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lacking light and hope within."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in Christ I find abundant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Victory and strength and power."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, come and live in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come and make me rich in Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All is in Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s dear Son is Lord of all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, pardon my transgressions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For my love is still so small;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I gave all my possessions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This would profit scarce at all."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis myself that Thou desirest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So I give myself, dear Master;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No thing hast Thou kept from me—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor will I keep aught from Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All is in Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your whole self present to Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vain your quest for lasting pleasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wealth, success, and worldly fame;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ alone must be your treasure,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His resource your only claim."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Come, let Him disperse the famine"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of your arid, waste existence."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let God’s Son, th’ Immortal King"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freely give you everything."
            }
          ]
        }
      ]
    }
  ],
