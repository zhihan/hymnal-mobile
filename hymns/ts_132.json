{
  "url": "https://www.hymnal.net/cn/hymn/ts/132",
  "title": "神在肉身显现",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "得 胜， 何 等"
            },
            {
              "chord": "E",
              "text": "夸 胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 自"
            },
            {
              "chord": "A",
              "text": "己 来"
            },
            {
              "chord": "E7",
              "text": "成 为"
            },
            {
              "chord": "A",
              "text": "人！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亲 自 穿 上 人 的"
            },
            {
              "chord": "E",
              "text": "性 情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "叫 神"
            },
            {
              "chord": "A",
              "text": "的 计"
            },
            {
              "chord": "E7",
              "text": "画 成"
            },
            {
              "chord": "A",
              "text": "全；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 著"
            },
            {
              "chord": "E",
              "text": "十 架"
            },
            {
              "chord": "F♯m",
              "text": "败 坏"
            },
            {
              "chord": "C♯7",
              "text": "魔 鬼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "以 『人"
            },
            {
              "chord": "A",
              "text": "子』 复"
            },
            {
              "chord": "E7",
              "text": "活 升"
            },
            {
              "chord": "A",
              "text": "天！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣凭着人的美德，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "逮捕了那诡诈者；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以‘人’身分抵挡试探，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有考验全通过！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如今我在灵的里头，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "拥有祂一切美德。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂作人的匀细生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是在耶稣灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人的美德已经‘子化’，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神的灵调为一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如今这灵丰富无比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "足供我全人所需。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等奥秘，却极真实，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人子在我里面住！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂正伸展到我全人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要从我里面活出。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，阿利路亚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要赞美永不止。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "何等奇妙，何等荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神是在肉身显现！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们乃是祂的肢体，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为将祂人性彰显。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现在凭祂而活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让神居所早得建。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
