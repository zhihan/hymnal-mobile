        {
          "segments": [
            {
              "chord": "C",
              "text": "All that"
            },
            {
              "chord": "",
              "text": "we"
            },
            {
              "chord": "G",
              "text": "were— our"
            },
            {
              "chord": "C",
              "text": "sin, our"
            },
            {
              "chord": "G",
              "text": "guilt,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our"
            },
            {
              "chord": "Am",
              "text": "death—"
            },
            {
              "chord": "G",
              "text": "was"
            },
            {
              "chord": "C",
              "text": "all"
            },
            {
              "chord": "D7",
              "text": "our"
            },
            {
              "chord": "G7",
              "text": "own:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All"
            },
            {
              "chord": "C",
              "text": "that"
            },
            {
              "chord": "F",
              "text": "we"
            },
            {
              "chord": "C",
              "text": "are we"
            },
            {
              "chord": "F",
              "text": "owe to"
            },
            {
              "chord": "G",
              "text": "Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou"
            },
            {
              "chord": "C",
              "text": "God of"
            },
            {
              "chord": "Dm7",
              "text": "grace"
            },
            {
              "chord": "G",
              "text": "a"
            },
            {
              "chord": "C",
              "text": "lone."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy mercy found us in our sins,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And gave us to believe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then, in believing, peace we found,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in Thy Christ we live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All that we are, as saints on earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that we hope to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Jesus comes and glory dawns,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We owe it all to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, how rich, how vast Thy love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whoe’er can Thee repay?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy love is past man’s finding out,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace no man can say."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But Lord, to me I pray Thee grant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More clearly may I see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I may e’er more fully know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How much I owe to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But if man’s heart should e’er suppose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He could repay Thy love,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It only means he nothing knows"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of love, all loves above."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So may we never bargains make"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With that dear love of Thine:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The love that made Thine heart once break,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whoe’er that love could win?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then nevermore suggest return,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His love is far too high;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But let our hearts with rapture burn"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He for us should die."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Father God, we owe Thee all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that we are and have!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With grateful thanks before Thee fall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis all that we can give."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
