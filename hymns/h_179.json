              "text": "In Him we will rejoice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making a cheerful noise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Saying with heart and voice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Worthy the Lamb!”"
            }
          ]
        }
