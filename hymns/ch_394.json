          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前随我之所欲，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今听主支配；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前不住的讨问，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今不断赞美。"
            }
          ]
        }
