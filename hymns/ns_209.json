    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord I believe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When all around me is defeat"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And it seems that nothing’s changing outwardly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No! I’m not discouraged,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m believing You."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yes, I believe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And there is no demand on me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Simple faith, yes, that is all You want from me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Freed from anxious doubting—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m free to just believe!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Believing You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because, Lord, You are my success!"
            }
          ]
        },
        {
          "segments": [
            {
