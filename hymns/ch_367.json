{
  "url": "https://www.hymnal.net/cn/hymn/ch/367",
  "title": "主你所有一切工作",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "所 有 一"
            },
            {
              "chord": "G",
              "text": "切 工"
            },
            {
              "chord": "D",
              "text": "作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "並 非 到 了 十 架 為"
            },
            {
              "chord": "A",
              "text": "止；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 今"
            },
            {
              "chord": "",
              "text": "乃 是 仍"
            },
            {
              "chord": "G",
              "text": "舊 生"
            },
            {
              "chord": "A",
              "text": "活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "從 你"
            },
            {
              "chord": "",
              "text": "另 一 形"
            },
            {
              "chord": "A",
              "text": "態"
            },
            {
              "chord": "A7",
              "text": "表"
            },
            {
              "chord": "D",
              "text": "示。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你今仍旧施行拯救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍旧说话，仍旧引导；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你今成灵，仍在涌流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍旧光照，使人仆倒。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你成那灵，不停能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你成那灵，不停运行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的感动、你的鼓励；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仍安慰，你仍命令。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因为你已成为那灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂来就是你又来地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的内住是你充盈，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是你灵，祂又是你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今在我的心执行"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的一切命令、希冀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有如从前你在世境，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "执行父的所有旨意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们识祂就是识你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "服祂就是服你旨意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们被祂渗透、洋溢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是充满你的自己。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你今不是远在高天，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不是一去就不复返，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是仍旧在这世间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "奇哉！并住在我心坎。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
  "metadata": {
    "category": "经历基督",
    "time": "4/4",
    "hymn_code": "1345671765",
    "midi_tune_url": "https://www.hymnal.net/Hymns/Chinese/midi/tunes/c0367_tune.midi",
    "current_key": "D Major",
    "original_key": "D Major",
    "capo": 0,
