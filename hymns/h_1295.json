    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May all the things that come to us daily"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto the gospel turn,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all may see we're bound for the gospel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And of the Lord may learn."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May we be bold and fearless in spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaking the Word of God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do it in love and do it in power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While living in the Lord."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we're expecting that we'll be given"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Boldness with every breath."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ must be magnified in our body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whether by life or death."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We hope in nothing to be ashamed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For us to live is Christ—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the Person in all our living,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our everything, our life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May all our lives be worthy the gospel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whatever may betide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All standing fast in oneness of spirit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All striving side by side."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us proclaim the gospel in fullness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To satisfy the Lord:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is the life, the church His expression,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sound everywhere abroad."
            }
          ]
