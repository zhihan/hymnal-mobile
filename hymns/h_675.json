    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep in unfathomable mines"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of never-failing skill,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He treasures up His bright designs,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And works His sovereign will."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Ye fearful saints, fresh courage take;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The clouds ye so much dread"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are big with mercy, and shall break"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In blessings on your head."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Judge not the Lord by feeble sense,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But trust Him for His grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Behind a frowning providence"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He hides a smiling face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His purposes will ripen fast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unfolding every hour:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The bud may have a bitter taste,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But sweet will be the flower."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Blind unbelief is sure to err,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And scan His work in vain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is His own Interpreter,"
            }
          ]
        },
        {
          "segments": [
