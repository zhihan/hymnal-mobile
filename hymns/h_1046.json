    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost persuaded,” come, come today;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost persuaded,” turn not away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus invites you here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Angels are ling’ring near,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Prayers rise from hearts so dear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O wand’rer, come!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, be persuaded! Christ never fails—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, be persuaded! His blood avails—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can save from every sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cleanse you without, within—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will you not let Him in?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open the door!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost persuaded,” harvest is past!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost persuaded,” doom comes at last;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost” cannot avail;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost” is but to fail!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sad, sad that bitter wail—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Almost—but lost!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Be now persuaded, oh, sinner, hear!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be now persuaded, Jesus is near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His voice is pleading still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Turn now with heart and will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Peace will your spirit fill—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, turn today!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
