              "text": "Yet shall it be, I know it shall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, I trust Thy faithfulness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If nothing is too hard for Thee,"
            }
          ]
