    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas most impossible of all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That here sin’s reign in me should cease;"
            }
          ]
