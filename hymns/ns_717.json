    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ is Head of the Body; we’re His members true."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When we hold fast the Head, life freely flows."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we’re daily enjoying, we with Christ are infused,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All His heart for the Body we’ll know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Members one of another, the Body will grow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As we’re knit together in our inward parts."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Open firstly to Christ our Head, then life He will bestow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the function in measure of each part."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For the sake of Your Body, Lord, unveil our eyes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deal with self, all the ground to You we give."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Save us from independence and all natural ties."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blend us all in Your Body to live."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
