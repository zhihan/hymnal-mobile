      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One with Christ in His Body, in the rich supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every part causing growth in love each day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus God’s purpose eternal will be realized—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ expressed through His Body for aye."
            }
          ]
