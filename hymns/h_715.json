    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God knows the way, He holds the key,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He guides us with unerring hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sometime with tearless eyes we’ll see;"
