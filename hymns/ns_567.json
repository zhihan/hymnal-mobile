      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The spontaneous issue of the life of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is a love for all the sons of God."
            }
          ]
        },
        {
          "segments": [
            {
