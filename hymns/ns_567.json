              "chord": "",
              "text": "Out of death (Out of death)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And into life (And into life)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Because we love (Because we love),"
            }
          ]
        },
        {
          "segments": [
            {
