{
  "url": "https://www.hymnal.net/cn/hymn/ch/122",
  "title": "我们的灵伏着注视",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "的 靈 伏 著"
            },
            {
              "chord": "G",
              "text": "注 視"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "在 榮"
            },
            {
              "chord": "A7",
              "text": "耀 裡"
            },
            {
              "chord": "",
              "text": "的 耶"
            },
            {
              "chord": "D",
              "text": "穌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們"
            },
            {
              "chord": "D7",
              "text": "在 彼"
            },
            {
              "chord": "",
              "text": "讀 祂"
            },
            {
              "chord": "G",
              "text": "故"
            },
            {
              "chord": "B",
              "text": "事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "如 何"
            },
            {
              "chord": "",
              "text": "在 世"
            },
            {
              "chord": "A7",
              "text": "受 羞"
            },
            {
              "chord": "D",
              "text": "辱。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的圣首满了羞辱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世人竟然大欢畅；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今日荣耀反面说出："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当日你心的忧伤。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当你挂在十字架时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "孤单被弃无人怜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "众圣今则向你唱诗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你则高升到父前。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神曾不顾你的无告！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神曾离弃你不瞧！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们从你憔悴面貌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "现今看见父荣耀。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵的主！注视这个，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不禁要赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿天地同心唱和："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "‘神的羔羊，你是配。’"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们的心应当起来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即今起来赞美父；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿歌颂、欢呼、爱戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "归给父子到永古。"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
