{
  "url": "https://www.hymnal.net/en/hymn/h/561",
  "title": "Thou hast said Thou art the Vine, Lord",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "Thou hast"
            },
            {
              "chord": "",
              "text": "said Thou art the"
            },
            {
              "chord": "A",
              "text": "Vine, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And that"
            },
            {
              "chord": "Gm",
              "text": "I'm a"
            },
            {
              "chord": "",
              "text": "branch in"
            },
            {
              "chord": "A",
              "text": "Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "But I"
            },
            {
              "chord": "",
              "text": "do not"
            },
            {
              "chord": "D7",
              "text": "know the"
            },
            {
              "chord": "Gm",
              "text": "reason"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Dm",
              "text": "Why I"
            },
            {
              "chord": "",
              "text": "should so"
            },
            {
              "chord": "A",
              "text": "barren"
            },
            {
              "chord": "Dm",
              "text": "be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Bearing fruit is my deep longing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More Thy life to manifest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Thy throne to bring more glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy will may be expressed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But I fail to understand, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What it means—“abide in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the more I seek “abiding,”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More I feel I’m not in Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How I feel I’m not abiding;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though I pray and strongly will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet from me Thou seemest distant"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my life is barren still."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet Thou art the Vine, Thou saidst it."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I am a branch in Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I take Thee as my Savior."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then this fact is wrought in me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m in Thee and I need not"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seek into Thyself to come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I’m joined to Thee already,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy flesh and bones I’m one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Not to “go in” is the secret."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But that I’m “already in“!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I ne’er may leave I’d ask Thee."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not how I may get within."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I am in, already in Thee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a place to which I’m brought!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s no need for prayer or struggling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God Himself the work has wrought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since I’m in, why ask to enter;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O how ignorant I’ve been!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now with praise and much rejoicing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thy Word, I dwell therein."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now in Thee I rest completely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With myself I gladly part;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art life and Thou art power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All in all to me Thou art."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    }
  ],
