    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O who like Thee, so mild, so bright,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Son of man, Thou Light of light?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O who like Thee did ever go"
            }
          ]
        },
        {
          "segments": [
            {
