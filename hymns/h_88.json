      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O who like Thee so humbly bore"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The scorn, the scoffs of men, before?"
