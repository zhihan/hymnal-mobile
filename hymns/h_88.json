        {
          "segments": [
            {
              "chord": "",
              "text": "So meek, so lowly, yet so high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So glorious in humility?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And death, that sets the prisoner free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was pang, and scoff, and scorn to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet love through all Thy torture glowed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And mercy with Thy life-blood flowed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O wondrous Lord, my soul would be"
            }
          ]
        },
        {
          "segments": [
            {
