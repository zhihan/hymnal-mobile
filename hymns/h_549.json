    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter the veil and go without the camp,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By heaven’s presence will the earth depart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If heaven’s glory doth my spirit charm,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can earth’s happiness possess my heart?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter the veil, behold the glorious Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go out the camp to Jesus, let Him lead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If throne and crown my spirit here enthrall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Manger and cross cannot my steps impede."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter the veil for resurrection pow’r,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go out the camp to bear the cross and woe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If I His radiant face in heaven see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His footsteps I will follow here below."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter the veil, on heaven’s fatness feast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without the camp, in hardship persevere;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though earthly trials sorely pain my heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaven’s communion doth my spirit cheer."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter the veil, Christ’s riches there enjoy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without the camp, the needs of men supply;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life of heaven living out thru me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The souls of earth will bless and satisfy."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Enter the veil till it exists no more,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Go out the camp till all the camps are gone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the heavens and the earth unite,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till God and man together dwell in one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
