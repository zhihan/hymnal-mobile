{
  "url": "https://www.hymnal.net/en/hymn/ns/468",
  "title": "Lord, in that coming day",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lord, in"
            },
            {
              "chord": "",
              "text": "that"
            },
            {
              "chord": "G",
              "text": "coming"
            },
            {
              "chord": "D",
              "text": "day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When all will"
            },
            {
              "chord": "E7",
              "text": "bow the"
            },
            {
              "chord": "A7",
              "text": "knee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "'Twill be"
            },
            {
              "chord": "",
              "text": "a common"
            },
            {
              "chord": "G",
              "text": "place display"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To"
            },
            {
              "chord": "D",
              "text": "waste one's"
            },
            {
              "chord": "A7",
              "text": "all on"
            },
            {
              "chord": "D",
              "text": "Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thee, Lord, on that day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ten thousand hearts would break,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And if there were ten thousand worlds,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "These all, men would forsake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But now, while yet ’tis rare,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My being won’t delay;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Inspired by Thy love, could I,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy noble tribute stay?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My all I gladly give"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In love’s response to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For how can I withhold my all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Thou gav’st all for me?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Time’s window soon shall close;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now, while ’tis open still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This golden moment I’d redeem,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy house with fragrance fill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The moments fly apace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thou art coming soon!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can I delay, and fail to grasp"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This moment opportune?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "While there is still today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Beyond, no guarantee),"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seizing this opportunity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I waste myself on Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "That woman’s noble deed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was for Thy going wrought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In view of Thy return, I too"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Would offer as I ought."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Two resurrections tell"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The foolish from the wise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Some would “beforehand” pay the price"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lukewarmness despise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I dare not passive be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But fully consecrate"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Beforehand”, lest I miss my chance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And risk arriving late."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "10"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There is but one regret"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Both hell and heaven hold—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The loss of opportunity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternity unfolds."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "11"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Performing love’s sweet task,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While time doth still permit,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I break mine alabaster flask"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thine own love requit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "12"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May this be, in that day"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I Thy coming hail"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(E’en if I sleep and wait for Thee),"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our love’s memorial."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "13"
    }
  ],
