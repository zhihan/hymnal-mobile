      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What we are, we’re the joint-heirs;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We inherit full salvation."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We overcome and share His throne."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things today we fully own."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re the joint-heirs, glorious!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What we are, we’re Christ’s partners:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We share the same anointing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer we’re just serving Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His riches we may all share in."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’re His partners, glorious!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What we are, we’re the brothers."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are all the holy brothers."
            }
          ]
        },
        {
          "segments": [
            {
