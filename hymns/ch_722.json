          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来投耶稣怀里面，"
            }
          ]
        },
        {
          "segments": [
