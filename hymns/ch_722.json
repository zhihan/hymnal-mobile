  "title": "飘渺人生何短暂",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "飘 渺"
            },
            {
              "chord": "",
              "text": "人 生 何 短 暂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好 似 浮 云 现 即 散，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又 似"
            },
            {
              "chord": "G",
              "text": "幻 梦"
            },
            {
              "chord": "",
              "text": "醒 就 完："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "A",
              "text": "时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "时 日"
            },
            {
              "chord": "D",
              "text": "飞 逝"
            },
            {
              "chord": "",
              "text": "在 宣 言："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "转 瞬"
            },
            {
              "chord": "G",
              "text": "就 到"
            },
            {
              "chord": "",
              "text": "死 亡 线，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再 迟"
            },
            {
              "chord": "D",
              "text": "必 在"
            },
            {
              "chord": "",
              "text": "地 狱"
            },
            {
              "chord": "A7",
              "text": "间："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "D",
              "text": "时！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及 时！ 要 及 时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当 今 耶 稣 在 召 唤："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "A",
              "text": "时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "若 在"
            },
            {
              "chord": "D",
              "text": "罪 中"
            },
            {
              "chord": "",
              "text": "仍 流 连，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 怕"
            },
            {
              "chord": "G",
              "text": "恩 门"
            },
            {
              "chord": "",
              "text": "向 你 关，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那 时"
            },
            {
              "chord": "D",
              "text": "呼 救"
            },
            {
              "chord": "",
              "text": "已 太"
            },
            {
              "chord": "A7",
              "text": "晚："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "D",
              "text": "时！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁是智者，该想看："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "鲜花朝艳暮凋残，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "英年要去何能挽？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，我求你早打算，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得过了死亡线，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人丧在地狱间："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当今耶稣在召唤："
            }
          ]
        },
        {
          "segments": [
