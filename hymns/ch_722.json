              "chord": "",
              "text": "来接基督进心间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来就救主趁今天："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
