        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵仍在把你感，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常与你来争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何不降服得平安？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主等候赐恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿意救你免悲惨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若踌躇何愚顽！"
            }
          ]
        },
        {
          "segments": [
