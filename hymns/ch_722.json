  "title": "飘渺人生何短暂",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "飄 渺"
            },
            {
              "chord": "",
              "text": "人 生 何 短 暫，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好 似 浮 雲 現 即 散，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "又 似"
            },
            {
              "chord": "G",
              "text": "幻 夢"
            },
            {
              "chord": "",
              "text": "醒 就 完："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "A",
              "text": "時！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "時 日"
            },
            {
              "chord": "D",
              "text": "飛 逝"
            },
            {
              "chord": "",
              "text": "在 宣 言："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "轉 瞬"
            },
            {
              "chord": "G",
              "text": "就 到"
            },
            {
              "chord": "",
              "text": "死 亡 線，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "再 遲"
            },
            {
              "chord": "D",
              "text": "必 在"
            },
            {
              "chord": "",
              "text": "地 獄"
            },
            {
              "chord": "A7",
              "text": "間："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "D",
              "text": "時！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及 時！ 要 及 時！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "當 今 耶 穌 在 召 喚："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "A",
              "text": "時！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "若 在"
            },
            {
              "chord": "D",
              "text": "罪 中"
            },
            {
              "chord": "",
              "text": "仍 流 連，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只 怕"
            },
            {
              "chord": "G",
              "text": "恩 門"
            },
            {
              "chord": "",
              "text": "向 你 關，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那 時"
            },
            {
              "chord": "D",
              "text": "呼 救"
            },
            {
              "chord": "",
              "text": "已 太"
            },
            {
              "chord": "A7",
              "text": "晚："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要 及"
            },
            {
              "chord": "D",
              "text": "時！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "谁是智者，该想看："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "鲜花朝艳暮凋残，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "英年要去何能挽？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，我求你早打算，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "免得过了死亡线，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全人丧在地狱间："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当今耶稣在召唤："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若在罪中仍流连，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只怕恩门向你关，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "那时呼救已太晚："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵仍在把你感，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时常与你来争战，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何不降服得平安？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救主等候赐恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿意救你免悲惨；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若踌躇何愚顽！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要及时！"
            }
          ]
        }
      ],
      "type": "verse",
