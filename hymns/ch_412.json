  "title": "摸你就得生命供应",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "恩 主，"
            },
            {
              "chord": "",
              "text": "我 今 凭 信"
            },
            {
              "chord": "G",
              "text": "摸 你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是"
            },
            {
              "chord": "G7",
              "text": "供 给"
            },
            {
              "chord": "",
              "text": "的 源"
            },
            {
              "chord": "C",
              "text": "头；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭 信 取 用"
            },
            {
              "chord": "G",
              "text": "你 的"
            },
            {
              "chord": "C",
              "text": "能 力，"
            }
          ]
        },
