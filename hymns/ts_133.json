    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "看哪！撒但来到地上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "破坏人类生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但神从中兴起一人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的价值无比！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从这一个女人后裔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神来成为肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这人耶稣─末后亚当─"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摧毁撒但诡计。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让我们凭着"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣的人性而站住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "洋溢出人性美德，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为中流砥柱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这世代，罪恶猖獗，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弯曲败坏，悖逆刚硬，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "召会必须强烈见证"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "耶稣完美人性！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "触目惊心，全地污染，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪中滚向下坡；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每况愈下，几无药救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人性何其堕落！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们却是天国子民，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显为世上的盐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在这不法世代里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙祂人性保全。"
            }
          ]
        }
      ]
    },
