              "text": "主名不断呼喊；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受祂的人性所有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天践踏撒但。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，让我们回转向主，"
            }
          ]
        },
        {
          "segments": [
