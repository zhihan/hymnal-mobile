    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stake out the camp within the dell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There we’ll find a springing well."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Theirs is the claim that leads to strife;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mine, inheriting life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Richer and great I grew to be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such gave rise to enmity."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Destined for joy, yet this I know,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God will not let me go."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though wells availed in all the land,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Still I came to doubt my stand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessings divine can ne’er replace"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s appearing in grace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I, in Beersheba, will remain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Build an altar, call His name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Draw from the well that flows so free"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the tamarisk tree."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig up the wells my father made;"
