    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We must repent for the kingdom’s at hand;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that we do, think, or feel, or have planned"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Must be abandoned and changed in our mind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leave all the world and self-seeking behind."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O let Him grow, O let Him grow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His kingdom life be all we know."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the kingdom is sown into us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, the kingdom, O how glorious!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All of religion has missed it again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Teaching for doctrines the concepts of men;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They vainly wait for the kingdom to be."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A dispensation they’re hoping to see."
            }
          ]
        }
      ],
