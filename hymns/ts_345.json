    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，你是我至爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽我曾顽梗又悖逆，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今放下一切，你前来侍立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只愿像你那样无己。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "真渴望活着就是你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺从神旨，不凭己意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与你心合拍，只要你所喜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "挣扎全停，尽是安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世上有谁像你如此美丽？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人间有何与你爱情能比？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，圣中之圣，你竟住我里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主耶稣，我深深爱你！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不愿再受欺，不愿再任意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿脱自己，只被你充溢；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你以外，哦，让一切都绝迹；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我惟一的最爱是你。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
