  "raw_sections": [
    "真 葡萄 樹，",
    "生命 何等 豐美，",
    "繁生 枝子無 數，",
    "結出 果實 纍纍；",
    "主， 你 是 樹，",
    "我們 是你 枝子，",
    "愛中 互相內 住，",
    "生命 湧流 不止；",
    "生機 結聯，",
    "彼此 合一 無間，",
    "享受 父神 栽培、 照護，",
    "生 命 充滿，",
    "不斷 洋溢、 擴展，",
    "彰顯 父神 一切 豐富。"
  ]
