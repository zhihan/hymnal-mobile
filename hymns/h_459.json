      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No longer is our life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A thing unused or vain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us e’en here to live is Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To us to die is gain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life is hid with Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ in God above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upward our heart would go to Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whom, seeing not, we love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He liveth, and we live!"
