    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The time past of our lives"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sufficeth to have wrought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fleshly will, which only ill"
            }
          ]
        },
