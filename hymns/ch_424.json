{
  "url": "https://www.hymnal.net/cn/hymn/ch/424",
  "title": "我心安息在于主",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 心"
            },
            {
              "chord": "",
              "text": "安"
            },
            {
              "chord": "A7",
              "text": "息 在"
            },
            {
              "chord": "D",
              "text": "於 主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 纔 真"
            },
            {
              "chord": "A7",
              "text": "是 安"
            },
            {
              "chord": "D",
              "text": "息！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除 此， 全"
            },
            {
              "chord": "A7",
              "text": "能 的"
            },
            {
              "chord": "D",
              "text": "耶 穌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪 人 有"
            },
            {
              "chord": "A7",
              "text": "何 希"
            },
            {
              "chord": "D",
              "text": "冀？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "光 是"
            },
            {
              "chord": "",
              "text": "我 的"
            },
            {
              "chord": "D",
              "text": "智 慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A7",
              "text": "愛 是"
            },
            {
              "chord": "",
              "text": "我 奮"
            },
            {
              "chord": "D",
              "text": "勉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "在 榮"
            },
            {
              "chord": "",
              "text": "耀 的"
            },
            {
              "chord": "D",
              "text": "地 位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天 天 引"
            },
            {
              "chord": "A7",
              "text": "我 進"
            },
            {
              "chord": "D",
              "text": "前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我罪虽大无法比，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你赐恩典更大；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是羔羊来献祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你死我免受罚；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我从罪中得释放，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就从灰尘重回；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你话是我的亮光，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你血是我宝贝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "温柔的主，你目的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟愿从我得成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着遵行你旨意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今奉献此生。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我虽是真的软弱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "可是你是能力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的子民万事绰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要他们有你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "黑云罩我最黑时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "正是你最近我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来使我信能坚持，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来教我灵不懦。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你怀里我安卧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "注视你的荣颜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你是我的安息所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撒但徒然离间。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "是你使我能喜乐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是你使我释放；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因此我要献诗歌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向你永远称扬。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上福乐和爱情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来源纵然全涸，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只须你恩有供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "或生或死都可。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
