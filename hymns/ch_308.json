    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "世上景色我已一阅，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你使我目复盲；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不然，我怕祂的喜悦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不如从前的显彰。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今不望离开苦刺，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘心软弱望加恩；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "座上荣耀、幔内启示，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "依然照亮无眼人。"
            }
          ]
        }
      ],
