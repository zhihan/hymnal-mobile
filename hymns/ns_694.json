    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal Father, source of each blessing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bestowed on Christ from heaven above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Your name keep us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Your hand hold us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From evil shield us, safe in Your love!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal Son, arose as the morning sun;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God in the flesh brought glory and grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your presence touched us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your kindness reached us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shine now upon us, light up Your face!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal Spirit, lift up Your countenance,"
