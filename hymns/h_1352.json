    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide in Him, anointing then will flow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, the Spirit’s lead we’ll know."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Obeying, we His riches apprehend;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Led by the Spirit, we will be His friend."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abide in Him, the light of grace will shine;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, all shadows will decline."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Obey the light, His life in us will grow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From darkness freed, our heart will comfort know."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, we are strengthened with each breath;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, His life will swallow death."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, all our sighing turns to song;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, our heart is gladdened, strong."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, this will Satan’s strength disarm;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, the world will lose its charm."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, we sin’s power need not fear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, the self will disappear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, thus conformed to Him we’ll be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, His life fills constantly."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, we experience His power;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, His riches, hour by hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Abiding, Lord, for Thee my spirit yearns;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In fellowship, Thy Spirit in me burns,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That all my being may be lost in Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And with Thee mingled through eternity."
            }
          ]
        }
      ],
