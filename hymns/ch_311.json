{
  "url": "https://www.hymnal.net/cn/hymn/ch/311",
  "title": "主阿求你将我看",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主 阿，"
            },
            {
              "chord": "A",
              "text": "求 你"
            },
            {
              "chord": "A7",
              "text": "将 我"
            },
            {
              "chord": "D",
              "text": "看，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐 我"
            },
            {
              "chord": "G",
              "text": "甜 美"
            },
            {
              "chord": "D",
              "text": "的 简"
            },
            {
              "chord": "A7",
              "text": "单；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "灵 中"
            },
            {
              "chord": "A",
              "text": "贫 穷，"
            },
            {
              "chord": "A7",
              "text": "心 卑"
            },
            {
              "chord": "D",
              "text": "微，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "寻 求"
            },
            {
              "chord": "G",
              "text": "犹 如"
            },
            {
              "chord": "A",
              "text": "向"
            },
            {
              "chord": "A7",
              "text": "日"
            },
            {
              "chord": "D",
              "text": "葵。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离作威的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离财奴之所倚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离显扬的兴趣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱离受夸的私欲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有供我骄傲的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你为我全抛弃；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我意志服你的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谦卑顺服到死地。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "使我回转像婴孩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我智、力、全毁坏；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只在你的光中行，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只靠你的能力动。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "倚在你爱的胸膛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像断奶的仰望；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感到神赐的平安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "充满在我全人间。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "让我活在这姿态，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天天满出赞美来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此到死也不变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我等候你显现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "羡慕",
    "time": "3/4",
    "hymn_code": "117544353542132",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/413",
        "language": "cn",
        "category": "h",
        "number": "413",
        "title": "E413"
      }
    ]
  },
  "raw_sections": [
    "主 阿，求 你将 我看，",
    "赐 我甜 美的 简单；",
    "灵 中贫 穷，心 卑微，",
    "寻 求犹 如向日葵。",
    "脱离作威的自己，",
    "脱离财奴之所倚，",
    "脱离显扬的兴趣，",
    "脱离受夸的私欲。",
    "所有供我骄傲的，",
    "求你为我全抛弃；",
    "使我意志服你的，",
    "谦卑顺服到死地。",
    "使我回转像婴孩，",
    "将我智、力、全毁坏；",
    "只在你的光中行，",
    "只靠你的能力动。",
    "倚在你爱的胸膛，",
    "好像断奶的仰望；",
    "感到神赐的平安，",
    "充满在我全人间。",
    "让我活在这姿态，",
    "天天满出赞美来，",
    "如此到死也不变，",
    "但我等候你显现。"
  ]
}