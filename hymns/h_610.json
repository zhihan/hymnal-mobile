    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God as the Father is the source,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God the Son doth Him express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God as the Spirit enters us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God as all we may possess."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father, who is veiled in light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son to man hath fully shown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit then transmitteth Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He may inwardly be known."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Son within the Father is,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now the Spirit is the Son."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit, Son, and Father God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are now in us and with us one."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God as the Father in the Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has been embodied and expressed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God the Spirit is the Son's"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reality to be possessed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "May God the Father's love to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In God the Son as grace be known,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru God the Spirit's fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That God our portion we may own."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
