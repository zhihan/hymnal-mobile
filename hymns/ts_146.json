{
  "url": "https://www.hymnal.net/cn/hymn/ts/146",
  "title": "经历包罗万有的灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主"
            },
            {
              "chord": "",
              "text": "你 在 复 活 里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "A",
              "text": "成 赐"
            },
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "A7",
              "text": "命 之"
            },
            {
              "chord": "D",
              "text": "灵；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 我 与 你 同 复"
            },
            {
              "chord": "A",
              "text": "起，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使"
            },
            {
              "chord": "G",
              "text": "我 重"
            },
            {
              "chord": "",
              "text": "生"
            },
            {
              "chord": "A7",
              "text": "得 生"
            },
            {
              "chord": "D",
              "text": "命。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这灵就是你进入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "带着丰盛的生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "包罗万有的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作我全备的供应。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如今这灵已内住，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你无数肢体里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与你得联属，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们活着就是你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "凭灵全备的供应，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们将你来活出；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为你的活见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为团体的基督。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借着你灵的率领，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "见证向外能普及；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们是你见证人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你传扬到地极。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此扩展这见证，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "达到终极的完成；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是新耶路撒冷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远丰满无止境。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
  "metadata": {
    "category": "灵与生命",
