  "title": "哦主你是万有的主",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 是 万"
            },
            {
              "chord": "D",
              "text": "有 的"
            },
            {
              "chord": "G",
              "text": "主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "A",
              "text": "得 荣"
            },
            {
              "chord": "A7",
              "text": "耀 冠"
            },
            {
              "chord": "D",
              "text": "冕；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因 你 权"
            },
            {
              "chord": "G",
              "text": "柄 和"
            },
            {
              "chord": "C",
              "text": "你 威"
            },
            {
              "chord": "",
              "text": "严，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万"
            },
            {
              "chord": "D",
              "text": "众 将"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D7",
              "text": "称"
            },
            {
              "chord": "G",
              "text": "赞。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神在人里活在地上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "曾经成为奴仆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人在神里住在天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尊为万有之主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是那人在荣耀里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与神同坐宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天上地上所有权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都归你得着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "升上高天，得被高举，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且得至高尊名；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万口无不称你为主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万膝无不跪敬。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神已使你作主基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵如此证明；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在荣耀里，并在天上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着宝座、权柄。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀之主，我们敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高声向你赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有之主，我们高举，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美惟你是配！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
