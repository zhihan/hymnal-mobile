    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thine only Son from death Thou raised,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Firstborn in resurrection;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His work completed, well He’s praised;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His vict’ry’s our possession."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ve now become Thy many sons;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our heart with praise is ringing;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that Thy firstborn Son has done"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fills all our days with singing."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "His God is also ours, we’re shown;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Father is our Father."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flesh of His flesh, bone of His bone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Naught us from Him can sever."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Him we’re now led back to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To sing in congregation;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Him and one with Him are we,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Firstborn’s duplication."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What grace and love divine this is!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Son and sons joined ever;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our blest eternal portion ’tis,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Father’s joy and pleasure!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Son will come from heaven soon;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Today we here await Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May this desire our hearts consume:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With lute and lyre to praise Him."
            }
          ]
        }
      ],
