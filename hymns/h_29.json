    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What led Thy Son, O God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To leave Thy throne on high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To shed His precious blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To suffer and to die?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Twas love—unbounded love to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Twas love—unbounded love to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Led Him to die and suffer thus."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What moved Thee to impart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit from above,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Therewith to fill our heart"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With heavenly peace and love?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Twas love—unbounded love to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Twas love—unbounded love to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Moved Thee to give Thy Spirit thus."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What love to Thee we owe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our God, for all Thy grace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts may well o'erflow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In everlasting praise!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us, O God, to praise Thee thus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us, O God, to praise Thee thus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all Thy boundless love to us."
            }
          ]
        }
