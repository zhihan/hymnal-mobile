{
  "url": "https://www.hymnal.net/cn/hymn/ch/352",
  "title": "我们虽然时常摇动",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 們"
            },
            {
              "chord": "",
              "text": "雖 然 時"
            },
            {
              "chord": "A",
              "text": "常"
            },
            {
              "chord": "A7",
              "text": "搖"
            },
            {
              "chord": "D",
              "text": "動，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但 祂 依 然 歷 久 不"
            },
            {
              "chord": "A",
              "text": "變；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "祂 的"
            },
            {
              "chord": "",
              "text": "應 許 無"
            },
            {
              "chord": "A",
              "text": "一"
            },
            {
              "chord": "A7",
              "text": "落"
            },
            {
              "chord": "D",
              "text": "空，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "天 地 沒 有 那"
            },
            {
              "chord": "A",
              "text": "樣"
            },
            {
              "chord": "A7",
              "text": "貞"
            },
            {
              "chord": "D",
              "text": "堅。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们虽然二三其心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但祂不肯撇弃我们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽受冷落，仍要亲近，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "地上朋友无祂这真！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂永不肯辜负我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有信托祂都尽力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为祂既爱了我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就爱我们一直到底。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "到底！我们对祂无良，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忘祂，伤祂，暗中心变；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂外，我们另事偶像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心里也不抱歉半点！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "到这偶像倾倒绝迹，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不禁悲伤，又来寻求"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们从前所辜负的，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这位始终如一的友！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂又收留安慰我们，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并引我们亲近自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一若毫无其事发生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并爱我们一直到底。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，我们对着这爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不能不发高声赞美；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "比死坚强，比水忍耐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们心融，只有感佩。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
