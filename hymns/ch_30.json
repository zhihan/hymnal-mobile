{
  "url": "https://www.hymnal.net/cn/hymn/ch/30",
  "title": "父阿我们向你下拜",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父 阿，"
            },
            {
              "chord": "",
              "text": "我 们 向"
            },
            {
              "chord": "D",
              "text": "你 下"
            },
            {
              "chord": "G",
              "text": "拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满 心 希"
            },
            {
              "chord": "D",
              "text": "奇 你"
            },
            {
              "chord": "A7",
              "text": "的 大"
            },
            {
              "chord": "D",
              "text": "爱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "人"
            },
            {
              "chord": "C",
              "text": "算 甚"
            },
            {
              "chord": "G",
              "text": "么， 你"
            },
            {
              "chord": "",
              "text": "竟 眷 念？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "轻"
            },
            {
              "chord": "C",
              "text": "微 如"
            },
            {
              "chord": "G",
              "text": "我 你"
            },
            {
              "chord": "D",
              "text": "也 拣"
            },
            {
              "chord": "G",
              "text": "选！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们赞美你的心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "原是计画要人像你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你生命，给你充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "有你形像，将你彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你来造人照你形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并将权柄交人执掌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且作生命给人接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要人享受你的所有。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你要进入人的里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与人调和，将人成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使人变质，同被建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作你居所，显你荣耀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "人虽堕落，你未放弃，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍要在人成全你意；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着救赎将人带回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出万般爱心、智慧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在子里已经显出，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死而复活成功救赎；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借成那灵也已进入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我里面施恩、眷顾。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你以我灵为至圣所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "其中设你施恩宝座；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要我灵里与你相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同祭司烧香、祷告。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在此恩惠如同江河，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流自你的施恩宝座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我流过、将我变化、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我建造成为你家。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们如此受宠、受惠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万分希奇你的圣垂；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心中感激你的大爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵里向你献上敬拜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
  "metadata": {
    "category": "敬拜父",
    "time": "3/4",
    "hymn_code": "1176512171",
    "midi_tune_url": "https://www.hymnal.net/Hymns/Chinese/midi/tunes/c0030_tune.midi",
