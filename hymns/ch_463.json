  "raw_sections": [
    "十 架樂 接受，",
    "窄 路肯 行 走，",
    "流 露生 命， 不 再 將 主扣；",
    "世 界丟 背後，",
    "主 外無 所 求，",
    "流 露生 命， 不 再將主扣。",
    "流 露！流 露！",
    "流 露生 命， 不 再 扣留；",
    "流露！流 露！",
    "流 露生 命， 不 再將主扣。"
  ]
