  "raw_sections": [
    "十 架乐 接受，",
    "窄 路肯 行 走，",
    "流 露生 命， 不 再 将 主扣；",
    "世 界丢 背后，",
    "主 外无 所 求，",
    "流 露生 命， 不 再将主扣。",
    "流 露！流 露！",
    "流 露生 命， 不 再 扣留；",
    "流露！流 露！",
    "流 露生 命， 不 再将主扣。"
  ]
