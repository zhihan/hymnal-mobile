    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy life and by its flowing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I can grow and be transformed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the saints coordinated,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Builded up, to Thee conformed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Keep the order in the Body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There to function in Thy will,"
            }
          ]
        },
        {
          "segments": [
