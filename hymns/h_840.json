              "text": "Ever serving, helping others,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy purpose to fulfill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In my knowledge and experience"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would not exalted be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But submitting and accepting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let the Body balance me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holding fast the Head, and growing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His increase, in His way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the joints and bands supplying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knit together day by day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy Spirit daily strengthened"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the inner man with might,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I would know Thy love surpassing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Know Thy breadth and length and height;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever of Thy riches taking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto all Thy fulness filled,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever growing into manhood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy Body Thou may build."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In God’s house and in Thy Body"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Builded up I long to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That within this corporate vessel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All shall then Thy glory see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy Bride, the glorious city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May appear upon the earth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a lampstand brightly beaming"
            }
          ]
        },
        {
          "segments": [
