              "chord": "F",
              "text": "sons of"
            },
            {
              "chord": "G",
              "text": "God"
            },
            {
              "chord": "D7",
              "text": "to"
            },
            {
              "chord": "G",
              "text": "come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the"
            },
            {
              "chord": "G7",
              "text": "creatures"
            },
            {
              "chord": "C",
              "text": "wait, expecting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That they all"
            },
            {
              "chord": "F",
              "text": "may"
            },
            {
              "chord": "C",
              "text": "free"
            },
            {
              "chord": "G7",
