          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All creation groans together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Subject now to vanity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Looking for their full deliv’rance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From corruption’s slavery."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Even we ourselves are groaning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till we reach maturity;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are growing into sonship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ in conformity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis for this the Spirit groaneth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That to Christ we be conformed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things also work together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That in life we be transformed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God will bring us into glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will then be glorified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully saturated with Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll be wholly sanctified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To the freedom of this glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All creation will be freed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the kid shall lie the leopard,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the cow with bear shall feed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Heirs with Christ in our full sonship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll His heritage possess,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorified with Him as brethren,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s full glory we’ll express."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
