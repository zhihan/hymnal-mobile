{
  "url": "https://www.hymnal.net/cn/hymn/ch/103",
  "title": "我的代替未见归回",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "我 的"
            },
            {
              "chord": "",
              "text": "代 替 未 見 歸"
            },
            {
              "chord": "D",
              "text": "回，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 怎 能 彀 放"
            },
            {
              "chord": "D7",
              "text": "心 無"
            },
            {
              "chord": "G",
              "text": "慮；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "會 否 我 罪 將 祂 連"
            },
            {
              "chord": "C",
              "text": "累，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未 能 救"
            },
            {
              "chord": "G",
              "text": "我， 祂"
            },
            {
              "chord": "D7",
              "text": "倒 被"
            },
            {
              "chord": "G",
              "text": "拘？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "能否是因我的罪孽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "太大、过多、无法赦免？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能否是因祂的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能力有限、包括不全？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "欢呼！耶稣已经复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "未损毫发，只增荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂虽进入黑暗处所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "黑暗未曾留下功效。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主得归回，就是凭据，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的公义已得满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的大爱仍施怜恤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主是已经完成救赎。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神用复回答复流血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承认流血所成救赎；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，我已清洁！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚，我得饶恕！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "赞美主",
    "time": "3/4",
    "hymn_code": "532156517",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/8103",
        "language": "cn",
        "category": "h",
        "number": "8103",
        "title": "E8103"
      }
    ]
  },
  "raw_sections": [
    "我 的代 替 未 見 歸回，",
    "我 怎 能 彀 放心 無慮；",
    "會 否 我 罪 將 祂 連累，",
    "未 能 救我， 祂倒 被拘？",
    "能否是因我的罪孽，",
    "太大、过多、无法赦免？",
    "能否是因祂的宝血，",
    "能力有限、包括不全？",
    "欢呼！耶稣已经复活，",
    "未损毫发，只增荣耀；",
    "祂虽进入黑暗处所，",
    "黑暗未曾留下功效。",
    "主得归回，就是凭据，",
    "神的公义已得满足，",
    "神的大爱仍施怜恤，",
    "主是已经完成救赎。",
    "神用复回答复流血，",
    "承认流血所成救赎；",
    "阿利路亚，我已清洁！",
    "阿利路亚，我得饶恕！"
  ]
}