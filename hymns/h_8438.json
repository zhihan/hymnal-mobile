      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ve chosen the Lord Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My very joy to be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him my heart, though aching,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has still a song to sing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him, I need no reason"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To shout exultantly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all my jubilation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From Him does spring."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Jesus Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is the One for me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart’s abiding at the source"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of every sweetest thing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Jesus Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He all my heart doth fill;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Him, I have no other plea,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Him, my heart is still."
            }
          ]
        }
      ],
