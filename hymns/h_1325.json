            },
            {
              "chord": "A7",
              "text": "time is"
            },
            {
              "chord": "D",
              "text": "cast."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For with time there is the"
            },
            {
              "chord": "D7",
              "text": "process,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "Time for"
            },
            {
              "chord": "D",
              "text": "His accomplish"
            },
            {
              "chord": "A7",
              "text": "ment;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "And in"
            },
            {
              "chord": "",
              "text": "time we're"
            },
            {
              "chord": "A7",
              "text": "merely"
            },
            {
              "chord": "D",
              "text": "travelers—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "For eterni"
            },
            {
              "chord": "A7",
              "text": "ty we're"
            },
            {
              "chord": "D",
              "text": "meant."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God would have a group of people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Built together in His plan,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blended, knit, coordinated"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As His vessel—one new man."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God would come into this vessel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With His nature, life and ways,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Mingling Spirit with our spirits"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His joy and to His praise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God has worked in three directions"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For His plan so marvelous:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As the Father, Son, and Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To dispense Himself to us!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All creation gives the setting—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heav’n and earth are for this plan;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis for this God made a body,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Soul and spirit—three-part man."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the center, as the kernel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of God’s plan our spirit is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Calling on the name of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Makes our spirit one with His."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the center to circumference"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God would saturate each part;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feeling, mind, and will renewing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making home in all our heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus in life we’re built together,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then in love we’re knit as one;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is now His plan fulfilling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Finishing what He’s begun."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, increase Thyself within us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we might be built by Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into that great corporate vessel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Filled with God exclusively."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As the product, the fulfillment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will the church in glory stand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Consummation of the purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In eternal ages planned."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God will have His corporate vessel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All His glory to contain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we’re wholly for Thy purpose"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy goal in us attain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
