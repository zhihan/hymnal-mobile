    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come and sing songs of Zion with me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sing of salvation’s rich outflow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Highways to Zion taking corporately,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leave, long-forgotten, all trials and woe."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I love, Lord, Your temple, Your home,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your dwelling place, in glory bright;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We dance with tambourines before Your throne,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In goodness of Your house delight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "My whole heart faces God’s throne;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My eyes see Zion alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll live as a sojourner gladly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Zion’s now everything to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Highest is calling to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is counting His own, one by one."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Singing, dancing, we all shout joyfully,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“All of our springs are found in thee.”"
            }
          ]
        }
      ],
