  "title": "岂能说透",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "Cm",
              "text": "問: 朋 友！"
            },
            {
              "chord": "",
              "text": "朋"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "友！ 告 訴 我"
            },
            {
              "chord": "Gm",
              "text": "說："
            },
            {
              "chord": "G",
              "text": "甚 麼"
            },
            {
              "chord": "",
              "text": "使"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "G7",
              "text": "這 樣"
            },
            {
              "chord": "",
              "text": "快"
            },
            {
              "chord": "Cm",
              "text": "活？ 為"
            },
            {
              "chord": "",
              "text": "何 喜"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "樂"
            },
            {
              "chord": "G♯",
              "text": "常 顯"
            },
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "Cm",
              "text": "面，"
            },
            {
              "chord": "Fm",
              "text": "似 有"
            },
            {
              "chord": "G7",
              "text": "活"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "泉 湧 自 你"
            },
            {
              "chord": "Cm",
              "text": "懷。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "（问）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的朋友，再告诉我，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是否你的就是这些？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "即或我罪都洗清洁，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的生活仍有所需。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（答）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，这恩主何其丰厚，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂是数语就能说尽，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已复活作我生命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为我的能力，供应。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "（同啍）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "啦…………（一遍）"
            }
          ]
        }
      ]
    },
    {
      "lines": [
