          "segments": [
            {
              "chord": "",
              "text": "（问）"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我是希奇你所得着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪已赦免，生命里活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但我不知像我这样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的救恩能否得着？"
            }
          ]
        },
        {
          "segments": [
