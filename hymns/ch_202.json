          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣灵的恩赐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今仍在等待；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂仍在说，挣扎果为何？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只与主死合，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "立刻解干渴；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一经约但，就必得圣鸽。"
            }
          ]
        }
