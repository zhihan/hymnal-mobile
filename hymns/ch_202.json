      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "吩咐磐石发出活水来！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵早已赐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "早与你同在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切的丰富，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等着你接受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你若肯信服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必享祂富有。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿心肯简单，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全的相信！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿心能平安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再苦求寻！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如同婴孩，静卧主怀间，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向世界断奶，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饱尝祂爱甜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "灵得安息，全由祂充满。"
            }
          ]
        }
