      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "荣耀遗赠有三："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "生命之律大能高超，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "将我变化完全；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我作祂民，祂作我神，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神圣福分无穷；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "对神认识深刻主观，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "惟凭内里生命。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "此外神已忘记我罪，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "不义一概宽恕；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "皆因救主十架代死，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我罪全都清除；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪案全勾，不再追究，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪过都己消踪；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "生命之律灵中引我，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "救恩路上直行。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "加略妙死双重功绩，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为神经纶效力："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "生命之律运行无碍，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "罪的拦阻绝迹！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "大工完成住入安息，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主今安坐天上；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "新约遗赠我们全享，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "凭祂代祷馨香。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "惟愿弃绝老旧观念，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "取用遗赠丰富；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主说成了我们享用，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "天天赞美不住！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "听大祭司幔内呼召-"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"前进！\"直到路终："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "直至达成终极目标，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "荣耀圣城撒冷！"
        }
      ]
    }
  ],
