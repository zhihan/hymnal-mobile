{
  "url": "https://www.hymnal.net/en/hymn/h/30",
  "title": "What love Thou hast bestowed on us",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "What love"
            },
            {
              "chord": "",
              "text": "Thou hast be"
            },
            {
              "chord": "Am",
              "text": "stowed on"
            },
            {
              "chord": "",
              "text": "us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We"
            },
            {
              "chord": "C",
              "text": "thank Thee"
            },
            {
              "chord": "",
              "text": "from our"
            },
            {
              "chord": "D",
              "text": "heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our"
            },
            {
              "chord": "G",
              "text": "Father,"
            },
            {
              "chord": "",
              "text": "we would"
            },
            {
              "chord": "C",
              "text": "worship"
            },
            {
              "chord": "",
              "text": "Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "G",
              "text": "praise for"
            },
            {
              "chord": "D7",
              "text": "all Thou"
            },
            {
              "chord": "G",
              "text": "art."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy heart Thou hast revealed to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made known th’ eternal will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the Son Thou hast come forth,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy purpose to fulfill."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou gavest Thy beloved Son"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In love to come and die,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may be Thy many sons,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As heirs with Him, made nigh."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Him we have Thy very life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thou our Father art;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy very nature, all Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost to us impart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy Spirit into ours has come"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may “Abba” cry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Spirit born, with Spirit sealed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be transformed thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The many sons to glory brought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is Thine eternal goal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to Thy Son’s own image wrought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wilt conform the whole."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout Thy transformation work"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou dost direct each one,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From glory unto glory bring"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Until the work is done."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "What love Thou, Father, hast bestowed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll ever grateful be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll worship Thee forevermore"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And praise unceasingly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
