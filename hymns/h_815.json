  "title": "Christ is the Word and Spirit too",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Christ is"
            },
            {
              "chord": "",
              "text": "the Word and Spirit"
            },
            {
              "chord": "A",
              "text": "too,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "D",
              "text": "as the"
            },
            {
              "chord": "E",
              "text": "Spirit"
            },
            {
              "chord": "",
              "text": "in"
            },
            {
              "chord": "E7",
              "text": "the"
            },
            {
              "chord": "A",
              "text": "Word;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And"
            },
            {
              "chord": "G",
              "text": "all the"
            },
            {
              "chord": "",
              "text": "words He speaks to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are"
            },
            {
              "chord": "D",
              "text": "life and"
            },
            {
              "chord": "",
              "text": "spirit"
            },
            {
              "chord": "A",
              "text": "thus"
            },
            {
              "chord": "A7",
              "text": "con"
            },
            {
              "chord": "D",
              "text": "ferred."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Holy Word we have without,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Holy Spirit is within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The greatest gifts divine are these,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may God enjoy therein."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word the Spirit doth express,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit its reality;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They're but two aspects of one thing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And should not separated be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Whene'er the Spirit lights the Word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word becometh life to us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When Word from Spirit is divorced,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "'Tis empty mental stimulus."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we the Word in spirit touch,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As life the Spirit it becomes;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit, when expressed from us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As words of life to others comes."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit we must exercise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To take the Word most inwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And then to give the Spirit forth;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The two as one with us should be."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, may Thy Word in me become"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Spirit as my life supply,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And may Thy Spirit in Thy Word"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My true expression be thereby."
            }
          ]
        }
      ]
    }
  ],
