  "title": "In ancient times the law of God",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "In ancient"
            },
            {
              "chord": "",
              "text": "times the"
            },
            {
              "chord": "D",
              "text": "law of"
            },
            {
              "chord": "G",
              "text": "God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In"
            },
            {
              "chord": "A",
              "text": "letter"
            },
            {
              "chord": "",
              "text": "was engraved"
            },
            {
              "chord": "A7",
              "text": "on"
            },
            {
              "chord": "D",
              "text": "stone;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "But now"
            },
            {
              "chord": "",
              "text": "it"
            },
            {
              "chord": "C",
              "text": "is a"
            },
            {
              "chord": "",
              "text": "law of"
            },
            {
              "chord": "D",
              "text": "life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which"
            },
            {
              "chord": "G",
              "text": "in our"
            },
            {
              "chord": "",
              "text": "heart is"
            },
            {
              "chord": "D",
              "text": "written"
            },
            {
              "chord": "G",
              "text": "down."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law in letters good demands"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus our utter weakness shows;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now the law of life sustains,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And strength for God to please bestows."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law in letters brings to us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s knowledge only outwardly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now the law of life supplies"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A deeper knowledge inwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The law in letters can but rule"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By dead commandments outwardly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But now the law of life controls"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By living knowledge inwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This living law is moving now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all of our experience,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To regulate us from within"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And check us by our inner sense."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "How deep its regulation is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the inmost part of us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A living consciousness to give,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God Himself impart to us."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by this living law of life"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We need no teaching outwardly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all God’s living knowledge now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This law will teach us inwardly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, teach us by this law to walk,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Its inner ruling to obey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we may of Thyself partake"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And know Thee in a living way."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
