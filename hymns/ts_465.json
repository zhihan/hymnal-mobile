    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "平凡如我，竟入圣城；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心羡锡安：得胜赤诚。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀异象，引我脚踪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "撇下缠累，踏上旅程。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亲爱良人，我愿随你同行；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀君王，今你据我全心。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作得胜者，被提满足你意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "锡安山上同你站立。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主恩眷临，祂爱激励；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭信筑坛，\"以撒\"为祭。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "世途成烬，馨香盈溢，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣经纶，此生意义。"
            }
          ]
        }
      ]
    },
