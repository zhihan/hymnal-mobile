{
  "url": "https://www.hymnal.net/cn/hymn/ts/147",
  "title": "神成那灵，话作实际",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "我 神"
            },
            {
              "chord": "",
              "text": "如"
            },
            {
              "chord": "A",
              "text": "今 你"
            },
            {
              "chord": "D",
              "text": "已 成"
            },
            {
              "chord": "",
              "text": "那 灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉 你 话 语 实 化 我 灵"
            },
            {
              "chord": "A",
              "text": "里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "运 用"
            },
            {
              "chord": "",
              "text": "我 灵 来 接 触 你"
            },
            {
              "chord": "A",
              "text": "话，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "话 中 之"
            },
            {
              "chord": "D",
              "text": "灵 我"
            },
            {
              "chord": "A",
              "text": "就 能"
            },
            {
              "chord": "",
              "text": "经"
            },
            {
              "chord": "D",
              "text": "历。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主 阿！ 你 话 离 我 并 不 远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在 我 口"
            },
            {
              "chord": "A",
              "text": "里 也"
            },
            {
              "chord": "A7",
              "text": "在 我"
            },
            {
              "chord": "",
              "text": "心"
            },
            {
              "chord": "D",
              "text": "里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 灵 藉 话 来 作 你 实"
            },
            {
              "chord": "Bm",
              "text": "际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "你 我"
            },
            {
              "chord": "",
              "text": "联"
            },
            {
              "chord": "D",
              "text": "调 合"
            },
            {
              "chord": "A7",
              "text": "并 永"
            },
            {
              "chord": "",
              "text": "为"
            },
            {
              "chord": "D",
              "text": "一。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你之所是及一切属性，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都具体实化基督里；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我享你灵、你话、你自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "经历中作我爱光圣义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿！你话离我并不远，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我口里也在我心里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你灵借话来作你实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你我联调合并永为一。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "住你话里就是住你里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我在爱里借话享受你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你住我里与我成为一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我活出你，彰显你秘密。"
            }
          ]
        }
      ],
      "type": "verse",
