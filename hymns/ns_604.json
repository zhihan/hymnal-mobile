    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Righteous on behalf"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of all unrighteous men,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was judged upon the cross"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To save us from our sins;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Removed the barrier and redeemed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To bring us back to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All praise to Jesus, Lamb of God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ has bore up our sins"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By dying on the tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And now the Crucified"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Is righteousness to me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus having died to all my sins"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I now may live to Him;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All praise to Jesus, Lamb of God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ’s vicarious death"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our trespass is appeased,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I am reconciled"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And God is really pleased;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The trespass offering made for me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has met all God’s demands;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All praise to Jesus, Lamb of God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ gave Himself for sins"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With just one goal in mind"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That He may rescue us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From this poor worldly grind;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Plucked out of this satanic age,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our sins He takes away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All praise to Jesus, Lamb of God!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, as our most High Priest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forever has sat down;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By one pure sacrifice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal cleansing found!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ shed His blood to make us clean,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our sins He washed away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All praise to Jesus, Lamb of God!"
            }
          ]
        }
