    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每当我们从父领受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总是丰富有盈馀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂所量给总是上好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "感谢领受永无虞。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂赐满足丰富深厚，"
