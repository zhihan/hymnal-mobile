      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "每当我们饱尝主爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总是丰富有盈馀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阔、长、高、深无法测度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "岂只应付我所需？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无人言语能以尽述，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的甘美和富庶；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们只有希奇感戴，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂名泱漭且全足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安然投靠祂爱胸膛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美祂名到永古。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
