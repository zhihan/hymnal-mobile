              "chord": "",
              "text": "Which by the power of God was supplied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And His great power in resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He wrought in Christ, even ascension!"
            }
          ]
        },
        {
          "segments": [
            {
