              "text": "都呼喊如故！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只要我有气息活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就必喊主，"
            }
          ]
