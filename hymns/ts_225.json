          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都是丰富的。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主耶稣，呼喊你名，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活着真喜乐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "每当把你的名吸入，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们就快活！"
            }
          ]
