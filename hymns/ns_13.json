    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In constitution, not corporeal;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But fully organic, entirely of life."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her one reality’s spiritual;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our living and work, at this we’ll arrive."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All aspects of New Jerusalem"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were by the apostles perceived and conveyed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their teaching was the whole New Testament;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All their living and work this vision displayed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Her base, her gates, her foundations, her wall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her temple, her throne, her supply and her light—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All shown by signs in the last book of all;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their significance rich we cannot deny."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One life, one work, this our one goal today:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For that highest point where we’ll all be the same;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flesh, nat’ral being no more have a place;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Going up step by step, God’s goal to attain."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
