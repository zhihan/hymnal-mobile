              "text": "His grace is sufficient to live by,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And should we be summoned to die"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twill light up the valley of shadows,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bear us away to Him nigh."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Or when we shall stand in His vict’ry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Christ in His glory shall see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’ll fall at His footstool confessing,"
            }
          ]
        },
        {
          "segments": [
            {
