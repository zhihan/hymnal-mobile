    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "那一次门徒们"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "看见你的改变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "虽然是真好，却是有限，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因为你那时候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "还没有经过死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不过是父怀中的爱子。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如今你再来到，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要得完全荣耀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "千万的圣徒，赞赏不置！"
