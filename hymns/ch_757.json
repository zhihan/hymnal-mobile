      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我不怕撒但权势，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一日在此，一日坚持，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阴府的门必不得胜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的基督已经执政。"
            }
          ]
        }
