    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今能否忘了儆醒？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "否，否，我心早晚深省！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟恐错过被提机会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "容让世事使我聋瞆。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！亲爱主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！主！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "来罢！我王！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我能否与世界结联？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "否，否，祂召我往上面！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我舍弃属地事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱祂，念祂，我的救主。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
