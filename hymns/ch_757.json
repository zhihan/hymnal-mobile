              "text": "我能否忘这个信息？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我要呼喊使地战栗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求主成全所赐信心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你的话早日证明。"
            }
