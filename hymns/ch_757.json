              "text": "来罢！我王！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "愿我逐日行在灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "吸取祂的生命能力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "儆醒，等候，直到祂来，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻豫备，不敢稍怠。"
            }
          ]
        }
      ],
