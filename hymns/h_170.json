{
  "url": "https://www.hymnal.net/en/hymn/h/170",
  "title": "Lord, Thou art the lovely Bridegroom",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "Lord, Thou"
            },
            {
              "chord": "F",
              "text": "art the"
            },
            {
              "chord": "",
              "text": "lovely"
            },
            {
              "chord": "C",
              "text": "Bridegroom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God appointed,"
            },
            {
              "chord": "D",
              "text": "dear to"
            },
            {
              "chord": "G",
              "text": "us;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "Thy dear"
            },
            {
              "chord": "F",
              "text": "self is"
            },
            {
              "chord": "",
              "text": "so at"
            },
            {
              "chord": "C",
              "text": "tractive,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our heart so"
            },
            {
              "chord": "G",
              "text": "beaute"
            },
            {
              "chord": "C",
              "text": "ous!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Dear Beloved, we admire Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who can tell Thy preciousness;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy love we deeply treasure"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thine untold loveliness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art fairer than the fairest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art sweeter than the sweet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art meek and Thou art gracious,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "None can e’er with Thee compete."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Full of myrrh are all Thy garments,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thy lips are filled with grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the savor of Thy suffering,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We in love Thyself embrace."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is with the oil of gladness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy God hath anointed Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From the palaces of ivory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise shall ever rise to Thee."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God hath blessed Thee, Lord, forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast won the victory;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we see Thee throned in glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy pow’r and majesty."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art the desire of nations,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All Thy worth they’ll ever prove;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, the chiefest of ten thousand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ever worthy of our love."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
