    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cusp of crucifixion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In great agony You prayed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You besought the Father greatly"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That You’d from this hour be saved."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But You rea’lized God’s intention;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Love outweighed Your apprehension,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Not as I will,” Your submission"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Father for our sake."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When God made You sin entire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dying for us on the cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God withdrew from You in judgment,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This by far Your greatest loss."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You made reconciliation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ending our great separation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making us a new creation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One new man, formed on the cross."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the veil within the temple,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Top to bottom, split in two,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rent because You’re now our access"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God’s glory ever new."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the Father we’ve reunion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Face to face in holy union,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reconciled in sweet communion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious twining through and through."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Separation has been dealt with,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We from God no more exiled!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Your sacrifice forgiven,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We to Him are reconciled!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We can live in resurrection,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Joined to God through Your oblation,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To express Your life and person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In our spirit, by the blood!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise the Son sent by the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lamb of God Whom God made sin!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise You for Your dread endurance,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As that breach brought judgment in!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Praise You for God’s satisfaction"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Your death and its transaction,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And that Your brief separation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Made us one with God fore’er!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
