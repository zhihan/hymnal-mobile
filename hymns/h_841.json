    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now Thy flowing life, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Doth enlighten me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Bringing in the spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fellowship with Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my need supplying,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Making Thy demand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Leading me to cleansing"
            }
          ]
        },
        {
          "segments": [
            {
