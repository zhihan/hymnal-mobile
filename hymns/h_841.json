              "text": "And in Thee to stand."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy anointing Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Me shall permeate,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my soul and spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou wouldst saturate;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every part transforming"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till conformed to Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till Thy life shall bring me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To maturity."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, Thy life abundant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Flowing, rich and free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Constantly refreshes"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And empowers me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death by life is swallowed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Weakness is made strong,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All my bonds are broken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gloom is turned to song."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I would give myself, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fully unto Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thy heart’s desire"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be fulfilled in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I no more would struggle"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To myself reform,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus in me to hinder"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What Thou wouldst perform."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I would cease completely"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From my efforts vain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Thy life transform me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full release to gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Build me up with others"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till in us Thou see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy complete expression"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorifying Thee."
            }
          ]
        }
      ],
