{
  "url": "https://www.hymnal.net/cn/hymn/ch/52",
  "title": "靠着我们救主流血",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "靠 著"
            },
            {
              "chord": "",
              "text": "我 們 救 主 流"
            },
            {
              "chord": "C",
              "text": "血 作"
            },
            {
              "chord": "G",
              "text": "祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "父 阿， 我"
            },
            {
              "chord": "D",
              "text": "們 前"
            },
            {
              "chord": "D7",
              "text": "來 一"
            },
            {
              "chord": "",
              "text": "同 就"
            },
            {
              "chord": "G",
              "text": "你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "距 離"
            },
            {
              "chord": "",
              "text": "已"
            },
            {
              "chord": "G",
              "text": "去， 藉"
            },
            {
              "chord": "",
              "text": "恩 已"
            },
            {
              "chord": "C",
              "text": "得 自"
            },
            {
              "chord": "Em",
              "text": "由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前 來 敬"
            },
            {
              "chord": "G",
              "text": "拜 向"
            },
            {
              "chord": "",
              "text": "你 讚"
            },
            {
              "chord": "D7",
              "text": "美、 歌"
            },
            {
              "chord": "G",
              "text": "謳。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦父，我们愿在你前献上"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的爱子之名所有馨香；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借着祂死为我所得恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在此凭信我们将祂观瞻。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你的喜乐我今与祂同享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂里面我心因你欢畅；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万人之上，祂比美者更美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的荣耀永不衰落败褪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你座前我们俯伏仰望，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭信看见你爱所有对象；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂今在此率领许多弟兄－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的众子，同声向你歌颂。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
  "metadata": {
    "category": "敬拜父",
    "time": "4/4",
    "hymn_code": "53533216165",
    "midi_tune_url": "https://www.hymnal.net/Hymns/Chinese/midi/tunes/c0052_tune.midi"
  },
  "raw_sections": [
    "靠 著我 們 救 主 流血 作祭，",
    "父 阿， 我們 前來 一同 就你；",
    "距 離已去， 藉恩 已得 自由，",
    "前 來 敬拜 向你 讚美、 歌謳。",
    "哦父，我们愿在你前献上",
    "你的爱子之名所有馨香；",
    "借着祂死为我所得恩典，",
    "在此凭信我们将祂观瞻。",
    "你的喜乐我今与祂同享，",
    "在祂里面我心因你欢畅；",
    "万人之上，祂比美者更美，",
    "祂的荣耀永不衰落败褪。",
    "在你座前我们俯伏仰望，",
    "凭信看见你爱所有对象；",
    "祂今在此率领许多弟兄－",
    "你的众子，同声向你歌颂。"
  ]
}