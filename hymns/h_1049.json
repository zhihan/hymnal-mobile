    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Stained with the sins which I have wrought"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In word and deed and secret thought;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For pardon which Thy Blood hath bought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Weary of selfishness and pride,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "False pleasures gone, vain hopes denied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deep in Thy wounds my shame to hide,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou knowest all my griefs and fears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace abused, my misspent years;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet now to Thee, for cleansing tears,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I would not, if I could, conceal"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The ills which only Thou canst heal;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "So to the Cross, where sinners kneel,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash me, and take away each stain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let nothing of my sin remain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For cleansing, though it be through pain,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To share with Thee Thy life divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy very likeness to be mine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since Thou hast made my nature Thine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To be what Thou wouldst have me be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Accepted, sanctified in Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through what Thy grace shall work in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ crucified, I come."
            }
          ]
        }
      ],
