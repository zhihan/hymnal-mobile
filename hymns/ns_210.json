              "text": "And we’re upheld by Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He says, “Don’t be disappointed.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He knows all your fears and failures;"
