    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "He gives support and comforts you,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Interceding night and day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And when you’re weak He groans for you"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With words you cannot say."
            }
          ]
        },
        {
          "segments": [
