    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Once we walked a soulish person,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wandering in the wilderness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Never knowing that our spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Craved God’s fullness to express;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At the moment Jesus entered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Instantly the whole was changed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now we’re people spirit-centered!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hallelujah! Rearranged!"
            }
          ]
        }
