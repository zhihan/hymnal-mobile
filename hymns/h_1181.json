    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now our spirit is our person—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a glorious fact is this!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ Himself in us expressing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s intent and holiness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not the soul-life’s vain delusion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But the spirit strengthened is;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ Himself is now our Person—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is ours and we are His."
            }
          ]
