{
  "url": "https://www.hymnal.net/cn/hymn/ch/43",
  "title": "父阿你是爱大无极",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "父 阿，"
            },
            {
              "chord": "",
              "text": "你 是 愛"
            },
            {
              "chord": "A",
              "text": "大 無"
            },
            {
              "chord": "",
              "text": "極，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "A7",
              "text": "們 要"
            },
            {
              "chord": "",
              "text": "來 讚"
            },
            {
              "chord": "D",
              "text": "美 你；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D7",
              "text": "們 是"
            },
            {
              "chord": "",
              "text": "受 恩"
            },
            {
              "chord": "G",
              "text": "典 教"
            },
            {
              "chord": "",
              "text": "益，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "前 不"
            },
            {
              "chord": "",
              "text": "能 不 歡"
            },
            {
              "chord": "D",
              "text": "喜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "A",
              "text": "從 世"
            },
            {
              "chord": "",
              "text": "前 就"
            },
            {
              "chord": "D",
              "text": "已 定"
            },
            {
              "chord": "",
              "text": "意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "豫"
            },
            {
              "chord": "E",
              "text": "備 我"
            },
            {
              "chord": "",
              "text": "們 的"
            },
            {
              "chord": "A7",
              "text": "地 位；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "在 時"
            },
            {
              "chord": "",
              "text": "來 就"
            },
            {
              "chord": "G",
              "text": "顯 能"
            },
            {
              "chord": "",
              "text": "力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就"
            },
            {
              "chord": "A",
              "text": "向 我"
            },
            {
              "chord": "",
              "text": "們 施"
            },
            {
              "chord": "D",
              "text": "恩 惠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你使祂从死里复活，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使祂成你首生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂已完成祂的工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们已信祂得胜。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现今已成众子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不能不快乐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "面向长子所有布置，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "日夜时常有诗歌。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的神是我们的神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂父也是我们父，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们与祂无法割分，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂与我们同骨肉。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂领我们回去见你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今日会中同唱诗；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "像祂，我们与祂合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因子，我们作众子。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神圣的爱！神圣的恩！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "子和众子永联合；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个就是我们永分！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这个就是父喜乐！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们现今等在这里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "等你儿子从天临；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求使我们所有心意，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "是到祂前鼓乐琴。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
  ],
