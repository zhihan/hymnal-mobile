    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Throned in heav'n, the Prince of Glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Equal God, with God on high;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Form of lowest servant taking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cross of shame to die:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In obedience, strong, unswerving,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blest Father's will to do;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death of shame, all undeserved,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "E'en to that His love could go."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaven's crown of brightest glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be to Him, the humbled One."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaven's robe of brightest splendor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be to Him and Him alone."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Name of Jesus bowing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every tongue shall Him confess"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord of earth and Lord of heaven;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Myriads shall this Monarch bless."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory, everlasting glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be to Him of peerless worth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the highest heav'n be glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory be to Him on earth."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unto God, our God, be glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory to the great I AM."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glory, everlasting glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Be to Christ, the throned Lamb."
            }
          ]
