  "title": "父你怜悯已向我们",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "父， 你"
            },
            {
              "chord": "",
              "text": "憐 憫"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已 向 我"
            },
            {
              "chord": "C",
              "text": "們 顯"
            },
            {
              "chord": "G",
              "text": "明，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "照 你 啟"
            },
            {
              "chord": "D",
              "text": "示；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "罪 人 如"
            },
            {
              "chord": "G",
              "text": "我 竟"
            },
            {
              "chord": "",
              "text": "能 有"
            },
            {
              "chord": "C",
              "text": "你 生"
            },
            {
              "chord": "G",
              "text": "命，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作"
            },
            {
              "chord": "D",
              "text": "你 兒"
            },
            {
              "chord": "G",
              "text": "子。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "憐 憫"
            },
            {
              "chord": "",
              "text": "器"
            },
            {
              "chord": "A",
              "text": "皿 乃"
            },
            {
              "chord": "A7",
              "text": "是 你"
            },
            {
              "chord": "",
              "text": "所 豫"
            },
            {
              "chord": "D7",
              "text": "定，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "貴 重"
            },
            {
              "chord": "",
              "text": "器"
            },
            {
              "chord": "C",
              "text": "皿 永"
            },
            {
              "chord": "",
              "text": "為 你"
            },
            {
              "chord": "D",
              "text": "作 見"
            },
            {
              "chord": "G",
              "text": "證。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘喜爱怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不喜爱祭祀，’"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你曾宣告；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因这怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们受你恩赐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并得荣耀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不在定意或是奔跑的人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃在你这愿发怜悯的神。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "父，你怜悯"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并你恩惠、慈爱，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我已得尝；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你这怜悯带来你的同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并你面光。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我今向你下拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赞你怜悯，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "歌颂直到万代。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    }
  ],
