        {
          "segments": [
            {
              "chord": "",
              "text": "One spirit... with You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We are united with Christ in our spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He dwells within us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "and makes His home in our heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To our body giving life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purified to be a member of Christ;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our every part is Christ!"
            }
          ]
        }
      ],
      "type": "verse",
