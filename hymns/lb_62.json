{
  "url": "https://www.hymnal.net/en/hymn/lb/62",
  "title": "He who is joined to the Lord is one spirit",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "He who"
            },
            {
              "chord": "",
              "text": "is joined to the Lord is one"
            },
            {
              "chord": "D",
              "text": "spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life is a life that's in organic"
            },
            {
              "chord": "G",
              "text": "union."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As a branch is in the vine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "Grafted,"
            },
            {
              "chord": "",
              "text": "His life and mine inter"
            },
            {
              "chord": "Am",
              "text": "twine."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D7",
              "text": "Lord, I"
            },
            {
              "chord": "",
              "text": "am joined to You!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "One spirit"
            },
            {
              "chord": "",
              "text": "with"
            },
            {
              "chord": "Am",
              "text": "You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "One spir"
            },
            {
              "chord": "D7",
              "text": "it, not"
            },
            {
              "chord": "G",
              "text": "two."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord,"
            },
            {
              "chord": "G7",
              "text": "we are"
            },
            {
              "chord": "",
              "text": "joined to"
            },
            {
              "chord": "Am7",
              "text": "You:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "One"
            },
            {
              "chord": "D7",
              "text": "spirit..."
            },
            {
              "chord": "",
              "text": "with"
            },
            {
              "chord": "G",
              "text": "You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through resurrection the Lord is now the Spirit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit by Him has been regenerated."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord, the Spirit, mingling"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With our spirit, is the most wondrous thing."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our spirit’s mingled, Lord!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One spirit with You;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One spirit, not two."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we are joined to You:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One spirit... with You."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Do you not know that our bodies"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "are Christ’s members?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This body’s a temple of the Holy Spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who, from God, is now inside,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Owning us that God may be glorified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, we’ve been bought by You!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One spirit with You;"
            }
          ]
