  "raw_sections": [
    "神 之于 人",
    "一 切正 常故 事，",
    "全 都在 于 灵里；",
    "人须 灵里",
    "摸 著神 灵本 质，",
    "对 神 才有 经历。",
    "灵 生灵，",
    "灵 拜灵，",
    "以 至灵充 满我；",
    "灵且 成话，",
    "带 著丰 盛生 命，",
    "流 出 活水 江河。",
    "神乃是灵，",
    "并且为人造灵，",
    "要人以灵拜灵；",
    "借此人能得着",
    "祂作生命，",
    "以祂为人供应。",
    "灵生灵，",
    "灵拜灵，",
    "以至灵充满我；",
    "灵且成话，",
    "带着丰盛生命，",
    "流出活水江河。",
    "神乃是灵",
    "进入人的灵中，",
    "叫人得着重生；",
    "人就能在灵里",
    "与祂交通，",
    "得享祂的丰盛。",
    "灵生灵，",
    "灵拜灵，",
    "以至灵充满我；",
    "灵且成话，",
    "带着丰盛生命，",
    "流出活水江河。",
    "神乃是灵",
    "充满、浇灌、滋润，",
    "将我变化、更新；",
    "直到能从我灵",
    "遍及全身，",
    "浸透我的全人。",
    "灵生灵，",
    "灵拜灵，",
    "以至灵充满我；",
    "灵且成话，",
    "带着丰盛生命，",
    "流出活水江河。",
    "神乃是灵",
    "与我融洽、调和，",
    "使我改变形状；",
    "祂的成分在我",
    "一再加多，",
    "直到能得显彰。",
    "灵生灵，",
    "灵拜灵，",
    "以至灵充满我；",
    "灵且成话，",
    "带着丰盛生命，",
    "流出活水江河。",
    "神的一切",
    "丰盛全在灵里，",
    "给我经历、享受；",
    "我须灵里时常",
    "将神呼吸，",
    "才得享神所有。",
    "灵生灵，",
    "灵拜灵，",
    "以至灵充满我；",
    "灵且成话，",
    "带着丰盛生命，",
    "流出活水江河。"
  ]
