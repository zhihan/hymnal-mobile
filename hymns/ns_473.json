    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In subtle opposition the enemy did move;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He offered king’s provisions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their loyalties to prove."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Daniel and companions"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Were equal to the test."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They spurned the royal dainties"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To settle for God’s best."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus through the proper eating,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The tree of life to take;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Preserving inward virtue,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Defilements forsake."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God blessed them with all wisdom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In visions and in dreams;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gave them understanding"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And made their spirits keen."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And when Nebuchadnezzar"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was startled by a dream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He gathered his magicians"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To tell him what he’d seen."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A statue as a portrait"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of human governments"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From earliest beginnings"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through predetermined ends."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "So Daniel told the vision,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The king he was amazed."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Daniel, you will have honor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Authority all your days."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like him our vision opened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our hearts they must be wise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To see in all these cultures;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The enemy’s disguise."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And through an open window"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s faithful one did pray;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As for the holy city"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He bowed three times a day."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stirred up were Satan’s minions"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With jealousy and strife"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To frustrate God’s recovery"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And snare His servant’s life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though still as roaring lion"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The enemy may rage,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Father seeks a people"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To terminate the age."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To stand within the lion’s den,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For God be absolute;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Christ as our companion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All earthly tide refute."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As victors, as victors"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ we take our stand."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To be His overcomers"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bring forth the victory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O’er the land."
            }
          ]
        }
      ],
      "type": "chorus"
