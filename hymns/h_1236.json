              "chord": "",
              "text": "With hallelujahs for Christ our land!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“I will build My church upon this rock,” said the Lord Jesus,"
