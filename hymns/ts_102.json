          "segments": [
            {
              "chord": "",
              "text": "鉴"
            },
            {
              "chord": "G",
              "text": "察， 焚"
            },
            {
              "chord": "D",
              "text": "烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "为 著"
            },
            {
              "chord": "",
              "text": "召 会"
            },
            {
              "chord": "A7",
              "text": "的 建"
            },
            {
              "chord": "D",
              "text": "造。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "圣灵乃是七倍灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应付召会死光景，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "圣徒转回得复苏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使主召会得恢复。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，神七灵，我恳求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你工作得成就！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将我鉴察并焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着召会的建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "鉴察，焚烧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着召会的建造。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "现今我们神的灵，"
            }
          ]
        },
        {
          "segments": [
