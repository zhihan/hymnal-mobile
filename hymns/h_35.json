              "text": "Once raised by the might of Thy power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When numbered along with the dead."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We think of the glory that chose us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas Thine, blessed Father, the Source;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The glory of love that redeemed us"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Jesus, the Man of Thy choice."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
