    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We think of the Man in Thy presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Set down there, exalted as Head;"
            }
          ]
        },
        {
          "segments": [
            {
