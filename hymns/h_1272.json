      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A double portion of the land"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was Joseph’s birthright—and ’tis ours"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If we our garments keep from sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And stay pure in temptation’s hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The priesthood was to Levi giv’n"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As his inheritance—for he"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Did count his family ties but loss"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And owned God’s things supreme to be."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The kingship, Judah did receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For tending to young Joseph’s need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Benjamin’s adversity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He was his comforter indeed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The double portion we would seek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The priesthood and the kingship too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make us so desperate, Lord, for Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thee, our birthright, we’d pursue."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "We would be those who pay the price,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deny the soul, reject the self;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ambitious for the birthright thus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We’d gain Thee, Lord, above all else."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The promise, Lord, ’twas giv’n to us,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let us ne’er this right despise;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Enflame us, Lord, to gain Thyself,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Thee, our birthright realize."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
