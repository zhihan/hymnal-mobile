              "text": "be our"
            },
            {
              "chord": "",
              "text": "goal, our"
            },
            {
              "chord": "D",
              "text": "highest"
            },
            {
              "chord": "",
              "text": "prize,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For"
            },
            {
              "chord": "G",
              "text": "we're the"
            },
            {
              "chord": "",
              "text": "church of"
            },
            {
