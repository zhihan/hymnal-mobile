      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "當 神"
            },
            {
              "chord": "",
              "text": "將 那 被 擄 的 帶 回 錫 安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 們 像 作 夢 的 人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "滿 懷"
