      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my feet are often wearied"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the rough and rugged path,"
            }
          ]
