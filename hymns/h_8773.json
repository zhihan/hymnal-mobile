    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As a pilgrim here I wander;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While afflicted, I rejoice,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For a better land I soon expect to see;"
