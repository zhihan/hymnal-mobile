{
  "url": "https://www.hymnal.net/cn/hymn/ts/141",
  "title": "神在基督耶稣里成那灵",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "神 在"
            },
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "A",
              "text": "耶 稣"
            },
            {
              "chord": "",
              "text": "里 成"
            },
            {
              "chord": "D",
              "text": "那"
            },
            {
              "chord": "D7",
              "text": "灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "流 入"
            },
            {
              "chord": "",
              "text": "我 们 灵 里 作 生"
            },
            {
              "chord": "D",
              "text": "命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "何 等"
            },
            {
              "chord": "",
              "text": "的 享"
            },
            {
              "chord": "A7",
              "text": "受， 三"
            },
            {
              "chord": "D",
              "text": "一 奇"
            },
            {
              "chord": "",
              "text": "妙 人 位，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "来 作"
            },
            {
              "chord": "",
              "text": "生 命"
            },
            {
              "chord": "A7",
              "text": "全 足"
            },
            {
              "chord": "",
              "text": "又 全"
            },
            {
              "chord": "D",
              "text": "丰。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是活神，我们向祂敞开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "由祂所生，经历何实在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "美妙的重生！神将我们充满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借祂生命不断流进来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是活灵住在我们灵里，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向外涌流，分赐祂自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在我们心间，祂正扩展不已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "逐步变化，成就祂美意。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，让我们配合里面的主，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "目标专一，只思念基督；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时刻转向祂，离弃打岔事物，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除祂以外，心别无所属。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们不仅灵中将主盛装，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "更要让祂定旨得开广；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "丢弃老观念，不再心思流荡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生命平安我们可得享。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦主，得着我们每一思想，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在你话中不断得滋养；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你话供应，心思常置于灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "心思意念圣别又更新。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们同来经历生命之神，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "思念那灵，操练当认真；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等的实际！凭祂而活有路！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，我们心与你永不分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
