  "raw_sections": [
    "靈 要操 練運 用，",
    "魂 卻要 拒絕；",
    "無 論生 活行 動，",
    "以 此為 祕訣。",
    "灵要操练运用，",
    "规条要弃绝；",
    "恩膏涂抹顺从，",
    "时刻无间歇。",
    "灵要操练运用，",
    "己意要拒绝；",
    "活在生命光中，",
    "让主作一切。",
    "灵肯操练运用，",
    "魂肯全拒绝，",
    "就能赞美、称颂，",
    "问题全解决。",
    "灵肯操练运用，",
    "主就有出路；",
    "灵肯操练运用，",
    "我就享丰富。",
    "灵肯操练运用，",
    "主就能摸到；",
    "灵肯操练运用，",
    "我就被建造。",
    "灵要操练运用，",
    "这是主所要；",
    "灵肯操练运用，",
    "主就得荣耀。"
  ]
