            {
              "chord": "",
              "text": "Something that speaks of Thee and of Thy glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Something compelling that will draw to Thee."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Father, I thank Thee that my quest is ended."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I reign in life with Christ upon the throne"
