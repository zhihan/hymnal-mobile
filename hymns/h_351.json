    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, by the Cross, the passion of Thy Christ,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, by the death of my Lord crucified,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From pow’r of darkness translate me today"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Into the kingdom of Thy light to abide."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill from the center with Thine utmost filling,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill to circumf’rence, fill right to the brim;"
