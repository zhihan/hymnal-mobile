    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Life Uncreated, Thou most holy God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life-giving Spirit, oh, create in me"
