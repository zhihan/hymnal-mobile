    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "A voluntary offering,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The young ones are to Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In consecration’s splendor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How beautiful to see!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For as the dew of morning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Refreshes all the land—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The young ones given to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are precious in Thy hand."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord hath sworn forever"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And never will turn back,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Thou art a priest forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As was Melchizedek.”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, Thou hast no beginning"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of days; of life: no end!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And on Thine intercession"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We ever do depend."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord is at Thy right hand"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in His day of wrath"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll strike through rulers, judging"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The nations in His path."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While riding on to triumph"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He’ll drink of us, the stream,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His head uplifted, strengthened,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The whole earth to redeem."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh Lord, Thou art ascended"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To God’s right hand to sit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As Head o’er all things, to Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God doth Thy foes commit."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our King—for us Thou reignest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our Priest—we are supplied,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our all we give unto Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Conqueror glorified."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
