      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当我观赏广大创造－"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神智所制订，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵受感，立献敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并肃静。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但是我神，你是深愿："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能得有众子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今在子里对你赞美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并赏识。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你话已向我们启示，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你情爱秘密，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要我们领略接受，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以爱你。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因此借着基督救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "既将敌全克，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在新造里你就带来"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "敬拜者。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "但愿荣耀归于圣父，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并圣子基督，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "且愿荣耀归于圣灵"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "到永古。"
            }
          ]
        }
