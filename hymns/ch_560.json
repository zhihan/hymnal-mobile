            {
              "chord": "D7",
              "text": "要"
            },
            {
              "chord": "G",
              "text": "對 這"
            },
            {
              "chord": "",
              "text": "山 說："
            },
            {
              "chord": "D",
              "text": "『去， 離"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "此， 投"
            },
            {
              "chord": "",
              "text": "在 海"
            },
            {
              "chord": "D",
              "text": "裡！』"
            },
            {
              "chord": "G",
              "text": "心 中"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "若"
            },
            {
              "chord": "G7",
              "text": "不 疑"
            },
            {
              "chord": "C",
              "text": "惑， 就"
            },
            {
              "chord": "A",
              "text": "必"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成"
            },
            {
              "chord": "A7",
              "text": "就 於"
            },
            {
              "chord": "D",
              "text": "你。"
            },
            {
              "chord": "D7",
              "text": "相"
            },
            {
              "chord": "G",
              "text": "信"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主"
            },
            {
              "chord": "Em",
              "text": "話， 必"
            },
            {
              "chord": "C",
              "text": "要 成"
            },
            {
              "chord": "G",
              "text": "全， 在"
            },
            {
              "chord": "Am",
              "text": "主"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "裡 面 吩"
            },
            {
              "chord": "G",
              "text": "咐"
            },
            {
              "chord": "D7",
              "text": "你"
            },
            {
              "chord": "G",
              "text": "山！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "取用救赎权利，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主的宝血所买；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使这权利有效，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "三一之神同来。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺服主话，必要成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主里面吩咐你山！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "自己、罪恶、病痛，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主已全部担当，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的要求满足，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你已得着释放。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倚靠主话，必要成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主里面吩咐你山！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "围绕高大墙垣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭信祷告放胆；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在墙未倒之先，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "喊出得胜颂赞。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "安心相信，必要成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主里面吩咐你山！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "所有铜门铁闩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全都仆倒降服，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "让那相信战士，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "高唱凯歌进入。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不睬仇敌，必要成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主里面吩咐你山！"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "取用神的信心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "脱去不信耻辱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "广行神迹之杖，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将理由尽逐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "站在主话，必要成全，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在主里面吩咐你山！"
            }
          ]
        }
      ]
