    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，你是我逾越节，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "因你神将我逾越；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你自己和你救赎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们得与神和谐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是神的羔羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被杀、流血、救赎我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应用你血作我赎价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并靠吃你而活着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是天降生命的粮，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是无酵生命饼；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们吃你，与你调和，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就得有分你功能。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羔羊和饼都是豫表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "象征你是我生命；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "筵席之上吃你、喝你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们享受你丰盛。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你也是属天吗哪，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们每日的食物；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "餧养、饱足、刚强、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "加力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "所有需要全应付。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你又是活的磐石，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我裂开，生命流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "饮于你这生命活水，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再干渴到永久。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主，你更是迦南美地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "超越、丰富又佳美，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "流奶与蜜，各物丰收，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡我需要无不备。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭你丰馀向神敬拜，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且借此相交通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此爱中彼此联结，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的建造得成功。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
