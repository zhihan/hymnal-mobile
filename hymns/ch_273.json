    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我几乎要求你停止你手，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "当我觉得我已无力再受；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但你是神，你怎可以让步？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你不要让步，等我顺服。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我眼有泪珠，看不清你脸面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像你话语真实不如前；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你使我减少，好叫你更加添，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好叫你旨意比前更甘甜。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如果你的旨意和你喜乐"
