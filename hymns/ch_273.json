        {
          "segments": [
            {
              "chord": "",
              "text": "就愿我的喜乐乃是在乎"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顺服你的旨意来受痛苦。"
            }
          ]
        }
