    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "At every time, in every clime I found"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Those, not with words to Christ, but Spirit bound."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He strengthens them with might each day, each hour;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Through them true works divine are wrought in power."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the Church the Spirit hath begot,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Elect from every people, Christ their lot."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They follow where His shepherd-staff doth lead;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The members of this host are blessed indeed."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And when on earth they meet His death to show,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him their vows of love they oft renew."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Some little flock will gather there or here;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, Head of all, to every soul most near."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the temple which our Lord approves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Church which truly honors Him and loves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose sacrifice is on the altar bound;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "She soon in glory will His throne surround."
            }
          ]
        }
      ],
