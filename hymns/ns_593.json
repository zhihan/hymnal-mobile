    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a preeminent Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My center, my hope, and my joy!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The power and wisdom of God!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The One I uniquely enjoy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To grow up in You in all things,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I ask You to shepherd my soul."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whatever You wish, Lord — amen."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I give You my heart as a whole."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a preeminent Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart You are making Your home."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As, choice after choice, I seek You,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In me You establish Your throne."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I open to let my King in,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor will I resist You, but still"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I raise the white flag of defeat,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surrendering all to Your will."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, what a preeminent Christ!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Surrender is truly a rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your cross is my gateway to joy."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your heart toward me harbors the best."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I love You with all of my heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For me, You are second to none."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cross has turned everything sweet;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I find my delight in the Son!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
