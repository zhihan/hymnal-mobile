  "title": "神的基督是我的义",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "基 督 是"
            },
            {
              "chord": "D",
              "text": "我 的"
            },
            {
              "chord": "G",
              "text": "义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A",
              "text": "我 的"
            },
            {
              "chord": "",
              "text": "美"
            },
            {
              "chord": "D",
              "text": "丽， 我"
            },
            {
              "chord": "A",
              "text": "的 锦"
            },
            {
              "chord": "D",
              "text": "衣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在"
            },
            {
              "chord": "G",
              "text": "宝 座"
            },
            {
              "chord": "D7",
              "text": "前 服"
            },
            {
              "chord": "G",
              "text": "此 盛"
            },
            {
              "chord": "",
              "text": "装，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "能 抬"
            },
            {
              "chord": "",
              "text": "头 欢"
            },
            {
              "chord": "C",
              "text": "乐"
            },
            {
              "chord": "D7",
              "text": "歌"
            },
            {
              "chord": "G",
              "text": "唱。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主阿，我信你的宝血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "已将我罪全都解决，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我洒在神施恩座，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "永远为我向神求赦。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "借你救赎，我已脱去"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我罪、我过、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我耻、我惧；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "审判大日我敢站立，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "谁能控告你所称义？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亚伯拉罕就是如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "蒙赎圣徒也都一式，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宣布你为罪人救星，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他们所夸只在你名。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "这件白衣永远不变，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "尽管旧造沉没多年；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "时代不能改其美艳，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "它的荣美永远新鲜。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "直到天上见你荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们仍要以你自骄："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我的美丽、我的锦衣，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我主耶稣是我的义。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
