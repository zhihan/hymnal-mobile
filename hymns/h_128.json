    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When the fierce tempest, uplifting its waves,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeks to engulf us, we cry and He saves;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Looking to Jesus, upheld by His hand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Tread we the billows as safe as on land."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Far above all! Far above all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus the crucified far above all!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "High as His members upon Him we call,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God hath exalted Him far above all!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "High are the cities that dare our assault,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Strong are the barriers that call us to halt;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "March we on fearless, and down they must fall,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Vanquish’d by faith in Him far above all."
            }
          ]
