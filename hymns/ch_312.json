{
  "url": "https://www.hymnal.net/cn/hymn/ch/312",
  "title": "恩主你是我的安息",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "恩 主，"
            },
            {
              "chord": "",
              "text": "你 是 我"
            },
            {
              "chord": "G7",
              "text": "的 安"
            },
            {
              "chord": "C",
              "text": "息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "深"
            },
            {
              "chord": "C",
              "text": "愿 我"
            },
            {
              "chord": "F",
              "text": "能 全"
            },
            {
              "chord": "G",
              "text": "享；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "停"
            },
            {
              "chord": "C",
              "text": "下 自"
            },
            {
              "chord": "F",
              "text": "己 所"
            },
            {
              "chord": "C",
              "text": "有 活"
            },
            {
              "chord": "Dm",
              "text": "动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "完"
            },
            {
              "chord": "F",
              "text": "全 将"
            },
            {
              "chord": "G7",
              "text": "你 饱"
            },
            {
              "chord": "C",
              "text": "尝。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，这诡诈、残酷自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "总是挣扎努力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将你与我的灵隔开，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我不得安息。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "‘己’取许多狡猾形状，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好像都是必要，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给我觉得安息于你，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并不一定可靠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今寻求神圣安息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全脱离自己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟独让你作王掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "里外全都管理。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我今躺卧在你手下，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求你着手工作；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿你恩典使我不再"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭自己活着。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主，作工直到这己"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全被你破碎，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我能完全有你形像，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "显出你的光辉。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
