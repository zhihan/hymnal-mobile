{
  "url": "https://www.hymnal.net/cn/hymn/ch/53",
  "title": "赞美你是神的活道",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "哦 主，"
            },
            {
              "chord": "",
              "text": "你 是 神 的 活 道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "太"
            },
            {
              "chord": "A",
              "text": "初 与"
            },
            {
              "chord": "A7",
              "text": "神 同"
            },
            {
              "chord": "D",
              "text": "在；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你 是 神 的 荣 耀 发 表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将"
            },
            {
              "chord": "A",
              "text": "神 表"
            },
            {
              "chord": "A7",
              "text": "明 出"
            },
            {
              "chord": "D",
              "text": "来。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞"
            },
            {
              "chord": "A",
              "text": "美 你"
            },
            {
              "chord": "",
              "text": "是 神"
            },
            {
              "chord": "D",
              "text": "的 活"
            },
            {
              "chord": "",
              "text": "道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将"
            },
            {
              "chord": "A",
              "text": "神 完"
            },
            {
              "chord": "E7",
              "text": "全 发"
            },
            {
              "chord": "A",
              "text": "表！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "神"
            },
            {
              "chord": "D",
              "text": "的 本"
            },
            {
              "chord": "",
              "text": "性、 神"
            },
            {
              "chord": "G",
              "text": "的 荣"
            },
            {
              "chord": "",
              "text": "耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "藉"
            },
            {
              "chord": "D",
              "text": "你 全"
            },
            {
              "chord": "A7",
              "text": "都 揭"
            },
            {
              "chord": "D",
              "text": "晓！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "诸天述说神的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "万有也在发声；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神能、神性，原难知晓，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你创造显明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "赞美你是神的活道，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神完全发表！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的本性、神的荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借你全都揭晓！"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "神的话语丰富、奥妙，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全是你的见证；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你在其中得着发表，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为要将神说明。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
