      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你这活道成为肉身，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在人的中间；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你的一切行事、为人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "就是神的彰显。"
            }
          ]
        }
      ],
