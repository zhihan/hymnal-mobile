    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the mind of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is thought for you,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Warm as summer sunshine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Sweet as morning dew;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why should you be fearful,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why take anxious thought,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Since the mind of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cares for those He bought?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the field of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There is work for you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such as even angels"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Might rejoice to do;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why stand idly sighing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For some life-work grand,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "While the field of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Seeks your reaping hand?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Church of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s a place for you;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Glorious, bright, and joyous,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Right and peaceful too;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Why then, like a wand’rer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Roam with weary pace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If the Church of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holds for you a place?"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
