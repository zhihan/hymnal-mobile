    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Via Nazareth! the pathway"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Narrows still as on we go,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Years of toil none understanding,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet God teaches us to know"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the servant is not greater"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Than the Lord, who through long years"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hid Himself from this world’s glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Follow Him! Count not the tears."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Via Galilee, we see Him!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Stones are hurled, and curses hissed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By the men who gather round Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Has He not the pathway missed?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No! unharmed the Savior passes,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And this rough bit of the way"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must travel, since like Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nothing can our purpose stay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Via too, the awful anguish"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the hours beneath the trees,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where the hosts of Satan linger,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Awful hours of anguish these!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet we fail not, for God’s angels"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Minister to us, and say,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Look, beloved, at the glory,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Conflict is but for a day!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the Cross! for via Calvary"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Every royal soul must go;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Here we draw the veil, for Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Only can the pathway show;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“If we suffer with Him,” listen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just a little, little while,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And the memory will have faded"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the glory of His smile!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then the grave, with dear ones weeping,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Knowing that all life has fled;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Fellow-pilgrims, art thou numbered"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the men the world calls dead?)"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thence we rise, and live with Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throned above the world’s mad strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gladly forfeiting forever,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All that worldlings count as life."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On we press! and yonder gleaming,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nearing every day, we see"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The great walls of that fair city,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God has built for such as we;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And we catch the tender music"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the choirs that sing of One"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who once died to have us with Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In His kingdom, on the throne."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just a few more miles, beloved!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our feet shall ache no more;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No more sin, and no more sorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hush thee, Jesus went before;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And I hear Him sweetly whispering,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Faint not, fear not, still press on,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For it may be ere tomorrow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The long journey will be done.”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
