    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奔跑路上，主恩丰满，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应时、多方，你们供应无限；"
