        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乐意全然信托你们；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们成为一个活祭，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主前侍立，讨主欢喜，"
            }
