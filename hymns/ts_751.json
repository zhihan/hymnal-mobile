          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弟兄姊妹最爱最亲。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我灵、我魂、我整个人，"
