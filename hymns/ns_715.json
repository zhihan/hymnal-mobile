    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through Christ’s words of grace and mercy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s no shortage, lack, or worry,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Don’t be bothered, vexed, or feel anxiety;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Jubilee of grace where"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our debt has been erased there,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are happy, joyful, filled with ecstasy!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s good news on your horizon—(Shout) Jubilee!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There’s a gospel worth announcin’—(Shout) Just believe!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s the word for which you’re waiting,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It’s a gift worth celebrating,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hear the trumpet, how elating—Be set free...."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To enjoy the Lord, receive abundant grace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Just enjoy the Lord, behold His shining face,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Jubilee! Just believe! Be set free!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the Jubilee!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When Christ is our satisfaction"
            }
          ]
        },
        {
