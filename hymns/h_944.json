    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Such is this life: in spirit poor,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With heart repentant, mourning, meek,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which is to others merciful"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And purely God Himself doth seek;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As sons of God the peace to make,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For righteousness e’en suffering pain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Reviled and hurt for Jesus’ sake,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Exceeding joyfulness to gain;"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "As salt to kill corruption rife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In darkness shining as the light,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In heart and action right and true,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In perfect love to claim no right."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "This life self-glory doth renounce"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And ever for God’s kingdom prays;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It trusts in God for every need"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And seeks His kingdom first always."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis strict with self, with others kind,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And always dealing with the Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It ever does the Father’s will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And acts according to His word."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "To Satan it does not give ground,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor to the world, or self, or sin,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But seeks beneath the heaven’s rule"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s full authority to win."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis such a life which subjugates"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things with pow’r to God’s behest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The time it hastens when the Lord"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will here His kingdom manifest."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
