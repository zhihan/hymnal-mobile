{
  "url": "https://www.hymnal.net/cn/hymn/ch/445",
  "title": "一想到神就受吸引",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "A",
              "text": "一 想"
            },
            {
              "chord": "",
              "text": "到 神， 就"
            },
            {
              "chord": "E",
              "text": "受 吸"
            },
            {
              "chord": "A",
              "text": "引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "吸 引"
            },
            {
              "chord": "",
              "text": "我 心 離"
            },
            {
              "chord": "A",
              "text": "地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "E",
              "text": "對 於"
            },
            {
              "chord": "",
              "text": "幻"
            },
            {
              "chord": "F♯m",
              "text": "景 立"
            },
            {
              "chord": "C♯",
              "text": "生 厭"
            },
            {
              "chord": "F♯m",
              "text": "心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "抵 消"
            },
            {
              "chord": "",
              "text": "地"
            },
            {
              "chord": "A",
              "text": "的"
            },
            {
              "chord": "E7",
              "text": "吸"
            },
            {
              "chord": "A",
              "text": "力。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "仅仅得救，免去沉沦，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "难够神之所想；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神之念激动我心，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使有更高愿望。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有神是人的住处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "路虽窄而崎岖；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "除神，无何能够满足"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我心深处所欲。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "只要从你心的深处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将神尊名称颂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一切引诱你的邪术，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "都要立即消踪。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "信靠之心、仰望之眼，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得神的引导；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果信心能够移山，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱心之力岂小？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，那追求神的道路，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仅走了一点！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "向神之心，对神之顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必能带你向前。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "从罪权下得着自由，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "生活不失检点；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这些比那爱心所求，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "仍是较低恩典。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "完全之路，肉体感难，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但在爱心不然；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如果你因要神而前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必胜一切纠缠。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "然后保守良心敏锐，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "顾到里面感觉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "膏油涂抹，时时跟随，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "这是成熟秘诀。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "9"
    }
  ],
