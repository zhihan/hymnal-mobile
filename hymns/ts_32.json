{
  "url": "https://www.hymnal.net/cn/hymn/ts/32",
  "title": "基督生活超凡佳美",
  "lines": [
    {
      "segments": [
        {
          "chord": "G",
          "text": "基 督"
        },
        {
          "chord": "",
          "text": "在 地 生 活 超"
        },
        {
          "chord": "D",
          "text": "凡 且"
        },
        {
          "chord": "D7",
          "text": "佳"
        },
        {
          "chord": "G",
          "text": "美，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂"
        },
        {
          "chord": "C",
          "text": "是 神、"
        },
        {
          "chord": "",
          "text": "人"
        },
        {
          "chord": "G",
          "text": "調 和，"
        },
        {
          "chord": "",
          "text": "價"
        },
        {
          "chord": "A",
          "text": "值 何"
        },
        {
          "chord": "A7",
          "text": "寶"
        },
        {
          "chord": "D",
          "text": "貴；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "態"
        },
        {
          "chord": "G",
          "text": "度、 揀"
        },
        {
          "chord": "",
          "text": "選、 喜 悅 全"
        },
        {
          "chord": "C",
          "text": "與 神"
        },
        {
          "chord": "",
          "text": "相"
        },
        {
          "chord": "D",
          "text": "合─ 惟"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "G",
          "text": "祂 是"
        },
        {
          "chord": "",
          "text": "那 配 住 神"
        },
        {
          "chord": "D",
          "text": "的 帳"
        },
        {
          "chord": "D7",
          "text": "幕"
        },
        {
          "chord": "G",
          "text": "者。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"神，求你保守我，因我投靠你\"─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "无论起何风暴，祂安居神里。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"你是我主我神，我一切好处\"─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "惟神是祂心中朝夕所思慕。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"论到地上圣民，尊高又可悦，\""
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "属神子民祂心最喜爱、关切，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂亲临地服事且照护殷殷，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "如四福音书中所记述显明。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"神外别有拣选，愁苦必加增\"─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "耶稣在地生活与偶像无分。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神外任何名号一概都不题，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂的追求、想望全是神自己。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"惟你是我产业，是我杯中分\"─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂在一切事上只拣选父神。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "\"那指教我的神，我昼夜称颂\"─"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂己全然弃绝，只活出神命。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "因此祂心喜乐，祂灵也欢腾，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "甚至被置死地仍能赞美神；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神必不将祂魂撇弃在阴间，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂的肉身安居，复活显神前。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神已使祂复起，赐祂荣耀冕，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "祂在神前所得喜乐何丰满。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "高升远超万有，父右边安坐，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "享受无穷无尽无终的福乐。"
        }
      ]
    }
  ],
  "metadata": {
    "category": "赞美的话",
    "time": "3/4",
    "hymn_code": "51123321271"
  },
  "raw_sections": [
    "基 督在 地 生 活 超凡 且佳美，",
    "祂是 神、人調 和，價值 何寶貴；",
    "態度、 揀選、 喜 悅 全與 神相合─ 惟",
    "祂 是那 配 住 神的 帳幕者。",
    "\"神，求你保守我，因我投靠你\"─",
    "无论起何风暴，祂安居神里。",
    "\"你是我主我神，我一切好处\"─",
    "惟神是祂心中朝夕所思慕。",
    "\"论到地上圣民，尊高又可悦，\"",
    "属神子民祂心最喜爱、关切，",
    "祂亲临地服事且照护殷殷，",
    "如四福音书中所记述显明。",
    "\"神外别有拣选，愁苦必加增\"─",
    "耶稣在地生活与偶像无分。",
    "神外任何名号一概都不题，",
    "祂的追求、想望全是神自己。",
    "\"惟你是我产业，是我杯中分\"─",
    "祂在一切事上只拣选父神。",
    "\"那指教我的神，我昼夜称颂\"─",
    "祂己全然弃绝，只活出神命。",
    "因此祂心喜乐，祂灵也欢腾，",
    "甚至被置死地仍能赞美神；",
    "神必不将祂魂撇弃在阴间，",
    "祂的肉身安居，复活显神前。",
    "神已使祂复起，赐祂荣耀冕，",
    "祂在神前所得喜乐何丰满。",
    "高升远超万有，父右边安坐，",
    "享受无穷无尽无终的福乐。"
  ]
}