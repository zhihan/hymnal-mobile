{
  "url": "https://www.hymnal.net/en/hymn/ns/575",
  "title": "From My Iniquity Wash Me Thoroughly",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "From my iniquity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wash me thoroughly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from my sin cleanse me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I do know my transgressions,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my sin’s before me continually."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold, You delight in truth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In the inward parts;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And in the hidden part"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You would make known wisdom to me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Purge my sin with hyssop, and I’ll be clean."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me hear gladness and joy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the bones You’ve broken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May exult, O God!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do hide Your face from all my sins,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, blot out all my iniquities."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Create in me a clean heart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And renew a steadfast"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit within me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Do not cast me from Your presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And sustain me with a willing spirit."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The sacrifices of God"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are a broken spirit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, You won’t despise"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A broken and a contrite heart;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For in sacrifice You do not delight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, do good unto Zion;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Build the walls of Jerusalem."
            }
          ]
        }
      ],
      "type": "verse"
    }
  ],
