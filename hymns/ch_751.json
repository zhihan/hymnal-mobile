      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们为神所生，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好为祂作王，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "但是还需训练，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "才能像王一样，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好在祂的国中，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜任作王掌权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使祂神圣王权，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "借我得着彰显。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "今天我需学习"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "服神的权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "甘愿受祂管治，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "严格对付言行。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此祂的权柄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我就得以分享，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来管理列国，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与祂儿子同王。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "严格对待自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "持守着公义，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对人宽大有恩，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "对神灵中欢喜；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一直都要活在"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度实际里面，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为着国度实现，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能得进入掌权。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "基督带着国度降临时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要将祂的王权"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐我作为赏赐；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "主要借我使祂公义彰显，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并将祂的智慧"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "给众天使看见。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "为着这个，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使徒曾努力向前，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "愿出任何代价，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不甘落在后面；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也为这个，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "他劝我们忠诚向上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "好在将来"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "得着国度作为奖赏。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "求主赐我恩典，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为国度活着，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今天受你训练，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来你肯赏我；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "求使国度实际，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今天作我操练，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将来我的奖赏，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "乃是国度实现。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
