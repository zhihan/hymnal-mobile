{
  "url": "https://www.hymnal.net/cn/hymn/ch/751",
  "title": "今天神的国度",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "今 天"
            },
            {
              "chord": "",
              "text": "神"
            },
            {
              "chord": "C",
              "text": "的"
            },
            {
              "chord": "G",
              "text": "國 度，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "對"
            },
            {
              "chord": "C",
              "text": "我 是"
            },
            {
              "chord": "",
              "text": "操"
            },
            {
              "chord": "G",
              "text": "練，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "將 來"
            },
            {
              "chord": "D",
              "text": "卻 是"
            },
            {
              "chord": "",
              "text": "獎"
            },
            {
              "chord": "G",
              "text": "賞，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "與 主"
            },
            {
              "chord": "A7",
              "text": "一 同"
            },
            {
              "chord": "",
              "text": "掌"
            },
            {
              "chord": "D7",
              "text": "權。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "這 是"
            },
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "智"
            },
            {
              "chord": "C",
              "text": "慧，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "現 今"
            },
            {
              "chord": "A7",
              "text": "將 我"
            },
            {
              "chord": "",
              "text": "訓"
            },
            {
              "chord": "D",
              "text": "練，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使 祂"
            },
            {
