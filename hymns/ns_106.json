  "title": "Until He comes again",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Until He comes again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll watch and wait and call on Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll pray that by His life and power,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’ll overcome in every hour."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Until He comes again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His blood will cleanse me of my sin"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His word will sanctify within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And make me wholly unto Him."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "(Bro.) He died to be life to me—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From death I’m free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Sis.) He rose and as Spirit He"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now lives in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Bro.) In splendor and in glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like Him I’ll be."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Until He comes again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My soul-life I’ll give up for Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No worldly pleasure can compare"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To what my Savior has to share."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "And when He comes again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All saints built up and one in Him."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His Body, Bride, and Counterpart,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternal pleasure of His heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "(Sis.) Lord, gain Your kingdom in me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I long to be..."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Bro.) One with my Savior and King,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Eternally."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "(Sis.) Oh, what a joy it will be"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Your face to see."
            }
          ]
        }
      ],
      "type": "chorus"
    }
