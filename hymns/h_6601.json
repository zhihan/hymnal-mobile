  "title": "God’s desire—Life for man",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s desire—Life for man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His intention—a building for His home;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shame the devil, victory won."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Take the Word—soon it will be done."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I call—build me now"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the saints; O Lord, but how?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Praying always, in the spirit"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With the Word.” Amen, Lord!"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ as Life—wondrous Person;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All His riches, now our full supply!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For the building, Life’s our need:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life will build us—the enemy will fly."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
