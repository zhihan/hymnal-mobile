        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Let us rise—with our weapon;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Give ourselves for the building of the Lord:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Slay contention, kill opinions:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This our weapon—the Spirit’s living sword."
            }
          ]
        }
      ],
