    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "亘古而出，奋力前进，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂的出来将得胜者兴起！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我献自己至死忠信，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随羔羊，与神七灵是一。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "活力事奉，编组成军；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代求守望，以维护神权益。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "建立灯台，照亮万民，"
