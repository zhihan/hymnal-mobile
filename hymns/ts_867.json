    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我时软弱、冷淡摇动，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仍来眷临，保养又顾惜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "爱里回应天上职事，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "摆上全人，为神经纶再起。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "与主同心，牧养群羊；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坚定持续，实行神所命定。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无论晴雨，劳苦不息，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全为应验神的梦-伯特利。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们愿以奉献为彩饰，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "献上自己作清晨甘露，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "解主干渴，生死不顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同生活，同争战，同荣辱。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "起来！写下神行动历史，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "承接时代荣耀的托付，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "作主新妇，同祂凯归，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "全地成主甘甜美丽国度。"
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "同受异象，作主先锋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "一听主号令全体向前冲。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "独一职事，独一工作，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神的奴仆，相调中同事奉。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "调和的灵是我秘诀；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死而复活，在配搭里行动。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同忧同乐，相爱相交，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "身体实际，达到锡安高峯。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
