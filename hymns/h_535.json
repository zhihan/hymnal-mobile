    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "’Twas most impossible of all"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That here sin’s reign in me should cease;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet shall it be, I know it shall;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Jesus, I trust Thy faithfulness."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If nothing is too hard for Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are possible to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Though earth and hell the Word gainsay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Word of God shall never fail;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Lord can break sin’s iron sway;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis certain, though impossible."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The thing impossible shall be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are possible to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are possible to God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Christ, the power of God in man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To me when I am all renewed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Christ am fully formed again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And from the reign of sin set free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are possible to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "All things are possible to God;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Christ, the power of God in me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now shed Thy mighty Self abroad,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let me no longer live, but Thee;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Give me this hour in Thee to prove"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sweet omnipotence of love."
            }
          ]
        }
