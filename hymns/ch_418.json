  "raw_sections": [
    "住 在主裡面，",
    "無 上的 福氣，",
    "常與 主交通，",
    "甜 美的 經歷；",
    "住 在 主裡 面，",
    "主 與我 聯合，",
    "常 與主交 通，",
    "我與主無隔。",
    "住在主里面，",
    "恩膏必运行，",
    "常与主交通，",
    "圣灵必引领；",
    "顺服主恩膏，",
    "得享主肥甘，",
    "跟随主圣灵，",
    "必作主同伴。",
    "住在主里面，",
    "恩光必照明，",
    "常与主交通，",
    "黑影必除净；",
    "恩光一顺从，",
    "生命必增长，",
    "黑影全脱离，",
    "心、灵才舒畅。",
    "住在主里面，",
    "软弱变刚强，",
    "常与主交通，",
    "生命吞死亡；",
    "住在主里面，",
    "叹息变歌唱，",
    "常与主交通，",
    "喜乐代忧伤。",
    "住在主里面，",
    "撒但难攻击，",
    "常与主交通，",
    "世界失吸力；",
    "住在主里面，",
    "罪恶无权势，",
    "常与主交通，",
    "自己必消逝。",
    "住在主里面，",
    "模成主荣形，",
    "常与主交通，",
    "充满主生命；",
    "住在主里面，",
    "经历主大能，",
    "常与主交通，",
    "吸取主丰盛。",
    "住在主里面，",
    "心、灵在渴慕，",
    "常与主交通，",
    "圣灵在催促；",
    "惟愿我全人",
    "浸在主里面，",
    "与主溶为一，",
    "从今到永远。"
  ]
