          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life more abundantly,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, give to me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
