    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy life in me be shown,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I would henceforth seek"
            }
          ]
        },
        {
          "segments": [
