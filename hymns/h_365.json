          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fresh springs that never cease,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But still increase."
            }
          ]
        }
      ],
