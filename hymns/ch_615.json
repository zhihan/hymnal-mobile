{
  "url": "https://www.hymnal.net/cn/hymn/ch/615",
  "title": "主你居所何等可爱",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "主， 你"
            },
            {
              "chord": "",
              "text": "居 所 何"
            },
            {
              "chord": "A",
              "text": "等 可"
            },
            {
              "chord": "D",
              "text": "愛！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我 心 渴 慕 你"
            },
            {
              "chord": "G",
              "text": "的 院"
            },
            {
              "chord": "A",
              "text": "宇！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "切 望 得"
            },
            {
              "chord": "D",
              "text": "到 你"
            },
            {
              "chord": "",
              "text": "的 同"
            },
            {
              "chord": "A",
              "text": "在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我"
            },
            {
              "chord": "D",
              "text": "的 心"
            },
            {
              "chord": "",
              "text": "腸 向"
            },
            {
              "chord": "A",
              "text": "你 呼"
            },
            {
              "chord": "D",
              "text": "籲。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你祭坛所在之处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并你香坛所在之所，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "麻雀找着可居房屋，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "燕子找着菢雏之窝。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "微弱虽如麻雀、燕子，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "住在你殿，便为有福！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凭着祭坛赎罪价值，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受香坛所有好处。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因着靠你而有力量，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "前途险阻毫不思顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "锡安大道心中想往，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此之人，便为有福。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽经巴迦，流泪之谷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "亦使变成泉源之地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "并且盖满秋雨之福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "成为路中福分之一。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "他们行走，力上加力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "要到锡安朝见主神；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "如此寻求你的自己，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "也需你来垂顾赐恩。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "在你院宇一日之留，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "胜住别处千日之久，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宁在你殿看门守候，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不在恶人帐棚住留。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你是日头，你是盾牌，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你要赐下恩惠、荣耀，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "以你自己和你同在，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "满足我的一切需要。"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你未留下一样好处，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不给行动正直的人；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "倚靠你的，便为有福，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必得恩惠、荣耀无尽。"
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "category": "召会",
    "time": "4/4",
    "hymn_code": "3215322133653142",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/851",
        "language": "cn",
