{
  "url": "https://www.hymnal.net/cn/hymn/ts/454",
  "title": "回归主自己",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "恩 主"
            },
            {
              "chord": "",
              "text": "我 心 至 爱， 今"
            },
            {
              "chord": "Em",
              "text": "我 归"
            },
            {
              "chord": "",
              "text": "你 怀"
            },
            {
              "chord": "D",
              "text": "抱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "B7",
              "text": "你"
            },
            {
              "chord": "Em",
              "text": "外 任"
            },
            {
              "chord": "G",
              "text": "何 事"
            },
            {
              "chord": "C",
              "text": "物， 不"
            },
            {
              "chord": "D",
              "text": "能 将"
            },
            {
              "chord": "",
              "text": "我 搅"
            },
            {
              "chord": "G",
              "text": "扰。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "C",
              "text": "曾 以"
            },
            {
              "chord": "",
              "text": "爱 呼"
            },
            {
              "chord": "D",
              "text": "召， 我"
            },
            {
              "chord": "Am",
              "text": "曾 被"
            },
            {
              "chord": "",
              "text": "你 吸"
            },
            {
              "chord": "D",
              "text": "引；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "B7",
              "text": "旷"
            },
            {
              "chord": "Em",
              "text": "野 道"
            },
            {
              "chord": "G",
              "text": "路 默"
            },
            {
              "chord": "C",
              "text": "默， 爱"
            },
            {
              "chord": "D",
              "text": "情 结"
            },
            {
              "chord": "",
              "text": "盟 紧"
            },
            {
              "chord": "G",
              "text": "紧。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿奉献自己，全因你的大爱；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "此情主未遗忘，时刻铭记心怀。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "幼年曙光黎明，前途一片灿烂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "坛火原不该灭，直至天光烂漫。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "偶像夺取人心，叫人醉倒倾迷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "无知的心受拐，不觉偷被牵离。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只是幼年恩爱，仍然呼召不已，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "能否保持此心，永为未耕之地？"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "虽我羞步迟疑，你仍诱导依依，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐我葡萄果园，使我陶醉忘己；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "应声亚割幽谷，踏上指望之门，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "怜爱脸光披露，重获久别良人。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "前虽汗劳一身，仅知工作主人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "今你成我丈夫，以爱聘娶委身。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "弃绝破裂池子，归依活水泉源，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "享受爱情筵宴，沈溺恩典深渊。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "恩主今我属你，与我心心相系，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "只望不再我活，永远与你合一，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你我只一空间，密切个人情深，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我愿消失你里，直至永世不分。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    }
  ],
