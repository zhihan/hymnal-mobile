    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Then this feast of feasts He ordered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feast of grace Divine;"
            }
          ]
