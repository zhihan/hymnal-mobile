{
  "url": "https://www.hymnal.net/en/hymn/h/254",
  "title": "O Lord of life, breathe on us now",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "O Lord"
            },
            {
              "chord": "",
              "text": "of life, breathe"
            },
            {
              "chord": "A",
              "text": "on us"
            },
            {
              "chord": "D",
              "text": "now."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And move within us"
            },
            {
              "chord": "E",
              "text": "while"
            },
            {
              "chord": "E7",
              "text": "we"
            },
            {
              "chord": "A",
              "text": "pray:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "The spring"
            },
            {
              "chord": "",
              "text": "of our new"
            },
            {
              "chord": "B7",
              "text": "life art"
            },
            {
              "chord": "Em",
              "text": "Thou,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "A7",
              "text": "The very"
            },
            {
              "chord": "D",
              "text": "light of"
            },
            {
              "chord": "A",
              "text": "our new"
            },
            {
              "chord": "D",
              "text": "day."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O strangely art Thou with us, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Neither in height nor depth to seek;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In nearness shall Thy voice be heard:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Spirit to spirit Thou dost speak."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou art our Advocate on high:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He is our Advocate within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "O plead the truth, and make reply"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To every argument of sin."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "But ah, this faithless heart of mine!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The way I know, I know my guide;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Forgive me, O my Friend divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That I so often turn aside."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Be with me when no other friend"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The myst’ry of my heart can share:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be Thou known, when fears transcend."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy best name of Comforter."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
