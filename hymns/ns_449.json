      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The priesthood of the gospel"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Brings sinners to His grace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet in our priestly service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Are we before His face?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Father still is seeking"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "True worship in His sight—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The “fat” and “blood” of Jesus"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Whom is His delight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "“The priests and sons of Zadok"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Shall draw near unto Me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And e’en before my table"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Within the sanctuary"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To minister unto Me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The fat and blood to bring”—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s precious work and person"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s longed-for offering."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "God’s people at Mount Horeb"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Upon three levels trod,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thus had different levels"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of fellowship with God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The nearer to His presence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The more their view could be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But two stood right before Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glory full to see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Just as upon Mount Hermon"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where Jesus brought the three—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where His transfiguration"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Was unveiled privately;—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our height of revelation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Will differ in degree;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, draw us ever nearer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "More of Thyself to see."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "One in the House of Feasting"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Life’s vict’ry testified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "One, busy with much service,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The outward needs supplied."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But one more thing was needed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To gain the better part:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A love with revelation"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To satisfy His heart."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Before the feet of Jesus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Attending every word,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A woman bearing ointment"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cared only for her Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His heart’s desire and preference"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To her alone revealed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Her flask was “wasted” on Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The house with fragrance filled."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we give Him the first place"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And first love following,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then first works manifest will"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His glory’s fragrance bring."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The house thus filled with fragrance"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Draws seeking sinners close;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such ministry to God is"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our service to His house."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "8"
    }
  ],
