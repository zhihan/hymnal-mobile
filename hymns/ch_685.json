  "title": "耶稣我救主作神羔",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "C",
              "text": "耶 稣"
            },
            {
              "chord": "",
              "text": "我 救 主"
            },
            {
              "chord": "F",
              "text": "作 神"
            },
            {
              "chord": "",
              "text": "羔"
            },
            {
              "chord": "C",
              "text": "羊，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G7",
              "text": "为 罪"
            },
            {
              "chord": "",
              "text": "人 受 死， 罪 债 清"
            },
            {
              "chord": "C",
              "text": "偿；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "将 祂 的 宝 血"
            },
            {
              "chord": "F",
              "text": "洒 你"
            },
            {
              "chord": "",
              "text": "身 上，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神 必 越"
            },
            {
              "chord": "C",
              "text": "过 你，"
            },
            {
              "chord": "G7",
              "text": "你 免"
            },
            {
              "chord": "",
              "text": "灭"
            },
            {
              "chord": "C",
              "text": "亡。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
