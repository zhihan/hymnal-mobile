      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "罪中的罪魁，耶稣肯救，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "凡祂所应许，祂必成就，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在祂这血下，虽有愆尤，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神必越过你，你得宽宥。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "审判要来到，无人免除；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在神公义前，谁能立足？"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟有让祂血将你掩护，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神必越过你，你免对簿。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，怜悯何大！哦，爱无边！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "哦，神圣恩典，丰盛、甘甜！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在血荫蔽下享受平安，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神必越过你，你要颂赞！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "奇妙羔羊血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "荣耀羔羊血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "宝贵羔羊血，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神一见羔羊血便逾越。"
            }
          ]
        }
