    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "In Jesus’ name we must declare"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That we shall overcome the foe;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We draw authority from Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The serpent’s head to crush below."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "No matter what, thou mountain high,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In heav’n or earth, where’er thou art,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At any cost we’ll level thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Jesus’ name thou must depart!"
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Faith orders thee “Remove from here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And be thou cast into the sea!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We should, we must, we can, we will,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fulfill God’s purpose faithfully."
            }
          ]
        }
      ]
    }
