              "text": "Oh, the fullness of His grace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Perfect rest to me is promised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In my Father's blest embrace."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When my spirit, clothed immortal,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Wings its flight to realms of day,"
            }
          ]
        },
        {
