              "chord": "",
              "text": "All the way my Savior leads me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Cheers each winding path I tread,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gives me grace for every trial,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Feeds me with the living bread."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Though my weary steps may falter,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And my soul athirst may be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gushing from the Rock before me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lo! a spring of joy I see,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gushing from the Rock before me,"
            }
          ]
        },
