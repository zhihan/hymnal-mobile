    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "紧紧跟随主内弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心合意齐建造；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "互作肢体，生命流通，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "联络、结合精而牢。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随弟兄，同心建造，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "不再单独来事奉；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随弟兄，彼此相调，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "守住等次尽功用。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "紧紧跟随地方召会，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为主恢复全奉献；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "取得全地归主支配，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "国度应许必实现。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随召会，献上所有，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "同心为着主恢复；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随召会，投身水流，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "直到带进主国度。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "主的圣言欢喜聆听，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "必使我们得加力；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "惟主、召会、弟兄是从，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "羊群脚踪不偏离。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随耶稣、召会、弟兄，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "跟随圣灵的水流；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "\"阿们\"主话，永不力穷，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神旨必定得成就。"
            }
          ]
        }
