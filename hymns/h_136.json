              "chord": "A7",
              "text": "hearts in"
            },
            {
              "chord": "",
              "text": "worship"
            },
            {
              "chord": "D",
              "text": "bow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There we"
            },
            {
              "chord": "D7",
              "text": "read the"
            },
            {
              "chord": "",
              "text": "wondrous"
            },
            {
              "chord": "G",
              "text": "sto"
            },
            {
              "chord": "B",
              "text": "ry"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "Em",
              "text": "Of the"
            },
            {
              "chord": "",
              "text": "cross— its"
            },
            {
              "chord": "A7",
              "text": "shame and"
            },
            {
              "chord": "D",
              "text": "woe."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Every mark of dark dishonor"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Heaped upon the thorn-crowned brow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the depths of Thy heart's sorrow"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Told in answ'ring glory now."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "On that cross, alone, forsaken,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Where no pity'ng eye was found;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Now, to God's right hand exalted,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "With Thy praise the heavens resound."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Did Thy God e'en then forsake Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hide His face from Thy deep need?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy face once marred and smitten,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All His glory now we read."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Gazing on it we adore Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Blessed, precious, holy Lord;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou the Lamb, alone art worthy—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This be earth's and heaven's accord."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Rise our hearts, and bless the Father,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ceaseless song e'en here begun,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Endless praise and adoration"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the Father and the Son."
            }
          ]
        }
      ]
    }
