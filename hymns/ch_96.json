{
  "url": "https://www.hymnal.net/cn/hymn/ch/96",
  "title": "神的基督从天至",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "G",
              "text": "神 的"
            },
            {
              "chord": "",
              "text": "基 督"
            },
            {
              "chord": "Em",
              "text": "從 天"
            },
            {
              "chord": "B",
              "text": "至，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "C",
              "text": "拯 救"
            },
            {
              "chord": "G",
              "text": "罪 人"
            },
            {
              "chord": "D",
              "text": "脫"
            },
            {
              "chord": "A7",
              "text": "罪、"
            },
            {
              "chord": "D",
              "text": "死，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "竟 然"
            },
            {
              "chord": "",
              "text": "稱 為 『憂 患"
            },
            {
              "chord": "C",
              "text": "子！』 阿"
            },
            {
              "chord": "",
              "text": "利"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "路"
            },
            {
              "chord": "D",
              "text": "亞！"
            },
            {
              "chord": "Em",
              "text": "何 等"
            },
            {
              "chord": "C",
              "text": "救"
            },
            {
              "chord": "G",
              "text": "主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "被人侮慢被人讥，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "代替我站罪人地，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "赐我生命赐我力，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！何等救主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "我们又弱又不好，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂是圣洁的羊羔，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "救赎竟然作得到！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！何等救主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "祂被举起，我免死；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂说成了，鬼失势；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "祂登宝座给恩赐。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！何等救主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "当祂复临遣天使，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "提接圣徒见祂时，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我们还要唱此诗："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "阿利路亚！何等救主！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
