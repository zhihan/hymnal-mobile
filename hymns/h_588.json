    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O blessed life, the mind that sees,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whatever change the years may bring,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A mercy still in everything,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shining through all mysteries."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O blessed life, as spirit soars,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When sense of mortal sight is dim,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Beyond the sense, beyond to Him,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose love unlocks the glorious doors."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O blessed life, heart, mind, and soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From self-born aims and wishes free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In all at one with Deity,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And loyal to the Lord’s control."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O life, how blessed, how divine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "High life, the earnest of a higher;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Savior, fulfil my deep desire,"
            }
          ]
        },
        {
          "segments": [
            {
