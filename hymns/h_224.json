    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It is by this blood of worth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The new testament was made;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For this better covenant,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis a sure foundation laid."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have been redeemed by God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not with silver or with gold,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, Lord, with Thy precious blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which Thy love doth e’er unfold."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "For remission of our sins"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast shed Thy cleansing blood."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which for us has fully met"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the righteous claims of God."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou hast washed us from our sins"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy pow’rful purging blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And our conscience purged by it,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus to serve the living God."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy separating blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have all been sanctified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by Thy preserving blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Holiness is testified."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thy propitiating blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have all been justified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "’Tis by Thy redeeming blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "God is fully satisfied."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thru Thy blood shed on the cross,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are reconciled to God,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the way to contact Him"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May in peace by us be trod."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By partaking of Thy blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have Thine eternal life;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In Thy blood and life received,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We have rest, free from all strife."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now, in heav’n Thy sprinkled blood"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Speaks for us of better things;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Under its defending pow’r"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We are kept from Satan’s stings."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By Thine overcoming blood,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We defeat the enemy;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Over our accuser thus,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will have the victory."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Of Thy blood, for fellowship,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We commune with all Thy saints;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Under its full covering,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our freed spirit never faints."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How can we exhaust, in words,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The account of Thy dear blood;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We will need eternity"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To declare its boundless good."
            }
          ]
        }
