    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Crown Him the Virgin’s Son,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The God Incarnate born,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose arm those crimson trophies won"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Which now His brow adorn:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fruit of the mystic Tree,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "As of that Tree the Stem;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Root whence flows Thy mercy free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Babe of Bethlehem."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Crown Him the Lord of Love:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Behold His hands and side;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rich wounds yet visible above"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In beauty glorified:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "No angel in the sky"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can fully bear that sight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But downward bends his burning eye"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "At mysteries so bright."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Crown Him the Lord of peace,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Whose power a scepter sways"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From pole to pole, that wars may cease,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And all be prayer and praise."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "His reign shall know no end,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And round His pierced feet"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fair flowers of glory now extend"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their fragrance ever sweet."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Crown Him the Lord of years,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The Potentate of time."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Creator of the rolling spheres,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ineffably sublime."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All hail, Redeemer, hail!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For Thou hast died for me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy praise shall never, never fail"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Throughout eternity."
            }
          ]
        }
