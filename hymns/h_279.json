    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ, the Rock, must first be smitten,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the living water flow;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Without death the Spirit's fulness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ne'er could dwell in man below."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If with Christ we die completely,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Willing thus our all to lose,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He will clothe us with His power"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to win the world will use."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the Cross, O Lord, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Put my soul-life all away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me any price to pay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full anointing to receive."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "First the altar, then the fire,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If no loss, there'll be no gain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If our all has not been offered,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To the throne we'll ne'er attain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If to sacrifice we're willing,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All forsaking, God t'obey,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He to us will be committed"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And thru us His pow'r display."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the Cross, O Lord, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Put my soul-life all away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me any price to pay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full anointing to receive."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "First we must prepare the vessels"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That the Oil they may contain;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Dig the valley full of ditches"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That they may be filled with Rain."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "First we must go thru the Jordan"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ere anointed from above;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "First in death we must be baptized,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Then experience the Dove."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the Cross, O Lord, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Put my soul-life all away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me any price to pay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full anointing to receive."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When we see the ripened harvest"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Of the golden countryside,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We may know that many seeds have"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fallen to the earth and died."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Ere the fruit of life may blossom,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We must surely suffer death;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If with Christ we've not been buried,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "We'll not feel the Spirit's breath."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Through the Cross, O Lord, I pray,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Put my soul-life all away;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make me any price to pay,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Full anointing to receive."
            }
          ]
        }
      ]
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since it must be thus, I pray, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Help me go the narrow way;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deal with pride and make me willing"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus to suffer, Thee t'obey."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I for greater power pray not,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Deeper death is what I need;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All the meaning of the Cross, Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Work in me—for this I plead."
            }
          ]
        }
      ]
    },
