    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O God, Thy righteousness condemned"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Savior to the cross to die;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet now to us Thy righteousness"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grants peace, forgives, and justifies."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Righteousness ruled all debts be paid;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Yet, also, righteousness forbade"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That when accounts were fully paid"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Again collection could be made."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now that my Lord His blood has shed,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You cannot sentence Him again,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Nor ask me further recompense,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Can but forgive and fully cleanse."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When first I heard of righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fearful, I sought to hide from thence,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But at its mention now I sense"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Such sweetness and such preciousness."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Since I have known Thy righteousness,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace I can more clearly see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy righteousness gives wondrous rest,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy grace supplies and comforts me."
            }
          ]
        }
      ],
