              "text": "Cannot compare with this."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I give myself to You completely;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "How I praise You for the flow of life!"
            }
          ]
        },
