    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, I long to have You flow in me."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My heart could never be"
            }
          ]
        },
        {
