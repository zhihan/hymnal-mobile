    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Like virgins who so single are,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They love the Groom so much,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They in His presence ever stay—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord Jesus, make us such."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, make us those who are so wise,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who gain You every day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The wise ones who enjoy the feast,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Who all the price will pay."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The virgins are mature in life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They grow so normally."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "They daily eat and drink the Lord,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Their lot eternally."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our need today is growth in life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Christ’s inward work indeed;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not knowledge, teachings, gifts, nor pow’r—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But life is all we need."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, as the seed of life within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Grow more in us each day;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By spreading from our deepest part,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Gain us in every way."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, strengthen Thou our inner man;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Make home in all our heart."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Fill us completely with Thyself"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every inward part."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    }
