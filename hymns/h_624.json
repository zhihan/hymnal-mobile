    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The heavier the cross, the better saint;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "This is the touchstone God applies."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The gardens many would be faint,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Unwet by showers from weeping eyes!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The gold by fire is purified;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The saint is by much trouble tried."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The heavier the cross, the stronger faith:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The loaded palm strikes deeper root;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The vine juice sweetly issueth"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When men have pressed the clustered fruit;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And courage grows where dangers come,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Like pearls beneath the salty foam."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The heavier the cross, the deeper prayer;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The bruised herbs most fragrant are."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If sky and wind were always fair,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The sailor would not watch the star;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And David's Psalms had ne'er been sung"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "If grief his heart had never wrung."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The heavier the cross, the more inspired;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From vales to climb to mountain crest;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The pilgrim, of the desert tired,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Longs for the Canaan of his rest."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The dove has here no rest in sight,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And to the ark she wings her flight."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "The heavier the cross, the easier to die;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Death is a kinder face to see;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Our life's decay we dare defy,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From life's distress we then are free."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The cross sublimely lifts our faith"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To Him who triumphed over death."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Crucified! the cross I bear."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The longer, may it dearer be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And lest I faint while ling'ring here,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Implant Thou such a heart in me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That faith and love may flourish e'er"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till for the cross the crown I wear."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
