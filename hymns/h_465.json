    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let me feel Thee near me;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The world is ever near;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I see the sights that dazzle,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The tempting sounds I hear;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My foes are ever near me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Around me and within;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But, Jesus, draw Thou nearer,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And shield my soul from sin."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, let me hear Thee speaking,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In accents clear and still,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Above the storms of passion,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The murmurs of self-will;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, speak to reassure me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To hasten, or control;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, speak, and make me listen,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou Guardian of my soul."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "O Jesus, Thou hast promised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To all who follow Thee"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That where Thou art in glory"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "There shall Thy servant be;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And Jesus, I have promised"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "To serve Thee to the end;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, give me grace to follow,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Master and my Friend."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
