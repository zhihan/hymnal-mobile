          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "我只属你而已。"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "被你爱吸引，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为你名所迷，"
            }
