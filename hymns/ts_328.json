      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "万王之王，你竟成人，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "为我受死，将我拯救；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "在复活里，我成童女，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "许配给你─我王！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "死而复活，你进我灵，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "使我得有你的神性；"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你我今同生命、性情，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神人二性合并！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "因你爱吸引，"
            }
          ]
        },
        {
          "segments": [
