    },
    {
      "segments": [
        {
          "chord": "",
          "text": "创世之前，你已定意："
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "与人联调为一！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "因那恶者阴谋、诡计，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我被罪恶败坏至极；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "但无何能断绝你爱，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我终投入你怀！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "（回副一）"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "万王之王，你竟成人，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为我受死，将我拯救；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "在复活里，我成童女，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "许配给你─我王！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "死而复活，你进我灵，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "使我得有你的神性；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "你我今同生命、性情，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "神人二性合并！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "因你爱吸引，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我得属于你；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主，我不属于自己，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我只属你而已。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "被你爱吸引，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "为你名所迷，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我为你人位所夺；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "愿你亲嘴与我。"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主，在这亲密交通里，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "我得与你倾心吐意；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "与你个人情深关系，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "是何等的甜蜜！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "逐日改变我之所是，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "主，占有我全心、全志；"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "将我全人变化、浸透，"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "成你新妇、佳偶！"
        }
      ]
    },
    {
      "segments": [
        {
          "chord": "",
          "text": "（回副二）"
        }
      ]
    }
