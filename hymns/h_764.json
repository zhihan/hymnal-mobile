{
  "url": "https://www.hymnal.net/en/hymn/h/764",
  "title": "Lord, in Thy presence",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "Lord, in"
            },
            {
              "chord": "",
              "text": "Thy presence"
            },
            {
              "chord": "A",
              "text": "silent"
            },
            {
              "chord": "A7",
              "text": "I would"
            },
            {
              "chord": "D",
              "text": "be,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That in the inmost"
            },
            {
              "chord": "E7",
              "text": "I to"
            },
            {
              "chord": "",
              "text": "Thee may"
            },
            {
              "chord": "A",
              "text": "come;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "D",
              "text": "I would"
            },
            {
              "chord": "",
              "text": "not in my"
            },
            {
              "chord": "G",
              "text": "own way"
            },
            {
              "chord": "",
              "text": "pray to"
            },
            {
              "chord": "D",
              "text": "Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "G",
              "text": "But let"
            },
            {
              "chord": "",
              "text": "Thy"
            },
            {
              "chord": "D",
              "text": "prayer in"
            },
            {
              "chord": "",
              "text": "me my"
            },
            {
              "chord": "A",
              "text": "prayer"
            },
            {
              "chord": "A7",
              "text": "be"
            },
            {
              "chord": "D",
              "text": "come."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "It seems Thou art in heaven hearing me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But right within my spirit Thou dost dwell;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "It seems that I am praying unto Thee,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But really from Thyself the prayers do well."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "When, Lord, no words my burden can express,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My spirit with Thy Spirit deeply groans;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not verbally I then my plea address,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But Thou dost pray within with words unknown."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "I would inhale Thee, Lord, e’en as I breathe,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And eat and drink Thee as my life supply."
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "A deeper fellowship with Thee bequeath"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "That Thou express Thyself through me thereby."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Here in this fellowship Thy light doth shine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy precious blood doth cleanse and make me clean;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "May I not only, Lord, Thy light enshrine,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "But may Thou be expressed and clearly seen."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Thy oil anoints me here in every way,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Anointing Thee within unceasingly;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I more decrease, Thou more increase each day,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thus full expression Thou shalt have through me."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "6"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Myself I open that Thou may flow in;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Op’ning myself to others, Lord, flow out;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "By such a stream, the fellowship within,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Thou, Lord, expressed will be my life throughout."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "7"
    }
  ],
