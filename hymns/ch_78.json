{
  "url": "https://www.hymnal.net/cn/hymn/ch/78",
  "title": "你在地上所有行径",
  "verses": [
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "D",
              "text": "你 在"
            },
            {
              "chord": "",
              "text": "地 上 所"
            },
            {
              "chord": "A",
              "text": "有 行"
            },
            {
              "chord": "D",
              "text": "徑，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何"
            },
            {
              "chord": "E",
              "text": "其 仁"
            },
            {
              "chord": "E7",
              "text": "慈、 美"
            },
            {
              "chord": "A",
              "text": "麗！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你"
            },
            {
              "chord": "D",
              "text": "在 人"
            },
            {
              "chord": "A",
              "text": "性 不"
            },
            {
              "chord": "A7",
              "text": "凡 生"
            },
            {
              "chord": "D",
              "text": "平，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "令"
            },
            {
              "chord": "G",
              "text": "人 歎"
            },
            {
              "chord": "A",
              "text": "賞、"
            },
            {
              "chord": "A7",
              "text": "驚"
            },
            {
              "chord": "D",
              "text": "奇！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "1"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你在艰苦历程显出"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "何等忍耐的爱！"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "艰苦至死亦所不顾，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "忍、爱，谁能比赛！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "你心受创，重负难减，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "常是忧患重重，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "然而从无不美怨言，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "出你缄默口中。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "敌者妒恨，拒者辱骂，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "从者显为不忠，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你仍不烦，宽赦有加，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "你心惟爱是从。"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "哦！主，在地你的生平，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "各方真如素祭："
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "柔细、香甜、"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "完全、均衡，"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "神、人共赏不已！"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
  ],
  "metadata": {
    "category": "赞美主",
    "time": "3/4",
    "hymn_code": "5342542171",
    "related": [
      {
        "url": "https://www.hymnal.net/cn/hymn/h/89",
        "language": "cn",
        "category": "h",
        "number": "89",
        "title": "E89*"
      }
    ]
  },
  "raw_sections": [
    "你 在地 上 所有 行徑，",
    "何其 仁慈、 美麗！",
    "你在 人性 不凡 生平，",
    "令人 歎賞、驚奇！",
    "你在艰苦历程显出",
    "何等忍耐的爱！",
    "艰苦至死亦所不顾，",
    "忍、爱，谁能比赛！",
    "你心受创，重负难减，",
    "常是忧患重重，",
    "然而从无不美怨言，",
    "出你缄默口中。",
    "敌者妒恨，拒者辱骂，",
    "从者显为不忠，",
    "你仍不烦，宽赦有加，",
    "你心惟爱是从。",
    "哦！主，在地你的生平，",
    "各方真如素祭：",
    "柔细、香甜、",
    "完全、均衡，",
    "神、人共赏不已！"
  ]
}