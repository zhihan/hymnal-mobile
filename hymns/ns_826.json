    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Who could change a soul like mine?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "The life I lived—God was so distant;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He arranged the day and time—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Salvation came, and in an instant!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Touched my sight; His light came in;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Words of light shined on my sins!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What a change my God has done!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I’m one with Christ, the risen Son!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I’m free—yes, free in Christ—"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all my chains my God has broken!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From that hold of sin and death,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My God has freed! For He has spoken:"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“If the Son has set you free,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "You are free, yes, free indeed!”"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "On the cross, Christ died for me"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "And bore my sins upon the tree!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Now I rest from all my strife,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For all my works could never save me!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "I depend on Christ my life,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "My Strength, my Hope, my Rock, my Safety!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Not of works—’tis all by grace!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Rest in Him—my Dwelling Place!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "What supply my Savior gives,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "“Because He lives, I also live!”"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "4"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Day by day, I now receive"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Abundant grace, and without measure;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "When I call His precious Name,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "He fills my heart with streams of pleasure!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Call His Name and take God in!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let Him fill you to the brim!"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Let His Spirit fill your soul,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Till with His joy you overflow!"
            }
          ]
        }
      ],
      "type": "verse",
      "number": "5"
    }
