    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Beloved Lord, since the year Thou ascended"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Everything here has been tasteless and dry;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Often in praying and often in watching,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "In every movement, for Thee, Lord, we sigh."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "2"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Come Thou, come now;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Lord, for Thy coming we yearn;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All our desire is Thy promised returning,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Oh, may Thou quickly return."
            }
          ]
        }
      ],
      "type": "chorus"
    },
    {
      "lines": [
        {
          "segments": [
            {
              "chord": "",
              "text": "Scenes although lovely, yet when will we meet Thee?"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Birds and the flowers fair beauty embrace;"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "All are delightsome, but none satisfy me,"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "For I am longing for Thy loving face."
            }
          ]
        }
      ],
      "type": "verse",
      "number": "3"
