          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "From every sunrise to every bright sunset"
            }
          ]
        },
        {
          "segments": [
            {
              "chord": "",
              "text": "Hope we each moment Thy coming to see."
            }
          ]
        }
